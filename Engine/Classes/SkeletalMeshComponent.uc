final function float GetAnimRateByDuration(name AnimSeqName, float Duration)
{
    UnknownLocal_1 = FindAnimSequence(AnimSeqName);
    // End:0x51
    if((UnknownLocal_1 == none) || UnknownLocal_1.RateScale <= 0)
    {
        return 1;
    }
    return UnknownLocal_1.SequenceLength / (Duration * UnknownLocal_1.RateScale);
    //return ReturnValue;    
}

final function float GetAnimLength(name AnimSeqName)
{
    UnknownLocal_1 = FindAnimSequence(AnimSeqName);
    // End:0x51
    if((UnknownLocal_1 == none) || UnknownLocal_1.RateScale <= 0)
    {
        return 0;
    }
    return UnknownLocal_1.SequenceLength / UnknownLocal_1.RateScale;
    //return ReturnValue;    
}

