class FluidSurfaceActor extends Actor
    native(Fluid)
    notplaceable
    hidecategories(Mobile,Navigation,MovementReplication)
    classgroup(Fluid)
    autoexpandcategories(FluidSurfaceActor,FluidSurfaceComponent);

var() const editconst export editinline FluidSurfaceComponent FluidComponent;
var() ParticleSystem ProjectileEntryEffect;

simulated event TakeDamage(float Damage, Controller EventInstigator, Vector HitLocation, Vector Momentum, class<DamageType> DamageType, optional TraceHitInfo HitInfo, optional IDamageCauser DamageCauser, optional DamagePipeline Pipeline)
{
    Damage
    EventInstigator
    HitLocation
    Momentum
    DamageType
    HitInfo
    DamageCauser
    Pipeline    
    FluidComponent.ApplyForce(HitLocation, FluidComponent.ForceImpact, FluidComponent.TestRippleRadius, true);
    //return;    
}

simulated event Touch(Actor Other, PrimitiveComponent OtherComp, Vector HitLocation, Vector HitNormal)
{
    super.Touch(Other, OtherComp, HitLocation, HitNormal);
    Other.ApplyFluidSurfaceImpact(self, HitLocation);
    //return;    
}

defaultproperties
{
    FluidComponent=FluidSurfaceComponent'Default__FluidSurfaceActor.NewFluidComponent'
    Components(0)=FluidSurfaceComponent'Default__FluidSurfaceActor.NewFluidComponent'
    CollisionType=ECollisionType.COLLIDE_CustomDefault
    bNoDelete=true
    bMovable=false
    bCollideActors=true
    bProjTarget=true
}