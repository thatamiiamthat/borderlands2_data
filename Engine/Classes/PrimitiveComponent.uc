function Behavior_ToggleVisibility()
{
    SetHidden(!HiddenGame);
    //return;    
}

function Behavior_ChangeVisibility(bool bVisible)
{
    SetHidden(!bVisible);
    //return;    
}

function Behavior_ChangeScale(float InScale)
{
    SetScale(InScale);
    //return;    
}

function TickInstanceDataAttachment()
{
    class'InstanceDataHelper'.static.TickInstanceDataAttachment(self);
    //return;    
}

function Behavior_ChangeCollision(byte NewCollisionType)
{
    switch(NewCollisionType)
    {
        // End:0x33
        case 1:
            SetActorCollision(false, false);
            SetBlockRigidBody(false);
            // End:0x1AF
            break;
        // End:0x38
        case 2:
        // End:0x3D
        case 3:
        // End:0x42
        case 6:
        // End:0x108
        case 9:
            UnknownLocal_1 = ((int(NewCollisionType) == 2) || int(NewCollisionType) == 6) || int(NewCollisionType) == 9;
            UnknownLocal_3 = ((int(NewCollisionType) == 2) || int(NewCollisionType) == 3) || int(NewCollisionType) == 9;
            SetActorCollision(true, true);
            SetTraceBlocking(UnknownLocal_3, UnknownLocal_1);
            SetBlockRigidBody(UnknownLocal_1 && int(NewCollisionType) != 9);
            // End:0x1AF
            break;
        // End:0x10D
        case 4:
        // End:0x112
        case 5:
        // End:0x19C
        case 7:
            UnknownLocal_1 = (int(NewCollisionType) == 4) || int(NewCollisionType) == 7;
            UnknownLocal_3 = (int(NewCollisionType) == 4) || int(NewCollisionType) == 5;
            SetActorCollision(true, false);
            SetTraceBlocking(UnknownLocal_3, UnknownLocal_1);
            SetBlockRigidBody(UnknownLocal_1);
            // End:0x1AF
            break;
        // End:0xFFFF
        default:
            SetActorCollision(false, false);
            // End:0x1AF
            break;
            break;
    }
    //return;    
}

function Behavior_ChangeCollisionSize(float NewRadius, float NewHeight)
{
    // End:0x40
    if(Owner != none)
    {
        Owner.Behavior_ChangeCollisionSize(NewRadius, NewHeight);
    }
    //return;    
}

