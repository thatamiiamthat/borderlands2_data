function OnDestroyForInviteComplete(name SessionName, bool bWasSuccessful)
{
    // End:0x11C
    if(bWasSuccessful)
    {
        OnlineSub.GameInterface.AddJoinOnlineGameCompleteDelegate(OnInviteJoinComplete);
        PreOnGameInviteAccepted();
        // End:0x119
