        //return;        
    }

    event Timer()
    {
        // End:0x11
        if(!bFrozen)
        {
            return;
        }
        bFrozen = false;
        bPressedJump = false;
        //return;        
    }

    event BeginState(name PreviousStateName)
    {
        // End:0x55
        if((Pawn != none) && Pawn.Controller == self)
        {
            Pawn.Controller = none;
        }
        Pawn = none;
        // UnresolvedToken (0x5E)
