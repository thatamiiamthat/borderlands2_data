function OnGameInviteAccepted(const out OnlineGameSearchResult InviteResult)
{
    // End:0x262
    if((OnlineSub != none) && NotEqual_InterfaceInterface(OnlineSub.GameInterface, OnlineGameInterface(none)))
    {
