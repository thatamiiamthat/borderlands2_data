    event EndState(name NextStateName)
    {
        CleanOutSavedMoves();
        Velocity = vect(0, 0, 0);
        Acceleration = vect(0, 0, 0);
        // End:0x66
        if(!PlayerReplicationInfo.bOutOfLives)
