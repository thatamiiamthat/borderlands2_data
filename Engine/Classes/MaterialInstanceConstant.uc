    //return;    
}

function Behavior_SetObjectParameterValue(const out int Section, const out name ParameterName, const out Object Value)
{
    UnknownLocal_1 = Texture(Value);
    UnknownLocal_3 = Font(Value);
    // End:0x56
    if(UnknownLocal_1 != none)
    {
        SetTextureParameterValue(ParameterName, UnknownLocal_1);        
    }
    else
    {
        // End:0x7A
        if(UnknownLocal_3 != none)
        {
            SetFontParameterValue(ParameterName, UnknownLocal_3, 0);
        }
    }
    //return;    
}
