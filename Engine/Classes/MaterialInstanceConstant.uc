function Behavior_SetVectorParameterValue(const out int Section, const out name ParameterName, const out Vector Value)
{
    local LinearColor Temp;

    Temp.R = Value.X;
    Temp.G = Value.Y;
    Temp.B = Value.Z;
    Temp.A = 1;
    SetVectorParameterValue(ParameterName, Temp);
    //return;    
}

function Behavior_SetColorParameterValue(const out int Section, const out name ParameterName, const out LinearColor Value)
{
    SetVectorParameterValue(ParameterName, Value);
    //return;    
}

function Behavior_SetFloatParameterValue(const out int Section, const out name ParameterName, const out float Value)
