            if((UnknownLocal_1.bPreparingMove && Ladder(UnknownLocal_1.MoveTarget) != none) && Ladder(UnknownLocal_1.MoveTarget).MyLadder == self)
            {
                UnknownLocal_1.bPreparingMove = false;
                PendingClimber = UnknownLocal_1.Pawn;                
                return;
            }            
        }        
    }
    //return;    
}

