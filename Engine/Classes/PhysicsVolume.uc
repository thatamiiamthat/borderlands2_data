simulated event PostBeginPlay()
{
    super.PostBeginPlay();
    BACKUP_bPainCausing = bPainCausing;
    // End:0x35
    if(int(Role) < int(ROLE_Authority))
    {
        return;
    }
    // End:0x65
    if(bPainCausing)
    {
        PainTimer = Spawn(class'VolumeTimer', self);
    }
    //return;    
}

