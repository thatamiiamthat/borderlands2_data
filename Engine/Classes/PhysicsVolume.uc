function TimerPop(VolumeTimer T)
{
    // End:0x8D
    if(T == PainTimer)
    {
        // End:0x28
        if(!bPainCausing)
        {
            return;
        }
        // End:0x8C
        foreach TouchingActors(class'Actor', UnknownLocal_1)
        {
            // End:0x8B
            if(UnknownLocal_1.bCanBeDamaged && !UnknownLocal_1.bStatic)
            {
                CausePainTo(UnknownLocal_1);
            }            
        }        
    }
    //return;    
}

simulated event Touch(Actor Other, PrimitiveComponent OtherComp, Vector HitLocation, Vector HitNormal)
{
    super(Actor).Touch(Other, OtherComp, HitLocation, HitNormal);
    // End:0x63
    if((Other == none) || Other.bStatic)
    {
        return;
    }
    // End:0xD6
    if((bNoInventory && DroppedPickup(Other) != none) && Other.Owner == none)
    {
        Other.LifeSpan = 1.5;
        return;
    }
    // End:0x20C
    if(bMoveProjectiles && ZoneVelocity != vect(0, 0, 0))
    {
        // End:0x155
        if(int(Other.Physics) == int(6))
        {
            Other.Velocity += ZoneVelocity;            
        }
        else
        {
            // End:0x20C
            if(((Other.Base == none) && Other.IsA('Emitter')) && int(Other.Physics) == int(0))
            {
                Other.SetPhysics(6);
                Other.Velocity += ZoneVelocity;
            }
        }
    }
    // End:0x2A1
    if(bPainCausing)
    {
        // End:0x25D
        if(Other.bDestroyInPainVolume)
        {
            Other.VolumeBasedDestroy(self);
            return;
        }
        // End:0x2A1
        if(bEntryPain && Other.bCanBeDamaged)
        {
            CausePainTo(Other);
        }
    }
    //return;    
}

function CausePainTo(Actor Other)
{
    // End:0x13A
    if(DamagePerSec > float(0))
    {
        // End:0x60
        if(WorldInfo.bSoftKillZ && int(Other.Physics) != int(1))
        {
            return;
        }
        // End:0x99
        if((DamageTypeDefinition == none) && (DamageType == none) || DamageType == class'DamageType')
        {
        }
        UnknownLocal_1 = GetDamagePipeline(DamageTypeDefinition, ImpactDefinition);
        Other.TakeDamage(DamagePerSec * PainInterval, DamageInstigator, Location, vect(0, 0, 1), DamageType,, IDamageCauser(self), UnknownLocal_1);
        ReleaseDamagePipeline(UnknownLocal_1);        
    }
    else
    {
        Other.HealDamage(-DamagePerSec * PainInterval, DamageInstigator, DamageType, DamageTypeDefinition);
    }
    //return;    
}

