simulated function float HermiteEval(float Slip)
{
    UnknownLocal_1 = SimObj.WheelLatExtremumSlip;
    UnknownLocal_3 = SimObj.WheelLatExtremumValue;
    UnknownLocal_5 = SimObj.WheelLatAsymptoteSlip;
    UnknownLocal_7 = SimObj.WheelLatAsymptoteValue;
    // End:0x13E
    if(Slip < UnknownLocal_1)
    {
        Slip /= UnknownLocal_1;
        UnknownLocal_9 = Slip * Slip;
        UnknownLocal_11 = UnknownLocal_9 * Slip;
        UnknownLocal_13 = (-2 * UnknownLocal_11) + (3 * UnknownLocal_9);
        UnknownLocal_15 = (UnknownLocal_11 - (2 * UnknownLocal_9)) + Slip;
        return (UnknownLocal_15 + UnknownLocal_13) * UnknownLocal_3;        
    }
    else
    {
        // End:0x15A
        if(Slip > UnknownLocal_5)
        {
            return UnknownLocal_7;            
        }
        else
        {
            Slip -= UnknownLocal_1;
            Slip /= (UnknownLocal_5 - UnknownLocal_1);
            UnknownLocal_9 = Slip * Slip;
            UnknownLocal_11 = UnknownLocal_9 * Slip;
            UnknownLocal_13 = (-2 * UnknownLocal_11) + (3 * UnknownLocal_9);
            UnknownLocal_17 = ((2 * UnknownLocal_11) - (3 * UnknownLocal_9)) + 1;
            return (UnknownLocal_17 * UnknownLocal_3) + (UnknownLocal_13 * UnknownLocal_7);
        }
    }
    //return ReturnValue;    
}

simulated function GetSVehicleDebug(out array<string> DebugInfo)
{
    DebugInfo[DebugInfo.Length] = "----Vehicle----: ";
    DebugInfo[DebugInfo.Length] = ((("Speed: " $ string(VSize(Velocity))) $ " Unreal -- ") $ string(VSize(Velocity) * 0.0426125)) $ " MPH";
    // End:0xDA
    if(Wheels.Length > 0)
    {
        DebugInfo[DebugInfo.Length] = "MotorTorque: " $ string(Wheels[0].MotorTorque);
    }
    DebugInfo[DebugInfo.Length] = "Throttle: " $ string(OutputGas);
    DebugInfo[DebugInfo.Length] = "Brake: " $ string(OutputBrake);
    DebugInfo[DebugInfo.Length] = "Handbrake: " $ string(bOutputHandbrake);
    //return;    
}

