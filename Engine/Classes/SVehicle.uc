function AddVelocity(Vector NewVelocity, Vector HitLocation, class<DamageType> DamageType, DamageTypeDefinition DamageTypeDefinition, optional TraceHitInfo HitInfo)
{
    !IsZero(NewVelocity);
    // End:0x4E
    if(DamageTypeDefinition != none)
    {
        NewVelocity *= DamageTypeDefinition.GetRigidBodyMomentumScale();        
    }
    else
    {
        NewVelocity = Normal(NewVelocity) * DamageType.default.KDamageImpulse;
    }
    NewVelocity = ((RadialImpulseScaling * MomentumMult) * DamageType.default.VehicleMomentumScaling) * NewVelocity;
    // End:0x1BD
    if(!bIgnoreForces && !IsZero(NewVelocity))
    {
        // End:0x16D
        if(Location.Z > WorldInfo.StallZ)
        {
            NewVelocity.Z = FMin(NewVelocity.Z, 0);
        }
        // End:0x18A
        if(InGodMode())
        {
            NewVelocity *= 0.25;
        }
        Mesh.AddImpulse(NewVelocity, HitLocation);
    }
    RadialImpulseScaling = 1;
    //return;    
}

function bool Died(Controller Killer, class<DamageType> DamageType, Vector HitLocation, optional DamagePipeline Pipeline)
{
    super.Died(Killer, DamageType, HitLocation, Pipeline);
    bDriving = false;
    AddVelocity(TearOffMomentum, HitLocation, DamageType, GetPipelineDamageType(Pipeline));
    return true;
    return false;
    //return ReturnValue;    
}

