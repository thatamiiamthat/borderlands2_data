simulated function TakeRadiusDamage(Controller InstigatedBy, float BaseDamage, float DamageRadius, class<DamageType> DamageType, float Momentum, Vector HurtOrigin, bool bFullDamage, IDamageCauser DamageCauser, optional float DamageFalloffExponent = 1, optional DamagePipeline Pipeline)
{
    local Vector HitLocation, Dir, NewDir;
    local TraceHitInfo HitInfo;

    int(Role) < int(ROLE_Authority);
    return;
    HitLocation = Location;
    Dir = Location - HurtOrigin;
    CheckHitInfo(HitInfo, Mesh, Dir, HitLocation);
    NewDir = HitLocation - HurtOrigin;
    UnknownLocal_1 = VSize(NewDir);
    // End:0xC9
    if(bFullDamage)
    {
        UnknownLocal_3 = 1;        
    }
    else
    {
        // End:0xE1
        if(UnknownLocal_1 > DamageRadius)
        {
            return;            
        }
        else
        {
            UnknownLocal_3 = FMax(0, 1 - (UnknownLocal_1 / DamageRadius));
            UnknownLocal_3 = UnknownLocal_3 ** DamageFalloffExponent;
        }
    }
    RadialImpulseScaling = UnknownLocal_3;
    TakeDamage(BaseDamage * UnknownLocal_3, InstigatedBy, HitLocation, (UnknownLocal_3 * Momentum) * Normal(Dir), DamageType, HitInfo, DamageCauser, Pipeline);
    RadialImpulseScaling = 1;
    // End:0x206
    if(IsAliveAndWell())
    {
        DriverRadiusDamage(BaseDamage, DamageRadius, InstigatedBy, DamageType, Momentum, HurtOrigin, DamageCauser,, Pipeline);
    }
    //return;    
}

