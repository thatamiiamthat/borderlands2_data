class Ladder extends NavigationPoint
    native
    placeable
    hidecategories(Mobile,Navigation,MovementReplication,Lighting,LightColor,Force);

var LadderVolume MyLadder;
var Ladder LadderList;

event bool SuggestMovePreparation(Pawn Other)
{
    // End:0x11
    if(MyLadder == none)
    {
        return false;
    }
    // End:0x68
    if(!MyLadder.InUse(Other))
    {
        MyLadder.PendingClimber = Other;
        return false;
    }
    Other.Controller.bPreparingMove = true;
    Other.Acceleration = vect(0, 0, 0);
    return true;
    //return ReturnValue;    
}

defaultproperties
{
    bSpecialMove=true
    bNotBased=true
    begin object name=CollisionCylinder class=CylinderComponent
        CollisionHeight=80
        CollisionRadius=40
    object end
    // Reference: CylinderComponent'Default__Ladder.CollisionCylinder'
    CylinderComponent=CollisionCylinder
    Components(0)=none
    Components(1)=none
    Components(2)=none
    begin object name=CollisionCylinder class=CylinderComponent
        CollisionHeight=80
        CollisionRadius=40
    object end
    // Reference: CylinderComponent'Default__Ladder.CollisionCylinder'
    Components(3)=CollisionCylinder
    Components(4)=none
    Components(5)=none
    begin object name=CollisionCylinder class=CylinderComponent
        CollisionHeight=80
        CollisionRadius=40
    object end
    // Reference: CylinderComponent'Default__Ladder.CollisionCylinder'
    CollisionComponent=CollisionCylinder
}