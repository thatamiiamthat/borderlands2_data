class Behavior_ToggleVisibility extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IAppearanceBehavior ContextInterface;

    ContextInterface = ContextObject.QueryInterface(class'IAppearanceBehavior');
    // End:0x72
    if(NotEqual_InterfaceInterface(ContextInterface, IAppearanceBehavior(none)))
    {
        ContextInterface.Behavior_ToggleVisibility();
    }
    //return;    
}
