class Behavior_PlaySound extends BehaviorBase
    native(Gearbox)
    editinlinenew
    collapsecategories
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) const AkEvent Sound;
var(Action) bool bReplicateSound;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local ISoundBehavior ContextInterface;

    // End:0x94
    if(Sound != none)
    {
        ContextInterface = ContextObject.QueryInterface(class'ISoundBehavior');
        // End:0x94
        if(NotEqual_InterfaceInterface(ContextInterface, ISoundBehavior(none)))
        {
            ContextInterface.Behavior_PostAkEvent(Sound, bReplicateSound);
        }
    }
    //return;    
}
