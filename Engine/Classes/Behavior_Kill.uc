class Behavior_Kill extends BehaviorBase
    native(Gearbox)
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) const IKilledBehavior.EScriptedKillType DeathType;
var(Action) const DamageTypeDefinition DamageType;
var(Action) const BehaviorContextData TargetContext;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IKilledBehavior KilledInterface;

    KilledInterface = GetBehaviorContextInterface(class'IKilledBehavior', TargetContext, SelfObject, MyInstigatorObject, OtherEventParticipantObject, EventData);
    // End:0xAF
    if(NotEqual_InterfaceInterface(KilledInterface, IKilledBehavior(none)))
    {
        KilledInterface.Behavior_Killed(Actor(ContextObject), DamageType, DeathType);
    }
    //return;    
}
