class SceneCaptureActor extends Actor
    abstract
    native
    notplaceable
    hidecategories(Mobile,Navigation,MovementReplication);

var() const export editinline SceneCaptureComponent SceneCapture;

simulated function OnToggle(SeqAct_Toggle Action)
{
    // End:0x11
    if(SceneCapture == none)
    {
        return;
    }
    // End:0x52
    if(Action.InputLinks[0].bHasImpulse)
    {
        UnknownLocal_1 = true;        
    }
    else
    {
        // End:0x93
        if(Action.InputLinks[1].bHasImpulse)
        {
            UnknownLocal_1 = false;            
        }
        else
        {
            // End:0xF2
            if(Action.InputLinks[2].bHasImpulse)
            {
                UnknownLocal_1 = !SceneCapture.bEnabled;
            }
        }
    }
    SceneCapture.SetEnabled(UnknownLocal_1);
    //return;    
}

defaultproperties
{
    Components(0)=none
    RemoteRole=ENetRole.ROLE_SimulatedProxy
