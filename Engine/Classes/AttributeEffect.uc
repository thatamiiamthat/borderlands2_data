class AttributeEffect extends Object
    native(Gearbox)
    hidecategories(Mobile);

struct native AppliedAttributeEffect
{
    var Object Context;
    var AttributeDefinition Attribute;
    var AttributeModifier Modifier;

    structdefaultproperties
    {
        Context=none
        Attribute=none
        Modifier=none
    }
};

struct native AttributeEffectData
{
    var() const AttributeDefinition AttributeToModify;
    var() const Core.AttributeModifier.EModifierType ModifierType;
    var() const AttributeInitializationData BaseModifierValue;

    structdefaultproperties
    {
        AttributeToModify=none
        ModifierType=EModifierType.MT_Scale
        BaseModifierValue=(BaseValueConstant=0,BaseValueAttribute=none,InitializationDefinition=none,BaseValueScaleConstant=1)
    }
};

static function ApplyAttributeEffects(Actor ContextSource, const out array<AttributeEffectData> InAttributeEffects, out array<AppliedAttributeEffect> OutModifiers, optional Object OptionalOverrideContextSource)
{
    local AttributeEffectData InData;
    local AppliedAttributeEffect Effect;

    InAttributeEffects
    InData
    ,
    Effect.Modifier = new (ContextSource) class'AttributeModifier';
    Effect.Modifier.Type = InData.ModifierType;
    Effect.Modifier.Value = class'AttributeInitializationDefinition'.static.EvaluateInitializationData(InData.BaseModifierValue, ContextSource, OptionalOverrideContextSource);
    Effect.Context = none;
    Effect.Attribute = InData.AttributeToModify;
    // End:0x1D6
    if(OptionalOverrideContextSource != none)
    {
        Effect.Context = Effect.Attribute.ResolveContext(OptionalOverrideContextSource);
    }
    // End:0x250
    if(Effect.Context == none)
    {
        Effect.Context = Effect.Attribute.ResolveContext(ContextSource);
    }
    // End:0x2FC
    if(Effect.Context != none)
    {
        // End:0x2F9
        if(Effect.Attribute.AddAttributeModifier(Effect.Context, Effect.Modifier))
        {
            OutModifiers.AddItem(Effect;            
        }        
    }        
    //return;    
}

static function RemoveAttributeEffects(Actor Owner, out array<AppliedAttributeEffect> EffectModifiers)
{
    local AppliedAttributeEffect Effect;

    // End:0xA5
    foreach EffectModifiers(Effect,)
    {
        // End:0xA4
        if(Effect.Context != none)
        {
            Effect.Attribute.RemoveAttributeModifier(Effect.Context, Effect.Modifier);
        }        
    }    
    EffectModifiers.Length = 0;
    //return;    
}
