function AddAccuracyImpulse(float Delta, bool bOffHand)
{
    // End:0xC8
    if(int(Role) == int(ROLE_Authority))
    {
        // End:0x77
        if(!bOffHand)
        {
            // End:0x74
            if(IsResourcePoolValid(AccuracyPool))
            {
                AccuracyPool.Data.AddCurrentValueImpulse(Delta);
            }            
        }
        else
        {
            // End:0xC8
            if(IsResourcePoolValid(OffHandAccuracyPool))
            {
                OffHandAccuracyPool.Data.AddCurrentValueImpulse(Delta);
            }
        }
    }
    //return;    
}

