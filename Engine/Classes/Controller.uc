simulated function DisplayDebugResourcePools(HUD HUD, out float out_YL, out float out_YPos)
{
    DisplayDebugResourcePoolManager(ResourcePoolManager, "Controller", HUD, out_YL, out_YPos);
    // End:0xCB
    if(WorldInfo.GRI != none)
    {
        DisplayDebugResourcePoolManager(WorldInfo.GRI.ResourcePoolManager, "GameReplicationInfo", HUD, out_YL, out_YPos);
    }
    //return;    
}

simulated function DisplayDebugResourcePoolManager(ResourcePoolManager PoolManager, string ManagerDescription, HUD HUD, out float out_YL, out float out_YPos)
{
    local string DebugText;
    local array<string> PoolDebugText;

    // End:0x3BF
    if(PoolManager != none)
    {
        HUD.Canvas.SetDrawColor(255, 255, 255);
        HUD.Canvas.DrawText(((ManagerDescription $ " Resource Pools (") $ string(PoolManager.GetNumberOfPoolsInUse())) $ " in use)");
        out_YPos += out_YL;
        HUD.Canvas.SetPos(4, out_YPos);
        // End:0x3BE
        foreach class'ResourcePoolManager'.static.AllResourcePools(PoolManager, UnknownLocal_1)
        {
            HUD.Canvas.SetDrawColor(0, 255, 0);
            DebugText = "   " $ string(UnknownLocal_1.Definition);
            HUD.Canvas.DrawText(DebugText);
            HUD.Canvas.TextSize(DebugText, UnknownLocal_3, UnknownLocal_5);
            PoolDebugText.Length = 0;
            UnknownLocal_1.GetDebugText(PoolDebugText);
            // End:0x379
            foreach PoolDebugText(DebugText,)
            {
                HUD.Canvas.SetPos((4 + float(4)) + UnknownLocal_3, out_YPos);
                HUD.Canvas.SetDrawColor(255, 255, 255);
                HUD.Canvas.DrawText("      " $ DebugText);
                out_YPos += out_YL;                
            }            
            HUD.Canvas.SetPos(4, out_YPos);            
        }        
    }
    //return;    
}

