class Behavior_ChangeScale extends BehaviorBase
    editinlinenew
    collapsecategories
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) const float Scale;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IScaleBehavior ContextInterface;

    ContextInterface = ContextObject.QueryInterface(class'IScaleBehavior');
    // End:0x7B
    if(NotEqual_InterfaceInterface(ContextInterface, IScaleBehavior(none)))
    {
        ContextInterface.Behavior_ChangeScale(Scale);
    }
    //return;    
}

defaultproperties
{
    Scale=1
}