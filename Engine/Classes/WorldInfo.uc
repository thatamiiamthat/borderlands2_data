simulated event bool CanBeginHostMigration()
{
    // End:0x80
    foreach LocalPlayerControllers(class'PlayerController', UnknownLocal_1)
    {
        // End:0x7F
        if(UnknownLocal_1.IsPrimaryPlayer())
        {
            // End:0x7F
            if(!UnknownLocal_1.CanAllPlayersPlayOnline() || UnknownLocal_1.BestNextHostPeers.Length == 0)
            {                
                return false;
            }
        }        
    }    
    return true;
    //return ReturnValue;    
}

