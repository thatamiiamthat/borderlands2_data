}

simulated function PreBeginPlay()
{
    super(Actor).PreBeginPlay();
    // End:0x1BD
    if((int(WorldInfo.NetMode) != int(NM_DedicatedServer)) && IsInPersistentLevel())
    {
        // End:0xC1
        if(EmitterPoolClassPath != "")
        {
            UnknownLocal_1 = class<EmitterPool>(DynamicLoadObject(EmitterPoolClassPath, class'Class'));
            // End:0xC1
            if(UnknownLocal_1 != none)
            {
                MyEmitterPool = Spawn(UnknownLocal_1, self,, vect(0, 0, 0), rot(0, 0, 0));
            }
        }
        // End:0x13F
        if(DecalManagerClassPath != "")
        {
            UnknownLocal_3 = class<DecalManager>(DynamicLoadObject(DecalManagerClassPath, class'Class'));
            // End:0x13F
            if(UnknownLocal_3 != none)
            {
                MyDecalManager = Spawn(UnknownLocal_3, self,, vect(0, 0, 0), rot(0, 0, 0));
            }
        }
        // End:0x1BD
        if(ParticleEventManagerClassPath != "")
        {
            UnknownLocal_5 = class<ParticleEventManager>(DynamicLoadObject(ParticleEventManagerClassPath, class'Class'));
            // End:0x1BD
            if(UnknownLocal_5 != none)
            {
                MyParticleEventManager = Spawn(UnknownLocal_5, self,, vect(0, 0, 0), rot(0, 0, 0));
            }
        }
    }
    //return;    
}

