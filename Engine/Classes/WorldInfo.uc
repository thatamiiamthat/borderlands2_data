simulated event NotifyHostMigrationStateChanged(WorldInfo.EHostMigrationProgress NewState, WorldInfo.EHostMigrationProgress OldState)
{
    // End:0x83
    if((int(OldState) == int(0)) && int(NewState) != int(0))
    {
        // End:0x82
        foreach LocalPlayerControllers(class'PlayerController', UnknownLocal_1)
        {
            // End:0x81
            if(UnknownLocal_1.IsPrimaryPlayer())
            {
                UnknownLocal_1.NotifyHostMigrationStarted();
                // End:0x82
                break;
            }            
        }        
    }
    //return;    
}

