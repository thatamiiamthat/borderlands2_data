        UpdateAchievements();
    }
    //return;    
}

function UpdateAchievements()
{
    // End:0x160
    if(PlayerControllerId != -1)
    {
        Achievements.Length = 0;
        UnknownLocal_1 = class'GameEngine'.static.GetOnlineSubsystem();
        // End:0x14D
        if((((UnknownLocal_1 != none) && NotEqual_InterfaceInterface(UnknownLocal_1.PlayerInterface, OnlinePlayerInterface(none))) && int(UnknownLocal_1.PlayerInterface.GetLoginStatus(byte(PlayerControllerId))) > int(0)) && !UnknownLocal_1.PlayerInterface.IsGuestLogin(byte(PlayerControllerId)))
        {
            UnknownLocal_1.PlayerInterface.ReadAchievements(byte(PlayerControllerId));
        }
        NotifyPropertyChanged('Achievements');
    }
    //return;    
}
