function OnPlayerAchievementsChanged(int TitleId)
{
    local OnlineSubsystem.EOnlineEnumerationReadState Result;

    // End:0x123
    if(PlayerControllerId != -1)
    {
        UnknownLocal_1 = class'GameEngine'.static.GetOnlineSubsystem();
        // End:0x123
        if(((UnknownLocal_1 != none) && NotEqual_InterfaceInterface(UnknownLocal_1.PlayerInterface, OnlinePlayerInterface(none))) && TitleId == 0)
        {
            Result = UnknownLocal_1.PlayerInterface.GetAchievements(byte(PlayerControllerId), Achievements, TitleId);
            // End:0x123
            if(int(Result) == int(2))
            {
                PopulateAchievementIcons();
                NotifyPropertyChanged('Achievements');
                NotifyPropertyChanged('TotalGamerPoints');
            }
        }
    }
    //return;    
}

function OnPlayerAchievementUnlocked(bool bWasSuccessful)
{
    // End:0x17
    if(bWasSuccessful)
