                UnknownLocal_1.PlayerInterface.AddLoginChangeDelegate(OnLoginChange);
                UnknownLocal_1.PlayerInterface.AddReadAchievementsCompleteDelegate(byte(PlayerControllerId), OnPlayerAchievementsChanged);
                UnknownLocal_1.PlayerInterface.AddUnlockAchievementCompleteDelegate(byte(PlayerControllerId), OnPlayerAchievementUnlocked);
