        if(BeaconArrow != none)
        {
            DetachComponent(BeaconArrow);
        }
        BeaconArrow = new (self) class'ArrowComponent';
        BeaconArrow.ArrowColor = MakeColor(BeaconColor.R, BeaconColor.G, BeaconColor.B, BeaconColor.A);
        BeaconArrow.ArrowSize = 2048;
        BeaconArrow.SetRotation(Rotator(vect(0, 0, 1)));
        BeaconArrow.bIsDebugBeacon = true;
        AttachComponent(BeaconArrow);
    }
    BeaconArrow.SetHidden(!bEnabled);
    //return;    
}

