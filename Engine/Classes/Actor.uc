}

function Behavior_ConsoleCommand(const string Command)
{
    // End:0x4D
    foreach LocalPlayerControllers(class'PlayerController', UnknownLocal_1)
    {        
        UnknownLocal_1.ConsoleCommand(Command);
        // End:0x4D
        break;        
    }    
    //return;    
}

function Behavior_ClientConsoleCommand(const string Command)
{
    // End:0x75
    if((Instigator != none) && Instigator.Controller != none)
    {
        Instigator.Controller.ClientConsoleCommand(Command);        
    }
    else
    {
        ClientConsoleCommand(Command);
    }
    //return;    
}

reliable client simulated function ClientConsoleCommand(const string Command)
{
    ConsoleCommand(Command);
    //return;    
}

