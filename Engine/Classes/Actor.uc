simulated function Behavior_ChangeCollisionSize(float NewRadius, float NewHeight)
{
    SetCollisionSize(NewRadius, NewHeight);
    // End:0x69
    if(bCollideActors && bBlockActors)
    {
        UnknownLocal_1 = bCollideAsEncroacher;
        bCollideAsEncroacher = true;
        SetLocation(Location);
        bCollideAsEncroacher = UnknownLocal_1;
    }
    //return;    
}

simulated function Behavior_ToggleVisibility()
{
    SetHidden(!bHidden);
    ForceNetRelevant();
    //return;    
}

simulated function Behavior_ChangeVisibility(bool bVisible)
{
    SetHidden(!bVisible);
    ForceNetRelevant();
    //return;    
}

simulated function WaitingForAttachmentBase()
{
    local IWorldBody BaseInterface, AttachmentBaseInterface;

    BaseInterface = Base.QueryInterface(class'IWorldBody');
    AttachmentBaseInterface = BaseInterface.GetWorldBodyAttachmentBase();
    // End:0xBC
    if(NotEqual_InterfaceInterface(AttachmentBaseInterface, IWorldBody(none)))
    {
        AttachmentBaseInterface.WorldBodyAttachActor(self,,, BaseBoneName);
        ClearTimer('WaitingForAttachmentBase');
    }
    //return;    
}

