simulated function Behavior_PlaySound(SoundCue Sound, bool bReplicateSound)
{
    PlaySound(Sound, !bReplicateSound, false, Sound.IsSoundLooping());
    //return;    
}

simulated function Behavior_PlaySoundForListener(SoundCue Sound, Actor Source, PlayerController Listener)
{
    // End:0x7E
    if(Listener != none)
    {
        Listener.ClientHearSound(Sound, Source, ((Source != none) ? Source.Location : vect(0, 0, 0)), true, false);
    }
    //return;    
}

