event OnRegister(LocalPlayer InPlayer)
{
    local OnlinePlayerInterface PlayerInterface;

    // End:0x1E5
    if(InPlayer != none)
    {
        PlayerControllerId = InPlayer.ControllerId;
        UnknownLocal_1 = class'GameEngine'.static.GetOnlineSubsystem();
        // End:0x15D
        if(UnknownLocal_1 != none)
        {
            PlayerInterface = UnknownLocal_1.PlayerInterface;
            // End:0xDC
            if(NotEqual_InterfaceInterface(PlayerInterface, OnlinePlayerInterface(none)))
            {
                PlayerInterface.AddLoginChangeDelegate(OnLoginChange);
            }
            // End:0x15A
            if(NotEqual_InterfaceInterface(UnknownLocal_1.PlayerInterfaceEx, OnlinePlayerInterfaceEx(none)))
            {
                UnknownLocal_1.PlayerInterfaceEx.AddProfileDataChangedDelegate(byte(PlayerControllerId), OnPlayerDataChange);
            }            
        }
        else
        {
            // End:0x1C6
            if((ProfileProvider != none) && ProfileProvider.Profile != none)
            {
                ProfileProvider.Profile.SetToDefaults();
            }
        }
        RegisterDelegates();
        OnLoginChange(byte(PlayerControllerId));
    }
    //return;    
}

event OnUnregister()
{
    local OnlinePlayerInterface PlayerInterface;

    // End:0x140
