function bool ProcessControlKey(name Key, Core.Object.EInputEvent Event)
{
    // End:0x78
    if((Key == 'LeftControl') || Key == 'RightControl')
    {
        // End:0x53
        if(int(Event) == int(1))
        {
            bCtrl = false;            
        }
        else
        {
            // End:0x73
            if(int(Event) == int(0))
            {
                bCtrl = true;
            }
        }
        return true;        
    }
    else
    {
        // End:0x2DD
        if(((bCtrl && int(Event) == int(0)) && Outer.Outer.GamePlayers.Length > 0) && Outer.Outer.GamePlayers[0].Actor != none)
        {
            // End:0x1AF
            if(Key == 'V')
            {
                AppendInputText(Outer.Outer.GamePlayers[0].Actor.PasteFromClipboard());
                return true;                
            }
            else
            {
                // End:0x234
                if(Key == 'C')
                {
                    Outer.Outer.GamePlayers[0].Actor.CopyToClipboard(TypedStr);
                    return true;                    
                }
                else
                {
                    // End:0x2DD
                    if(Key == 'X')
                    {
                        // End:0x2DB
                        if(TypedStr != "")
                        {
                            Outer.Outer.GamePlayers[0].Actor.CopyToClipboard(TypedStr);
                            SetInputText("");
                            SetCursorPos(0);
                        }
                        return true;
                    }
                }
            }
        }
    }
    return false;
    //return ReturnValue;    
}

