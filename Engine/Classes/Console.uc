                            if((Key == 'Enter') && int(Event) == int(1))
                            {
                                // End:0x294
                                if(TypedStr != "")
                                {
                                    Temp = TypedStr;
                                    SetInputText("");
                                    SetCursorPos(0);
                                    // End:0x277
                                    if(Temp ~= "cls")
                                    {
                                        ClearOutput();                                        
                                    }
                                    else
                                    {
                                        ShippingConsoleCommand(Temp);
                                    }
                                    UpdateCompleteIndices();
                                }
                                return true;                                
                            }
                            else
                            {
                                // End:0x2D9
                                if(global.InputKey(ControllerId, Key, Event, AmountDepressed, bGamepad))
                                {
                                    return true;                                    
                                }
                                else
                                {
                                    // End:0x35E
                                    if((int(Event) != int(0)) && int(Event) != int(2))
                                    {
                                        // End:0x359
                                        if(!bGamepad)
                                        {
                                            return ((Key != 'LeftMouseButton') && Key != 'MiddleMouseButton') && Key != 'RightMouseButton';
                                        }
                                        return false;                                        
                                    }
                                    else
                                    {
                                        // End:0x482
                                        if(Key == 'Up')
                                        {
                                            // End:0x428
                                            if(!bCtrl)
                                            {
                                                // End:0x425
                                                if(HistoryBot >= 0)
                                                {
                                                    // End:0x3C0
                                                    if(HistoryCur == HistoryBot)
                                                    {
                                                        HistoryCur = HistoryTop;                                                        
                                                    }
                                                    else
                                                    {
                                                        -- HistoryCur;
                                                        // End:0x3E9
                                                        if(HistoryCur < 0)
                                                        {
                                                            HistoryCur = 16 - 1;
                                                        }
                                                    }
                                                    SetInputText(History[HistoryCur]);
                                                    SetCursorPos(Len(History[HistoryCur]));
                                                }                                                
                                            }
                                            else
                                            {
                                                // End:0x47D
                                                if(SBPos < (Scrollback.Length - 1))
                                                {
                                                    ++ SBPos;
                                                    // End:0x47D
                                                    if(SBPos >= Scrollback.Length)
                                                    {
                                                        SBPos = Scrollback.Length - 1;
                                                    }
                                                }
                                            }
                                            return true;                                            
                                        }
                                        else
                                        {
                                            // End:0x576
                                            if(Key == 'Down')
                                            {
                                                // End:0x53D
                                                if(!bCtrl)
                                                {
                                                    // End:0x53A
                                                    if(HistoryBot >= 0)
                                                    {
                                                        // End:0x4E4
                                                        if(HistoryCur == HistoryTop)
                                                        {
                                                            HistoryCur = HistoryBot;                                                            
                                                        }
                                                        else
                                                        {
                                                            HistoryCur = __NFUN_253__(HistoryCur + 1, 16);
                                                        }
                                                        SetInputText(History[HistoryCur]);
                                                        SetCursorPos(Len(History[HistoryCur]));
                                                    }                                                    
                                                }
                                                else
                                                {
                                                    // End:0x571
                                                    if(SBPos > 0)
                                                    {
                                                        -- SBPos;
                                                        // End:0x571
                                                        if(SBPos < 0)
                                                        {
                                                            SBPos = 0;
                                                        }
                                                    }
                                                }
                                                return true;                                                
                                            }
                                            else
                                            {
                                                // End:0x607
                                                if(Key == 'BackSpace')
                                                {
                                                    // End:0x602
                                                    if(TypedStrPos > 0)
                                                    {
                                                        SetInputText(Left(TypedStr, TypedStrPos - 1) $ Right(TypedStr, Len(TypedStr) - TypedStrPos));
                                                        SetCursorPos(TypedStrPos - 1);
                                                        bAutoCompleteLocked = false;
                                                    }
                                                    return true;                                                    
                                                }
                                                else
                                                {
                                                    // End:0x680
                                                    if(Key == 'Delete')
                                                    {
                                                        // End:0x67B
                                                        if(TypedStrPos < Len(TypedStr))
                                                        {
                                                            SetInputText(Left(TypedStr, TypedStrPos) $ Right(TypedStr, (Len(TypedStr) - TypedStrPos) - 1));
                                                        }
                                                        return true;                                                        
                                                    }
                                                    else
                                                    {
                                                        // End:0x6B5
                                                        if(Key == 'Left')
                                                        {
                                                            SetCursorPos(Max(0, TypedStrPos - 1));
                                                            return true;                                                            
                                                        }
                                                        else
                                                        {
                                                            // End:0x6F4
                                                            if(Key == 'Right')
                                                            {
                                                                SetCursorPos(Min(Len(TypedStr), TypedStrPos + 1));
                                                                return true;                                                                
                                                            }
                                                            else
                                                            {
                                                                // End:0x728
                                                                if(bCtrl && Key == 'Home')
                                                                {
                                                                    SBPos = 0;                                                                    
                                                                }
                                                                else
                                                                {
                                                                    // End:0x74F
                                                                    if(Key == 'Home')
                                                                    {
                                                                        SetCursorPos(0);
                                                                        return true;                                                                        
                                                                    }
                                                                    else
                                                                    {
                                                                        // End:0x78F
                                                                        if(bCtrl && Key == 'End')
                                                                        {
                                                                            SBPos = Scrollback.Length - 1;                                                                            
                                                                        }
                                                                        else
                                                                        {
                                                                            // End:0x7C0
                                                                            if(Key == 'End')
                                                                            {
                                                                                SetCursorPos(Len(TypedStr));
                                                                                return true;                                                                                
                                                                            }
                                                                            else
                                                                            {
                                                                                // End:0x867
                                                                                if((Key == 'PageUp') || Key == 'MouseScrollUp')
                                                                                {
                                                                                    // End:0x862
                                                                                    if(SBPos < (Scrollback.Length - 1))
                                                                                    {
                                                                                        // End:0x828
                                                                                        if(bCtrl)
                                                                                        {
                                                                                            SBPos += 5;                                                                                            
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            ++ SBPos;
                                                                                        }
                                                                                        // End:0x862
                                                                                        if(SBPos >= Scrollback.Length)
                                                                                        {
                                                                                            SBPos = Scrollback.Length - 1;
                                                                                        }
                                                                                    }
                                                                                    return true;                                                                                    
                                                                                }
                                                                                else
                                                                                {
                                                                                    // End:0x8EA
                                                                                    if((Key == 'PageDown') || Key == 'MouseScrollDown')
                                                                                    {
                                                                                        // End:0x8E8
                                                                                        if(SBPos > 0)
                                                                                        {
                                                                                            // End:0x8C3
                                                                                            if(bCtrl)
                                                                                            {
                                                                                                SBPos -= 5;                                                                                                
                                                                                            }
                                                                                            else
                                                                                            {
                                                                                                -- SBPos;
                                                                                            }
                                                                                            // End:0x8E8
                                                                                            if(SBPos < 0)
                                                                                            {
                                                                                                SBPos = 0;
                                                                                            }
                                                                                        }
                                                                                        return true;
                                                                                    }
                                                                                }
                                                                            }
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        return true;
        //return ReturnValue;        
    }

    event PostRender_Console(Canvas Canvas)
    {
        local string OutStr;

        Canvas.Font = class'Engine'.static.GetSmallFont();
        UnknownLocal_1 = Canvas.ClipY * 0.75;
        Canvas.SetDrawColor(255, 255, 255, 255);
        Canvas.SetPos(0, 0);
        Canvas.DrawTile(DefaultTexture_Black, Canvas.ClipX, UnknownLocal_1, 0, 0, 32, 32);
        OutStr = "(>" @ TypedStr;
        Canvas.StrLen(OutStr, UnknownLocal_3, UnknownLocal_5);
        Canvas.SetPos(0, (UnknownLocal_1 - float(12)) - UnknownLocal_5);
        Canvas.SetDrawColor(0, 255, 0);
        Canvas.DrawTile(DefaultTexture_White, Canvas.ClipX, 2, 0, 0, 32, 32);
        Canvas.SetPos(0, UnknownLocal_1);
        Canvas.DrawTile(DefaultTexture_White, Canvas.ClipX, 2, 0, 0, 32, 32);
        Canvas.SetPos(0, (UnknownLocal_1 - float(5)) - UnknownLocal_5);
        Canvas.bCenter = false;
        Canvas.DrawText(OutStr, false);
        // End:0x64C
        if(AutoCompleteIndices.Length > 0)
        {
            UnknownLocal_7 = AutoCompleteIndices[0];
            Canvas.SetPos(0 + UnknownLocal_3, (UnknownLocal_1 - float(5)) - UnknownLocal_5);
            Canvas.SetDrawColor(87, 148, 87);
            Canvas.DrawText(Right(AutoCompleteList[UnknownLocal_7].Command, Len(AutoCompleteList[UnknownLocal_7].Command) - Len(TypedStr)), false);
            Canvas.StrLen("(>", UnknownLocal_3, UnknownLocal_5);
            UnknownLocal_9 = UnknownLocal_1 + float(5);
            UnknownLocal_11 = 0;
            J0x478:

            // End:0x64C [Loop If]
            if((UnknownLocal_11 < AutoCompleteIndices.Length) && UnknownLocal_11 < 10)
            {
                UnknownLocal_7 = AutoCompleteIndices[UnknownLocal_11];
                Canvas.SetPos(0 + UnknownLocal_3, UnknownLocal_9);
                Canvas.StrLen(AutoCompleteList[UnknownLocal_7].Desc, UnknownLocal_13, UnknownLocal_15);
                Canvas.SetDrawColor(0, 0, 0);
                Canvas.DrawTile(DefaultTexture_White, UnknownLocal_13, UnknownLocal_15, 0, 0, 32, 32);
                Canvas.SetPos(0 + UnknownLocal_3, UnknownLocal_9);
                Canvas.SetDrawColor(0, 255, 0);
                Canvas.DrawText(AutoCompleteList[UnknownLocal_7].Desc, false);
                UnknownLocal_9 += UnknownLocal_15;
                ++ UnknownLocal_11;
                // [Loop Continue]
                goto J0x478;
            }
        }
        OutStr = "(>" @ Left(TypedStr, TypedStrPos);
        Canvas.StrLen(OutStr, UnknownLocal_3, UnknownLocal_5);
        Canvas.SetPos(UnknownLocal_3, (UnknownLocal_1 - float(3)) - UnknownLocal_5);
        Canvas.DrawText("_");
        UnknownLocal_7 = SBHead - SBPos;
        UnknownLocal_9 = (UnknownLocal_1 - float(16)) - (UnknownLocal_5 * float(2));
        // End:0x749
        if(Scrollback.Length == 0)
        {
            return;
        }
        Canvas.SetDrawColor(255, 255, 255, 255);
        J0x770:

        // End:0x8B8 [Loop If]
        if((UnknownLocal_9 > UnknownLocal_5) && UnknownLocal_7 >= 0)
        {
            Canvas.SetPos(0, UnknownLocal_9);
            Canvas.StrLen(Scrollback[UnknownLocal_7], UnknownLocal_17, UnknownLocal_19);
            // End:0x870
            if(UnknownLocal_19 > UnknownLocal_5)
            {
                UnknownLocal_9 -= (UnknownLocal_19 - UnknownLocal_5);
                Canvas.SetPos(Canvas.CurX, UnknownLocal_9, Canvas.CurZ);
            }
            Canvas.DrawText(Scrollback[UnknownLocal_7], false);
            -- UnknownLocal_7;
            UnknownLocal_9 -= UnknownLocal_5;
            // [Loop Continue]
            goto J0x770;
        }
        //return;        
    }

    event BeginState(name PreviousStateName)
    {
        bCaptureKeyInput = true;
        HistoryCur = HistoryTop;
        SBPos = 0;
        bCtrl = false;
        // End:0x57
        if(PreviousStateName == 'None')
        {
            FlushPlayerInput();
        }
        //return;        
    }
    stop;    
}

