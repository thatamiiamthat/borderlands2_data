simulated function SetPickupMesh()
{
    // End:0xE7
    if(InventoryType.default.PickupFactoryMesh != none)
    {
        // End:0x51
        if(PickupMesh != none)
        {
            DetachComponent(PickupMesh);
            PickupMesh = none;
        }
        PickupMesh = new (self) InventoryType.default.PickupFactoryMesh.Class (InventoryType.default.PickupFactoryMesh);
        AttachComponent(PickupMesh);
        // End:0xDD
        if(bPickupHidden)
        {
            SetPickupHidden();            
        }
        else
        {
            SetPickupVisible();
        }
    }
    //return;    
}

function Reset()
{
    // End:0x1E
    if(bIsSuperItem)
    {
        GotoState('Sleeping');        
    }
    else
    {
        GotoState('Pickup');
    }
    super(Actor).Reset();
    //return;    
}

function bool CheckForErrors()
{
    local Vector HitLocation, HitNormal;

    UnknownLocal_1 = Trace(HitLocation, HitNormal, Location - vect(0, 0, 10), Location, false);
    // End:0x4F
    if(UnknownLocal_1 == none)
