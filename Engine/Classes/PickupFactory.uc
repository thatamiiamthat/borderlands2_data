}

simulated event ReplicatedEvent(name VarName)
{
    // End:0x3E
    if(VarName == 'bPickupHidden')
    {
        // End:0x31
        if(bPickupHidden)
        {
            SetPickupHidden();            
        }
        else
        {
            SetPickupVisible();
        }        
    }
    else
    {
        // End:0x5F
        if(VarName == 'InventoryType')
        {
            InitializePickup();
        }
    }
    //return;    
}

simulated event PreBeginPlay()
{
