struct native ImpulseData
{
    var Vector Impulse;
    var Vector Source;

    structdefaultproperties
    {
        Impulse=(X=0,Y=0,Z=0)
        Source=(X=0,Y=0,Z=0)
    }
};

var repnotify ImpulseData ReplicatedImpulse;

replication
{
    // Pos:0x000
     if(bNetInitial && int(Role) == int(ROLE_Authority))
        ReplicatedImpulse;
}

simulated event ReplicatedEvent(name VarName)
{
    // End:0x2D
    if(VarName == 'ReplicatedImpulse')
    {
        SetTimer(0.1, false, 'ApplyReplicatedImpulse');        
    }
    else
    {
        super.ReplicatedEvent(VarName);
    }
    //return;    
}

simulated function ApplyReplicatedImpulse()
{
    CollisionComponent.AddImpulse(ReplicatedImpulse.Impulse, ReplicatedImpulse.Source);
    //return;    
}

