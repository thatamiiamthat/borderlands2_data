protected simulated function SkeletalMeshComponent CloneInventorySkelMeshComponent(Actor CloneOwner, SkeletalMeshComponent SourceMeshComponent, float SourceMeshScale, optional SkeletalMeshComponent DestMeshComponent)
{
    local editinline SkeletalMeshComponent ClonedMeshComponent;

    !CloneOwner != none;
    return none;
    ClonedMeshComponent = DestMeshComponent;
    // End:0x17A
    if(SourceMeshComponent != none)
    {
        // End:0x7A
        if(ClonedMeshComponent == none)
        {
            ClonedMeshComponent = new (CloneOwner) SourceMeshComponent.Class;
        }
        // End:0x8D
        if(!ClonedMeshComponent != none)
        {
            return none;
        }
        ClonedMeshComponent.SetSkeletalMesh(SourceMeshComponent.SkeletalMesh);
        ClonedMeshComponent.InitGestaltMeshDataFromOther(SourceMeshComponent);
        ClonedMeshComponent.SetScale(ClonedMeshComponent.Scale * SourceMeshScale);
        ClonedMeshComponent.bOverrideAttachmentOwnerVisibility = SourceMeshComponent.bOverrideAttachmentOwnerVisibility;
    }
    return ClonedMeshComponent;
    //return ReturnValue;    
}

simulated event MeshComponent ClonePrimaryMeshForUI()
{
    local editinline MeshComponent PrimaryMesh;

    PrimaryMesh = ClonePrimaryMesh();
    // End:0x8C
    if(PrimaryMesh != none)
    {
        PrimaryMesh.SetShadowParent(none);
        UnknownLocal_1 = GetInventoryDefinition();
        PrimaryMesh.SetRotation(UnknownLocal_1.UIMeshRotation);
    }
    return PrimaryMesh;
    //return ReturnValue;    
}

