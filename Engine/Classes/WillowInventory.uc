protected simulated event TranslateUseFailure(Pawn Other, int FailureFlag, out string Output)
{
    UnknownLocal_1 = GetInventoryDefinition();
    // End:0x13C
    if(UnknownLocal_1 != none)
    {
        switch(FailureFlag)
        {
            // End:0xDE
            case 0:
                UnknownLocal_3 = GetPlayerExpLevelRequiredToUse(Other);
                // End:0xA9
                if(UnknownLocal_3 > 72)
                {
                    UnknownLocal_5 = UnknownLocal_3 - 72;
                    Output = Repl(GetUseFailureOPLevelMessage(), "%0", string(72));
                    Output = Repl(Output, "%1", string(UnknownLocal_5));                    
                }
                else
                {
                    Output = Repl(UnknownLocal_1.UseFailureLevelMessage, "%d", string(UnknownLocal_3));
                }
                // End:0x13C
                break;
            // End:0x109
            case 1:
                Output = UnknownLocal_1.UseFailureConstraintsMessage;
                // End:0x13C
                break;
            // End:0x139
            case 2:
                Output = GetDLCRestrictedMessage(GetPawnController(Other), false);
                // End:0x13C
                break;
            // End:0xFFFF
            default:
                break;
        }
    }
    else
    {
        //return;        
    }
}

