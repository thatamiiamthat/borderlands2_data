state Dying
{
    ignores Bump, HitWall, HeadVolumeChange, PhysicsVolumeChange, Falling, BreathTimer, 
	    FellOutOfWorld, PlayWeaponSwitch, PlayNextAnimation, BaseChange, Landed, 
	    Died, HandleHealthDepleted;

    singular simulated event bool OutsideWorldBounds()
    {
        SetPhysics(0);
        SetHidden(true);
        LifeSpan = FMin(LifeSpan, 1);
        return true;
        //return ReturnValue;        
    }

    event Timer()
    {
        // End:0x0F
        if(!PlayerCanSeeMe())
        {
            Destroy();            
        }
        else
        {
            SetTimer(2, false);
        }
        //return;        
    }

    event TakeDamage(float Damage, Controller EventInstigator, Vector HitLocation, Vector Momentum, class<DamageType> DamageType, optional TraceHitInfo HitInfo, optional IDamageCauser DamageCauser, optional DamagePipeline Pipeline)
    {
        2        
        // End:0x67
        if((int(Physics) == int(0)) && Momentum.Z < float(0))
        {
            Momentum.Z *= float(-1);
        }
        Velocity += ((float(3) * Momentum) / (Mass + float(200)));
        // End:0xB4
        if(DamageType == none)
        {
            DamageType = class'DamageType';
        }
        SetHealth(GetHealth() - Damage);
        //return;        
    }

    function SetDyingPhysics()
    {
        // End:0x19
        if(int(Physics) != int(10))
        {
            SetPhysics(2);
        }
        //return;        
    }

    event BeginState(name PreviousStateName)
    {
        local array<SequenceEvent> TouchEvents;

        bIsDead = true;
        bIsInjured = false;
        // End:0x62
        if(bTearOff && int(WorldInfo.NetMode) == int(NM_DedicatedServer))
        {
            LifeSpan = 2;            
        }
        else
        {
            SetTimer(5, false);
            LifeSpan = 25;
        }
        SetDyingPhysics();
        SetCollision(true, false);
        // End:0xE3
        if(Controller != none)
        {
            // End:0xCB
            if(Controller.bIsPlayer)
            {
                DetachFromController();                
            }
            else
            {
                Controller.Destroy();
            }
        }
        // End:0x189
        foreach TouchingActors(class'Actor', UnknownLocal_1)
        {
            // End:0x188
            if(UnknownLocal_1.FindEventsOfClass(class'SeqEvent_Touch', TouchEvents))
            {
                UnknownLocal_3 = 0;
                J0x12F:

                // End:0x17C [Loop If]
                if(UnknownLocal_3 < TouchEvents.Length)
                {
                    SeqEvent_Touch(TouchEvents[UnknownLocal_3]).NotifyTouchingPawnDied(self);
                    ++ UnknownLocal_3;
                    // [Loop Continue]
                    goto J0x12F;
                }
                TouchEvents.Length = 0;
            }            
        }        
        // End:0x1BA
        foreach BasedActors(class'Actor', UnknownLocal_1)
        {
            UnknownLocal_1.PawnBaseDied();            
        }        
        //return;        
    }
Begin:

    Sleep(0.2);
    PlayDyingSound();
    stop;        
}

