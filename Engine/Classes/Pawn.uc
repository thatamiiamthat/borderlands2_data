function bool Died(Controller Killer, class<DamageType> DamageType, Vector HitLocation, optional DamagePipeline Pipeline)
{
    DamageType == none;
    DamageType = class'DamageType';
    // End:0x91
    if((bDeleteMe || WorldInfo.Game == none) || WorldInfo.Game.bLevelChange)
    {
        return false;
    }
    // End:0x101
    if((DamageType.default.bCausedByWorld && (Killer == none) || Killer == Controller) && LastHitBy != none)
    {
        Killer = LastHitBy;
    }
    // End:0x184
    if(WorldInfo.Game.PreventDeath(self, Killer, DamageType, GetPipelineDamageType(Pipeline), HitLocation))
    {
        SetHealth(float(Max(int(GetHealth()), 1)));
        return false;
    }
    SetHealth(float(Min(0, int(GetHealth()))));
    DestroyHealthPool();
    // End:0x1C7
    if(default.KismetDeathDelayTime > float(0))
    {
        DelayTriggerDeath();        
    }
    else
    {
        TriggerEventClass(class'SeqEvent_Death', self);
    }
    KismetDeathDelayTime = default.KismetDeathDelayTime + WorldInfo.TimeSeconds;
    // End:0x241
    foreach LatentActions(UnknownLocal_1,)
    {
        UnknownLocal_1.AbortFor(self);        
    }    
    LatentActions.Length = 0;
    // End:0x2C3
    if(DrivenVehicle != none)
    {
        Velocity = DrivenVehicle.Velocity;
        DrivenVehicle.DriverDied(DamageType, GetPipelineDamageType(Pipeline));        
    }
    else
    {
        // End:0x359
        if(((Weapon != none) && WorldInfo.Game.ShouldPawnDropWeaponOnDeath(self)) && Weapon.bDropOnDeath)
        {
            Weapon.HolderDied();
            ThrowWeaponOnDeath();
        }
    }
    // End:0x3C4
    if(Controller != none)
    {
        WorldInfo.Game.Killed(Killer, Controller, self, DamageType, Pipeline);        
    }
    else
    {
        WorldInfo.Game.Killed(Killer, Controller(Owner), self, DamageType, Pipeline);
    }
    DrivenVehicle = none;
    // End:0x45F
    if(InvManager != none)
    {
        InvManager.OwnerDied();
    }
    Velocity.Z *= 1.3;
    // End:0x4B8
    if(IsHumanControlled())
    {
        PlayerController(Controller).ForceDeathUpdate();
    }
    NetUpdateFrequency = default.NetUpdateFrequency;
    PlayDying(DamageType, GetPipelineDamageType(Pipeline), GetPipelineImpactDefinition(Pipeline), HitLocation);
    TellOpportunityPawnIsDead(false);
    class'PawnAllegiance'.static.RemoveParent(QueryInterface(class'ITargetable'));
    class'PawnAllegiance'.static.RemoveChildren(QueryInterface(class'ITargetable'));
    return true;
    //return ReturnValue;    
}

