simulated event ReplicatedEvent(name VarName)
{
    super.ReplicatedEvent(VarName);
    // End:0x4A
    if(VarName == 'FlashCount')
    {
        FlashCountUpdated(Weapon, FlashCount, true);        
    }
    else
    {
        // End:0x81
        if(VarName == 'OffHandFlashCount')
        {
            FlashCountUpdated(OffHandWeapon, OffHandFlashCount, true);            
        }
        else
        {
            // End:0x9B
            if(VarName == 'FlashLocation')
            {                
            }
            else
            {
                // End:0xD2
                if(VarName == 'FiringMode')
                {
                    FiringModeUpdated(Weapon, FiringMode, true);                    
                }
                else
                {
                    // End:0x105
                    if(VarName == 'DrivenVehicle')
                    {
                        // End:0x102
                        if(DrivenVehicle != none)
                        {
                            NotifyTeamChanged();
                        }                        
                    }
                    else
                    {
                        // End:0x129
                        if(VarName == 'PlayerReplicationInfo')
                        {
                            NotifyTeamChanged();                            
                        }
                        else
                        {
                            // End:0x175
                            if(VarName == 'Allegiance')
                            {
                                class'TargetableList'.static.ResetAllegiance(QueryInterface(class'ITargetable'));                                
                            }
                            else
                            {
                                // End:0x25D
                                if(VarName == 'Controller')
                                {
                                    // End:0x25A
                                    if((Controller != none) && Controller.Pawn == none)
                                    {
                                        Controller.Pawn = self;
                                        // End:0x25A
                                        if((PlayerController(Controller) != none) && PlayerController(Controller).ViewTarget == Controller)
                                        {
                                            PlayerController(Controller).SetViewTarget(self);
                                        }
                                    }                                    
                                }
                                else
                                {
                                    // End:0x29B
                                    if(VarName == 'bUsedByMatinee')
                                    {
                                        // End:0x28E
                                        if(bUsedByMatinee)
                                        {
                                            BeginAIGroup();                                            
                                        }
                                        else
                                        {
                                            FinishAIGroup();
                                        }                                        
                                    }
                                    else
                                    {
                                        // End:0x2BC
                                        if(VarName == 'BalanceDefinitionState')
                                        {
                                            ApplyBalanceDefinitionCustomizations();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    //return;    
}

function InitializeBalanceDefinitionState(BaseBalanceDefinition BalanceDefinition, int GradeIndex)
{
    BalanceDefinitionState.BalanceDefinition = BalanceDefinition;
    BalanceDefinitionState.GradeIndex = GradeIndex;
    BalanceDefinitionState.bGradeCustomizationsApplied = false;
    ApplyBalanceDefinitionCustomizations();
    //return;    
}

simulated function ApplyBalanceDefinitionCustomizations()
{
    // End:0xB3
    if(!BalanceDefinitionState.bGradeCustomizationsApplied && BalanceDefinitionState.BalanceDefinition != none)
    {
        BalanceDefinitionState.bGradeCustomizationsApplied = BalanceDefinitionState.BalanceDefinition.ApplyGradeCustomizations(self, BalanceDefinitionState.GradeIndex);
    }
    //return;    
}

