exec function ToggleAILogging()
{
    UnknownLocal_1 = class'Engine'.static.GetEngine();
    // End:0x107
    if(Outer.Pawn != none)
    {
        // End:0xB8
        if(UnknownLocal_1.bDisableAILogging)
        {
            Outer.Pawn.MessagePlayer("OK! AI logging is now ON");            
        }
        else
        {
            Outer.Pawn.MessagePlayer("OK! AI logging is now OFF");
        }
    }
    UnknownLocal_1.bDisableAILogging = !UnknownLocal_1.bDisableAILogging;
    //return;    
}

