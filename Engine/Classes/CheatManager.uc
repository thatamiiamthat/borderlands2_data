exec function BehaviorDebug()
{
    class'BehaviorBase'.static.ToggleBehaviorDebug();
    // End:0xB6
    if(class'BehaviorBase'.static.IsBehaviorDebugEnabled())
    {
        Outer.ClientMessage("BehaviorDebug on");        
        Outer.ConsoleCommand("unsuppress Behaviors");        
    }
    else
    {
        Outer.ClientMessage("BehaviorDebug off");        
        Outer.ConsoleCommand("suppress Behaviors");
    }
    //return;    
}

