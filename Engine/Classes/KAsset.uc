class KAsset extends Actor
    native(Physics)
    nativereplication
    placeable
    hidecategories(Mobile,Navigation,MovementReplication)
    classgroup(Physics);

var() const editconst export editinline SkeletalMeshComponent SkeletalMeshComponent;
var() bool bDamageAppliesImpulse;
var() bool bWakeOnLevelStart;
var() bool bBlockPawns;
var repnotify transient SkeletalMesh ReplicatedMesh;
var repnotify transient PhysicsAsset ReplicatedPhysAsset;

replication
{
    // Pos:0x000
     if(int(Role) == int(ROLE_Authority))
        ReplicatedMesh, ReplicatedPhysAsset;
}

simulated event PostBeginPlay()
{
    super.PostBeginPlay();
    // End:0x37
    if(bWakeOnLevelStart)
    {
        SkeletalMeshComponent.WakeRigidBody();
    }
    ReplicatedMesh = SkeletalMeshComponent.SkeletalMesh;
    ReplicatedPhysAsset = SkeletalMeshComponent.PhysicsAsset;
    //return;    
}

final function SetMeshAndPhysAsset(SkeletalMesh NewMesh, PhysicsAsset NewPhysAsset)
{
    SkeletalMeshComponent.SetSkeletalMesh(NewMesh);
    ReplicatedMesh = NewMesh;
    SkeletalMeshComponent.SetPhysicsAsset(NewPhysAsset);
    ReplicatedPhysAsset = NewPhysAsset;
    //return;    
}

simulated event ReplicatedEvent(name VarName)
{
    // End:0x43
    if(VarName == 'ReplicatedMesh')
    {
        SkeletalMeshComponent.SetSkeletalMesh(ReplicatedMesh);        
    }
    else
    {
        // End:0x83
        if(VarName == 'ReplicatedPhysAsset')
        {
            SkeletalMeshComponent.SetPhysicsAsset(ReplicatedPhysAsset);
        }
    }
    //return;    
}

simulated event TakeDamage(float Damage, Controller EventInstigator, Vector HitLocation, Vector Momentum, class<DamageType> DamageType, optional TraceHitInfo HitInfo, optional IDamageCauser DamageCauser, optional DamagePipeline Pipeline)
{
    Damage
    EventInstigator
    HitLocation
    Momentum
    DamageType
    HitInfo
    DamageCauser
    Pipeline    
    // End:0x1D9
    if(bDamageAppliesImpulse && DamageType.default.KDamageImpulse > float(0))
    {
        // End:0xA1
        if(VSize(Momentum) < 0.001)
        {
            return;
        }
        CheckHitInfo(HitInfo, SkeletalMeshComponent, Normal(Momentum), HitLocation);
        // End:0x121
        if(GetPipelineDamageType(Pipeline) != none)
        {
            Momentum *= GetPipelineDamageType(Pipeline).GetRigidBodyMomentumScale();            
        }
        else
        {
            Momentum = Normal(Momentum) * DamageType.default.KDamageImpulse;
        }
        // End:0x1D9
        if(HitInfo.HitComponent != none)
        {
            HitInfo.HitComponent.AddImpulse(Momentum, HitLocation, HitInfo.BoneName);
        }
    }
    //return;    
}

simulated function TakeRadiusDamage(Controller InstigatedBy, float BaseDamage, float DamageRadius, class<DamageType> DamageType, float Momentum, Vector HurtOrigin, bool bFullDamage, IDamageCauser DamageCauser, optional float DamageFalloffExponent = 1, optional DamagePipeline Pipeline)
{
    GetPipelineDamageType(Pipeline) != none;
    Momentum *= GetPipelineDamageType(Pipeline).GetRigidBodyMomentumScale();
    goto J0x82;
    Momentum = DamageType.default.RadialDamageImpulse;
    J0x82:

    // End:0x113
    if((bDamageAppliesImpulse && Momentum > float(0)) && int(Role) == int(ROLE_Authority))
    {
        CollisionComponent.AddRadialImpulse(HurtOrigin, DamageRadius, Momentum, 1, DamageType.default.bRadialDamageVelChange);
    }
    //return;    
}

simulated function OnToggle(SeqAct_Toggle Action)
{
    // End:0x57
    if(Action.InputLinks[0].bHasImpulse)
    {
        SkeletalMeshComponent.WakeRigidBody();
    }
    //return;    
}

simulated function OnTeleport(SeqAct_Teleport inAction)
{
    UnknownLocal_1 = Actor(SeqVar_Object(inAction.VariableLinks[1].LinkedVariables[0]).GetObjectValue());
    // End:0xAB
    if(UnknownLocal_1 != none)
    {
        SkeletalMeshComponent.SetRBPosition(UnknownLocal_1.Location);        
    }
    else
    {
        inAction.ScriptLog((("No Destination for" @ string(inAction)) @ "on") @ string(self));
    }
    //return;    
}

function DoKismetAttachment(Actor Attachment, SeqAct_AttachToActor Action)
{
    Attachment.SetBase(self,, SkeletalMeshComponent, Action.BoneName);
    //return;    
}

