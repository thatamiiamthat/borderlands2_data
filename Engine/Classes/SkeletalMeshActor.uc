        // End:0x170
        if(AnimNotifyData.BoneName != 'None')
        {
            SkeletalMeshComponent.AttachComponent(NewForceFieldComponent, AnimNotifyData.BoneName);
        }
    }
    return true;
    //return ReturnValue;    
}

