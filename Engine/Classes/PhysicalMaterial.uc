            OutSoundSingle = UnknownLocal_1.FractureSoundSingle;
        }
        // End:0xB0
        if(OutSoundExplosion == none)
        {
            OutSoundExplosion = UnknownLocal_1.FractureSoundExplosion;
        }
        UnknownLocal_1 = UnknownLocal_1.Parent;
        // [Loop Continue]
        goto J0x1D;
    }
    return;
    //return;    
}

