class Behavior_ReCalculateResourcePoolValues extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) const ResourceDefinition Resource;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IResourcePoolProvider Provider;
    local ResourcePoolReference PoolReference;

    Provider = ContextObject.QueryInterface(class'IResourcePoolProvider');
    // End:0xE4
    if(NotEqual_InterfaceInterface(Provider, IResourcePoolProvider(none)))
    {
        PoolReference = Provider.GetResourcePoolForResourceDefinition(Resource);
        // End:0xE4
        if(class'Actor'.static.IsResourcePoolValid(PoolReference))
        {
            PoolReference.Data.CalculateBaseValues(true);
        }
    }
    //return;    
}
