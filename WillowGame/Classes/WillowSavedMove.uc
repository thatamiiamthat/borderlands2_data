class WillowSavedMove extends SavedMove
    native
    hidecategories(Mobile);

var bool bSprint;

function Clear()
{
    super.Clear();
    bSprint = false;
    //return;    
}

function bool CanCombineWith(SavedMove NewMove, Pawn inPawn, float MaxDelta)
{
    return super.CanCombineWith(NewMove, inPawn, MaxDelta) && bSprint == WillowSavedMove(NewMove).bSprint;
    //return ReturnValue;    
}

function SetMoveFor(PlayerController P, float DeltaTime, Vector newAccel, Engine.Actor.EDoubleClickDir InDoubleClick, byte InAnalogPct)
{
    super.SetMoveFor(P, DeltaTime, newAccel, InDoubleClick, InAnalogPct);
    bSprint = WillowPlayerController(P).bInSprintState;
    //return;    
}

function byte CompressedFlags()
{
    UnknownLocal_1 = DoubleClickMove;
    // End:0x25
    if(bRun)
    {
        UnknownLocal_1 += 8;
    }
    // End:0x3B
    if(bDuck)
    {
        UnknownLocal_1 += 16;
    }
    // End:0x51
    if(bPressedJump)
    {
        UnknownLocal_1 += 32;
    }
    // End:0x67
    if(bSprint)
    {
        UnknownLocal_1 += 64;
    }
    // End:0x7D
    if(bPreciseDestination)
    {
        UnknownLocal_1 += 128;
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

