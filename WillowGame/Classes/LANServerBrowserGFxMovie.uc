function bool HandleInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    local UniqueNetId SelectedId;

    // End:0x31
    if(ControllerId != int(WPCOwner.GetMyControllerId()))
    {
        return true;
    }
    switch(ukey)
    {
        // End:0x50
        case 'XboxTypes_X':
        // End:0x8D
        case 'R':
            // End:0x8B
            if(!bSearchingForGames && int(uevent) == int(1))
            {
                FindGames();
            }
            return true;
        // End:0x99
        case 'XboxTypeS_Y':
        // End:0x1F2
        case 'V':
            // End:0x1F0
            if(!bSearchingForGames && int(uevent) == int(1))
            {
                // End:0x1F0
                if(SortedResults.Length > 0)
                {
                    SelectedId = SortedResults[ServerBrowserObj.GetSelectedServerIndex()].Game.GameSettings.OwningPlayerId;
                    // End:0x1F0
                    if(WPCOwner.GetFrontendMovie().CanViewGamercard(ControllerId, SelectedId))
                    {
                        WPCOwner.OnlineSub.PlayerInterfaceEx.ShowGamerCardUI(byte(ControllerId), SelectedId);
                    }
                }
            }
            return true;
        // End:0x1FE
        case 'XboxTypeS_B':
        // End:0x2BD
        case 'Escape':
            // End:0x2BB
            if(int(uevent) == int(1))
            {
                // End:0x238
                if(bSearchingForGames)
                {
                    CancelGameSearch();                    
                }
                else
                {
                    // End:0x286
                    if(bIsLanBrowser)
                    {
                        WPCOwner.bHostLanGame = true;
                        WPCOwner.AttemptSystemLinkTransition(true);
                    }
                    WPCOwner.GetFrontendMovie().HideServerBrowser();
                }
            }
            return true;
        // End:0x2C9
        case 'XboxTypeS_LeftShoulder':
        // End:0x317
        case 'Comma':
            // End:0x315
            if(int(uevent) == int(1))
            {
                // End:0x315
                if(!bSearchingForGames)
                {
                    SetSort(GetNextSortType(), SortDirection);
                }
            }
            return true;
        // End:0x323
        case 'XboxTypeS_RightShoulder':
        // End:0x381
        case 'Period':
            // End:0x37F
            if(int(uevent) == int(1))
            {
                // End:0x37F
                if(!bSearchingForGames)
                {
                    SetSort(SortType, ((int(SortDirection) == int(0)) ? 1 : 0));
                }
            }
            return true;
        // End:0xFFFF
        default:
            return bSearchingForGames;
            break;
    }
    //return ReturnValue;    
}

