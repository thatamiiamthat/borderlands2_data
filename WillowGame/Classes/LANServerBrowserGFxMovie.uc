function HandleServerBrowserItemClick(int ServerIndex)
{
    local byte PlatformInfo[80];

    // End:0x29E
    if((ServerIndex >= 0) && ServerIndex < SortedResults.Length)
    {
        MatchmakingResult = SortedResults[ServerIndex].Game;
        // End:0x136
        if(bIsLanBrowser)
        {
            // End:0xB3
            if(IncompatibleGameVersionsServerIndex.Find(ServerIndex == -1)
            {
                WPCOwner.ShowConnectingDialog();
                JoinMatchmakingSession();                
            }
            else
            {
                WPCOwner.GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgCannotConnectLANIncompatibleVersion");
            }            
        }
        else
        {
            // End:0x29E
            if(WPCOwner.OnlineSub.GameInterface.ReadPlatformSpecificSessionInfo(MatchmakingResult, PlatformInfo))
            {
                WPCOwner.ShowConnectingDialog();
                WPCOwner.WorldInfo.Game.TellClientsToTravelToSession('Game', WPCOwner.OnlineSub.GameInterface.GetGameSearch().Class, PlatformInfo);
                TimerPauseTicker.SetTimer(1, false, 'JoinMatchmakingSession', self);
            }
        }
    }
    //return;    
}

function JoinMatchmakingSession()
{
    WPCOwner.DestroyOnlineGameWithDelegate(OnDestroyGameForMatchJoinComplete);
    //return;    
}

function OnDestroyGameForMatchJoinComplete(name SessionName, bool bWasSuccessful)
{
    WPCOwner.OnlineSub.GameInterface.ClearDestroyOnlineGameCompleteDelegate(OnDestroyGameForMatchJoinComplete);
    WPCOwner.EndUpdatingSession();
    WPCOwner.EnableListenServer(false);
    WPCOwner.OnlineSub.GameInterface.AddJoinOnlineGameCompleteDelegate(OnJoinMatchComplete);
    WPCOwner.OnlineSub.GameInterface.JoinOnlineGame(WPCOwner.GetMyControllerId(), 'Game', MatchmakingResult);
    //return;    
}

function OnJoinMatchComplete(name SessionName, bool bWasSuccessful)
{
    local string URL;

    WPCOwner.OnlineSub.GameInterface.ClearJoinOnlineGameCompleteDelegate(OnJoinMatchComplete);
    // End:0x13B
    if(bWasSuccessful)
    {
        // End:0x13B
        if(WPCOwner.OnlineSub.GameInterface.GetResolvedConnectString(SessionName, URL))
        {
            UnknownLocal_1 = true;
            WPCOwner.ShowConnectingDialog(true);
            WPCOwner.bIgnoreNetworkMessages = false;
            WPCOwner.ClientTravel(URL, 0);
        }
    }
    // End:0x165
    if(!UnknownLocal_1)
    {
        WPCOwner.OnConnectionFailed();
    }
    //return;    
}

