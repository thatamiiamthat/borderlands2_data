function PopulateSearchResults()
{
    local OnlineGameSearchResult Result;
    local string CharInfo, MissionInfo, ConnectionQuality, BaseLocalVersion, BaseServerVersion, Ping;

    local ResultEntry NewEntry, SortedResult;
    local string LevelString;

    // End:0x2C
    if(bUseDebugSearchResults)
    {
        // End:0x29
        if(SortedResults.Length == 0)
        {
            DebugGenerateSearchResults(40);
        }        
    }
    else
    {
        SortedResults.Length = 0;
        // End:0x35B
        foreach WPCOwner.OnlineSub.GameInterface.GetGameSearch().Results(Result,)
        {
            NewEntry.Game = Result;
            NewEntry.Name = Result.GameSettings.OwningPlayerName;
            NewEntry.ExpLevel = class'WillowOnlineGameSettings'.static.GetExpLevel(Result.GameSettings);
            NewEntry.Mission = class'WillowOnlineGameSettings'.static.GetActivePlotMission(Result.GameSettings) - 1;
            NewEntry.PlayThrough = Max(1, class'WillowOnlineGameSettings'.static.GetPlaythrough(Result.GameSettings));
            NewEntry.NumPlayers = Result.GameSettings.NumPublicConnections - Result.GameSettings.NumOpenPublicConnections;
            NewEntry.MaxPlayers = Result.GameSettings.NumPublicConnections;
            NewEntry.Ping = Result.GameSettings.PingInMs;
            SortedResults.AddItem(NewEntry;            
        }        
    }
    SortResults();
    ServerBrowserObj.BeginConfigureServerList();
    UnknownLocal_1 = false;
    IncompatibleGameVersionsServerIndex.Length = 0;
    UnknownLocal_3 = 0;
    // End:0x863
    foreach SortedResults(SortedResult,)
    {
        BaseLocalVersion = Left(class'OnlineGameSettings'.static.GetGameVersionString(), Len(class'OnlineGameSettings'.static.GetGameVersionString()) - 1);
        // End:0x428
        if(bUseDebugSearchResults)
        {
            BaseServerVersion = BaseLocalVersion;            
        }
        else
        {
            BaseServerVersion = Left(SortedResult.Game.GameSettings.BuildUniqueString, Len(SortedResult.Game.GameSettings.BuildUniqueString) - 1);
        }
        UnknownLocal_1 = true;
        // End:0x53B
        if(SortedResult.ExpLevel > class'WillowPlayerController'.static.GetMaximumPossiblePlayerLevelCap())
        {
            LevelString = string(class'WillowPlayerController'.static.GetMaximumPossiblePlayerLevelCap()) $ "+";            
        }
        else
        {
            LevelString = string(SortedResult.ExpLevel);
        }
        CharInfo = Repl(Localize("LANServerBrowserGFxMovie", "CharInfoFormat", "WillowMenu"), "%level%", LevelString);
        MissionInfo = Localize("LANServerBrowserGFxMovie", "MissionInfoFormat", "WillowMenu");
        MissionInfo = Repl(MissionInfo, "%mission%", ResolveMission(SortedResult.Mission));
        UnknownLocal_5 = SortedResult.PlayThrough;
        MissionInfo = Repl(MissionInfo, "%PLAYTHROUGH_NAME%", Localize("Playthrough", "PLAYTHROUGH_NAME_" $ string(UnknownLocal_5), "WillowMenu"));
        ConnectionQuality = class'WillowOnlineGameSettings'.static.GetConnectionQualityUIString(Result.GameSettings);
        // End:0x74C
        if(ConnectionQuality == "none")
        {
            Ping = "---";            
        }
        else
        {
            Ping = string(SortedResult.Ping);
        }
        ServerBrowserObj.AddServerListEntry(class'Actor'.static.ReplaceHTMLMarkup(SortedResult.Name), SortedResult.NumPlayers, SortedResult.MaxPlayers, CharInfo, MissionInfo, ConnectionQuality, Ping);
        // End:0x85B
        if(BaseLocalVersion != BaseServerVersion)
        {
            IncompatibleGameVersionsServerIndex[IncompatibleGameVersionsServerIndex.Length] = UnknownLocal_3;
        }
        ++ UnknownLocal_3;        
    }    
    // End:0x892
    if(!UnknownLocal_1)
    {
        ServerBrowserObj.SetGameCountString("");        
    }
    else
    {
        ServerBrowserObj.SetGameCountString(Repl(ResolveDataStoreMarkup(Localize("LANServerBrowserGFxMovie", "GameCountFormat", "WillowMenu")), "%gamecount%", string(SortedResults.Length)));
    }
    ServerBrowserObj.EndConfigureServerList();
    SetSearchingForGames(false);
    //return;    
}

// Export ULANServerBrowserGFxMovie::execSortResults(FFrame&, void* const)
native function SortResults();

function SetBrowserType(bool bInIsLanBrowser)
{
    bIsLanBrowser = bInIsLanBrowser;
    SetHeaderText();
    //return;    
}

function SetHeaderText()
{
    local string HeaderText;

    // End:0x59
    if(bIsLanBrowser)
    {
        HeaderText = Localize("LANServerBrowserGFxMovie", "HeaderTextLAN", "WillowMenu");        
    }
    else
    {
        HeaderText = Localize("LANServerBrowserGFxMovie", "HeaderTextCustom", "WillowMenu");
    }
    SetVariableString(HeaderTextPath, ResolveDataStoreMarkup(HeaderText));
    //return;    
}

function SetSearchingForGames(bool bSearching)
{
    bSearchingForGames = bSearching;
    ServerBrowserObj.SetSearchingForGames(bSearching);
    SetTooltips();
    //return;    
}

function SetTooltips()
{
    local GearboxFramework.GearboxGlobals.EGBXPlatform Platform;
    local UniqueNetId SelectedId;
    local string NewTooltip;

    // End:0x5C
    if(bSearchingForGames)
    {
        NewTooltip = Localize("LANServerBrowserGFxMovie", "TooltipSearching", "WillowMenu");        
    }
    else
    {
        // End:0x302
        if(SortedResults.Length > 0)
        {
            SelectedId = SortedResults[ServerBrowserObj.GetSelectedServerIndex()].Game.GameSettings.OwningPlayerId;
            Platform = class'GearboxGlobals'.static.GetPlatform();
            // End:0x1EC
            if(WPCOwner.GetFrontendMovie().CanViewGamercard(int(WPCOwner.GetMyControllerId()), SelectedId))
            {
                NewTooltip = Localize("LANServerBrowserGFxMovie", ((int(Platform) == int(0)) ? "TooltipDefaultGamercardPC" : "TooltipDefaultGamercard"), "WillowMenu");                
            }
            else
            {
                NewTooltip = Localize("LANServerBrowserGFxMovie", ((int(Platform) == int(0)) ? "TooltipDefaultPC" : "TooltipDefault"), "WillowMenu");
            }
            NewTooltip = Repl(NewTooltip, "%SORT%", GetSortString());
            NewTooltip = Repl(NewTooltip, "%DIR%", GetSortDirectionString());
            ServerBrowserObj.SetSortTypeButtonLabel(GetSortString());
            ServerBrowserObj.SetSortDirectionButtonLabel(GetSortDirectionString());            
        }
        else
        {
            NewTooltip = Localize("LANServerBrowserGFxMovie", "TooltipNoGames", "WillowMenu");
        }
    }
    SetVariableString(TooltipTextPath, ResolveDataStoreMarkup(NewTooltip));
    //return;    
}

function string GetSortString()
{
    local string Key;

    switch(SortType)
    {
        // End:0x32
        case 3:
            Key = "SortMission";
            // End:0xAD
            break;
        // End:0x4E
        case 1:
            Key = "SortName";
            // End:0xAD
            break;
        // End:0x6B
        case 2:
            Key = "SortLevel";
            // End:0xAD
            break;
        // End:0x87
        case 4:
            Key = "SortPing";
            // End:0xAD
            break;
        // End:0xAA
        case 0:
            Key = "SortPlayerCount";
            // End:0xAD
            break;
        // End:0xFFFF
        default:
            break;
    }
    return Localize("LANServerBrowserGFxMovie", Key, "WillowMenu");
    //return ReturnValue;    
}

function string GetSortDirectionString()
{
    local string Key;

    switch(SortDirection)
    {
        // End:0x34
        case 0:
            Key = "SortAscending";
            // End:0x59
            break;
        // End:0x56
        case 1:
            Key = "SortDescending";
            // End:0x59
            break;
        // End:0xFFFF
        default:
            break;
    }
    return Localize("LANServerBrowserGFxMovie", Key, "WillowMenu");
    //return ReturnValue;    
}

function HandleServerBrowserSortTypeButtonClick(GFxObject EventObj)
{
    // End:0x2C
    if(!bSearchingForGames)
    {
        SetSort(GetNextSortType(), SortDirection);
    }
    //return;    
}

function HandleServerBrowserSortDirectionButtonClick(GFxObject EventObj)
{
    // End:0x3C
    if(!bSearchingForGames)
    {
        SetSort(SortType, ((int(SortDirection) == int(0)) ? 1 : 0));
    }
    //return;    
}

function extLANServerBrowserOnLoad(string TargetPath, string HeaderPath, string VersionPath, string TooltipPath)
{
    local string TooltipTextfieldPath;

    HeaderTextPath = HeaderPath;
    TooltipTextPath = TooltipPath;
    SetHeaderText();
    SetTooltips();
    SetVariableString(VersionPath, GetFriendlyGameVersionString());
    ServerBrowserObj = LANServerBrowserGFxObject(GetVariableObject(TargetPath, class'LANServerBrowserGFxObject'));
    ServerBrowserObj.SetFunction("HandleServerBrowserItemClick", self, 'HandleServerBrowserItemClick');
    ServerBrowserObj.SetFunction("HandleServerBrowserSortTypeButtonClick", self, 'HandleServerBrowserSortTypeButtonClick');
    ServerBrowserObj.SetFunction("HandleServerBrowserSortDirectionButtonClick", self, 'HandleServerBrowserSortDirectionButtonClick');
    __OnInputKey__Delegate = HandleInputKey;
    FindGames();
    TooltipTextfieldPath = Left(TooltipPath, InStr(TooltipPath, ".", true));
    SetVariableNumber(TooltipTextfieldPath $ "._height", 100);
    SetVariableBool(TooltipTextfieldPath $ ".multiline", true);
    SetVariableBool(TooltipTextfieldPath $ ".wordWrap", true);
    //return;    
}

function string GetFriendlyGameVersionString()
{
    local string GameVersion;

    GameVersion = class'OnlineGameSettings'.static.GetGameVersionString();
    GameVersion = Repl(GameVersion, "BORDERLANDS2-", "");
    GameVersion = Left(GameVersion, Len(GameVersion) - 1);
    return Repl(ResolveDataStoreMarkup(Localize("LANServerBrowserGFxMovie", "FriendlyGameVersion", "WillowMenu")), "%version%", GameVersion);
    //return ReturnValue;    
}

defaultproperties
{
    bBlurLesserMovies=true
    Priority=2
}