class Action_CoverAttack extends WillowActionSequencePawn
    native(AI)
    editinlinenew
    hidecategories(Mobile,Object,HideMe,ActionSequence,LoadBalance,Movement);

var(Attack) const export editinline array<export editinline AttackLocation> Limits;
var(Attack) const float LineOfSightTime;
var transient CoverInfo MyCover;
var transient CombatZone MyZone;
var transient float IdleTime;

// Export UAction_CoverAttack::execInitData(FFrame&, void* const)
native function InitData();

event Init()
{
    super.Init();
    InitData();
    //return;    
}

event name CanRun()
{
    local name TempVal;

    TempVal = super(ActionSequence).CanRun();
    // End:0x35
    if(TempVal != 'None')
    {
        return TempVal;
    }
    // End:0x4E
    if(!CoverValid())
    {
        return 'NoCover';
    }
    return 'None';
    //return ReturnValue;    
}

event Start()
{
    super.Start();
    CheckForNewZone();
    WillowAI.bCanUseCover = true;
    WillowAI.DesiredCover = MyCover;
    SetPawnMovementSpeed(1);
    MyWillowMind.bWantsToFireWeapon = true;
    //return;    
}

event Stop()
{
    super.Stop();
    WillowAI.bCanUseCover = false;
    WillowAI.UnclaimCombatZone(MyZone);
    MyWillowMind.bWantsToFireWeapon = false;
    //return;    
}

event Update()
{
    super(ActionSequence).Update();
    CheckExpiredZone();
    CheckStateTransition();
    //return;    
}

function CheckStateTransition()
{
    local name DesiredState;

    DesiredState = GetStateName();
    // End:0x30
    if(IsInCover())
    {
        DesiredState = 'StayInCover';        
    }
    else
    {
        DesiredState = 'MoveToCover';
    }
    // End:0x62
    if(DesiredState != GetStateName())
    {
        GotoState(DesiredState);
    }
    //return;    
}

// Export UAction_CoverAttack::execGetCoverLocation(FFrame&, void* const)
native final function Vector GetCoverLocation();

// Export UAction_CoverAttack::execGetCoverPoint(FFrame&, void* const)
native final function CoverInfo GetCoverPoint();

// Export UAction_CoverAttack::execCreateCoverList(FFrame&, void* const)
native final function CreateCoverList(const out Vector TestLoc);

// Export UAction_CoverAttack::execIsValidCover(FFrame&, void* const)
native final function bool IsValidCover(const out CoverInfo Cover);

// Export UAction_CoverAttack::execCheckCoverLocation(FFrame&, void* const)
native final function bool CheckCoverLocation(const out CoverInfo Cover, const out Vector CoverLoc, out int BestScore);

final function bool CoverValid()
{
    return (MyCover.Link != none) && MyCover.SlotIdx != -1;
    //return ReturnValue;    
}

final function bool IsInCover()
{
    return ((CoverValid() && MyWillowPawn.super(Action_CoverAttack).IsInCover()) && MyWillowPawn.MyCoverState.Cover.Link == MyCover.Link) && MyWillowPawn.MyCoverState.Cover.SlotIdx == MyCover.SlotIdx;
    //return ReturnValue;    
}

function bool ReachedCoverLoc()
{
    // End:0x11
    if(!CoverValid())
    {
        return true;
    }
    return MyWillowPawn.ReachedPoint(GetCoverLocation(), none);
    //return ReturnValue;    
}

function FindCover()
{
    local CoverInfo OldCover;

    OldCover = MyCover;
    MyCover = GetCoverPoint();
    WillowAI.DesiredCover = MyCover;
    // End:0xD5
    if((MyCover.Link != OldCover.Link) || MyCover.SlotIdx != OldCover.SlotIdx)
    {
        InvalidatePath();
    }
    CheckForNewZone();
    //return;    
}

function CheckForNewZone()
{
    local Vector NewLoc;
    local CombatZone OldZone;

    OldZone = MyZone;
    MyZone.Index = -1;
    // End:0x88
    if(CoverValid())
    {
        NewLoc = GetCoverLocation();
        MyZone = WillowAI.GetCombatZoneByLocation(NewLoc);
    }
    // End:0xF5
    if(!WillowAI.CombatZoneAvailable(MyZone))
    {
        MyCover.Link = none;
        MyZone.Index = -1;
    }
    // End:0x152
    if(IsRunning())
    {
        WillowAI.UnclaimCombatZone(OldZone);
        WillowAI.ClaimCombatZone(MyZone);
    }
    //return;    
}

function CheckExpiredZone()
{
    // End:0x3B
    if((IdleTime <= float(0)) || MyZone.Index == -1)
    {
        return;
    }
    // End:0x8F
    if(MyZone.Index != WillowAI.CurrentZone.Index)
    {
        return;
    }
    // End:0xBD
    if(WillowAI.ZoneTime < IdleTime)
    {
        return;
    }
    MyCover.Link = none;
    WillowAI.MarkCurrentCombatZone();
    //return;    
}

event bool PathFind()
{
    FindCover();
    return false;
    //return ReturnValue;    
}

state MoveToCover
{
    event bool PathFind()
    {
        global.PathFind();
        // End:0x1B
        if(!CoverValid())
        {
            return false;
        }
        CreateVectorPath(GetCoverLocation());
        // End:0x99
        if(!PathIsValid())
        {
            MyCover.Link = none;
            WillowAI.InvalidateCombatZone(MyZone.Index);
        }
        return true;
        //return ReturnValue;        
    }
Begin:

    WaitForPath();
    FollowPath();
    Sleep(0.1);
    goto 'Begin';
    stop;            
}

state StayInCover
{Begin:

    InvalidatePath();
    MyNavHandle.ClearPath();
    stop;                    
}

defaultproperties
{
    Limits(0)=AttackLocation_Range'Default__Action_CoverAttack.RangeLimit'
    LineOfSightTime=5
    MyZone=(Index=-1,Bounds=(Min=(X=0,Y=0,Z=0),Max=(X=0,Y=0,Z=0),IsValid=0))
}