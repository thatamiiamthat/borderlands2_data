class LatentRewardGFxMovie extends WillowGFxMovie3D
    config(Game)
    hidecategories(Mobile);

var transient MissionRewardGFxObject RewardObject;

event bool Start(optional bool StartPaused = false)
{
    UnknownLocal_1
    super.Start(StartPaused);
    // End:0x51
    if(UnknownLocal_1)
    {
        __OnInputAxis__Delegate = HandleInputAxis;
        TickRateSeconds = 0.001;
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

event OnClose()
{
    // End:0x2E
    if(RewardObject != none)
    {
        RewardObject.FreeCellData();
    }
    super(WillowGFxMovie).OnClose();
    //return;    
}

function extTryDisplayRewardPanel()
{
    // End:0x52
    if(WPCOwner.UnclaimedRewards.Length > 0)
    {
        DisplayRewardsPanel(WPCOwner.UnclaimedRewards[0]);        
    }
    else
    {
        Close();
    }
    //return;    
}

function DisplayRewardsPanel(PendingMissionRewardData MissionReward)
{
    SingleArgInvokeS("latentRewardOuter.gotoAndPlay", "in");
    Advance(0);
    PlayUISound('OpenMissionComplete');
    // End:0x7D
    if(RewardObject != none)
    {
        RewardObject.FreeCellData();
    }
    RewardObject = MissionRewardGFxObject(GetVariableObject("latentRewardOuter.missionReward", class'MissionRewardGFxObject'));
    // End:0xD7
    if(!RewardObject != none)
    {
        return;
    }
    RewardObject.Init(self);
    RewardObject.SetPendingMissionRewardData(MissionReward);
    __OnInputKey__Delegate = HandleRewardInputKey;
    //return;    
}

function extOnClickedChoice(int RewardChoice)
{
    // End:0x37
    if(RewardObject != none)
    {
        RewardObject.OnClickedChoice(RewardChoice);
    }
    //return;    
}

function AcceptReward(int RewardChoice)
{
    PlayUISound('claim_reward');
    // End:0x69
    if(RewardObject != none)
    {
        RewardObject.AcceptReward(RewardChoice);
        RewardObject.FreeCellData();
    }
    SingleArgInvokeS("latentRewardOuter.gotoAndPlay", "out");
    //return;    
}

function extRewardPanelClosed()
{
    RewardObject = none;
    // End:0x34
    if(!WPCOwner.UnclaimedRewards.Length > 0)
    {
        return;
    }
    WPCOwner.UnclaimedRewards.Remove(0, 1;
    //return;    
}

function extOnFocusedChoice(int RewardChoice)
{
    PlayUISound('VerticalMovement');
    // End:0x4A
    if(RewardObject != none)
    {
        RewardObject.OnFocusedChoice(RewardChoice);
    }
    //return;    
}

function extOnRolloverChoice(int RewardChoice)
{
    PlayUISound('VerticalMovement');
    // End:0x4A
    if(RewardObject != none)
    {
        RewardObject.OnRolloverChoice(RewardChoice);
    }
    //return;    
}

function bool HandleRewardInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    UnknownLocal_1 = false;
    // End:0x107
    if(LocalPlayer(WPCOwner.Player).ControllerId == ControllerId)
    {
        // End:0x107
        if(int(uevent) == int(1))
        {
            switch(ukey)
            {
                // End:0x84
                case 'XboxTypeS_A':
                // End:0x90
                case 'Enter':
                // End:0x9C
                case 'XboxTypeS_Start':
                // End:0x104
                case 'LeftMouseButton':
                    // End:0x101
                    if(RewardObject.GetNumItems() < 2)
                    {
                        AcceptReward(RewardObject.GetNumItems() - 1);
                        UnknownLocal_1 = true;
                    }
                    // End:0x107
                    break;
                // End:0xFFFF
                default:
                    break;
            }
        }
        else
        {
        }/* !MISMATCHING REMOVE, tried If got Type:Else Position:0x107! */
        // End:0x151
        if(!UnknownLocal_1)
        {
            UnknownLocal_1 = RewardObject.PanelOnInputKey(ControllerId, ukey, uevent);
        }
        return UnknownLocal_1;
        //return ReturnValue;        
    }/* !MISMATCHING REMOVE, tried Else got Type:If Position:0x007! */
}

function bool HandleInputAxis(int ControllerId, name ukey, float Delta, float DeltaTime)
{
    // End:0x6B
    if((ukey == 'XboxTypeS_RightY') && DoHorizontalSplitscreenPanning())
    {
        FocusOffset.Y += ((500 * Delta) * DeltaTime);
        ClampFocusOffset();
        return true;
    }
    return false;
    //return ReturnValue;    
}

function OnClosedOnDeath()
{
    // End:0x2E
    if(RewardObject != none)
    {
        RewardObject.Interrupted();
    }
    //return;    
}

defaultproperties
{
    bAlwaysHideInCinematicMode=true
    bCloseOnDeath=true
    bOnlyOwnerFocusable=true
    bDiscardNonOwnerInput=true
    bInputAllKeys=true
    bInputOwnerOnly=true
    SceneDPG=ESceneDepthPriorityGroup.SDPG_World
}