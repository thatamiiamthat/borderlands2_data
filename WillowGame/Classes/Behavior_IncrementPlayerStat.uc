class Behavior_IncrementPlayerStat extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) const name StatId;
var(Action) const int IncAmount;
var(Action) const bool bReplicateToServer;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    UnknownLocal_1 = ResolveController(ContextObject);
    // End:0x156
    if(UnknownLocal_1 != none)
    {
        // End:0x61
        if(bReplicateToServer)
        {
            UnknownLocal_1.ServerIncrementStatByValue(StatId, IncAmount);            
        }
        else
        {
            // End:0x156
            if((UnknownLocal_1.PlayerStats != none) && int(UnknownLocal_1.Role) == int(ROLE_Authority))
            {
                UnknownLocal_1.PlayerStats.IncrementIntStat(StatId, IncAmount);
                WillowGameReplicationInfo(UnknownLocal_1.WorldInfo.GRI).MissionTracker.EvaluateStat(StatId);
            }
        }
    }
    //return;    
}

private final function WillowPlayerController ResolveController(Object Obj)
{
    // End:0x2E
    if(WillowPlayerController(Obj) != none)
    {
        return WillowPlayerController(Obj);        
    }
    else
    {
        // End:0x7A
        if(Pawn(Obj) != none)
        {
            return WillowPlayerController(Pawn(Obj).Controller);            
        }
        else
        {
            // End:0xEE
            if(Weapon(Obj) != none)
            {
                UnknownLocal_1 = Weapon(Obj).Instigator;
                // End:0xEE
                if(UnknownLocal_1 != none)
                {
                    return WillowPlayerController(UnknownLocal_1.Controller);
                }
            }
        }
    }
    return none;
    //return ReturnValue;    
}

