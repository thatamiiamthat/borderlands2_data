function bool SwitchToQueuedInputHandler(name ukey, Core.Object.EInputEvent uevent)
{
    // End:0xA0
    if(QueuedTriggerKey != 'None')
    {
        // End:0x9E
        if((int(uevent) == int(1)) && ukey == QueuedTriggerKey)
