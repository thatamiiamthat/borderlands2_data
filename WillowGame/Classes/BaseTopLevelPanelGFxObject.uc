function SetComparingTweenInfo(name MainCardName, name CompareCardName, name LeftPanelName, name RightPanelName)
{
    local CardInfo MainCard, CompareCard;
    local CardInfoRelativeToPanel MainCardSettings_Left, MainCardSettings_Right, CompareCardSettings_Left, CompareCardSettings_Right;

    MainCard = GetCard(MainCardName);
    CompareCard = GetCard(CompareCardName);
    MainCardSettings_Left = MainCard.CompareSettings[MainCard.CompareSettings.Find('PanelName', LeftPanelName];
    MainCardSettings_Right = MainCard.CompareSettings[MainCard.CompareSettings.Find('PanelName', RightPanelName];
    CompareCardSettings_Left = CompareCard.CompareSettings[CompareCard.CompareSettings.Find('PanelName', LeftPanelName];
    CompareCardSettings_Right = CompareCard.CompareSettings[CompareCard.CompareSettings.Find('PanelName', RightPanelName];
    __SetComparingTweenInfo(ParentMovieDef.TweenTime, MainCardSettings_Left.ComparePosition.X, MainCardSettings_Left.ComparePosition.Y, MainCardSettings_Left.ComparePosition.Z, MainCardSettings_Right.ComparePosition.X, MainCardSettings_Right.ComparePosition.Y, MainCardSettings_Right.ComparePosition.Z, CompareCardSettings_Left.ComparePosition.X, CompareCardSettings_Left.ComparePosition.Y, CompareCardSettings_Left.ComparePosition.Z, CompareCardSettings_Right.ComparePosition.X, CompareCardSettings_Right.ComparePosition.Y, CompareCardSettings_Right.ComparePosition.Z, MainCardSettings_Left.CompareScale, MainCardSettings_Right.CompareScale, CompareCardSettings_Left.CompareScale, CompareCardSettings_Right.CompareScale);
    //return;    
}

