final simulated function GetWeaponHoldAnimSets(name HoldName, EnvironmentTagDefinition EnvironmentTag, out array<AnimSet> OutAnimSets)
{
    // End:0x49
    if(WeaponActionParentClass != none)
    {
        WeaponActionParentClass.super(BodyClassDefinition).GetWeaponHoldAnimSets(HoldName, EnvironmentTag, OutAnimSets);
    }
    UnknownLocal_1 = GetWeaponHoldDef(HoldName, EnvironmentTag, false, true);
    // End:0x9E
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_1.GetAnimSets(OutAnimSets);
        return;
    }
    //return;    
}

