    }
    UnknownLocal_1 = GetFirstPersonWeaponHoldDef(HoldName, EnvironmentTag, false, true);
    // End:0x9E
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_1.GetAnimSets(OutAnimSets);
