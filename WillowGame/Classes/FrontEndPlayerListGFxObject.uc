        UnknownLocal_1 = (GetCurrentPlaythrough()) + 1;
        PlaythroughText = Repl(Localize("PlayerDetailsGFxMovie", "Playthrough", "WillowMenu"), "%PLAYTHROUGH_NAME%", Localize("Playthrough", "PLAYTHROUGH_NAME_" $ string(UnknownLocal_1), "WillowMenu"));
    }
