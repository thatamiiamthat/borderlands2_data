function string GetPlayerName(UniqueNetId UniqueId, bool bFormatForHTML)
{
    local OnlineFriend Friend;
    local string Result;
    local UniqueNetId NetId;

    UnknownLocal_1 = 0;
    J0x07:

    // End:0x1CB [Loop If]
    if(UnknownLocal_1 < WPCOwner.WorldInfo.GRI.PRIArray.Length)
    {
        // End:0x1C1
        if(WPCOwner.WorldInfo.GRI.PRIArray[UnknownLocal_1].UniqueId == UniqueId)
        {
            // End:0x150
            if(bFormatForHTML)
            {
                Result = WPCOwner.WorldInfo.GRI.PRIArray[UnknownLocal_1].GetHumanReadableHTMLName();                
            }
            else
            {
                Result = WPCOwner.WorldInfo.GRI.PRIArray[UnknownLocal_1].GetHumanReadableName();
            }
            // [Explicit Break]
            goto J0x1CB;
        }
        ++ UnknownLocal_1;
        // [Loop Continue]
        goto J0x07;
    }
    J0x1CB:

    // End:0x28D
    if((Result == "") && OwningMovie.GetFriend(Friend, UniqueId))
    {
        // End:0x267
        if(bFormatForHTML)
        {
            Result = class'Actor'.static.ReplaceHTMLMarkup(Friend.NickName);            
        }
        else
        {
            Result = Friend.NickName;
        }
    }
    // End:0x3DF
    if(Result == "")
    {
        WPCOwner.OnlineSub.PlayerInterface.GetUniquePlayerId(WPCOwner.GetMyControllerId(), NetId);
        // End:0x3DF
        if(UniqueId == NetId)
        {
            Result = WPCOwner.OnlineSub.PlayerInterface.GetPlayerNickname(WPCOwner.GetMyControllerId());
            // End:0x3DF
            if(bFormatForHTML)
            {
                Result = class'Actor'.static.ReplaceHTMLMarkup(Result);
            }
        }
    }
    return Result;
    //return ReturnValue;    
}

