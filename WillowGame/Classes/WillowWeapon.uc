    if(DefinitionData.WeaponTypeDefinition != none)
    {
        switch(DefinitionData.WeaponTypeDefinition.WeaponType)
        {
            // End:0x74
            case 0:
                return int(DamageCauserType) == int(1);
            // End:0x8B
            case 1:
                return int(DamageCauserType) == int(2);
            // End:0xA2
            case 2:
                return int(DamageCauserType) == int(5);
            // End:0xB9
            case 3:
                return int(DamageCauserType) == int(4);
            // End:0xD0
            case 5:
                return int(DamageCauserType) == int(12);
            // End:0xE7
            case 4:
                return int(DamageCauserType) == int(3);
            // End:0xFFFF
            default:
                break;
            }
    }
    else
    {
        return false;
        //return ReturnValue;        
    }
}

