simulated state WeaponReloading
{
    simulated function BeginState(name PreviousStateName)
    {
        local ILightProjectileManagerOwner ILPMgrOwner;

        // End:0xB8
        if(WorldInfo.Game != none)
        {
            WillowGameInfo(WorldInfo.Game).GetSkillManager().NotifySkillEvent(33, Instigator.Controller, Instigator.Controller,,, self);
        }
        bAmmoRefilledDuringReload = false;
        bSuppressCrosshair = false;
        AmmoLeftInClipDuringReload = ReloadCnt;
        // End:0xF0
        if(bUseOverheatBehavior)
        {
        }
        // End:0x1ED
        if(WillowPawn(Instigator) != none)
        {
            // End:0x145
            if(int(bOffHand) == int(0))
            {
                WillowPawn(Instigator).bReloading = 1;
            }
            WillowPawn(Instigator).DialogComponent.TriggerEvent(class'WillowDialogGlobalsDefinition'.static.Get().DET_Reloading);
            WillowPawn(Instigator).PostPlayerEvent(16, Instigator, self);
        }
        super(Object).BeginState(PreviousStateName);
        SetReplicatedReloadState(1);
        // End:0x23F
        if(int(WorldInfo.NetMode) != int(NM_DedicatedServer))
        {
            PlayReloadAnim();
        }
        ForceUnzoom();
        TimeWeaponReload();
        // End:0x327
        if(bContinuousBeamIsFiring)
        {
            bContinuousBeamIsFiring = false;
            // End:0x327
            if(int(Role) == int(ROLE_Authority))
            {
                UnknownLocal_1 = none;
                ILPMgrOwner = Instigator.QueryInterface(class'ILightProjectileManagerOwner');
                // End:0x301
                if(NotEqual_InterfaceInterface(ILPMgrOwner, ILightProjectileManagerOwner(none)))
                {
                    UnknownLocal_1 = ILPMgrOwner.GetLightProjMgrFor(self);
                }
                // End:0x327
                if(UnknownLocal_1 != none)
                {
                    UnknownLocal_1.DeleteAllBeamsFromWeapon();
                }
            }
        }
        //return;        
    }

    simulated function EndState(name NextStateName)
    {
        HideBonesInMesh(FirstPersonMesh);
        // End:0x1D0
        if(WillowPawn(Instigator) != none)
        {
            // End:0x68
            if(int(bOffHand) == int(0))
            {
                WillowPawn(Instigator).bReloading = 0;
            }
            // End:0x1D0
            if(bAmmoRefilledDuringReload && WorldInfo.Game != none)
            {
                WillowGameInfo(WorldInfo.Game).GetSkillManager().NotifySkillEvent(21, Instigator.Controller, Instigator.Controller,,, self);
                // End:0x1D0
                if(bManualReload)
                {
                    WillowGameInfo(WorldInfo.Game).GetSkillManager().NotifySkillEvent(35, Instigator.Controller, Instigator.Controller,,, self);
                }
            }
        }
        Playing1stPersonReloadSMD = none;
        Playing3rdPersonReloadSMD = none;
        bAmmoRefilledDuringReload = false;
        bManualReload = false;
        //return;        
    }

    simulated function StartZoom()
    {
        SetPendingFire(1);
        //return;        
    }

    simulated function StopReloading()
    {
        global.StopReloading();
        GotoState('Active');
        //return;        
    }
    stop;    
}

simulated state Active
{
    simulated function BeginState(name PreviousStateName)
    {
        bSuppressCrosshair = false;
        bActivatedDuringVehicleTransition = false;
        bOnlyPlayFirstPersonAnimOnNextEquip = false;
        super.BeginState(PreviousStateName);
        // End:0xC2
        if((InvManager != none) && InvManager.LastAttemptedSwitchToWeapon != none)
        {
            InvManager.LastAttemptedSwitchToWeapon.ClientWeaponSet(true);
            InvManager.LastAttemptedSwitchToWeapon = none;
        }
        OnAnimEnd(none, 0, 0);
        // End:0x1AE
        if(Instigator != none)
        {
            UnknownLocal_1 = WillowPlayerController(Instigator.Controller);
            // End:0x1AE
            if((UnknownLocal_1 != none) && Instigator.IsLocallyControlled())
            {
                // End:0x17E
                if(UnknownLocal_1.bPendingZoom)
                {
                    UnknownLocal_1.ZoomIfPending();                    
                }
                else
                {
                    // End:0x1AE
                    if((int(ZoomState) == int(0)) && PendingFire(1))
                    {
                        BeginFire(1);
                    }
                }
            }
        }
        //return;        
    }

    simulated function BeginFire(byte FireModeNum)
    {
        // End:0x27
        if(int(FireModeNum) == 1)
        {
            super.BeginFire(FireModeNum);            
        }
        else
        {
            // End:0x53
            if(bUseOverheatBehavior && ReloadCnt == 0)
            {
                PlayDryFireSound(true);                
            }
            else
            {
                // End:0x7A
                if(!HasAmmo(FireModeNum))
                {
                    PlayDryFireSound(true);                    
                }
                else
                {
                    // End:0xEF
                    if((((ReloadCnt > 0) && WorldInfo.TimeSeconds > LastAutomaticBurstTime) && !bIsBlockedAfterBusy) && !bBurstDelayActive)
                    {
                        super.BeginFire(FireModeNum);                        
                    }
                    else
                    {
                        // End:0x10F
                        if(bBurstDelayActive)
                        {
                            global.BeginFire(FireModeNum);
                        }
                    }
                }
            }
        }
        //return;        
    }

    simulated function BurstDelayComplete()
    {
        bBurstDelayActive = false;
        // End:0x46
        if((PendingFire(0) && !bWeaponPutDown) && HasAnyAmmo())
        {
            BeginFire(0);
        }
        //return;        
    }

    simulated function Activate(optional bool bEquipInOffHand)
    {
        ForceWeaponToBeEquipped();
        global.Activate(bEquipInOffHand);
        //return;        
    }
    stop;    
}

simulated state WeaponBusy
{
    ignores StartZoom;

    simulated function BeginState(name PreviousStateName)
    {
        bSuppressCrosshair = false;
        // End:0x36
        if(PreviousStateName != 'WeaponBusy')
        {
            StoredPreviousStateName = PreviousStateName;
        }
        // End:0x59
        if(IsTimerActive('RefireDelayAfterBusy'))
        {
            bIsBlockedAfterBusy = true;
        }
        //return;        
    }

    simulated function FinishedWeaponAction()
    {
        // End:0x2A
        if(StoredPreviousStateName == 'WeaponFiring')
        {
            StoredPreviousStateName = 'Active';
        }
        GotoState(StoredPreviousStateName);
        //return;        
    }
    stop;    
}

defaultproperties
{
    AmmoPool=(PoolManager=none,PoolIndexInManager=255,PoolGUID=0,Data=none)
    bHoldToZoom=true
    bFadeOnZoomBegin=true
    bFadeOnZoomEnd=true
    bCrosshairEnabled=true
}