simulated event ReplicatedEvent(name VarName)
{
    // End:0x24
    if(VarName == 'DefinitionData')
    {
        ClientInitializeFromWeaponTypeDefinition();        
    }
    else
    {
        // End:0xB1
        if(VarName == 'ReplicatedReloadState')
        {
            switch(GetReplicatedReloadState())
            {
                // End:0x96
                case 1:
                    // End:0x93
                    if((Instigator != none) && !Instigator.IsLocallyControlled())
                    {
                        PlayReloadAnim();
                    }
                    // End:0xAE
                    break;
                // End:0xA8
                case 2:
                    StopReloadAnim();
                    // End:0xAE
                    break;
                // End:0xFFFF
                default:
                    // End:0xAE
                    break;
                    break;
            }            
        }
        else
        {
            // End:0x11D
            if(VarName == 'PutDownAnimState')
            {
                // End:0x11A
                if(int(PutDownAnimState) != int(0))
                {
                    // End:0xFF
                    if(int(PutDownAnimState) == int(3))
                    {
                        StopWeaponPutDownAnim();                        
                    }
                    else
                    {
                        PlayWeaponPutDown(int(PutDownAnimState) == int(2));
                    }
                }                
            }
            else
            {
                // End:0x14A
                if(VarName == 'BarrelSpinState')
                {
                    BarrelSpinStateChanged(BarrelSpinState);                    
                }
                else
                {
                    // End:0x177
                    if(VarName == 'MagazineSpinState')
                    {
                        MagazineSpinStateChanged(MagazineSpinState);                        
                    }
                    else
                    {
                        // End:0x1B5
                        if(VarName == 'bDeRezzed')
                        {
                            // End:0x1A8
                            if(bDeRezzed)
                            {
                                PlayDeRezEffect();                                
                            }
                            else
                            {
                                PlayRezEffect();
                            }                            
                        }
                        else
                        {
                            // End:0x1E6
                            if(VarName == 'bReadied')
                            {
                                // End:0x1E3
                                if(bReadied)
                                {
                                    CheckWeaponAgainstBackpackInventoryBeingEquipped();
                                }                                
                            }
                            else
                            {
                                // End:0x207
                                if(VarName == 'QuickSelectSlot')
                                {
                                    CheckWeaponAgainstEquippedWeaponsBeingSwapped();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    super(Inventory).ReplicatedEvent(VarName);
    //return;    
}

