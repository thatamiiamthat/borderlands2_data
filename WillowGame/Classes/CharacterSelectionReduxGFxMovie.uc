function extCharacterSelectOnLoad(string TargetPath, string P1CustomizationMenuTargetPath, string P2CustomizationMenuTargetPath, string P1CustomizationListTargetPath, string P2CustomizationListTargetPath)
{
    CharacterSelectClip = CharacterSelectionGFxObject(GetVariableObject(TargetPath, class'CharacterSelectionGFxObject'));
    // End:0xCC
    if(CharacterSelectClip != none)
    {
        BuildCharacterList();
        CharacterSelectClip.SetFunction("HandleCharacterClicked", self, 'HandleCharacterClicked');
        CharacterSelectClip.SetFunction("HandleCharacterMouseOver", self, 'HandleCharacterMouseOver');
    }
    CustomizationMenu[0] = CharacterCustomizationMenuGFxObject(GetVariableObject(P1CustomizationMenuTargetPath, class'CharacterCustomizationMenuGFxObject'));
    CustomizationMenu[0].SetFunction("HandleMenuEntryClick", self, 'HandleCustomizationMenuEntryClick');
    CustomizationMenu[1] = CharacterCustomizationMenuGFxObject(GetVariableObject(P2CustomizationMenuTargetPath, class'CharacterCustomizationMenuGFxObject'));
    CustomizationMenu[1].SetFunction("HandleMenuEntryClick", self, 'HandleCustomizationMenuEntryClick');
    CustomizationList[0] = CharacterSelectionCustomizationListGFxObject(GetVariableObject(P1CustomizationListTargetPath, class'CharacterSelectionCustomizationListGFxObject'));
    CustomizationList[0].SetFunction("HandleCustomizationSelected", self, 'HandleCustomizationSelected');
    CustomizationList[1] = CharacterSelectionCustomizationListGFxObject(GetVariableObject(P2CustomizationListTargetPath, class'CharacterSelectionCustomizationListGFxObject'));
    CustomizationList[1].SetFunction("HandleCustomizationSelected", self, 'HandleCustomizationSelected');
    //return;    
}

