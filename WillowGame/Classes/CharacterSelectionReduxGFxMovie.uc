}

private final function AppendTooltipPlayerRestriction(out string TooltipString, bool bAvailableToP1, bool bAvailableToP2)
{
    // End:0x28
    if(class'UIInteraction'.static.GetLocalPlayer(1) == none)
    {
        return;
    }
    // End:0xA6
    if(bAvailableToP1 && !bAvailableToP2)
    {        
        TooltipString @= ResolveDataStoreMarkup(Localize("CharacterSelect", "TooltipPlayerAppendP1", "WillowMenu"));        
    }
    else
    {
        // End:0x121
        if(!bAvailableToP1 && bAvailableToP2)
        {            
            TooltipString @= ResolveDataStoreMarkup(Localize("CharacterSelect", "TooltipPlayerAppendP2", "WillowMenu"));
        }
    }
    //return;    
}

private final function AppendSelectTooltipSuffix(out string TooltipString, int PlayerIndex)
{
    switch(CurrentUIState[PlayerIndex])
    {
        // End:0x7F
        case 1:
            TooltipString = Repl(TooltipString, "%2", Localize("CharacterSelect", "TooltipSelectClassSuffix", "WillowMenu"));
            // End:0x1AE
            break;
        // End:0x18F
        case 3:
            // End:0xFA
            if(SelectedEntryIdx[PlayerIndex] == 0)
            {
                TooltipString = Repl(TooltipString, "%2", Localize("CharacterSelect", "TooltipSelectHeadSuffix", "WillowMenu"));                
            }
            else
            {
                // End:0x170
                if(SelectedEntryIdx[PlayerIndex] == 1)
                {
                    TooltipString = Repl(TooltipString, "%2", Localize("CharacterSelect", "TooltipSelectSkinSuffix", "WillowMenu"));                    
                }
                else
                {
                    TooltipString = Repl(TooltipString, "%2", "");
                }
            }
            // End:0x1AE
            break;
        // End:0xFFFF
        default:
            TooltipString = Repl(TooltipString, "%2", "");
            break;
    }
    //return;    
}

