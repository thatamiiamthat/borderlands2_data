}

function bool ShouldLookAtPlayer()
{
    // End:0x24
    if(MyWillowMind.ShouldLookAtPlayer())
    {
        return true;
    }
    // End:0x70
    if((GetStateName() == 'LookAtPlayer') && MyWillowPawn.DialogComponent.IsTalking())
    {
        return true;
    }
    return false;
    //return ReturnValue;    
}

function name GetDesiredStateName()
{
    // End:0x1A
    if(ShouldLookAtPlayer())
    {
        return 'LookAtPlayer';        
    }
    else
    {
        // End:0x49
        if(MyWillowMind.bScriptedHoldPosition)
