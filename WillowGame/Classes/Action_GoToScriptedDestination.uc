            return 'ScriptedHold';            
        }
        else
        {
            // End:0xAB
            if(MyWillowMind.FollowActor != none)
            {
                // End:0x9E
                if(MyWillowMind.FollowComponent != none)
                {
                    return 'FollowActorFormation';                    
                }
                else
                {
                    return 'FollowActor';
                }                
            }
            else
            {
                // End:0x14E
                if(MyWillowMind.IsInScriptedMovement())
                {
                    MyWillowMind.LastScriptedNode = WillowAIMoveNode(MyWillowMind.ScriptedMoveTarget);
                    // End:0x144
                    if(MyWillowMind.LastScriptedNode != none)
                    {
                        return 'FollowMoveNodes';                        
                    }
                    else
                    {
                        return 'ScriptedMove';
                    }
                }
            }
        }
    }
    return 'None';
    //return ReturnValue;    
}

function CheckStateTransition()
{
    local name DesiredState;

    DesiredState = GetDesiredStateName();
    // End:0x39
    if(DesiredState == 'None')
    {
        Finish();        
    }
    else
    {
        // End:0x58
        if(DesiredState != GetStateName())
        {
            GotoState(DesiredState);
        }
    }
    //return;    
}

