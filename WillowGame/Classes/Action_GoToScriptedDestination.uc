        else
        {
            // End:0x122
            if(WillowAI.HasTarget() && int(MyWillowMind.ScriptedFocusStyle) == int(1))
            {
                MyWillowMind.SetFacingPolicy(2, WillowAI.GetTarget());                
            }
            else
            {
                // End:0x18B
                if(int(MyWillowMind.ScriptedFocusStyle) != int(0))
                {
                    MyWillowMind.SetFacingPolicy(2, MyWillowMind.ScriptedMoveTarget);
                }
            }
        }
    }
    //return;    
}

