state ScriptedHold
{Begin:

    MyNavHandle.ClearPath();
Loop:


    // End:0x8E
    if((Target != none) && MyWillowMind.bScriptedCanAttack)
    {
        SetPawnMovementSpeed(1);
        MyWillowMind.SetFacingPolicy(2, Target);        
    }
    else
    {
        MyWillowMind.SetFacingPolicy(1);
    }
    Sleep(0.1);
    CheckStateTransition();
    goto 'Loop';
    stop;                
}

state ScriptedMove
{
    event ActivateEvent(name EventName)
    {
        global.ActivateEvent(EventName);
        SetMoveNodeSpeed();
        SetMoveFacingPolicy();
        // End:0xEB
        if(EventName == 'Scripted')
        {
            InvalidatePath();
            InterruptLatentAction();
            MyNavHandle.ClearPath(false);
            MyWillowMind.LastScriptedNode = WillowAIMoveNode(MyWillowMind.ScriptedMoveTarget);
            // End:0xEB
            if(MyWillowMind.LastScriptedNode != none)
            {
                GotoState('FollowMoveNodes');
            }
        }
        //return;        
    }

    event bool PathFind()
    {
        // End:0x0F
        if(PathIsValid())
        {
            return false;
        }
        // End:0x1E
        if(ReachedDestination())
        {
            return false;
        }
        // End:0x44
        if(MyGearboxMind.ScriptedMoveTarget == none)
        {
            return false;
        }
        CreateActorPath(MyGearboxMind.ScriptedMoveTarget);
        return true;
        //return ReturnValue;        
    }
Loop:

    SetMoveNodeSpeed();
    SetMoveFacingPolicy();
    // End:0x4C
    if(MyWillowMind.ScriptedMoveTarget != none)
    {
        WaitForPath();
        FollowPath();
    }
    // End:0x10F
    if(MyWillowMind.ScriptedFocus != none)
    {
        // End:0xFB
        if(MyWillowPawn.LookAtTarget != MyWillowMind.ScriptedFocus)
        {
            MyWillowPawn.SetLookAtTarget(MyWillowMind.ScriptedFocus, vect(0, 0, 0));
        }
        LookAtScriptedFocus();
        WaitForPawnToTurn();
    }
    // End:0x15D
    if((MyWillowMind.ScriptedMoveTarget != none) && !ReachedDestination())
    {
        Sleep(0);
        goto 'Loop';
    }
    Sleep(0);
    MyWillowMind.ClearScriptedMove();
    CheckStateTransition();
    goto 'Loop';
    stop;            
}

state FollowMoveNodes
{
    event ActivateEvent(name EventName)
    {
        global.ActivateEvent(EventName);
        // End:0x7D
        if(EventName == 'Scripted')
        {
            InterruptPath();
            MyWillowMind.LastScriptedNode = WillowAIMoveNode(MyWillowMind.ScriptedMoveTarget);            
        }
        else
        {
            SetMoveNodeSpeed();
        }
        //return;        
    }
    stop;    
}

state FollowActor
{
    function BeginState(name PreviousStateName)
    {
        InvalidatePath();
        MyNavHandle.ClearPath();
        //return;        
    }

    event ActivateEvent(name EventName)
    {
        global.ActivateEvent(EventName);
        // End:0x55
        if(EventName == 'Scripted')
        {
            InvalidatePath();
            MyNavHandle.ClearPath();
        }
        //return;        
    }

    function bool InRange(Vector TestLoc)
    {
        // End:0x26
        if(MyWillowMind.FollowActor == none)
        {
            return true;
        }
        UnknownLocal_1 = VSize(MyWillowMind.FollowActor.Location - TestLoc);
        return (UnknownLocal_1 < MyWillowMind.FollowMaxDist) && !PathIsValid() || UnknownLocal_1 < MyWillowMind.FollowMinDist;
        //return ReturnValue;        
    }

    event Update()
    {
        global.Update();
        CheckStateTransition();
        UnknownLocal_1 = InRange(MyWillowPawn.Location);
        // End:0x75
        if(UnknownLocal_1)
        {
            InvalidatePath();
            MyNavHandle.ClearPath();
        }
        SetMoveNodeSpeed();
        UnknownLocal_3 = ((MyWillowMind.bScriptedCanAttack && Target != none) ? Target : MyWillowMind.FollowActor);
        UnknownLocal_5 = Normal(UnknownLocal_3.Location - MyWillowPawn.Location) Dot Vector(MyWillowPawn.Rotation);
        UnknownLocal_7 = ((UnknownLocal_1) ? UnknownLocal_5 < MyWillowPawn.GetHeadLookMinDot() : int(MyWillowPawn.GetMoveStyle()) == int(0));
        // End:0x1E1
        if(UnknownLocal_7 && UnknownLocal_3 != none)
        {
            MyWillowMind.SetFacingPolicy(2, UnknownLocal_3);            
        }
        else
        {
            // End:0x22E
            if(int(MyWillowPawn.GetMoveStyle()) == int(0))
            {
                MyWillowMind.SetFacingPolicy(1);
            }
        }
        //return;        
    }

    function bool WantsPath()
    {
        return !InRange(MyWillowPawn.Location) && !PathIsValid() || !InRange(GetFinalDestination());
        //return ReturnValue;        
    }

    event bool PathFind()
    {
        // End:0x11
        if(!WantsPath())
        {
            return false;
        }
        CreateActorPath(MyWillowMind.FollowActor);
        return true;
        //return ReturnValue;        
    }
Begin:

    // End:0x44
    if(!InRange(MyWillowPawn.Location))
    {
        WaitForPath();
        FollowPath();        
    }
    else
    {
        InvalidatePath();
        MyNavHandle.ClearPath();
    }
    Sleep(0.1);
    goto 'Begin';
    stop;                
}

state FollowActorFormation
{
    function BeginState(name PreviousStateName)
    {
        InvalidatePath();
        MyNavHandle.ClearPath();
        MyWillowPawn.CurrentFormation = MyWillowMind.FollowComponent;
        //return;        
    }

    function EndState(name NextStateName)
    {
        MyWillowPawn.CurrentFormation = none;
        //return;        
    }

    event Update()
    {
        global.Update();
        SetMoveNodeSpeed();
        UnknownLocal_1 = ReachedFormation(MyWillowPawn.Location);
        UnknownLocal_3 = MyWillowMind.bScriptedCanAttack && Target != none;
        // End:0xDC
        if(UnknownLocal_3 && UnknownLocal_1 || MyWillowPawn.CanUseAimOffsets())
        {
            MyWillowMind.SetFacingPolicy(2, Target);            
        }
        else
        {
            // End:0x14B
            if(!UnknownLocal_3 && !UnknownLocal_1)
            {
                MyWillowMind.SetFacingPolicy(3,, MyWillowMind.FollowComponent.GetWorldBodyLocation());                
            }
            else
            {
                MyWillowMind.SetFacingPolicy(3,, MyWillowPawn.Location + (float(1000) * Vector(MyWillowMind.FollowComponent.GetWorldBodyRotation())));
            }
        }
        //return;        
    }

    event bool PathFind()
    {
        local Vector FormationLoc;
        local BasedPosition NearestPos;

        // End:0x26
        if(MyWillowMind.FollowComponent == none)
        {
            return false;
        }
        // End:0x7E
        if(ReachedFormation(MyWillowPawn.Location))
        {
            InvalidatePath();
            MyNavHandle.ClearPath(false);
            return false;
        }
        // End:0xD7
        if(PathIsValid() && ReachedFormation(class'Actor'.static.BP2Vect(PathData.FinalDest)))
        {
            return false;
        }
        FormationLoc = MyWillowMind.FollowComponent.GetWorldBodyLocation();
        MyNavHandle.GetNearestPositionOnNavMesh(128, FormationLoc, NearestPos, MyNavHandle.CachedPathParams);
        CreateVectorPath(class'Actor'.static.BP2Vect(NearestPos));
        // End:0x1FC
        if(!PathIsValid() && CanFollowFormationOwner())
        {
            CreateActorPath(MyWillowMind.FollowComponent.Owner);
        }
        return true;
        //return ReturnValue;        
    }
Begin:

    WaitForPath();
    FollowPath();
    Sleep(0.25);
    goto 'Begin';
    stop;            
}

state LookAtPlayer
{
    event Update()
    {
        global.Update();
        UnknownLocal_1 = false;
        // End:0xDE
        if(MyWillowPawn.LookAtTarget != none)
        {
            UnknownLocal_3 = Normal(MyWillowPawn.LookAtTarget.Location - MyWillowPawn.Location) Dot Vector(MyWillowPawn.Rotation);
            UnknownLocal_1 = UnknownLocal_3 < MyWillowPawn.GetHeadLookMinDot();
        }
        // End:0x129
        if(UnknownLocal_1)
        {
            MyWillowMind.SetFacingPolicy(2, MyWillowPawn.LookAtTarget);            
        }
        else
        {
            MyWillowMind.SetFacingPolicy(1);
        }
        //return;        
    }
Loop:

    MyNavHandle.ClearPath();
    Sleep(0.1);
    CheckStateTransition();
    goto 'Loop';
    stop;                
}

