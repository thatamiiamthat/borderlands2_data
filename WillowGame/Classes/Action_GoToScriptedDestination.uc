{
    UnknownLocal_1 = __NFUN_228__(MyWillowPawn.Location - MyWillowMind.FollowComponent.Owner.Location);
    UnknownLocal_3 = __NFUN_228__(MyWillowMind.FollowComponent.Translation);
    return UnknownLocal_1 > UnknownLocal_3;
    //return ReturnValue;    
}

function bool ReachedFormation(Vector TestLoc)
{
    local Vector FormationLoc;

    FormationLoc = MyWillowMind.FollowComponent.GetWorldBodyLocation();
    UnknownLocal_1 = MyWillowMind.FollowMinDist * MyWillowMind.FollowMinDist;
    return __NFUN_228__(TestLoc - FormationLoc) < UnknownLocal_1;
