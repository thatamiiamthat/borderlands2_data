    // End:0x11E
    if(currentFriendsList.Length > 0)
    {
        SortFriends();
    }
    // End:0x36A
    foreach currentFriendsList(friendIter,)
    {
        Suffix = "";
        // End:0x28A
        if(friendIter.bIsPlayingThisGame)
        {
            Suffix = "-";
            Presence = SplitString(friendIter.PresenceInfo, "
");
            // End:0x1D5
