    switch(PlayerMovementType)
    {
        // End:0x56
        case 0:
            bEnableAnalogMovement = false;
            bEnableGamepadWalkRunMovement = false;
            bRun = 0;
            // End:0x9B
            break;
        // End:0x75
        case 1:
            bEnableAnalogMovement = false;
            bEnableGamepadWalkRunMovement = true;
            // End:0x9B
            break;
        // End:0x95
        case 2:
            bEnableAnalogMovement = true;
            bEnableGamepadWalkRunMovement = false;
            // End:0x9B
            break;
        // End:0xFFFF
        default:
            // End:0x9B
            break;
            break;
    }
    //return;    
}

