function bool ConditionalIncrementTechWeaponPickedUpStat(WillowDamageTypeDefinition WillowDamageTypeDef)
{
    // End:0x131
    if(WillowDamageTypeDef != none)
    {
        switch(WillowDamageTypeDef.DamageType)
        {
            // End:0x68
            case 2:
                PlayerStats.IncrementIntStat('STAT_PLAYER_SHOCK_WEAPONS_PICKED_UP');
                // End:0x131
                break;
            // End:0x99
            case 4:
                PlayerStats.IncrementIntStat('STAT_PLAYER_CORROSIVE_WEAPONS_PICKED_UP');
                // End:0x131
                break;
            // End:0xCA
            case 1:
                PlayerStats.IncrementIntStat('STAT_PLAYER_INCENDIARY_WEAPONS_PICKED_UP');
                // End:0x131
                break;
            // End:0xFB
            case 3:
                PlayerStats.IncrementIntStat('STAT_PLAYER_EXPLOSIVE_WEAPONS_PICKED_UP');
                // End:0x131
                break;
            // End:0x12C
            case 7:
                PlayerStats.IncrementIntStat('STAT_PLAYER_SLAG_WEAPONS_PICKED_UP');
                // End:0x131
                break;
            // End:0xFFFF
            default:
                return false;
                break;
        }
    }
    return true;
    //return ReturnValue;    
}

