function JoinFriendGame(int ControllerId, UniqueNetId FriendId)
{
    ShowConnectingDialog();
    OnlineSub.GameInterface.AddJoinOnlineGameCompleteDelegate(OnJoinGameComplete);
    // End:0x146
    if(!OnlineSub.PlayerInterface.JoinFriendGame(byte(ControllerId), FriendId))
    {
        OnlineSub.GameInterface.ClearJoinOnlineGameCompleteDelegate(OnJoinGameComplete);
        HideConnectingDialog();
        GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgGameNotJoinable");
    }
    //return;    
}

function OnJoinGameComplete(name SessionName, bool bWasSuccessful)
{
    local string URL;

    // End:0x1E5
    if(NotEqual_InterfaceInterface(OnlineSub.GameInterface, OnlineGameInterface(none)))
    {
        OnlineSub.GameInterface.ClearJoinOnlineGameCompleteDelegate(OnJoinGameComplete);
        // End:0x1DA
        if(bWasSuccessful)
        {
            // End:0x1CC
            if(OnlineSub.GameInterface.GetResolvedConnectString(SessionName, URL))
            {
                ShowConnectingDialog(true);
                bIgnoreNetworkMessages = false;
                // End:0x126
                if(IsBinkMoviePlaying(IntroMovieName))
                {
                    class'Engine'.static.StopMovie(false);
                    UnknownLocal_1 = true;
                }
                // End:0x16B
                if((int(WorldInfo.NetMode) == int(NM_Client)) || UnknownLocal_1)
                {
                    WillowClientShowLoadingMovie("", true);
                }
                ClientTravel(URL, 2);
                // End:0x1C9
                if(int(WorldInfo.NetMode) == int(NM_Client))
                {
                    HideLobbyUI();
                    ForceUnloadStreamingLevels();
                    ClearOnlineDelegates();
                }                
            }
            else
            {
                OnConnectionFailed();
            }            
        }
        else
        {
            OnConnectionFailed();
        }
    }
    //return;    
}

