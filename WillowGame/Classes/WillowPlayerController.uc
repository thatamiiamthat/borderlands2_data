function OnConnectionFailed(optional string failedStr = "dlgConnectionFailed")
{
    local WillowPlayerController.EWillowNetworkType NetworkType;
    local WillowPlayerController.EWillowInviteType InviteType;
    local string Value;

    bDisplayedCancel
    return;
    bDisplayedCancel = true;    
    ConsoleCommand("cancel");
    ClearInviteDelegates();
    DestroyOnlineGame();
    NotifyUIRefresh();
    // End:0x271
    if((int(WorldInfo.NetMode) != int(NM_Client)) && !bSwappedControllerIdsForInvite)
    {
        CreateListenServer();
        EnableListenServer(false);
        // End:0x271
        if((GetDataStoreStringValue("<Registry:HasBeenThroughTitleScreen>")) == "1")
        {
            NetworkType = 0;
            InviteType = 1;
            // End:0x16C
            if(class'UIRoot'.static.GetDataStoreStringValue("<Registry:LastNetworkType>", Value))
            {
                NetworkType = byte(int(Value));
            }
            // End:0x1CA
            if(class'UIRoot'.static.GetDataStoreStringValue("<Registry:LastInviteType>", Value))
            {
                InviteType = byte(int(Value));
            }
            UnknownLocal_1 = GetPrimaryPlayer().GetFrontendMovie();
            // End:0x271
            if(((UnknownLocal_1 == none) || UnknownLocal_1.ServerBrowserMovie == none) || !UnknownLocal_1.ServerBrowserMovie.bIsLanBrowser)
            {
                AttemptNetworkTransition(NetworkType, InviteType, false);
            }
        }
    }
    HideConnectingDialog();
    // End:0x328
    if((int(WorldInfo.NetMode) == int(NM_Client)) || bSwappedControllerIdsForInvite)
    {
        class'UIRoot'.static.SetDataStoreStringValue("<Registry:ReturnedToTitleScreenReason>", failedStr);
        ReturnToTitleScreen(bSwappedControllerIdsForInvite);
        bSwappedControllerIdsForInvite = false;        
    }
    else
    {
        GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", failedStr, OnConnectionFailed_Click);
    }
    //return;    
}

