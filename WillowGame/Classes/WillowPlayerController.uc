function ShowConnectingDialog(optional bool bCanCancel = false)
{
    !IsPrimaryPlayer();
    GetPrimaryPlayer().ShowConnectingDialog(bCanCancel);
    goto J0x290;
    // End:0x1B5
    if(bCanCancel)
    {
        // End:0x88
