        UnknownLocal_3 = byte(CompressAccel(int(BuildAccel.Y)));
        UnknownLocal_5 = byte(CompressAccel(int(BuildAccel.Z)));
        OldServerMove(OldMove.TimeStamp, UnknownLocal_1, UnknownLocal_3, UnknownLocal_5, OldMove.CompressedFlags(), OldMove.AnalogPct);
    }
    InAccel = NewMove.Acceleration * float(10);
    // End:0x500
    if(PendingMove != none)
    {
        // End:0x37F
        if((((((InAccel == vect(0, 0, 0)) && PendingMove.StartVelocity == vect(0, 0, 0)) && int(NewMove.DoubleClickMove) == int(0)) && PendingMove.Acceleration == vect(0, 0, 0)) && int(PendingMove.DoubleClickMove) == int(0)) && !PendingMove.bDoubleJump)
        {
            // End:0x2B9
