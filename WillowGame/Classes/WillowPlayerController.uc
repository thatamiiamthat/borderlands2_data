function string FixUpLoadString(coerce string InLoadString)
{
    local string Num;

    // End:0x51
    if(!Right(InLoadString, 4) ~= ".sav" && !Right(InLoadString, 4) ~= ".bak")
    {        
        InLoadString $= ".sav";
    }
    // End:0x72
    if(InLoadString ~= QuickSaveFileName)
    {
        return InLoadString;
    }
    // End:0xA7
    if(!Left(InLoadString, 4) ~= "save")
    {
        InLoadString = "Save" $ InLoadString;
    }
    // End:0x153
    if(Len(InLoadString) < 12)
    {
        Num = Mid(InLoadString, 4, 4 - (12 - Len(InLoadString)));
        UnknownLocal_1 = Len(Num);
        UnknownLocal_3 = 0;
        J0xFB:

        // End:0x130 [Loop If]
        if(UnknownLocal_3 < (4 - UnknownLocal_1))
        {
            Num = "0" $ Num;
            ++ UnknownLocal_3;
            // [Loop Continue]
            goto J0xFB;
        }
        InLoadString = ("Save" $ Num) $ ".sav";
    }
    return InLoadString;
    //return ReturnValue;    
}

