}

protected function ReturnToTitleScreenAfterSave()
{
    // End:0x23
    if(bRemoveSplitPlayerAfterSave)
    {
        bRemoveSplitPlayerAfterSave = false;
        SplitScreenLeave();
    }
    UnknownLocal_1 = OnlineSub.GameInterface.GetGameSettings('Game');
    // End:0x1F5
    if(UnknownLocal_1 != none)
    {
        // End:0x146
        if(int(UnknownLocal_1.GameState) == int(3))
        {
            OnlineSub.GameInterface.AddEndOnlineGameCompleteDelegate(OnEndGameForReturnToTitleComplete);
            bAsyncInProgress = true;
            // End:0x137
            if(OnlineSub.GameInterface.EndOnlineGame('Game'))
            {
                BeginUpdatingSession();                
            }
            else
            {
                bAsyncInProgress = false;
            }            
        }
        else
        {
            OnlineSub.GameInterface.AddDestroyOnlineGameCompleteDelegate(OnDestroyGameForReturnToTitleComplete);
            bAsyncInProgress = true;
            // End:0x1E6
            if(OnlineSub.GameInterface.DestroyOnlineGame('Game'))
            {
                BeginUpdatingSession();                
            }
            else
            {
                bAsyncInProgress = false;
            }
        }        
    }
    else
    {
        EndUpdatingSession();
        // End:0x21F
        if(IsBinkMoviePlaying(IntroMovieName))
        {
            StopAnyBinkMovie();
        }
        ClientTravel("?closed", 0);
    }
    //return;    
}

