    {
        return false;
        //return ReturnValue;        
    }
Begin:

    ClientPublishCachedSaveGameToPRI();
    ClientSetupInputDevices();
    SetCameraMode('Lobby');
    stop;                    
}

state PlayerQuickLook
{
    ignores SeePlayer, HearNoise, Bump;

    function PlayerMove(float DeltaTime)
    {
        UpdateRotation(DeltaTime);
        QuickLookPlayerMove(DeltaTime);
        //return;        
    }

    event BeginState(name PreviousStateName)
    {
        HLQPlayerMoving = false;
        Pawn.SetPhysics(0);
        Pawn.Acceleration = vect(0, 0, 0);
        Pawn.Velocity = vect(0, 0, 0);
        //return;        
    }
    stop;    
}

state PlayerWalking
{
    ignores SeePlayer, HearNoise, Bump;

    event BeginState(name PreviousStateName)
    {
        super.BeginState(PreviousStateName);
        // End:0x4D
        if(Pawn.DrivenVehicle != none)
        {
            SetTimer(0.1, true, 'CheckVehicleDataHasClearedOut');            
        }
        else
        {
            UpdateInputContext();
        }
        //return;        
    }

    function CheckVehicleDataHasClearedOut()
    {
        // End:0x42
        if(Pawn.DrivenVehicle == none)
        {
            ClearTimer('CheckVehicleDataHasClearedOut');
            UpdateInputContext();
        }
        //return;        
    }

    function ProcessMove(float DeltaTime, Vector newAccel, Engine.Actor.EDoubleClickDir DoubleClickMove, Rotator DeltaRot, byte AnalogPct)
    {
        UnknownLocal_1 = WillowPlayerPawn(Pawn);
        UnknownLocal_3 = WillowPlayerInput(PlayerInput);
        super.ProcessMove(DeltaTime, newAccel, DoubleClickMove, DeltaRot, AnalogPct);
        // End:0x18C
        if(IsLocalPlayerController())
        {
            // End:0xDD
            if(bInSprintState)
            {
                // End:0xDA
                if(((UnknownLocal_1 == none) || !UnknownLocal_1.CanContinueSprinting()) || !UnknownLocal_3.InputAllowsSprint())
                {
                    EndSprint();
                }                
            }
            else
            {
                // End:0x189
                if(bWantsToSprint)
                {
                    // End:0x126
                    if((UnknownLocal_1 == none) || !UnknownLocal_3.InputAllowsSprint())
                    {
                        bWantsToSprint = false;                        
                    }
                    else
                    {
                        // End:0x189
                        if(UnknownLocal_1.IsOnGroundOrShortFall() && !IsZoomed())
                        {
                            // End:0x17D
                            if(UnknownLocal_1.CanSprint())
                            {
                                BeginSprint();
                            }
                            bWantsToSprint = false;
                        }
                    }
                }
            }            
        }
        else
        {
            // End:0x1B7
            if(bClientIsSprinting && !bInSprintState)
            {
                BeginSprint();                
            }
            else
            {
                // End:0x1DF
                if(!bClientIsSprinting && bInSprintState)
                {
                    EndSprint();
                }
            }
        }
        //return;        
    }

    function EndState(name NextState)
    {
        super.EndState(NextState);
        ClearTimer('CheckVehicleDataHasClearedOut');
        // End:0x3E
        if(bInSprintState)
        {
            EndSprint();
        }
        bPressedSprint = false;
        //return;        
    }

    function bool NotifyLanded(Vector HitNormal, Actor FloorActor)
    {
        // End:0x21
        if(global.NotifyLanded(HitNormal, FloorActor))
        {
            return true;
        }
        return false;
        //return ReturnValue;        
    }

    function PlayerMove(float DeltaTime)
    {
        UnknownLocal_1 = WillowGameReplicationInfo(WorldInfo.GRI);
        // End:0x69
        if((Pawn != none) && int(Pawn.Physics) == int(10))
        {
            return;
        }
        GroundPitch = 0;
        // End:0x155
        if((UnknownLocal_1 == none) || Pawn != none)
        {
            // End:0x142
            if(CurrentLunge.Target != none)
            {
                PlayerInput.aForward = 1;
                PlayerInput.aStrafe = 0;
                PlayerInput.RawJoyUp = 1;
                PlayerInput.RawJoyRight = 0;
            }
            super.PlayerMove(DeltaTime);
        }
        bPressedSprint = false;
        //return;        
    }
    stop;    
}

state PlayerDriving
{
    event BeginState(name PreviousStateName)
    {
        super.BeginState(PreviousStateName);
        UpdateInputContext();
        //return;        
    }
    stop;    
}

