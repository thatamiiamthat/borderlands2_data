    {
        UnknownLocal_1 = OnlineSub.GameInterface.GetGameSettings('Game');
        // End:0x34D
        if(UnknownLocal_1 != none)
        {
            // End:0x262
            if(UnknownLocal_1.bIsLanMatch)
            {
                OnlineSub.PlayerInterfaceEx.SetBifrostSelfAvailability(int(NetworkType) == int(0));
                // End:0x228
                if(int(NetworkType) == int(0))
                {
                    AttemptInternetTransition(InviteType, bPrompt);                    
                }
                else
                {
                    // End:0x253
                    if(int(NetworkType) == int(2))
                    {
                        AttemptOfflineTransition(bPrompt);                        
                    }
                    else
                    {
                        bRestoringNetwork = false;
                    }
                }                
            }
            else
            {
                OnlineSub.PlayerInterfaceEx.SetBifrostSelfAvailability(int(NetworkType) == int(0));
                // End:0x2DC
                if(int(NetworkType) == int(0))
                {
                    AttemptInternetInviteTypeTransition(InviteType, bPrompt);                    
                }
                else
                {
                    // End:0x313
                    if(int(NetworkType) == int(1))
                    {
                        bHostLanGame = true;
                        AttemptSystemLinkTransition(bPrompt);                        
                    }
                    else
                    {
                        // End:0x33E
                        if(int(NetworkType) == int(2))
                        {
                            AttemptOfflineTransition(bPrompt);                            
                        }
                        else
                        {
                            bRestoringNetwork = false;
                        }
                    }
                }
            }            
        }
        else
        {
            OnlineSub.PlayerInterfaceEx.SetBifrostSelfAvailability(int(NetworkType) == int(0));
            // End:0x3C7
            if(int(NetworkType) == int(0))
            {
                AttemptInternetTransition(InviteType, bPrompt);                
