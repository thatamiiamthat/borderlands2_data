    GraveyardFileName="Graveyard.sav"
    SparkStatFlushIntervalSeconds=900
    PlayerLocationSparkPulseIntervalSeconds=5
    bAlwaysLookDownCamera=true
    bLandingShake=true
    bInitialSpawn=true
    bShowBasicPlayerDebugInfo=true
    bSaveBeforeInviteJoin=true
    bAutoAimEnabled=true
    bAllowPerShotForceFeedback=true
    MatineeCameraClass='WillowPlayerCamera'
    DefaultPlayerCharacterClassName="GD_Soldier.Character.CharClass_Soldier"
    ExpPool=(PoolManager=none,PoolIndexInManager=255,PoolGUID=0,Data=none)
    SkillCooldownPool=(PoolManager=none,PoolIndexInManager=255,PoolGUID=0,Data=none)
    MeleeSkillCooldownPool=(PoolManager=none,PoolIndexInManager=255,PoolGUID=0,Data=none)
}