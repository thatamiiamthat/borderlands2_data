    MissionPlaythroughs[MissionPlaythroughIdx].MissionList[MissionDataIdx].SubObjectiveSets = SavedMStatus.SubObjectiveSets;
    MissionPlaythroughs[MissionPlaythroughIdx].MissionList[MissionDataIdx].Status = SavedMStatus.Status;
    MissionPlaythroughs[MissionPlaythroughIdx].MissionList[MissionDataIdx].MissionDef = SavedMStatus.MissionDef;
    MissionPlaythroughs[MissionPlaythroughIdx].MissionList[MissionDataIdx].GameStage = SavedMStatus.GameStage;
    MissionPlaythroughs[MissionPlaythroughIdx].MissionList[MissionDataIdx].bNeedsRewards = SavedMStatus.bNeedsRewards;
    MissionPlaythroughs[MissionPlaythroughIdx].MissionList[MissionDataIdx].bHeardKickoff = SavedMStatus.bHeardKickoff;
    //return;    
}

