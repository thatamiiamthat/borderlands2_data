            {
                UnknownLocal_7 = Velocity == vect(0, 0, 0);                
            }
            else
            {
                UnknownLocal_7 = Pawn.Velocity == vect(0, 0, 0);
            }
            // End:0x37F
            if(UnknownLocal_7)
            {
                ServerMove(NewMove.TimeStamp, InAccel, ClientLoc, NewMove.CompressedFlags(), ClientRoll, View, NewMove.AnalogPct);
                return;
            }
        }
        DualServerMove(PendingMove.TimeStamp, PendingMove.Acceleration * float(10), PendingMove.CompressedFlags(), ((PendingMove.Rotation.Yaw & 65535) << 16) + (PendingMove.Rotation.Pitch & 65535), PendingMove.AnalogPct, NewMove.TimeStamp, InAccel, ClientLoc, NewMove.CompressedFlags(), ClientRoll, View, NewMove.AnalogPct);        
    }
    else
    {
        // End:0x5EF
        if(((InAccel == vect(0, 0, 0)) && int(NewMove.DoubleClickMove) == int(0)) && !NewMove.bDoubleJump)
        {
            ShortServerMove(NewMove.TimeStamp, ClientLoc, NewMove.CompressedFlags(), ClientRoll, View, NewMove.AnalogPct);            
        }
        else
        {
            ServerMove(NewMove.TimeStamp, InAccel, ClientLoc, NewMove.CompressedFlags(), ClientRoll, View, NewMove.AnalogPct);
        }
    }
    //return;    
}

