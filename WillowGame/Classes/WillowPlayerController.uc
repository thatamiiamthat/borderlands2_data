        {
            NoCancelConnectingDlg.Close();
            NoCancelConnectingDlg = none;
        }
        bDisplayedCancel = false;
        ConnectionDuration = float(ConnectionTimeout);
        // End:0x16A
        if(ConnectingDlg == none)
        {
            ConnectingDlg = GFxUIManager.ShowDialog();
            ConnectingDlg.AutoLocEnable("WillowMenu", "dlg");
            ConnectingDlg.AutoAppendButton('Cancel', OnConnectionCancel_Click);
            ConnectingDlg.ApplyLayout();
        }
        SetRemainingConnectionDuration(int(ConnectionDuration));
        PauseTicker.SetTimer(ConnectingDialogRefreshTime, false, 'UpdateConnecting', self);        
    }
    else
    {
        // End:0x290
        if(NoCancelConnectingDlg == none)
        {
            NoCancelConnectingDlg = GFxUIManager.ShowDialog();
            NoCancelConnectingDlg.AutoLocEnable("WillowMenu", "dlgNoCancelConnecting");
            NoCancelConnectingDlg.ApplyLayout();
            NoCancelConnectingDlg.SetQuadrant(255);
            NoCancelConnectingDlg.ShowTooltips(false);
        }
    }
    J0x290:

    //return;    
}

function HideConnectingDialog()
{
    // End:0x32
    if(!IsPrimaryPlayer())
    {
        GetPrimaryPlayer().HideConnectingDialog();        
    }
    else
    {
        PauseTicker.ClearTimer('UpdateConnecting', self);
        // End:0x95
        if(ConnectingDlg != none)
        {
            ConnectingDlg.Close();
            ConnectingDlg = none;
        }
        // End:0xCF
        if(NoCancelConnectingDlg != none)
        {
            NoCancelConnectingDlg.Close();
            NoCancelConnectingDlg = none;
        }
    }
    //return;    
}

function SetRemainingConnectionDuration(int ConnDuration)
{
    // End:0x11
    if(ConnectingDlg == none)
    {
        return;
    }
    ConnectingDlg.AutoLocEnable("WillowMenu", "dlgConnecting");
    ConnectingDlg.ReplaceDialogText("%TIME%", string(ConnDuration));
    // End:0xC8
    if(float(ConnDuration) < 2)
    {
        ConnectingDlg.ReplaceDialogText("%SECONDS%", OneSecond);        
    }
    else
    {
        ConnectingDlg.ReplaceDialogText("%SECONDS%", MoreThanOneSecond);
    }
    ConnectingDlg.ApplyFlashText();
    //return;    
}

function UpdateConnecting()
{
    ConnectionDuration -= ConnectingDialogRefreshTime;
    // End:0x33
    if(ConnectionDuration <= float(0))
    {
        OnConnectionFailed();        
    }
    else
    {
        SetRemainingConnectionDuration(int(ConnectionDuration));
        PauseTicker.SetTimer(ConnectingDialogRefreshTime, false, 'UpdateConnecting', self);
    }
    //return;    
}

