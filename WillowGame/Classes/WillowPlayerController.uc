        SavePlayer(PlayersToSave[0]);        
    }
    else
    {
        UnknownLocal_1 = WorldInfo.RealTimeSeconds - SaveStartTime;
        // End:0x77
        if(UnknownLocal_1 >= MinSaveDuration)
