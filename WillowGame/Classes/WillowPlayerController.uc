function InnerOnGameInviteAcceptedP(int P, const out OnlineGameSearchResult InviteResult)
{
    SavedInviteControllerId = P;
    // End:0x534
    if(InviteResult.GameSettings != none)
    {
        // End:0x26C
        if((IsInactiveController(P)) && IsPlayerInMyGame(InviteResult.GameSettings.OwningPlayerId))
        {
            // End:0x211
            if(class'UIInteraction'.static.GetPlayerCount() < 2)
            {
                // End:0x150
                if(class'WorldInfo'.static.IsMenuLevel())
                {
                    // End:0x14C
                    foreach GFxUIManager.ScreenMovies(UnknownLocal_1,)
                    {
                        // End:0x14B
                        if(UnknownLocal_1.IsA('FrontendGFxMovie'))
                        {
                            FrontendGFxMovie(UnknownLocal_1).HandleSplitscreenJoinAttempt(P);                            
                        }
                        else
                        {                            
                        }
                    }                                        
                }
                else
                {
                    // End:0x1F0
                    foreach GFxUIManager.ScreenMovies(UnknownLocal_1,)
                    {
                        // End:0x1EF
                        if(UnknownLocal_1.IsA('PauseGFxMovie') || UnknownLocal_1.IsA('LobbyGFxMovie'))
                        {
                            UnknownLocal_3 = true;
                            FrontendGFxMovie(UnknownLocal_1).HandleSplitscreenJoinAttempt(P);                            
                        }
                        else
                        {                            
                        }
                    }                    
                    // End:0x20E
                    if(!UnknownLocal_3)
                    {
                        UnregisteredControllerButtonPress(P);
                    }
                }                
            }
            else
            {
                DisplayGameMessage(5, 5, Localize("WillowPlayerController", "MaxSplitscreenPlayers", "WillowMenu"), "");
            }            
        }
        else
        {
            // End:0x3BC
            if(IsInactiveController(P))
            {
                // End:0x3AF
                if(!NeedsCompatibilityContent())
                {
                    // End:0x390
                    if((GetDataStoreStringValue("<Registry:HasBeenThroughTitleScreen>")) == "1")
                    {
                        HideConnectingDialog();
                        SavedInviteSearchResult = InviteResult;
                        InviteDlg = GFxUIManager.ShowDialog();
                        InviteDlg.DisplayYesNoBox("WillowMenu", "dlgConfirmKickPlayersForInvite", OnConfirmKickPlayersForInvite);
                        InviteDlg.SetAllowNonOwnerInput(true);                        
                    }
                    else
                    {
                        OnGameInviteAcceptedP(P, InviteResult);
                    }                    
                }
                else
                {
                    NotifyNeedsCompatibilityContent();
                }                
            }
            else
            {
                // End:0x527
                if(!NeedsCompatibilityContent())
                {
                    // End:0x51A
                    if(InviteHasEnoughSpace(InviteResult.GameSettings))
                    {
                        // End:0x50D
                        if(CanAllPlayersPlayOnline())
                        {
                            // End:0x4BE
                            if(GameHasNonLocalPlayers())
                            {
                                HideConnectingDialog();
                                SavedInviteSearchResult = InviteResult;
                                InviteDlg = GFxUIManager.ShowDialog();
                                InviteDlg.DisplayYesNoBox("WillowMenu", "dlgConfirmKickNetworkedPlayersForInvite", OnKickNetworkedPlayersForInvite_Confirm);                                
                            }
                            else
                            {
                                // End:0x4F7
                                if(P != int(GetMyControllerId()))
                                {
                                    NonPrimaryOnGameInviteAccepted(P, InviteResult);                                    
                                }
                                else
                                {
                                    OnGameInviteAcceptedCheckController(InviteResult);
                                }
                            }                            
                        }
                        else
                        {
                            NotifyNotAllPlayersCanJoinInvite();
                        }                        
                    }
                    else
                    {
                        NotifyNotEnoughSpaceInInvite();
                    }                    
                }
                else
                {
                    NotifyNeedsCompatibilityContent();
                }
            }
        }        
    }
    else
    {
        NotifyInviteFailed();
    }
    //return;    
}

