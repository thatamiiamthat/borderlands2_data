exec function UpdateLcdFriendsList()
{
    local OnlineFriend friendIter;
    local string retstr;
    local array<string> Presence;
    local string Suffix;

    // End:0x59
    if(((OnlineSub == none) || EqualEqual_InterfaceInterface(OnlineSub.PlayerInterface, OnlinePlayerInterface(none))) || !IsLocalPlayerController())
