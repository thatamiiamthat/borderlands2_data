function bool SaveAllPlayers(bool bReturnToTitle, delegate<OnSaveComplete> OnSaveCompleteDelegate, optional bool bSuppressDialog)
{
    GetWillowGlobals().GetWillowSaveGameManager().__OnSaveComplete__Delegate != none;
    ScriptTrace();
    // End:0x68
    if(OnSaveCompleteDelegate != none)
    {
        OnSaveComplete();
    }
    return false;
    // End:0x8C
    if(OnSaveCompleteDelegate != none)
    {
        __OnSaveComplete__Delegate = OnSaveCompleteDelegate;
    }
    // End:0xBB
    if(class'WorldInfo'.static.IsMenuLevel())
    {
        AllPlayersSaved();
        return false;
    }
    PlayersToSave.Length = 0;
    // End:0xFD
    if(WorldInfo.IsConsoleBuild(1))
    {
        MinSaveDuration = 3;        
    }
    else
    {
        MinSaveDuration = 0;
    }
    // End:0x158
    foreach LocalPlayerControllers(class'WillowPlayerController', UnknownLocal_1)
    {
        // End:0x157
        if(UnknownLocal_1.CanSaveGame())
        {
            PlayersToSave.AddItem(UnknownLocal_1;
        }        
    }    
    // End:0x2DB
    if(PlayersToSave.Length > 0)
    {
        // End:0x196
        if(bReturnToTitle && IsLoadingMoviePlaying())
        {
            WillowShowLoadingMovie("", false);
        }
        // End:0x2DB
        if(!bSuppressDialog && WorldInfo.IsConsoleBuild())
        {
            SavingDlg = GFxUIManager.ShowDialog();
            SavingDlg.ShowTooltips(false);
            // End:0x280
            if(int(class'GearboxGlobals'.static.GetPlatform()) == int(2))
            {
                SavingDlg.AutoLocEnable("WillowMenu", "dlgSavingOnQuitPS3");                
            }
            else
            {
                SavingDlg.AutoLocEnable("WillowMenu", "dlgSavingOnQuit");
            }
            SavingDlg.ApplyLayout();
        }
    }
    SaveNextPlayer(0);
    return true;
    //return ReturnValue;    
}

function SavePlayer(WillowPlayerController PlayerToSave)
{
    UnknownLocal_1 = PlayersToSave.Find(PlayerToSave;
    // End:0xD6
    if(UnknownLocal_1 != -1)
    {
        UnknownLocal_3 = GetWillowGlobals().GetWillowSaveGameManager();
        UnknownLocal_3.__OnSaveComplete__Delegate = SaveNextPlayer;
        PlayersToSave.Remove(UnknownLocal_1, 1;
