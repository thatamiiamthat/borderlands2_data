                    switch(UnknownLocal_3.NumOverpowerLevelsUnlocked)
                    {
                        // End:0x251
                        case 1:
                            LocalizedTrainingMessage = Localize("OverpowerUnlock", "SuccessfulUnlockOP1", "WillowMenu");
                            // End:0x2EF
                            break;
                        // End:0x2A6
                        case MaximumValue:
                            LocalizedTrainingMessage = Localize("OverpowerUnlock", "SuccessfulUnlockOP8", "WillowMenu");
                            // End:0x2EF
                            break;
                        // End:0xFFFF
                        default:
                            LocalizedTrainingMessage = Localize("OverpowerUnlock", "SuccessfulUnlock", "WillowMenu");
                            // End:0x2EF
                            break;
                            break;
                    }
                    LocalizedTrainingMessageTitle = Localize("OverpowerUnlock", "SuccessfulUnlockTitle", "WillowMenu");
                    class'Actor'.static.ReplaceText(LocalizedTrainingMessage, "%d", string(UnknownLocal_3.NumOverpowerLevelsUnlocked));                    
                }
                else
                {
                    LocalizedTrainingMessage = Localize("OverpowerUnlock", "UnsuccessfulUnlock", "WillowMenu");
                    LocalizedTrainingMessageTitle = Localize("OverpowerUnlock", "UnsuccessfulUnlockTitle", "WillowMenu");
                }
            }            
        }
        else
        {
            LocalizedTrainingMessage = Localize("OverpowerUnlock", "LevelRequirementNotMet", "WillowMenu");
            LocalizedTrainingMessageTitle = Localize("OverpowerUnlock", "LevelRequirementNotMetTitle", "WillowMenu");
            class'Actor'.static.ReplaceText(LocalizedTrainingMessage, "%d", string(class'WillowPlayerController'.static.GetMaximumPossiblePlayerLevelCap()));
        }
        DisplayTrainingMessage(0, LocalizedTrainingMessage, LocalizedTrainingMessageTitle, UnknownLocal_1, MessageColor, "", true, 1, true);
    }
    //return;    
}

