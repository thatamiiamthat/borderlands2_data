event LoadPlayerSaveGame(PlayerSaveGame NewSaveGame)
{
    // End:0x5F3
    if(NewSaveGame != none)
    {
        // End:0x54F
        if(NewSaveGame.PlayerClassDefinition == PlayerClass)
        {
            AttemptPreSaveGameLoadFixup(NewSaveGame);
            OverpowerChoiceValue = NewSaveGame.LastOverpowerChoice;
            // End:0xC8
            if(int(Role) < int(ROLE_Authority))
            {
                AttemptReplicateSaveGame(NewSaveGame);
                ClientShowSendingSaveGameDialog();
                ServerSetRemoteGoldenKeyData(GetNumGoldenKeysAcquired(), GetNumGoldenKeysAvailable());                
            }
            else
            {
                // End:0x100
                if(IsLocalController())
                {
                    bSaveGameLoaded = true;
                    class'WillowLeviathanService'.static.PublishEvents();
                }
            }
            ConsoleEcho((("Loading SaveGame from LoadSaveGame: " $ string(self)) $ " -> SaveGame: ") $ string(NewSaveGame));
            ApplyPlayerUIPreferencesData(NewSaveGame);
            ApplyPlayerSaveGameData(NewSaveGame);
            ApplyPlayerCustomizationData(NewSaveGame);
            ApplySkillSaveGameData(NewSaveGame);
            LoadBlackMarketUpgrades(NewSaveGame);
            ApplyItemSaveGameData(NewSaveGame);
            ApplyResourceSaveGameData(NewSaveGame);
            ApplyInventorySlotSaveGameData(NewSaveGame);
            ApplyInventorySaveGameData(NewSaveGame);
            ApplyStatsSaveGameData(NewSaveGame);
            ApplyGameStageData(NewSaveGame);
            // End:0x25A
            if(IsLocalController())
            {
                ApplyMissionSaveGameData(NewSaveGame, true);
                ApplyVisitedTeleporterData(NewSaveGame);
            }
            // End:0x27C
            if(int(Role) == int(ROLE_Authority))
            {
                ServerResetPlayerChallenges(true);                
            }
            else
            {
                ClientResetPlayerChallenges();
            }
            ApplyPlayerChallengeData(NewSaveGame);
            // End:0x2CA
            if(int(Role) == int(ROLE_Authority))
            {
                ApplyQueuedTrainingMessageData(NewSaveGame);
                ResetStatsListeners();
            }
            ApplyDiscoveredWorldAreaData(NewSaveGame);
            // End:0x30B
            if(IsLocalController())
            {
                GetHUDMovie().extInitMinimapFogOfWar(none);
            }
            ApplyDLCExpansionData(NewSaveGame);
            StoreUnloadableDlcContent(NewSaveGame);
            // End:0x35B
            if(IsLocalPlayerController())
            {
                ApplyMarketingCodeSaveGameData(NewSaveGame);
                GrantNewMarketingCodeBonuses();
            }
            GrantUnconsumedDemoPerk();
            ProcessShiftEntitlements(false);
            SetNeedsUpdateOnlineGameSettings();
            LoadTheBank(NewSaveGame);
            ApplyLockoutData(NewSaveGame);
            ApplyAwesomeSkillSaveGameData(NewSaveGame);
            ApplyVehicleCustomizationData(NewSaveGame);
            ApplyVehicleSteeringModeData(NewSaveGame);
            ServerSendInitialColiseumStat(PlayerStats.GetIntStat('STAT_PLAYER_KILLS'));
            // End:0x52C
            if(int(Role) == int(ROLE_Authority))
            {
                UnknownLocal_1 = int(class'AttributeInitializationDefinition'.static.EvaluateInitializationData(GetWillowGlobals().GetGlobalsDefinition().GeneralSkillPointsTotalForCurrentLevel, self));
                UnknownLocal_3 = WillowPlayerReplicationInfo(PlayerReplicationInfo).GeneralSkillPoints;
                UnknownLocal_5 = ((PlayerSkillTree != none) ? PlayerSkillTree.GetSkillPointsSpentInTree() : 0);
                // End:0x52C
                if(UnknownLocal_1 > (UnknownLocal_5 + UnknownLocal_3))
                {
                    WillowPlayerReplicationInfo(PlayerReplicationInfo).GeneralSkillPoints = UnknownLocal_1 - UnknownLocal_5;
                }
            }
            // End:0x54C
            if(IsLocalPlayerController())
            {
                DetectAndRestoreMissingProfileData(NewSaveGame);
            }            
        }
        else
        {
            ConsoleEcho((("Player class mismatch.  Class is " $ PlayerClass.GetFullDefinitionName()) $ " and SaveGame is ") $ NewSaveGame.PlayerClassDefinition.GetFullDefinitionName());
            GetHighestSaveGameId();
        }
    }
    TriggerGlobalEventClass(class'WillowSeqEvent_PlayerJoined', none);
    //return;    
}

