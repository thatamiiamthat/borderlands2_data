reliable client simulated event ClientSetLevelChallengeUnlockMask(ChallengeDefinition AssociatedChallenge, int Index, int Mask, int TotalObjectCount)
{
    // End:0x2F
    if(LevelChallengeUnlocks.Length <= Index)
    {
        LevelChallengeUnlocks.Length = Index + 1;
    }
    LevelChallengeUnlocks[Index] = Mask;
    // End:0x82
    if(CheckHasCompletedLevelObjectChallengeFromBitmask(Mask, TotalObjectCount))
    {
        ServerCompleteChallenge(AssociatedChallenge);        
    }
    else
    {
        ShowChallengeProgressUpdate(AssociatedChallenge, -1, -1, GetNumLevelObjectsFoundFromBitmask(Mask), TotalObjectCount);
    }
    UpdateLcdWatchedChallenges();
    //return;    
}

reliable client simulated event ClientSetOneOffCompletion(int OneOffIndex, int CompletionIndex, int CompletionMask)
{
    local DlcContentId MapContentId;

    MapContentId = class'WillowDownloadableContentManager'.static.StaticGetDlcContentIdForCurrentMap();
    // End:0x59
    if(OneOffLevelChallengeCompletion.Length <= OneOffIndex)
    {
        OneOffLevelChallengeCompletion.Length = OneOffIndex + 1;
    }
    // End:0xC2
    if(OneOffLevelChallengeCompletion[OneOffIndex].Completion.Length <= CompletionIndex)
    {
        OneOffLevelChallengeCompletion[OneOffIndex].Completion.Length = CompletionIndex + 1;
    }
    OneOffLevelChallengeCompletion[OneOffIndex].Completion[CompletionIndex] = CompletionMask;
    OneOffLevelChallengeCompletion[OneOffIndex].PackageId = byte(MapContentId.PackageId);
    OneOffLevelChallengeCompletion[OneOffIndex].ContentId = byte(MapContentId.ContentId);
    //return;    
}

