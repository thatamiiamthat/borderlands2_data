                                                ScreenParticleRecords[UnknownLocal_3].Component.SetHidden(true);
                                            }                                            
                                        }
                                        else
                                        {
                                            UnknownLocal_3 = FindScreenParticleRecordIndexByTag(UnknownLocal_1.InjuredScreenFadeParticleTag);
                                            // End:0x398
                                            if(UnknownLocal_3 != -1)
                                            {
                                                ScreenParticleRecords[UnknownLocal_3].Component.bIsActive = true;
                                                ScreenParticleRecords[UnknownLocal_3].Component.SetHidden(false);
