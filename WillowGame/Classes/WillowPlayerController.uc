function ProcessViewRotation(float DeltaTime, out Rotator out_ViewRotation, Rotator DeltaRot)
{
    local Vector TargetDir, TargetLoc;
    local ITargetable MeleeTarget;

    // End:0x4E
    if(GFxUIManager != none)
    {
        // End:0x4E
        if(GFxUIManager.super(WillowGFxUIManager).ProcessViewRotation(DeltaTime, out_ViewRotation, DeltaRot))
        {
            return;
        }
    }
    // End:0x115
    if(((Pawn != none) && Pawn.DrivenVehicle != none) && Pawn.DrivenVehicle.IsA('WillowWeaponPawn'))
    {
        WillowWeaponPawn(Pawn.DrivenVehicle).ProcessViewRotation(DeltaTime, out_ViewRotation, DeltaRot);
    }
    // End:0x33F
    if(CurrentLunge.Target != none)
    {
        MeleeTarget = CurrentLunge.Target.QueryInterface(class'ITargetable');
        // End:0x1C9
        if(NotEqual_InterfaceInterface(MeleeTarget, ITargetable(none)))
        {
            TargetLoc = MeleeTarget.GetSnapLocation();            
        }
        else
        {
            TargetLoc = CurrentLunge.Target.CollisionComponent.Bounds.Origin;
            TargetLoc.Z += (CurrentLunge.Target.CollisionComponent.Bounds.BoxExtent.Z * 0.8);
        }
        TargetDir = TargetLoc - Pawn.GetPawnViewLocation();
        out_ViewRotation = RInterpTo(out_ViewRotation, Rotator(TargetDir), DeltaTime, 20);
        DeltaRot = rot(0, 0, 0);
    }
    super(PlayerController).ProcessViewRotation(DeltaTime, out_ViewRotation, DeltaRot);
    //return;    
}

