function HandleLoginStatusChange()
{
    local Engine.OnlineSubsystem.ELoginStatus LoginStatus;
    local UniqueNetId NetId;
    local WillowPlayerController.EWillowNetworkType NetworkType;
    local WillowPlayerController.EWillowInviteType InviteType;
    local string Value, LocKey;

    UnknownLocal_1 = IsPrimaryPlayer();
    LoginStatus = GetLoginStatus();
    SetName(OnlineSub.PlayerInterface.GetPlayerNickname(GetMyControllerId()));
    // End:0x11D
    if(WillowPlayerReplicationInfo(PlayerReplicationInfo) != none)
    {
        OnlineSub.PlayerInterface.GetUniquePlayerId(byte(LocalPlayer(Player).ControllerId), NetId);
        WillowPlayerReplicationInfo(PlayerReplicationInfo).ServerMigrateUniqueId(NetId);
    }
    // End:0x7D3
    if(UnknownLocal_1)
    {
        // End:0x57F
        if(int(LoginStatus) == int(1))
        {
            // End:0x190
            if(int(class'GearboxGlobals'.static.GetPlatform()) == int(1))
            {
                LocKey = "dlgLost360OnlineLinkInMainMenu";                
            }
            else
            {
                // End:0x1E7
                if(int(class'GearboxGlobals'.static.GetPlatform()) == int(2))
                {
                    LocKey = "dlgLostPS3OnlineLinkInMainMenu";                    
                }
                else
                {
                    // End:0x254
                    if(OnlineSub.Class.Name == 'OnlineSubsystemSteamworks')
                    {
                        LocKey = "dlgLostPCOnlineLinkInMainMenu";                        
                    }
                    else
                    {
                        LocKey = "dlgLostEpicPCOnlineLinkInMainMenu";
                    }
                }
            }
            DisplayGameMessage(1, 3, Localize(LocKey, "Caption", "WillowMenu"), Localize(LocKey, "Prompt", "WillowMenu"));
            UnknownLocal_3 = OnlineSub.GameInterface.GetGameSettings('Game');
            NetworkType = GetRestoreNetworkType(UnknownLocal_3);
            InviteType = class'WillowGFxMovie'.static.GetInviteType(UnknownLocal_3);
            // End:0x569
            if(int(NetworkType) == int(0))
            {
                // End:0x47E
                if(!class'UIRoot'.static.GetDataStoreStringValue("<Registry:RestoreNetworkType>", Value) || Value == "")
                {
                    class'UIRoot'.static.SetDataStoreStringValue("<Registry:RestoreNetworkType>", string(int(NetworkType)) $ "");
                    class'UIRoot'.static.SetDataStoreStringValue("<Registry:RestoreInviteType>", string(int(InviteType)) $ "");
                }
                // End:0x517
                if(int(WorldInfo.NetMode) == int(NM_Client))
                {
                    // End:0x514
                    if(!bReturningToMenu)
                    {
                        class'UIRoot'.static.SetDataStoreStringValue("<Registry:ReturnedToTitleScreenReason>", GetConnectionFailureNoticeMsg());
                        ReturnToTitleScreen();
                    }                    
                }
                else
                {
                    // End:0x542
                    if((NoCancelConnectingDlg != none) || ConnectingDlg != none)
                    {
                        OnConnectionFailed();
                    }
                    bHostLanGame = true;
                    DestroyOnlineGameWithDelegate(OnDestroyGameForSystemLinkComplete);
                }
            }
            NotifyUILoginStatusChange(LoginStatus);            
        }
        else
        {
            // End:0x7D3
            if(int(LoginStatus) == int(2))
            {
                // End:0x5EC
                if(int(class'GearboxGlobals'.static.GetPlatform()) == int(1))
                {
                    LocKey = "dlgGained360OnlineLinkInMainMenu";                    
                }
                else
                {
                    // End:0x645
                    if(int(class'GearboxGlobals'.static.GetPlatform()) == int(2))
                    {
                        LocKey = "dlgGainedPS3OnlineLinkInMainMenu";                        
                    }
                    else
                    {
                        // End:0x6B4
                        if(OnlineSub.Class.Name == 'OnlineSubsystemSteamworks')
                        {
                            LocKey = "dlgGainedPCOnlineLinkInMainMenu";                            
                        }
                        else
                        {
                            LocKey = "dlgGainedEpicPCOnlineLinkInMainMenu";
                        }
                    }
                }
                DisplayGameMessage(1, 3, Localize(LocKey, "Caption", "WillowMenu"), Localize(LocKey, "Prompt", "WillowMenu"));
                // End:0x7D3
                if(int(WorldInfo.NetMode) != int(NM_Client))
                {
                    // End:0x7C9
                    if(class'WorldInfo'.static.IsMenuLevel() && (GetFrontendMovie()) != none)
                    {
                        AddDownloadPatcherFilesCompleteDelegate(OnDownloadPatcherFilesBeforeRestore);
                        DownloadPatcherFiles();                        
                    }
                    else
                    {
                        OnDownloadPatcherFilesBeforeRestore();
                    }
                }
            }
        }
    }
    //return;    
}

function OnDownloadPatcherFilesBeforeRestore()
{
    local WillowPlayerController.EWillowNetworkType NetworkType;
    local WillowPlayerController.EWillowInviteType InviteType;
    local string Value;

    ClearDownloadPatcherFilesCompleteDelegate(OnDownloadPatcherFilesBeforeRestore);
    NotifyUIRefresh();
    // End:0x12F
    if(!GameHasNonLocalPlayers())
    {
        // End:0x12F
        if(class'UIRoot'.static.GetDataStoreStringValue("<Registry:RestoreNetworkType>", Value) && Value != "")
        {
            NetworkType = byte(int(Value));
            class'UIRoot'.static.GetDataStoreStringValue("<Registry:RestoreInviteType>", Value);
            InviteType = byte(int(Value));
            bRestoringNetwork = true;
            AttemptNetworkTransition(NetworkType, InviteType, false);
        }
    }
    //return;    
}

