function OnExternalUIChanged(bool bIsOpening)
{
    bIsExternalUIOpen = bIsOpening;
    // End:0x60
    if(bIsOpening)
    {
        // End:0x49
        if(!ShouldAllowExternalUIPause())
        {
            SetTimer(0.1, true, 'CheckCanPauseFromExternalUINow');
            return;            
        }
        else
        {
            super(PlayerController).OnExternalUIChanged(bIsOpening);
        }        
    }
    else
    {
        ClearTimer('CheckCanPauseFromExternalUINow');
        // End:0xBD
        if((GFxUIManager == none) || !GFxUIManager.WantsPause())
        {
            super(PlayerController).OnExternalUIChanged(bIsOpening);
        }
    }
    //return;    
}

