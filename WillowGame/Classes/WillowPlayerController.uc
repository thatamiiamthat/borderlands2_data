                }
                else
                {
                    // End:0x130
                    if(ShouldEnterLobbySpectatorMode())
                    {
                        GotoState('PlayerLobby');                        
                    }
                    else
                    {
                        SetWaitingForAsyncCharacterLoadAndShowBusyDialog();
                        class'WillowGlobals'.static.GetWillowGlobals().GetPlayerPawnDataManager().LoadPlayerPawnDataAsync(class'GBXDefinition'.static.GetDefinition(class'PlayerClassDefinition', DefaultPlayerCharacterClassName).PawnArchetypePath, self, class'GBXDefinition'.static.GetDefinition(class'PlayerClassDefinition', DefaultPlayerCharacterClassName), self, 0, 0, 'RestartPlayerAfterLogin');
                    }
                }                
            }
            else
            {
                ClientPublishCachedSaveGameToPRI();
            }
        }
        //return;        
    }

    function bool CanRestartPlayer()
    {
        return false;
        //return ReturnValue;        
    }

    function RestartAfterLogin()
    {
        class'WillowGameInfo'.static.SetRestartPlayerAfterLogin(GetPlayerIndex(), false);
        UnknownLocal_1 = GetCachedSaveGame();
        // End:0x68
        if(UnknownLocal_1 != none)
        {
            UnknownLocal_3 = UnknownLocal_1.PlayerClassDefinition;            
        }
        else
        {
            UnknownLocal_3 = class'GBXDefinition'.static.GetDefinition(class'PlayerClassDefinition', DefaultPlayerCharacterClassName);
        }
        UnknownLocal_5 = class'WillowGlobals'.static.GetWillowGlobals().GetPlayerPawnDataManager().LoadPlayerPawnData(UnknownLocal_3.PawnArchetypePath, self);
        RunStreamingDataEvent('RestartPlayerAfterLogin', UnknownLocal_3, UnknownLocal_5);
        //return;        
    }
Begin:

    WaitForGRI();
    stop;        
}

