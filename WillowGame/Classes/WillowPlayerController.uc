    CalculateNextBadassRewardsToOffer();
    // End:0x11B
    if(IsLocalPlayerController())
    {
        UnknownLocal_1 = GetProfileSettings();
        UnknownLocal_1.SetProfileSettingValue(143, PackedBadassRewards);
