                {                    
                    Suffix @= friendIter.PresenceInfo;                    
                }
                else
                {                    
                    Suffix @= (Localize("FriendsListGfxMovie", "OnlinePlayingBorderlands", "WillowGame"));
                }
            }            
        }
        else
        {
            // End:0x2D6
            if(friendIter.bIsOnline)
            {
                // End:0x2D3
                if(!UnknownLocal_3)
                {
                    UnknownLocal_3 = true;                    
                    retstr $= "
";
                }                
            }
            else
            {
                // End:0x2FF
                if(!UnknownLocal_3)
                {
                    UnknownLocal_3 = true;                    
                    retstr $= "
";
                }
                // End:0x328
                if(!UnknownLocal_5)
                {
                    UnknownLocal_5 = true;                    
                    retstr $= "
";
                }
            }
        }        
        retstr $= ((friendIter.NickName @ Suffix) $ "
");        
    }    
    // End:0x394
    if(!UnknownLocal_3)
    {
        UnknownLocal_3 = true;        
        retstr $= "
";
    }
    // End:0x3BD
    if(!UnknownLocal_5)
    {
        UnknownLocal_5 = true;        
        retstr $= "
";
    }    
    retstr $= "
";
    UnknownLocal_1.UpdateFriendData(retstr);
    //return;    
}

event InviteFriendByIndex(int FriendIndex)
{
