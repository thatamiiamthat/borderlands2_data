class WillowSeqAct_ClientFlagSet extends SequenceAction
    forcescriptorder(true)
    hidecategories(Mobile,Object);

var(Action) name ClientFlagName;
var(Action) bool bEnableFlag;

event Activated()
{
    UnknownLocal_1 = WillowGameReplicationInfo(GetWorldInfo().GRI);
    // End:0x67
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_1.ClientFlagSet(ClientFlagName, bEnableFlag);
    }
    //return;    
}

defaultproperties
{
    bEnableFlag=true
    VariableLinks=none
    ObjName="Client Flag Set"
    ObjCategory="Willow Seq"
}