var(Action) const TemporalField TemporalField;
var(Action) const float LifeSpan;
var(LocationContext) const BehaviorContextData LocationContext;
var(LocationContext) const name AttachmentPointName;
var(LocationContext) const bool bAttachToContext;
var(LocationContext) const Vector RelativeLocation;
var(LocationContext) const Rotator RelativeRotation;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local ISpawnActor SpawnActorInterface;
    local IWorldBody WorldBodyInterface;
    local Vector SpawnLocation;

    // End:0x2D9
    if((ContextObject != none) && TemporalField != none)
    {
        SpawnActorInterface = ContextObject.QueryInterface(class'ISpawnActor');
        WorldBodyInterface = GetBehaviorContextInterface(class'IWorldBody', LocationContext, SelfObject, MyInstigatorObject, OtherEventParticipantObject, EventData);
        // End:0x2D9
        if(NotEqual_InterfaceInterface(SpawnActorInterface, ISpawnActor(none)) && NotEqual_InterfaceInterface(WorldBodyInterface, IWorldBody(none)))
        {
            // End:0x1DB
            if(bAttachToContext)
            {
                UnknownLocal_1 = SpawnActorInterface.SpawnForMap(TemporalField.Class, Actor(ContextObject),, WorldBodyInterface.GetWorldBodyLocation(), WorldBodyInterface.GetWorldBodyRotation(), TemporalField, true);
                // End:0x1D8
                if(UnknownLocal_1 != none)
                {
                    WorldBodyInterface.WorldBodyAttachActor(UnknownLocal_1, RelativeLocation, RelativeRotation, AttachmentPointName);
                }                
            }
            else
            {
                SpawnLocation = GetAttachmentLocation(WorldBodyInterface);
                UnknownLocal_1 = SpawnActorInterface.SpawnForMap(TemporalField.Class, Actor(ContextObject),, SpawnLocation, WorldBodyInterface.GetWorldBodyRotation() + RelativeRotation, TemporalField, true);
            }
            // End:0x2D9
            if(UnknownLocal_1 != none)
            {
                UnknownLocal_1.LifeSpan = LifeSpan * UnknownLocal_1.MyTickMultiplier;
            }
        }
    }
    //return;    
}

protected function Vector GetAttachmentLocation(IWorldBody WorldBodyInterface)
{
    local Vector AttachmentLocation;

    // End:0xDA
    if(NotEqual_InterfaceInterface(WorldBodyInterface, IWorldBody(none)))
    {
        // End:0x6F
        if(AttachmentPointName != 'None')
        {
            UnknownLocal_1 = WorldBodyInterface.GetWorldBodyAttachmentLocation(AttachmentPointName, AttachmentLocation);
        }
        // End:0xA3
        if(!UnknownLocal_1)
        {
            AttachmentLocation = WorldBodyInterface.GetWorldBodyLocation();
        }
        AttachmentLocation += (RelativeLocation >> WorldBodyInterface.GetWorldBodyRotation());
    }
    return AttachmentLocation;
    //return ReturnValue;    
}
