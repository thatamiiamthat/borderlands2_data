            class'WillowLeviathanService'.static.RecordItemFromInventoryEventForPlayer(GetOwningPlayerController(), 15, InventorySlot, UnknownLocal_1, 0);
            RemoveFromInventory(UnknownLocal_1);
            UnknownLocal_1.Destroy();
        }        
    }    
    ClientRemoveMissionWeapons(MissionWeapon);
    //return;    
}

