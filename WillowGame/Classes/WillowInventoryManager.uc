}

event RemoveMissionWeapons(MissionWeaponBalanceDefinition MissionWeapon)
{
    local array<WillowWeapon> WeaponList;
    local WillowLeviathanService.EInventorySlot InventorySlot;

    // End:0x18
    if(!int(Role) == int(ROLE_Authority))
    {
        return;
    }
    GetWeaponList(WeaponList, false, true);
    // End:0x11F
