simulated function IncPlayerRarityStat(int RarityLevel, WillowPlayerController WPC)
{
    local GlobalsDefinition.EItemRarity Rarity;

    UnknownLocal_1 = class'WillowGlobals'.static.GetWillowGlobals().GetGlobalsDefinition();
    Rarity = UnknownLocal_1.GetRarityForLevel(RarityLevel);
    switch(Rarity)
    {
        // End:0x84
        case 0:
            // End:0x22B
            break;
        // End:0xCA
        case 1:
            WPC.PlayerStats.IncrementIntStat('STAT_PLAYER_NUM_COMMON_ITEMS_FOUND');
            // End:0x22B
            break;
        // End:0x110
        case 2:
            WPC.PlayerStats.IncrementIntStat('STAT_PLAYER_NUM_UNCOMMON_ITEMS_FOUND');
            // End:0x22B
            break;
        // End:0x156
        case 3:
            WPC.PlayerStats.IncrementIntStat('STAT_PLAYER_NUM_RARE_ITEMS_FOUND');
            // End:0x22B
            break;
        // End:0x19C
        case 4:
            WPC.PlayerStats.IncrementIntStat('STAT_PLAYER_NUM_VERY_RARE_ITEMS_FOUND');
            // End:0x22B
            break;
        // End:0x1E2
        case 5:
            WPC.PlayerStats.IncrementIntStat('STAT_PLAYER_NUM_LEGENDARY_ITEMS_FOUND');
            // End:0x22B
            break;
        // End:0x228
        case 7:
            WPC.PlayerStats.IncrementIntStat('STAT_ANEMONE_PLAYER_NUM_RAINBOW_ITEMS_FOUND');
            // End:0x22B
            break;
        // End:0xFFFF
        default:
            break;
    }
    // End:0x27D
    if(int(Rarity) >= int(2))
    {
        WPC.PlayerStats.IncrementIntStat('STAT_PLAYER_NUM_UNCOMMON_OR_BETTER_ITEMS_FOUND');
    }
    //return;    
}

