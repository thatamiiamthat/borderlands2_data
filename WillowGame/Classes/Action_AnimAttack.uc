class Action_AnimAttack extends Action_GenericAttack
    native(AI)
    editinlinenew
    hidecategories(Mobile,Object,HideMe,ActionSequence,LoadBalance,Movement);

enum EAimType
{
    AimType_HoldStill,
    AimType_FollowTarget,
    AimType_AlignToTarget,
    AimType_MAX
};

var(Aim) const Action_AnimAttack.EAimType AimType;
var(Aim) const float VisionAngle;
var(Animation) const SpecialMoveDefinition AttackAnim;
var transient float Aim;
var transient bool bTargetHeld;
var transient bool bTempHardAttach;

event Init()
{
    super.Init();
    Aim = Cos(FClamp(VisionAngle, 0, 180) * 0.01745329);
    //return;    
}

event Start()
{
    CheckExpiredZone();
    super.Start();
    HoldTarget();
    //return;    
}

event Stop()
{
    super.Stop();
    ReleaseTarget();
    CheckExpiredZone();
    //return;    
}

event Update()
{
    super.Update();
    HoldTarget();
    //return;    
}

function name GetDesiredState()
{
    local name DesiredState;

    // End:0x40
    if(AI.GetAIComponent().MovementOnHold())
    {
        return GetStateName();        
    }
    else
    {
        // End:0x74
        if((ReachedAttackLoc()) || !CanMove())
        {
            DesiredState = 'RotateToTarget';            
        }
        else
        {
            DesiredState = 'MoveToTarget';
        }
    }
    return DesiredState;
    //return ReturnValue;    
}

function bool CanCheckExpiredZone()
{
    return false;
    //return ReturnValue;    
}

function bool OnlyExpireMyZone()
{
    return false;
    //return ReturnValue;    
}

function AttackFinished()
{
    Finish();
    //return;    
}

function HoldTarget()
{
    // End:0xB0
    if(!bTargetHeld && int(WillowAIComponent(AI.GetAIComponent()).GetThreatLevel(Target)) == int(3))
    {
        bTargetHeld = true;
        AI.GetAIComponent().HoldTarget('Attack', self);
    }
    //return;    
}

function ReleaseTarget()
{
    // End:0x59
    if(bTargetHeld)
    {
        bTargetHeld = false;
        AI.GetAIComponent().ReleaseTarget('Attack', self);
    }
    //return;    
}

function bool IsAimed()
{
    return (GetDotToTarget()) >= Aim;
    //return ReturnValue;    
}

state RotateToTarget
{
    ignores WantsPathFind, CheckStateTransition;
Begin:

    FinishPath();
    InvalidatePath();
    CheckForNewZone();
    MyWillowMind.StopMovement();
    // End:0x9C
    if(IsAimed())
    {
        CheckCloaked(2, !bBurrowAttack);
        Sleep(0);
        // End:0x8F
        if(IsAimed())
        {
            GotoState('Attack');            
        }
        else
        {
            goto 'Begin';
        }        
    }
    else
    {
        MyWillowMind.SetFacingPolicy(2, Target);
        Sleep(0);
        goto 'Begin';
    }
    stop;                
}

state Attack
{
    ignores CheckStateTransition;

    function BeginState(name PreviousStateName)
    {
        TriggerBehavior('Attack');
        StartAtomic();
        MyNavHandle.ClearPath();
        MyWillowMind.bWantsToFireWeapon = false;
        switch(AimType)
        {
            // End:0x15C
            case 2:
                // End:0xF6
                if(MyWillowPawn.CanUseAimOffsets())
                {
                    MyWillowPawn.InterpRotation(MyWillowPawn.AimOffset.GetCurrentAim(), 0.1);                    
                }
                else
                {
                    MyWillowPawn.InterpRotation(Rotator(Target.Location - MyWillowPawn.Location), 0.1);
                }
            // End:0x1B0
            case 0:
                MyWillowMind.SetFacingPolicy(1);
                WillowAI.HoldMovement('Attack', self);
                // End:0x20B
                break;
            // End:0x208
            case 1:
                // End:0x205
                if(!MyWillowPawn.bHardAttach)
                {
                    bTempHardAttach = true;
                    MyWillowPawn.SetHardAttach(true);
                }
                // End:0x20B
                break;
            // End:0xFFFF
            default:
                break;
        }
        //return;        
    }

    function EndState(name NextStateName)
    {
        StopAtomic();
        // End:0x61
        if(int(AimType) != int(1))
        {
            AI.GetAIComponent().ReleaseMovement('Attack', self);            
        }
        else
        {
            // End:0x9A
            if(bTempHardAttach)
            {
                bTempHardAttach = false;
                MyWillowPawn.SetHardAttach(false);
            }
        }
        //return;        
    }
Begin:

    MyWillowPawn.SMComponent.Play(AttackAnim,,, 'AttackFinished', self);
    J0x4A:

    // End:0x9C [Loop If]
    if(MyWillowPawn.SMComponent.IsPlaying(AttackAnim))
    {
        Sleep(0);
        // [Loop Continue]
        goto J0x4A;
    }
    Finish();
    stop;                    
}

defaultproperties
{
    VisionAngle=25
    Limits(0)=AttackLocation_Range'Default__Action_AnimAttack.RangeLimit'
    Limits(1)=AttackLocation_LineOfSight'Default__Action_AnimAttack.LOSLimit'
    CheckRate=0.1
    BehaviorOutputs=/* Array type was not detected. */
}