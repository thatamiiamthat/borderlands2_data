class UpsellGFxNotificationObject extends GFxObject within GFxMoviePlayer
    hidecategories(Mobile);

function UpdateFrameForAspectRatio(bool bWidescreen)
{
    // End:0x20
    if(bWidescreen)
    {
        GotoAndStop("16x9");        
    }
    else
    {
        GotoAndStop("4x3");
    }
    //return;    
}
