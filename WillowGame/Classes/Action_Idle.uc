class Action_Idle extends Action_Burrow
    editinlinenew
    hidecategories(Mobile,Object,HideMe,ActionSequence,LoadBalance,Movement);

enum EFollowType
{
    Follow_None,
    Follow_Parent,
    Follow_Target,
    Follow_Master,
    Follow_MAX
};

var(Idle) const AIRange IdleTime;
var(Idle) const Behavior_AICloak.ECloakOverride CloakBehavior;
var(Follow) const Action_Idle.EFollowType FollowType;
var(Idle) const bool bLookAtTarget;
var(Follow) const float DistMin;
var(Follow) const float DistMax;
var(Follow) const float CheckRate;

event name CanRun()
{
    local name SuperVal;

    SuperVal = super(ActionSequence).CanRun();
    // End:0x35
    if(SuperVal != 'None')
    {
        return SuperVal;
    }
    // End:0x79
    if((int(FollowType) == int(2)) && !WillowAI.HasTarget())
    {
        return 'NoTarget';
    }
    // End:0xBD
    if((int(FollowType) == int(1)) && MyWillowMind.SpawnParent == none)
    {
        return 'NoParent';
    }
    // End:0x101
    if((int(FollowType) == int(3)) && MyWillowPawn.PlayerMaster == none)
    {
        return 'NoMaster';
    }
    return 'None';
    //return ReturnValue;    
}

event Start()
{
    super.Start();
    GotoState('Idle');
    CheckStateTransition();
    SetPawnMovementSpeed(1);
    MyWillowPawn.SetTimer(CheckRate, true, 'CheckStateTransition', self);
    // End:0xA6
    if(RangeIsValid(IdleTime))
    {
        MyWillowPawn.SetTimer(GetRangeValue(IdleTime), false, 'IdleFinished', self);
    }
    //return;    
}

event Stop()
{
    super(WillowActionSequencePawn).Stop();
    MyWillowPawn.ClearTimer('IdleFinished', self);
    MyWillowPawn.ClearTimer('CheckStateTransition', self);
    //return;    
}

function IdleFinished()
{
    Finish();
    //return;    
}

function Actor GetGoalActor()
{
    switch(FollowType)
    {
        // End:0x1A
        case 0:
            return none;
        // End:0x3F
        case 2:
            return WillowAI.GetTarget();
        // End:0x78
        case 1:
            return MyWillowMind.SpawnParent.Pawn;
        // End:0xB1
        case 3:
            return MyWillowPawn.PlayerMaster.Pawn;
        // End:0xFFFF
        default:
            return none;
            break;
    }
    //return ReturnValue;    
}

function bool ShouldPathToTarget()
{
    UnknownLocal_1 = GetGoalActor();
    // End:0x1D
    if(UnknownLocal_1 == none)
    {
        return false;
    }
    UnknownLocal_3 = VSize(UnknownLocal_1.Location - MyWillowPawn.Location);
    // End:0x77
    if(UnknownLocal_3 > DistMax)
    {
        return true;        
    }
    else
    {
        // End:0x8F
        if(UnknownLocal_3 < DistMin)
        {
            return false;            
        }
        else
        {
            return PathIsValid();
        }
    }
    //return ReturnValue;    
}

function CheckStateTransition()
{
    local name DesiredStateName;

    // End:0x23
    if(ShouldPathToTarget())
    {
        DesiredStateName = 'MoveToTarget';        
    }
    else
    {
        DesiredStateName = 'Idle';
    }
    // End:0x55
    if(GetStateName() != DesiredStateName)
    {
        GotoState(DesiredStateName);
    }
    //return;    
}

state Idle
{Begin:

    InvalidatePath();
    MyNavHandle.ClearPath();
    // End:0x4C
    if(int(CloakBehavior) == int(1))
    {
        ForceCloak();        
    }
    else
    {
        // End:0x6A
        if(int(CloakBehavior) == int(2))
        {
            ForceUncloak();
        }
    }
    // End:0xDF
    if(bLookAtTarget && WillowAI.HasTarget())
    {
        MyWillowMind.SetFacingPolicy(2, WillowAI.GetTarget());        
    }
    else
    {
        MyWillowMind.SetFacingPolicy(1);
    }
    stop;        
}

state MoveToTarget
{
    event bool PathFind()
    {
        // End:0x11
        if(!ShouldPathToTarget())
        {
            return false;
        }
        // End:0x66
        if(PathIsValid())
        {
            UnknownLocal_1 = VSize((GetFinalDestination()) - GetGoalActor().Location);
            // End:0x66
            if(UnknownLocal_1 < DistMax)
            {
                return false;
            }
        }
        CreateActorPath(GetGoalActor());
        return true;
        //return ReturnValue;        
    }
Begin:

    CheckCloaked(1);
    // End:0x73
    if(WillowAI.HasTarget())
    {
        MyWillowMind.SetFacingPolicy(2, WillowAI.GetTarget());        
    }
    else
    {
        MyWillowMind.SetFacingPolicy(1);
    }
    J0x96:

    WaitForPath();
    FollowPath();
    InvalidatePath();
    MyNavHandle.ClearPath();
    Sleep(0);
    goto 'Loop';
    stop;        
}

defaultproperties
{
    DistMin=1024
    DistMax=2048
    CheckRate=1
}