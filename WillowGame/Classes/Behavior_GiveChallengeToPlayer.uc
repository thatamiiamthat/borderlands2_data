class Behavior_GiveChallengeToPlayer extends BehaviorBase
    native
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var const ChallengeDefinition Challenge;
var(Action) const array<ChallengeDefinition> Challenges;
var(Action) const bool bGiveToAllPlayers;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IChallengeRecipient ContextInterface;

    // End:0x9C
    if(bGiveToAllPlayers)
    {
        // End:0x98
        foreach Actor(ContextObject).LocalPlayerControllers(class'WillowPlayerController', UnknownLocal_1)
        {
            ContextInterface = UnknownLocal_1.QueryInterface(class'IChallengeRecipient');
            // End:0x97
            if(NotEqual_InterfaceInterface(ContextInterface, IChallengeRecipient(none)))
            {
                // End:0x98
                break;
            }            
        }                
    }
    else
    {
        ContextInterface = ContextObject.QueryInterface(class'IChallengeRecipient');
    }
    // End:0x133
    if(NotEqual_InterfaceInterface(ContextInterface, IChallengeRecipient(none)))
    {
        // End:0x132
        foreach Challenges(UnknownLocal_3,)
        {
            ContextInterface.ReceiveChallenge(UnknownLocal_3, false, bGiveToAllPlayers);            
        }        
    }
    //return;    
}
