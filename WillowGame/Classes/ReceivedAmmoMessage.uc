static function Color GetAmmoColor()
{
    UnknownLocal_1 = class'WillowGlobals'.static.GetWillowGlobals().GetGlobalsDefinition();
    return UnknownLocal_1.GetRarityColorForLevel(default.AmmoFakedRarityLevelForItemColor);
    //return ReturnValue;    
}

