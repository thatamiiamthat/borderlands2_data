static function ClientAmmoReceive(PlayerController P, optional int Switch, optional PlayerReplicationInfo RelatedPRI_1, optional PlayerReplicationInfo RelatedPRI_2, optional int GainedAmount)
{
    local string MessageString;

    MessageString
    GetAmmoString(Switch, RelatedPRI_1 == P.PlayerReplicationInfo, RelatedPRI_1, RelatedPRI_2, GainedAmount);
    // End:0x261
    if(MessageString != "")
    {
        P.DisplayHUDMessage(GetMsgType(Switch, RelatedPRI_1 == P.PlayerReplicationInfo, RelatedPRI_1, RelatedPRI_2, none), MessageString, GetLifeTime(Switch), GetColor(Switch, RelatedPRI_1, RelatedPRI_2, none), default.Class, Switch, RelatedPRI_1, none);
        // End:0x261
        if((((IsConsoleMessage(Switch)) && LocalPlayer(P.Player) != none) && LocalPlayer(P.Player).ViewportClient != none) && !class'WorldInfo'.static.IsConsoleBuild())
        {
            LocalPlayer(P.Player).ViewportClient.ViewportConsole.OutputText(MessageString);
        }
    }
    //return;    
}

static function string GetAmmoString(optional int Switch, optional bool bPRI1HUD, optional PlayerReplicationInfo RelatedPRI_1, optional PlayerReplicationInfo RelatedPRI_2, optional int GainedAmount)
{
    local string NumberOfRoundsString;

    NumberOfRoundsString
    GetNumberOfRoundsString(Switch, bPRI1HUD, RelatedPRI_1, RelatedPRI_2, GainedAmount);
    // End:0xD2
    if((RelatedPRI_1 != none) && GainedAmount > 0)
    {
        // End:0x91
        if(bPRI1HUD)
        {
            return Repl(default.SelfReceivedAmmo, "%s", NumberOfRoundsString);            
        }
        else
        {
            return Repl(Repl(default.ReceivedAmmo, "%s1", RelatedPRI_1.GetHumanReadableName()), "%s", NumberOfRoundsString);
        }
    }
    return "";
    //return ReturnValue;    
}

