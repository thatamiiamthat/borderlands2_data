    native
    config(Game)
    hidecategories(Mobile);

enum EAmmoMessageSwitch
{
    RECEIVEDAMMO_CombatRifle,
    RECEIVEDAMMO_SMG,
    RECEIVEDAMMO_Revolver,
    RECEIVEDAMMO_Repeater,
    RECEIVEDAMMO_Shotgun,
    RECEIVEDAMMO_SniperRifle,
    RECEIVEDAMMO_Rocket,
