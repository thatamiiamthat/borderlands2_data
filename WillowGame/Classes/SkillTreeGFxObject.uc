function SkillTreeGFxObject.ESkillTreeFailureReason CanUpgradeSkill()
{
    local SkillTreeGFxObject.ESkillTreeFailureReason retVal;
    local SkillTreeSkillStateData SkillState;

    UnknownLocal_1 = WillowPlayerReplicationInfo(WPCOwner.PlayerReplicationInfo);
    retVal = 3;
    UnknownLocal_3 = CurrentSkill;
    // End:0x190
    if(WPCOwner.PlayerSkillTree.GetSkillState(UnknownLocal_3, SkillState))
    {
        // End:0xE1
        if(!SkillState.bIsUnlocked || UnknownLocal_1.ExpLevel < 5)
        {
            retVal = 1;            
        }
        else
        {
            // End:0x12B
            if(SkillState.SkillGrade == UnknownLocal_3.MaxGrade)
            {
                retVal = 2;                
            }
            else
            {
                // End:0x149
                if(NumSkillPoints <= 0)
                {
                    retVal = 0;                    
                }
                else
                {
                    // End:0x190
                    if(SkillState.SkillGrade < UnknownLocal_3.MaxGrade)
                    {
                        retVal = 4;
                    }
                }
            }
        }
    }
    return retVal;
    //return ReturnValue;    
}

function RequestSkillUpgrade()
{
    local SkillTreeGFxObject.ESkillTreeFailureReason Result;

    Result = CanUpgradeSkill();
    switch(Result)
    {
        // End:0xB4
        case 4:
            ProgressionMaskSpeed = MovieDef.BranchProgressionMaskSpeed;
            WPCOwner.ServerUpgradeSkill(CurrentSkill);
            WPCOwner.PlayerSkillTree.UpdateBranchProgression(self);
            // End:0x18F
            break;
        // End:0xEA
        case 3:
            Movie.PlaySpecialUISound("ResultFailure");
            // End:0x18F
            break;
        // End:0x120
        case 0:
            Movie.PlaySpecialUISound("ResultFailure");
            // End:0x18F
            break;
        // End:0x156
        case 1:
            Movie.PlaySpecialUISound("ResultFailure");
            // End:0x18F
            break;
        // End:0x18C
        case 2:
            Movie.PlaySpecialUISound("ResultFailure");
            // End:0x18F
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

function HandleSkillGradeChange(SkillDefinition Skill, byte NewSkillPoints, byte Grade)
{
    HandleSkillPointsChange(int(NewSkillPoints));
    Flash_SendInitialSkillData();
    UpdateSkillIcon(CurrentSkill);
    UpdateInfoBox();
    CalculateBranchProgression();
    PlaySpendFlourish(Skill, int(Grade));
    // End:0xB9
    if(int(Skill.SkillType) == int(1))
    {
        Movie.PlayUISound('BuyActionAbility');        
    }
    else
    {
        switch(Grade)
        {
            // End:0xFC
            case 1:
                Movie.PlayUISound('BuyPoint1');
                // End:0x1BF
                break;
            // End:0x12C
            case 2:
                Movie.PlayUISound('BuyPoint2');
                // End:0x1BF
                break;
            // End:0x15C
            case 3:
                Movie.PlayUISound('BuyPoint3');
                // End:0x1BF
                break;
            // End:0x18C
            case 4:
                Movie.PlayUISound('BuyPoint4');
                // End:0x1BF
                break;
            // End:0x1BC
            case 5:
                Movie.PlayUISound('BuyPoint5');
                // End:0x1BF
                break;
            // End:0xFFFF
            default:
                break;
        }
    }
    //return;    
}

