        MovieDef = SkillDef;
        ProgressionMaskSpeed = MovieDef.BranchProgressionMaskSpeedEnterScreen;
        NumSkillPoints = UnknownLocal_1.GeneralSkillPoints;
        Init();
    }
    //return;    
}

