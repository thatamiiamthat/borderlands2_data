function HandleClose()
{
    ClearCellMap();
    WPCOwner.SavedSkillTreeSkill = CurrentSkill;
    WPCOwner.SavedBranchNavPref = BranchNavPref;
    WPCOwner.SavedCellNavPref = CellNavPref;
    WPCOwner.UnregisterSkillGradeChangedDelegate();
    WPCOwner.UnregisterSkillPointsChangedDelegate(HandleSkillPointsChange);
    WPCOwner.UnregisterSkillTreeResetDelegate();
    WPCOwner = none;
    //return;    
}

