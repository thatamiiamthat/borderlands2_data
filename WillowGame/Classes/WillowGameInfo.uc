function UpdateStartGameState()
{
    switch(StartGameState)
    {
        // End:0x27
        case 0:
            StartGameState = 1;
            // End:0xC6
            break;
        // End:0x73
        case 1:
            StartGameState = 2;
            // End:0x70
            if(GameReplicationInfo.PRIArray.Length > 1)
            {
                SetStartGameTimer(CharacterSelectTimeInSeconds);
            }
            // End:0xC6
            break;
        // End:0x91
        case 2:
            StartGameState = 3;
            BeginStartGame();
            // End:0xC6
            break;
        // End:0xAF
        case 3:
            StartGameState = 4;
            EndStartGame();
            // End:0xC6
            break;
        // End:0xC3
        case 4:
            StartGameState = 0;
            // End:0xC6
            break;
        // End:0xFFFF
        default:
            break;
    }
    UnknownLocal_1 = WillowGameReplicationInfo(GameReplicationInfo);
    // End:0x10D
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_1.StartGameState = StartGameState;
    }
    //return;    
}

