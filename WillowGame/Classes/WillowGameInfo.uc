function InitiateTravel(PlayerController InstigatingPlayer, optional name StationDefinitionName, optional Behavior_CheckMapChangeConditions Behavior, optional ICustomEvent EventInterface, optional TravelStationDefinition StationDefinition)
{
    !TravelCountdownInProcess();
    TravelBehavior = Behavior;
    TravelEventInterface = EventInterface;
    TravelStationDef = StationDefinition;
    TravelInstigator = WillowPlayerController(InstigatingPlayer);
    bDlcTravelFailureReceived = false;
    // End:0xDE
    if((StationDefinition != none) && StationDefinition.DlcExpansion != none)
    {
        bDlcTravelFailureReceived = !CanAllPlayersTravelToDlcDestination(StationDefinition.DlcExpansion);
    }
    UnknownLocal_1 = class'WillowGlobals'.static.GetWillowGlobals().GetFastTravelStationsLookup();
    // End:0x24D
    if(CheckMapChangeConditions(InstigatingPlayer))
    {
        // End:0x17D
        if((GetNumPlayers()) > 1)
        {
            TravelCountdownTime = MyGlobals.TravelDelay;
            SetTimer(1, false, 'TravelCountdown');            
        }
        else
        {
            TravelPostCountdownTime = 3;
            SetTimer(1, false, 'TravelPostCountdown');
            // End:0x1D6
            if(TravelBehavior != none)
            {
                Behavior.MapChangeEvent(TravelEventInterface);                
            }
            else
            {
                // End:0x1FC
                if(TravelStationDef != none)
                {
                    TravelToStation(TravelStationDef);                    
                }
                else
                {
                    TravelStationDef = UnknownLocal_1.FindFastTravelStationLookupObject(StationDefinitionName);
                    // End:0x24D
                    if(TravelStationDef != none)
                    {
                        TravelToStation(TravelStationDef);
                    }
                }
            }
        }
    }
    //return;    
}

function TravelCountdown()
{
    // End:0x1A8
    if(CheckMapChangeConditions())
    {
        -- TravelCountdownTime;
        // End:0xD0
        if(TravelCountdownTime > 0)
        {
            // End:0xB9
            foreach WorldInfo.AllControllers(class'WillowPlayerController', UnknownLocal_1)
            {
                UnknownLocal_1.ReceiveLocalizedMessage(class'LocalMapChangeMessage', 15 + TravelCountdownTime);
                UnknownLocal_1.PlaySpecialHUDSound("TravelCountdown");                
            }            
            SetTimer(1, false, 'TravelCountdown');            
        }
        else
        {
            // End:0x11E
            foreach WorldInfo.AllControllers(class'WillowPlayerController', UnknownLocal_1)
            {
                UnknownLocal_1.ClearHUDMessage(0);                
            }            
            // End:0x159
            if(TravelBehavior != none)
            {
                TravelBehavior.MapChangeEvent(TravelEventInterface);                
            }
            else
            {
                // End:0x17C
                if(TravelStationDef != none)
                {
                    TravelToStation(TravelStationDef);
                }
            }
            ClearTravelData();
            TravelPostCountdownTime = 3;
            SetTimer(1, false, 'TravelPostCountdown');
        }        
    }
    else
    {
        // End:0x1DF
        if(TravelBehavior != none)
        {
            TravelBehavior.PlayerBusyEvent(TravelEventInterface);
        }
        ClearTravelData();
    }
    //return;    
}

function TravelPostCountdown()
{
    -- TravelPostCountdownTime;
    // End:0x2D
