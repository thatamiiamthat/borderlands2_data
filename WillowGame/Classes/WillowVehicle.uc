reliable server function ServerAfterburnerOn()
{
    AfterburnerOn();
    AfterburnerEngaged = true;
    Mesh.AddImpulse(VehicleDef.AfterburnerImpulse, Location + (VehicleDef.AfterburnerImpulseOrigin >> Rotation));
    //return;    
}

simulated function AfterburnerOn()
{
    AfterburnerActivationTime = WorldInfo.TimeSeconds;
    AfterburnerTorqueBonus = VehicleDef.AfterburnerTorqueBonus;
    SetTimer(VehicleDef.AfterburnerCameraShakeRepeatTime, true, 'AfterburnerShakeTimer');
    VehicleEvent('Afterburner');
    UnwrapSimpleSettings();
    VehicleDesiredFOV = GetAfterburnerVehicleFOV();
    VehicleFOVState = 1;
    VehicleDef.OnAfterburnerEngaged(ConsumerHandle);
    //return;    
}

reliable server event ServerAfterburnerOff()
{
    AfterburnerOff();
    AfterburnerEngaged = false;
    //return;    
}

simulated function AfterburnerOff()
{
    VehicleEvent('NoAfterburner');
    KillAfterburnerEffects();
    VehicleDesiredFOV = GetDefaultVehicleFOV();
    VehicleFOVState = 2;
    UnwrapSimpleSettings();
    VehicleDef.OnAfterburnerDisengaged(ConsumerHandle);
    //return;    
}

