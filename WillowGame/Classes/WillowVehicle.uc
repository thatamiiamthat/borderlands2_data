    {
        UnknownLocal_1 = ReverseAngleDegrees * 0.5;
    }
    Rot.Yaw = int(UnknownLocal_1 * 182.0444);
    LeftVec = vect(-1, 0, 0) >> Rot;
    RightVec = vect(-1, 0, 0) << Rot;
    LeftVec = LeftVec >> Rotation;
    RightVec = RightVec >> Rotation;
    LocOffset = Location + (vect(5, 0, 0) >> Rotation);
    DrawDebugLine(LocOffset, LocOffset + (LeftVec * float(500)), 128, 255, 128, false);
    DrawDebugLine(LocOffset, LocOffset + (RightVec * float(500)), 128, 255, 128, false);
    LocOffset = Location - (vect(5, 0, 0) >> Rotation);
    DrawDebugLine(LocOffset, LocOffset + (LeftVec * float(500)), 255, 128, 128, false);
    DrawDebugLine(LocOffset, LocOffset + (RightVec * float(500)), 255, 128, 128, false);
    DrawDebugLine(Location, Location + (vecForward * float(500)), 128, 128, 255, false);
    //return;    
}

