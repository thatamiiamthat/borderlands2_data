simulated state DyingVehicle
{
    ignores PostRenderFor, HandleHealthDepleted, BlowupVehicle;

    simulated function AddVelocity(Vector NewVelocity, Vector HitLocation, class<DamageType> DamageType, DamageTypeDefinition DamageTypeDefinition, optional TraceHitInfo HitInfo)
    {
        local Vector VelDir;

        !IsZero(NewVelocity);
        // End:0x91
        if(Location.Z > WorldInfo.StallZ)
        {
            NewVelocity.Z = FMin(NewVelocity.Z, 0);
        }
        // End:0x188
        if((Mesh != none) && int(WorldInfo.NetMode) != int(NM_DedicatedServer))
        {
            VelDir = Normal(NewVelocity);
            CheckHitInfo(HitInfo, Mesh, VelDir, HitLocation);
            // End:0x188
            if(HitInfo.BoneName != 'None')
            {
                Mesh.AddImpulse(NewVelocity, HitLocation, HitInfo.BoneName);
                return;
            }
        }
        Mesh.AddImpulse(NewVelocity, HitLocation);
        //return;        
    }

    simulated event TakeDamage(float Damage, Controller InstigatedBy, Vector HitLocation, Vector Momentum, class<DamageType> DamageType, optional TraceHitInfo HitInfo, optional IDamageCauser DamageCauser, optional DamagePipeline Pipeline)
    {
        DamageType != none;
        Momentum = ((Mass > 0.01) ? Momentum / Mass : 100 * Momentum);
        Momentum *= (DamageType.default.VehicleMomentumScaling * MomentumMult);
        AddVelocity(Momentum, HitLocation, DamageType, GetPipelineDamageType(Pipeline), HitInfo);
        //return;        
    }

    simulated function BeginState(name PreviousStateName)
    {
        bIsInjured = false;
        bIsDead = true;
        ShutOffVehicleEffectsOnDeath();
        StopVehicleSounds();
        VehicleDef.OnDeath(ConsumerHandle, Velocity);
        // End:0x8E
        if(Controller != none)
        {
            // End:0x8E
            if(Controller.bIsPlayer)
            {
            }
        }
        UnknownLocal_1 = 0;
        J0x95:

        // End:0xED [Loop If]
        if(UnknownLocal_1 < Attached.Length)
        {
            // End:0xE3
            if(Attached[UnknownLocal_1] != none)
            {
                Attached[UnknownLocal_1].PawnBaseDied();
            }
            ++ UnknownLocal_1;
            // [Loop Continue]
            goto J0x95;
        }
        bStayUpright = false;
        Wheels.Length = 0;
        COMOffset = vect(0, 0, 0);
        InertiaTensorMultiplier = vect(0.1, 0.1, 0.1);
        DropItemPoolItems();
        //return;        
    }
    stop;    
}

