function Behavior_ChangeUsability(Engine.ITargetable.EChangeStatus ChangeType, ActorComponent UsedComponent, IUsable.EUsabilityType UsedType)
{
    // End:0x18
    if(!int(UsedType) == int(0))
    {
        return;
    }
    switch(ChangeType)
    {
        // End:0x3F
        case 1:
            bIsAvailableForUse = true;
            // End:0x75
            break;
        // End:0x53
        case 2:
            bIsAvailableForUse = false;
            // End:0x75
            break;
        // End:0x72
        case 0:
            bIsAvailableForUse = !bIsAvailableForUse;
            // End:0x75
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

function Behavior_ChangeUsabilityCost(Engine.ITargetable.EChangeStatus ChangeType, Engine.WillowInventoryDefinition.ECurrencyType CostType, int CostAmount, IUsable.EUsabilityType UsedType)
{
    // End:0x18
    if(!int(UsedType) == int(0))
    {
        return;
    }
    switch(ChangeType)
    {
        // End:0x4A
        case 0:
            bCostsToUse = !bCostsToUse;
            // End:0x75
            break;
        // End:0x5E
        case 1:
            bCostsToUse = true;
            // End:0x75
            break;
        // End:0x72
        case 2:
            bCostsToUse = false;
            // End:0x75
            break;
        // End:0xFFFF
        default:
            break;
    }
    // End:0xA8
    if(bCostsToUse)
    {
        CostsToUseType = CostType;
        CostsToUseAmount = CostAmount;
    }
    //return;    
}

