function Behavior_RegisterTargetable(bool bUnregister)
{
    local ITargetable SelfTargetable;

    SelfTargetable = QueryInterface(class'ITargetable');
    // End:0xF7
    if(NotEqual_InterfaceInterface(SelfTargetable, ITargetable(none)))
    {
        // End:0xA3
        if(!bUnregister)
        {
            class'GearboxEngineGlobals'.static.GetGearboxEngineGlobals().GetTargetableList().RegisterTargetable(SelfTargetable);            
        }
        else
        {
            class'GearboxEngineGlobals'.static.GetGearboxEngineGlobals().GetTargetableList().UnRegisterTargetable(SelfTargetable);
        }
    }
    //return;    
}

