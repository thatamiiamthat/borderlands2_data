event FreezeForCinematicMode()
{
    ClearTimer('SitAnimFinished');
    ClearTimer('UnsitAnimFinished');
    ClearTimer('ClientCheckForSitAnimFinished');
    bNoTeleportEffects = true;
    UnknownLocal_1 = 0;
    J0x4F:

    // End:0x2E6 [Loop If]
    if(UnknownLocal_1 < Seats.Length)
    {
        Seats[UnknownLocal_1].SeatLockTime = 0;
        Seats[UnknownLocal_1].bSwitchingSeats = false;
        Seats[UnknownLocal_1].bExiting = false;
        // End:0x2DC
        if(Seats[UnknownLocal_1].SeatPawn != none)
        {
            // End:0x216
            if(Seats[UnknownLocal_1].StoragePawn != none)
            {
                // End:0x1BE
                if(Seats[UnknownLocal_1].SeatPawn.IsAttachedRiderSeat())
                {
                    Seats[UnknownLocal_1].SeatPawn.DriverEnter(Seats[UnknownLocal_1].StoragePawn, true);                    
                }
                else
                {
                    WillowPawn(Seats[UnknownLocal_1].StoragePawn).SMComponent.StopAny(true, true);
                }
            }
            Seats[UnknownLocal_1].SeatPawn.ClearTimer('SitAnimFinished');
            Seats[UnknownLocal_1].SeatPawn.ClearTimer('ClientCheckForSitAnimFinished');
            Seats[UnknownLocal_1].SeatPawn.ClearTimer('UnsitAnimFinished');
        }
        ++ UnknownLocal_1;
        // [Loop Continue]
        goto J0x4F;
    }
    bNoTeleportEffects = false;
    RefreshCrewIdleAnimations();
    //return;    
}

