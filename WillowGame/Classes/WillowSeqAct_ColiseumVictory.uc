class WillowSeqAct_ColiseumVictory extends SequenceAction
    forcescriptorder(true)
    hidecategories(Mobile,Object);

event Activated()
{
    // End:0x6E
    foreach GetWorldInfo().AllControllers(class'WillowPlayerController', UnknownLocal_1)
    {
        // End:0x6D
        if(UnknownLocal_1.IsLocalPlayerController())
        {
            UnknownLocal_1.ShowColiseumVictoryScreen();
            // End:0x6E
            break;
        }        
    }    
    //return;    
}

defaultproperties
{
    VariableLinks=none
    ObjName="Show Round Survived Screen"
    ObjCategory="Coliseum"
}