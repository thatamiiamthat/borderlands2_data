class FixedMarker extends Trigger
    hidecategories(Mobile,Navigation,MovementReplication);

var() bool DisplayOnCompass;
var() Texture2D MarkerTexture;
var() Color MarkerColor;
var() float MarkerScale;

replication
{
    // Pos:0x000
     if(bNetDirty)
        DisplayOnCompass;
}

simulated function OnToggle(SeqAct_Toggle Action)
{
    // End:0x43
    if(Action.InputLinks[0].bHasImpulse)
    {
        DisplayOnCompass = true;
    }
    // End:0x86
    if(Action.InputLinks[1].bHasImpulse)
    {
        DisplayOnCompass = false;
    }
    // End:0xD5
    if(Action.InputLinks[2].bHasImpulse)
    {
        DisplayOnCompass = !DisplayOnCompass;
    }
    //return;    
}

defaultproperties
{
    DisplayOnCompass=true
    MarkerTexture=Texture2D'WillowHUD.Textures.Fixed_Marker_Flag'
    MarkerColor=(B=255,G=255,R=255,A=255)
    MarkerScale=1
    CylinderComponent=CylinderComponent'Default__FixedMarker.CollisionCylinder'
    begin object name=Sprite class=SpriteComponent
        Sprite=Texture2D'WillowHUD.Textures.Fixed_Marker_Flag'
    object end
    // Reference: SpriteComponent'Default__FixedMarker.Sprite'
    Components(0)=Sprite
    Components(1)=CylinderComponent'Default__FixedMarker.CollisionCylinder'
    DrawScale=0.25
    RemoteRole=ENetRole.ROLE_SimulatedProxy
    bAlwaysRelevant=true
    CollisionComponent=CylinderComponent'Default__FixedMarker.CollisionCylinder'
}