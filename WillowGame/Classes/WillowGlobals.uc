    //return;    
}

function WillowSpectatorPoint GetFirstSpectatorPoint()
{
    // End:0x1C
    if(SpectatorPointList.Length > 0)
    {
        return SpectatorPointList[0];
    }
    return none;
    //return ReturnValue;    
}

function WillowSpectatorPoint GetNextSpectatorPoint(WillowSpectatorPoint CurrentPoint)
{
    UnknownLocal_1 = CurrentPoint;
    // End:0x6D
    if(SpectatorPointList.Length > 1)
    {
        UnknownLocal_3 = SpectatorPointList.Find(CurrentPoint;
        // End:0x6D
        if(UnknownLocal_3 > -1)
        {
            UnknownLocal_1 = SpectatorPointList[__NFUN_253__(++ UnknownLocal_3, SpectatorPointList.Length)];
        }
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

function WillowSpectatorPoint GetPrevSpectatorPoint(WillowSpectatorPoint CurrentPoint)
{
    UnknownLocal_1 = CurrentPoint;
    // End:0x86
    if(SpectatorPointList.Length > 1)
    {
        UnknownLocal_3 = SpectatorPointList.Find(CurrentPoint;
        // End:0x86
        if(UnknownLocal_3 > -1)
        {
            UnknownLocal_1 = ((UnknownLocal_3 == 0) ? SpectatorPointList[SpectatorPointList.Length - 1] : SpectatorPointList[UnknownLocal_3 - 1]);
        }
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

