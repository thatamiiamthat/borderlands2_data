    autoexpandcategories(WillowInteractiveObject,MissionDirectives,Loot);

enum EElevButtonState
{
    BS_Enabled,
    BS_Disabled,
    BS_InUse,
    BS_MAX
};

var() WillowElevator.ElevatorButtonUsage Usage;
var WillowElevatorButton.EElevButtonState ButtonState;
var() int CallFloor;
var() bool bGlowing;
var() name BehaviorSetName_Enabled;
var() name BehaviorSetName_Disabled;
var() name BehaviorSetName_InUse;
var() name BehaviorSetName_EnabledButUseless;
var() name BehaviorSetName_Enabled_Glowing;
