class Behavior_ClearStatusEffects extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) bool bKillImmediately;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IStatusEffectTarget ContextInterface;

    ContextInterface = ContextObject.QueryInterface(class'IStatusEffectTarget');
    // End:0x7C
    if(NotEqual_InterfaceInterface(ContextInterface, IStatusEffectTarget(none)))
    {
        ContextInterface.Behavior_ClearStatusEffects(bKillImmediately);
    }
    //return;    
}
