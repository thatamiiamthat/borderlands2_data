simulated function EndExecuteEarlyDueToCollision()
{
    ClearTimer('ExecuteDashTimerUp');
    // End:0x44
    if(int(Role) == int(ROLE_Authority))
    {
        OnExecuteEndEarlyDueToCollision(ConsumerHandle, MyWillowPawn);
    }
    // End:0x5E
    if(ForceSwingOnWallCollision)
