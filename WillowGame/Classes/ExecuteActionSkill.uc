function TriggerExecuteAttack()
{
    local Vector Dir, TargetEpicenter;

    EndExecuteDash();
    Dir = Vector(MyController.Rotation);
    TargetEpicenter = MyWillowPawn.Location + (Dir * (InitiateMeleeDistance / float(2)));
    DrawGhettoDebugSphere(TargetEpicenter, Dir, InitiateMeleeDistance, 0, 0, 255);
    ClientPerformExecuteAttack();
    GotoState('ExecuteActionSkillExecuting');
    //return;    
}

