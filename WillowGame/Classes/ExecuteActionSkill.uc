simulated state ExecuteActionSkillActive
{
    simulated event BeginState(name PreviousStateName)
    {
        // End:0x51
        if(int(Role) == int(ROLE_Authority))
        {
            MyWillowPawn.bNotifyBeginWalking = true;
            OnExecuteBegin(ConsumerHandle, MyWillowPawn);
        }
        SetExecuteFlagInstanceData();
        MinHitWallOverride = MyWillowPawn.EvaluateAttributeInitialization(MinHitWallOverrideFormula);
        // End:0xB6
        if((CanHitExecuteTarget()) || IsPlayerLookingStraightDownWhileOnGround())
        {
            TriggerExecuteAttack();            
        }
        else
        {
            // End:0x110
            if(int(Role) == int(ROLE_Authority))
            {
                // End:0xF6
                if(MyWillowPawn.IsLocallyControlled())
                {
                    FirePawnCannon();
                }
                SetTimer(ExecuteDuration, false, 'ExecuteDashTimerUp');                
            }
            else
            {
                ServerFirePawnCannon();
            }
            UnknownLocal_1 = PlayExecuteBeginAnim();
            SetTimer(UnknownLocal_1, false, 'PlayExecuteIdleAnim');
            bFindMeleeTarget = true;
        }
        //return;        
    }

    simulated function bool IsPlayerLookingStraightDownWhileOnGround()
    {
        local Vector Dir, DirToGround;

        // End:0x2B
        if(int(MyWillowPawn.Physics) != int(1))
        {
            return false;
        }
        Dir = Vector(MyController.Rotation);
        DirToGround = vect(0, 0, -1);
        UnknownLocal_1 = Dir Dot DirToGround;
        // End:0x9E
        if(UnknownLocal_1 > CancelDashAngleCos)
        {
            return true;            
        }
        else
        {
            return false;
        }
        //return ReturnValue;        
    }

    simulated function float PlayExecuteBeginAnim()
    {
        AttachMeleeWeapon();
        UnknownLocal_1 = MyWillowPawn.GetSMComponent().Play(BeginExecuteSMD);
        return UnknownLocal_1;
        //return ReturnValue;        
    }

    simulated function PlayExecuteIdleAnim()
    {
        AttachMeleeWeapon();
        MyWillowPawn.GetSMComponent().Play(IdleExecuteSMD);
        //return;        
    }

    simulated event EndState(name NextStateName)
    {
        ClearTimer('PlayExecuteIdleAnim');
        // End:0x75
        if(NextStateName != 'ExecuteActionSkillExecuting')
        {
            MyWillowPawn.GetSMComponent().Stop(IdleExecuteSMD);
            CleanUpExecute();
        }
        //return;        
    }
    stop;    
}

simulated state ExecuteActionSkillExecuting
{
    simulated event BeginState(name PreviousStateName)
    {
        // End:0x30
        if(int(Role) == int(ROLE_Authority))
        {
            OnExecuteAttackBegin(ConsumerHandle, MyWillowPawn);
        }
        bAttemptedExecute = true;
        PlayMeleeAttackAnim();
        // End:0x71
        if(int(Role) == int(ROLE_Authority))
        {
            SetTimer(ExecuteAnimDelay, false, 'InitiateMeleeAttackDamage');
        }
        SetTimer(RestoreControlAfterMeleeSwingDelay, false, 'RestorePlayerMovementPostExecute');
        //return;        
    }

    function InitiateMeleeAttackDamage()
    {
        ExecuteMeleeDef.MeleeAttack(MyWillowPawn);
        // End:0xA6
        if(MyTarget != none)
        {
            // End:0x81
            if(MyTarget.IsAliveAndWell())
            {
                OnExecuteFailedToKillTarget(ConsumerHandle, MyWillowPawn, MyTarget);                
            }
            else
            {
                OnExecuteKilledTarget(ConsumerHandle, MyWillowPawn, MyTarget);
            }
        }
        //return;        
    }

    simulated function MeleeAttackComplete()
    {
        EndExecute();
        //return;        
    }

    simulated event EndState(name NextStateName)
    {
        CleanUpExecute();
        //return;        
    }
    stop;    
}

