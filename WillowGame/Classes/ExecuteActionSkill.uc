        EndExecuteDash();
        EndExecute();
        ClientEndExecute();
    }
    //return;    
}

simulated function CleanUpExecute()
{
    ClearTimer('TryExecuting');
    bFindMeleeTarget = false;
    bCleaningUpExecute = true;
    // End:0x5C
    if(int(Role) == int(ROLE_Authority))
    {
        OnExecuteEnd(ConsumerHandle, MyWillowPawn);
    }
    UnknownLocal_1 = WillowWeapon(MyWillowPawn.Weapon);
    // End:0xCC
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_1.ChangeFirstPersonVisibility(true);
        UnknownLocal_1.ChangeThirdPersonVisibility(true);
    }
    MyWillowPC.Behavior_DetachMeleeWeapon(true, true);
    bAttachedMeleeWeapon = false;
    // End:0x13B
    if(MyWillowPawn.IsLocallyControlled())
    {
        MyWillowPlayerPawn.StopFirstPersonAnimations();
    }
    MyWillowPC.WeaponActionComplete();
    RestorePhysicsPostExecute();
    MyWillowPawn.SMComponent.StopAny();
    // End:0x236
    if(MyWillowPlayerPawn != none)
    {
        // End:0x22C
        if(MyWillowPlayerPawn.IsLocallyControlled())
        {
            MyWillowPlayerPawn.bGrabWeaponPickup = false;
            MyWillowPawn.GetSMComponent().Stop(IdleExecuteSMD);
        }
        RestorePlayerMovementPostExecute();
    }
    RemoveExecuteFlagInstanceData();
    MyWillowPC.UpdateInputContext();
    bAttemptedExecute = false;
    bBlockDeactivate = false;
    //return;    
}

