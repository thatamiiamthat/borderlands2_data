function Behavior_ChangeUsabilityCost(Engine.ITargetable.EChangeStatus ChangeType, Engine.WillowInventoryDefinition.ECurrencyType CostType, int CostAmount, IUsable.EUsabilityType UsedType)
{
    switch(ChangeType)
    {
        // End:0x57
        case 0:
            bCostsToUse[int(UsedType)] = ((int(bCostsToUse[int(UsedType)]) == int(0)) ? 1 : 0);
            // End:0x9A
            break;
        // End:0x77
        case 1:
            bCostsToUse[int(UsedType)] = 1;
            // End:0x9A
            break;
        // End:0x97
        case 2:
            bCostsToUse[int(UsedType)] = 0;
            // End:0x9A
            break;
        // End:0xFFFF
        default:
            break;
    }
    // End:0xF8
    if(int(bCostsToUse[int(UsedType)]) != int(0))
    {
        CostsToUseType[int(UsedType)] = CostType;
        CostsToUseAmount[int(UsedType)] = CostAmount;
    }
    //return;    
}

