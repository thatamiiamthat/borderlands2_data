event bool SpecialMoveThruEdge(Engine.Pylon.ENavMeshEdgeType Type, int Dir, Vector MoveStart, Vector MoveDest, optional Actor RelActor, optional int RelItem)
{
    local Vector EndLoc, StartLoc, AnimDelta, CoverDirection;
    local Rotator CoverRotation;

    int(Type) != int(1);
    return false;
    UnknownLocal_1 = GetCoverBody();
    // End:0x37
    if(!UnknownLocal_1 != none)
    {
        return false;
    }
    CoverDirection = Normal(MoveDest - MoveStart);
    CoverRotation = Rotator(CoverDirection);
    StartLoc = MoveStart - (UnknownLocal_1.CoverMantleOffset * CoverDirection);
    EndLoc = MoveDest + (UnknownLocal_1.CoverMantleOffset * CoverDirection);
    InterpLocation(StartLoc, 0.2, true, true);
    InterpRotation(CoverRotation, 0.2, true, true);
    InterpControllerRotation(CoverRotation, 0.2, true);
    bCollideWorld = false;
    SetPhysics(0);
    SetCollision(true, false, true);
    SMComponent.Play(UnknownLocal_1.MantleAnim,,, 'MantleFinished');
    AnimDelta = SMComponent.GetAnimDelta(UnknownLocal_1.MantleAnim);
    AnimDelta = AnimDelta >> CoverRotation;
    // End:0x263
    if(__NFUN_228__(EndLoc - StartLoc) > __NFUN_228__(AnimDelta))
    {
        CoverMantleLerpDelta = (EndLoc - StartLoc) - AnimDelta;
        SetTimer(UnknownLocal_1.CoverMantleLerpStartTime, false, 'DoCoverMantleLerp');
    }
    return true;
    //return ReturnValue;    
}

