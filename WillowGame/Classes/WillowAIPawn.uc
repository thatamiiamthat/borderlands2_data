function HandleMomentum(Vector Momentum, Vector HitLocation, class<DamageType> DamageType, optional TraceHitInfo HitInfo)
{
    local Vector OldVelocity;
    local Rotator KnockbackRot;

    ((IsDead()) || bHardAttach) || AIClass.bIsTurret;
    return;
    // End:0x70
    if(SMComponent.IsPlayingClass(class'SpecialMove_Spawned'))
    {
        return;
    }
    // End:0x9D
    if(SMComponent.IsPlayingClass(class'SpecialMove_PhysicsJump'))
    {
        return;
    }
    // End:0xE3
    if(__NFUN_228__(Momentum) < BodyClass.GetKnockbackBody().MinKnockbackMomentum)
    {
        return;
    }
    // End:0x153
    if(((MyWillowMind != none) && MyWillowMind.WillowNav != none) && MyWillowMind.WillowNav.WantsToFly())
    {
        return;
    }
    super(Pawn).HandleMomentum(Momentum, HitLocation, DamageType, HitInfo);
    // End:0x2CF
    if(!bInKnockback)
    {
        // End:0x1C9
        if(MyWillowMind.AIComponent.OnHold())
        {
            return;
        }
        bInKnockback = true;
        OldVelocity = Velocity;
        MyWillowMind.AIComponent.Hold('Knockback', self);
        MyWillowMind.AIComponent.HoldMovement('Knockback', self);
        SMComponent.Play(BodyClass.GetKnockbackBody().KnockbackSMD);
        Velocity = OldVelocity;
    }
    // End:0x2DE
    if(IsDead())
    {
        return;
    }
    KnockbackRot = Rotator(Momentum);
    KnockbackRot.Yaw += 32768;
    InterpRotation(KnockbackRot, 10, false);
    // End:0x349
    if(int(Physics) != int(2))
    {
        SetPhysics(2);
    }
    //return;    
}

function StopKnockback()
{
    // End:0x157
    if(bInKnockback)
    {
        bInKnockback = false;
        SMComponent.Stop(BodyClass.GetKnockbackBody().KnockbackSMD);
        SMComponent.Play(BodyClass.GetKnockbackBody().KnockbackLandSMD,,, 'FinishKnockback');
        // End:0x130
        if(!SMComponent.IsPlaying(BodyClass.GetKnockbackBody().KnockbackLandSMD))
        {
            FinishKnockback();
        }
        // End:0x157
        if(MyWillowMind.IsFlying())
        {
            SetPhysics(4);
        }
    }
    //return;    
}

function FinishKnockback()
{
    MyWillowMind.AIComponent.Release('Knockback', self);
    MyWillowMind.AIComponent.ReleaseMovement('Knockback', self);
    //return;    
}

