event MAT_BeginAIGroup(Vector StartLoc, Rotator StartRot, Engine.InterpGroupAI.InterpGroupAlignmentTypes AlignmentType, float LerpTime, bool bDemiGod)
{
    bUnderMatineeControl = true;
    switch(AlignmentType)
    {
        // End:0x3F
        case 1:
            SetLocation(StartLoc);
            SetRotation(StartRot);
            // End:0x86
            break;
        // End:0x83
        case 2:
            InterpLocation(StartLoc, LerpTime, true, false);
            InterpRotation(StartRot, LerpTime, true, false);
            // End:0x86
            break;
        // End:0xFFFF
        default:
            break;
    }
    HoldAIForMatinee(bDemiGod);
    // End:0x16F
    if((MyWillowMind != none) && MyWillowMind.WillowNav != none)
    {
        MyWillowMind.WillowNav.FixMode = 0;
        MyWillowMind.WillowNav.ClearAnchor();
        MyWillowMind.WillowNav.ClearPath();
    }
    //return;    
}

event MAT_FinishAIGroup()
{
    // End:0x17
    if(bUnderMatineeControl)
    {
        ReleaseAIFromMatinee();
    }
    bUnderMatineeControl = false;
    RotationRate = AIClass.RotationRate;
    //return;    
}

