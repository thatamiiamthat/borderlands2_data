simulated function RegisterExtraDeathImpulse(Vector Impulse, Vector Offset, name BoneName, bool VelocityRatherThanForce, bool TransformImpulseByVelocityDirection)
{
    RagdollDeathExtraImpulses.Length = RagdollDeathExtraImpulses.Length + 1;
    RagdollDeathExtraImpulses[RagdollDeathExtraImpulses.Length - 1].Impulse = Impulse;
    RagdollDeathExtraImpulses[RagdollDeathExtraImpulses.Length - 1].Offset = Offset;
    RagdollDeathExtraImpulses[RagdollDeathExtraImpulses.Length - 1].BoneName = BoneName;
    RagdollDeathExtraImpulses[RagdollDeathExtraImpulses.Length - 1].VelocityRatherThanForce = VelocityRatherThanForce;
    RagdollDeathExtraImpulses[RagdollDeathExtraImpulses.Length - 1].TransformImpulseByVelocityDirection = TransformImpulseByVelocityDirection;
    //return;    
}

simulated function ApplyExtraRagdollDeathImpulsesAndStatusEffect()
{
    local Vector ImpulseDir;
    local RagdollDeathImpulseStruct OneImpulse;
    local editinline StatusEffectsComponent StatusComponent;

    // End:0x59
    if(RagdollDeathExtraStatusEffect != none)
    {
        StatusComponent = GetStatusEffectsComponent();
        StatusComponent.ApplyStatusEffect(none, class'WillowDmgSource_StatusEffect', RagdollDeathExtraStatusEffect);
    }
    UnknownLocal_1 = 0;
    J0x60:

    // End:0x1D4 [Loop If]
    if(UnknownLocal_1 < RagdollDeathExtraImpulses.Length)
    {
        OneImpulse = RagdollDeathExtraImpulses[UnknownLocal_1];
        // End:0xFA
        if(OneImpulse.TransformImpulseByVelocityDirection)
        {
            ImpulseDir = Velocity;
            ImpulseDir.Z = 0;
            ImpulseDir = Normal(ImpulseDir);            
        }
        else
        {
            ImpulseDir = Normal(OneImpulse.Impulse);
        }
        Mesh.AddImpulse(VSize(OneImpulse.Impulse) * ImpulseDir, Location + OneImpulse.Offset, OneImpulse.BoneName, OneImpulse.VelocityRatherThanForce);
        ++ UnknownLocal_1;
        // [Loop Continue]
        goto J0x60;
    }
    RagdollDeathExtraImpulses.Length = 0;
    //return;    
}

state Staggered
{
    simulated function PlayStagger()
    {
        // End:0xAF
        if(StaggerState.bIsStaggered)
        {
            switch(StaggerState.State)
            {
                // End:0x4B
                case 2:
                // End:0xA9
                case 3:
                    ++ StaggerState.RestaggeredCount;
                    SetupRagdollPhysics();
                    // End:0xA6
                    if(StaggerRecoveryBlend != none)
                    {
                        StaggerRecoveryBlend.StopStaggerAnimation();
                    }
                    // End:0xAC
                    break;
                // End:0xFFFF
                default:
                    break;
            }            
        }
        else
        {
            // End:0x11A
            if(StaggerState.bForced)
            {
                // End:0xFD
                if(StaggerRecoveryBlend != none)
                {
                    StaggerRecoveryBlend.StopStaggerAnimation();
                }
                SetPhysics(2);
                RestorePreRagDollPhysics();
                GotoState('Auto');
            }
        }
        //return;        
    }

    simulated function BeginState(name PreviousState)
    {
        DropCombatPerch();
        // End:0xD7
        if(int(Role) == int(ROLE_Authority))
        {
            UnknownLocal_1 = WillowMind(Controller);
            // End:0xD7
            if((UnknownLocal_1 != none) && UnknownLocal_1.AIComponent != none)
            {
                UnknownLocal_1.AIComponent.Hold('Staggered', self);
                UnknownLocal_1.AIComponent.HoldMovement('Staggered', self);
            }
        }
        HoldLeftHandIK('Staggering', self);
        //return;        
    }

    simulated function PlayStaggerRecoveryAnim()
    {
        RestorePreRagDollPhysics();
        // End:0x5F
        if((StaggerRecoveryBlend != none) && StaggerRecoveryBlend.PlayStaggerAnimation())
        {
            StaggerState.State = 3;            
        }
        else
        {
            GotoState('Auto');
        }
        //return;        
    }

    simulated function Tick(float DeltaTime)
    {
        UnknownLocal_1 = GetStaggerSettings();
        switch(StaggerState.State)
        {
            // End:0x2A0
            case 0:
                // End:0x25E
                if(int(Role) == int(ROLE_Authority))
                {
                    // End:0x196
                    if(VSize(Velocity) <= UnknownLocal_1.StaggeredRestVelocity)
                    {
                        // End:0x135
                        if(StaggerState.StaggerEndRagdollTime < 0)
                        {
                            StaggerState.StaggerEndRagdollTime = WorldInfo.TimeSeconds + ((FRand() * (UnknownLocal_1.StaggeredRestTimeMax - UnknownLocal_1.StaggeredRestTimeMin)) + UnknownLocal_1.StaggeredRestTimeMin);                            
                        }
                        else
                        {
                            // End:0x193
                            if(WorldInfo.TimeSeconds >= StaggerState.StaggerEndRagdollTime)
                            {
                                StaggerState.State = 1;
                            }
                        }                        
                    }
                    else
                    {
                        // End:0x239
                        if((UnknownLocal_1.StaggeredRestGiveUpTime > 0) && (WorldInfo.TimeSeconds - StaggerState.StaggerStartTime) > UnknownLocal_1.StaggeredRestGiveUpTime)
                        {
                            StaggerState.State = 1;                            
                        }
                        else
                        {
                            StaggerState.StaggerEndRagdollTime = -1;
                        }
                    }                    
                }
                else
                {
                    // End:0x29D
                    if(StaggerState.bIsUnstaggering)
                    {
                        StaggerState.State = 1;
                    }
                }
                // End:0x4AD
                break;
            // End:0x3FF
            case 1:
                // End:0x3FC
                if((StaggerState.NextUnstaggerCheckTime < 0) || WorldInfo.TimeSeconds >= StaggerState.NextUnstaggerCheckTime)
                {
                    TryUnstagger();
                    // End:0x3FC
                    if(((int(Role) == int(ROLE_Authority)) && int(StaggerState.State) == int(1)) && UnknownLocal_1.UnstaggerGiveUpTime > 0)
                    {
                        // End:0x3FC
                        if((WorldInfo.TimeSeconds - StaggerState.StaggerRecoveryStartTime) > UnknownLocal_1.UnstaggerGiveUpTime)
                        {
                            Behavior_Killed(StaggerState.StaggerInstigator);
                        }
                    }
                }
                // End:0x4AD
                break;
            // End:0x4A2
            case 2:
                Mesh.PhysicsWeight -= (DeltaTime * UnknownLocal_1.StaggeredPhysicsBlendOutSpeed);
                // End:0x49F
                if(Mesh.PhysicsWeight <= 0)
                {
                    Mesh.PhysicsWeight = 0;
                    PlayStaggerRecoveryAnim();
                }
                // End:0x4AD
                break;
            // End:0x4AA
            case 3:
                // End:0x4AD
                break;
            // End:0xFFFF
            default:
                break;
        }
        //return;        
    }

    simulated function TryUnstagger()
    {
        local Rotator NewRotation;
        local Vector HitLocation, HitNormal, TraceEnd, TraceStart, StaggerLocation;

        UnknownLocal_1 = GetStaggerSettings();
        // End:0x43
        if(int(Role) == int(ROLE_Authority))
        {
            StaggerState.bIsUnstaggering = true;
        }
        CollisionComponent = StaggerState.PreviousCollisionComponent;
        StaggerLocation = Location;
        TraceStart = Location + (vect(0, 0, -1) * CollisionComponent.Bounds.BoxExtent.Z);
        TraceEnd = Location + (vect(0, 0, 1) * (GetCollisionHeight()));
        UnknownLocal_3 = Trace(HitLocation, HitNormal, TraceEnd, TraceStart, true, GetCollisionExtent());
        // End:0x16C
        if(UnknownLocal_3 == none)
        {
            HitLocation = TraceEnd;
        }
        // End:0x528
        if(SetStaggerEndLocation(UnknownLocal_3, HitLocation, StaggerLocation))
        {
            UnknownLocal_5 = Location.Z - StaggerLocation.Z;
            // End:0x1F6
            if(UnknownLocal_5 > 0)
            {
                MoveSmooth(vect(0, 0, -1) * UnknownLocal_5);
            }
            CylinderComponent.SetActorCollision(true, true);
            SetSecondaryCollisionEnabled(true);
            TraceStart = Location + (vect(0, 0, -1) * CollisionComponent.Bounds.BoxExtent.Z);
            TraceEnd = TraceStart + ((vect(0, 0, -1) * (GetCollisionHeight())) * float(2));
            UnknownLocal_3 = Trace(HitLocation, HitNormal, TraceEnd, TraceStart, true);
            // End:0x34F
            if(UnknownLocal_3 != none)
            {
                MoveSmooth(vect(0, 0, -1) * ((TraceStart.Z - HitLocation.Z) - float(5)));
            }
            StaggerState.State = 2;
            StaggerState.StaggerRecoveryStartTime = WorldInfo.TimeSeconds;
            // End:0x3C9
            if(int(Role) == int(ROLE_Authority))
            {
                bReplicateMovement = true;
            }
            SetPhysics(0);
            Mesh.SetComponentRBFixed(true);
            // End:0x50D
            if(StaggerRecoveryBlend != none)
            {
                Mesh.PhysicsWeight = 1;
                NewRotation = Rotation;
                NewRotation.Yaw = Rotator(Mesh.GetBoneAxis(UnknownLocal_1.StaggeredRecoveryRotation.BoneName, UnknownLocal_1.StaggeredRecoveryRotation.BoneAxis)).Yaw;
                SetRotation(NewRotation);
                StaggerRecoveryBlend.StartStaggerBlend();                
            }
            else
            {
                RestorePreRagDollPhysics();
                GotoState('Auto');
            }            
        }
        else
        {
            CollisionComponent = Mesh;
            SetLocation(StaggerLocation);
            StaggerState.NextUnstaggerCheckTime = WorldInfo.TimeSeconds + 1;
        }
        //return;        
    }

    simulated function bool SetStaggerEndLocation(Actor HitActor, Vector HitLocation, Vector StaggerLocation)
    {
        local Vector HitPawnToSelf, SourceLocation, HitPawnToSelfNormal;

        UnknownLocal_1 = Pawn(HitActor);
        // End:0x26A
        if(UnknownLocal_1 != none)
        {
            HitPawnToSelf = Location - UnknownLocal_1.Location;
            HitPawnToSelf.Z = 0;
            HitPawnToSelf = Normal(HitPawnToSelf);
            HitPawnToSelfNormal = HitPawnToSelf Cross vect(0, 0, 1);
            // End:0x124
            if(Vehicle(UnknownLocal_1) != none)
            {
                UnknownLocal_3 = Vehicle(UnknownLocal_1).ExitRadius;
                // End:0x121
                if(UnknownLocal_3 == float(0))
                {
                    UnknownLocal_3 = UnknownLocal_1.GetCollisionRadius() + VehicleCheckRadius;
                }                
            }
            else
            {
                UnknownLocal_3 = UnknownLocal_1.GetCollisionRadius();
            }
            UnknownLocal_3 += (GetCollisionRadius());
            SourceLocation = UnknownLocal_1.Location;
            SourceLocation.Z = StaggerLocation.Z + (GetCollisionHeight());
            // End:0x267
            if((((TryStandupLocation(SourceLocation + (HitPawnToSelf * UnknownLocal_3))) || TryStandupLocation(SourceLocation - (HitPawnToSelf * UnknownLocal_3))) || TryStandupLocation(SourceLocation + (HitPawnToSelfNormal * UnknownLocal_3))) || TryStandupLocation(SourceLocation - (HitPawnToSelfNormal * UnknownLocal_3)))
            {
                return true;
            }            
        }
        else
        {
            // End:0x282
            if(TryStandupLocation(StaggerLocation))
            {
                return true;
            }
        }
        return false;
        //return ReturnValue;        
    }

    simulated function bool TryStandupLocation(Vector StandupLocation)
    {
        return SetLocation(StandupLocation) && CheckValidLocation(StandupLocation);
        //return ReturnValue;        
    }

    simulated function bool CheckValidLocation(Vector StaggerLocation)
    {
        local Vector HitLocation, HitNormal, DestFinalZ;

        // End:0x41
        if(Trace(HitLocation, HitNormal, Location, StaggerLocation, false, vect(10, 10, 10),, 1) == none)
        {
            return true;
        }
        DestFinalZ = StaggerLocation;
        StaggerLocation.Z = Location.Z;
        // End:0x10F
        if((Trace(HitLocation, HitNormal, DestFinalZ, StaggerLocation, false, vect(10, 10, 10)) == none) && Trace(HitLocation, HitNormal, Location, DestFinalZ, false, vect(10, 10, 10),, 1) == none)
        {
            return true;
        }
        return false;
        //return ReturnValue;        
    }

    simulated event OnAnimEnd(AnimNodeSequence SeqNode, float PlayedTime, float ExcessTime)
    {
        // End:0x63
        if(int(StaggerState.State) == int(3))
        {
            // End:0x55
            if(StaggerRecoveryBlend != none)
            {
                StaggerRecoveryBlend.EndStaggerBlend();
            }
            GotoState('Auto');
        }
        //return;        
    }

    simulated function RestorePreRagDollPhysics()
    {
        Mesh.SetBlockRigidBody(false);
        Mesh.PhysicsWeight = 0;
        Mesh.PutRigidBodyToSleep();
        Mesh.bUpdateKinematicBonesFromAnimation = true;
        Mesh.SetRBChannel(StaggerState.PreviousCollisionChannel);
        Mesh.SetRBCollidesWithChannel(0, false);
        Mesh.SetRBCollidesWithChannel(2, false);
        Mesh.SetRBCollidesWithChannel(3, false);
        Mesh.SetPhysMaterialOverride(StaggerState.PreviousOverridePhysicalMaterial);
        CollisionComponent = StaggerState.PreviousCollisionComponent;
        CylinderComponent.SetActorCollision(true, true);
        Mesh.SetTickGroup(0);
        //return;        
    }

    simulated function EndState(name NextState)
    {
        // End:0x19
        if(int(Physics) != int(10))
        {
            SetPhysics(2);
        }
        // End:0x111
        if(int(Role) == int(ROLE_Authority))
        {
            StaggerState.bIsStaggered = false;
            bReplicateMovement = true;
            UnknownLocal_1 = WillowMind(Controller);
            // End:0x111
            if((UnknownLocal_1 != none) && UnknownLocal_1.AIComponent != none)
            {
                UnknownLocal_1.AIComponent.Release('Staggered', self);
                UnknownLocal_1.AIComponent.ReleaseMovement('Staggered', self);
            }
        }
        ReleaseLeftHandIK('Staggering', self);
        StaggerState.StaggerEndTime = WorldInfo.TimeSeconds;
        //return;        
    }
    stop;    
}
