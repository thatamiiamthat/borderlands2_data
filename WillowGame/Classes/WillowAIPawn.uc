            class'BehaviorKernel'.static.BroadcastBehaviorEventFromScript(ConsumerHandle, BodyClass.TauntCustomEvent);            
        }
        else
        {
            DialogComponent.TriggerEvent(class'WillowDialogGlobalsDefinition'.static.Get().DET_Taunt, MyWillowMind.GetAIComponent().GetTarget());
        }
        UnknownLocal_1 = (FRand() * (BodyClass.SubsequentTauntWait.MaxVal - BodyClass.SubsequentTauntWait.MinVal)) + BodyClass.SubsequentTauntWait.MinVal;
        SetTimer(UnknownLocal_1, false, 'PlayTaunt');
    }
    //return;    
}

