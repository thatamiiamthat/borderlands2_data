function Behavior_ChangeUsability(Engine.ITargetable.EChangeStatus ChangeType, ActorComponent UsedComponent, IUsable.EUsabilityType UsedType)
{
    switch(ChangeType)
    {
        // End:0x5B
        case 0:
            SetUsable(((int(bUsable[int(UsedType)]) == int(0)) ? true : false), UsedComponent, UsedType);
            // End:0xA8
            break;
        // End:0x80
        case 1:
            SetUsable(true, UsedComponent, UsedType);
            // End:0xA8
            break;
        // End:0xA5
        case 2:
            SetUsable(false, UsedComponent, UsedType);
            // End:0xA8
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

