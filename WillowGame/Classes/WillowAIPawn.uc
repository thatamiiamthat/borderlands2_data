function bool UseObject(Pawn User, PrimitiveComponent UsedComponent, IUsable.EUsabilityType UsedType)
{
    local editinline ActorComponent ActualUsedComponent;

    // End:0x32
    if(IsComponentUsable(UsedComponent, UsedType))
    {
        ActualUsedComponent = UsedComponent;
    }
    UnknownLocal_1 = WillowPlayerController(User.Controller);
    // End:0x6E
    if(!UnknownLocal_1 != none)
    {
        return false;
    }
    // End:0xED
    if((((UnknownLocal_1 == none) || MyWillowMind == none) || MyWillowMind.AIClass == none) || MyWillowMind.AIClass.AIDef == none)
    {
        return false;
    }
    FireOnUsedBehaviors(2, User, ActualUsedComponent, UsedType);
    // End:0x318
    if(int(UsedType) == int(0))
    {
        CountMyMissionsByState(UnknownLocal_1, UnknownLocal_3, UnknownLocal_5, UnknownLocal_7);
        // End:0x1EF
        if(((UnknownLocal_3 + UnknownLocal_5) + UnknownLocal_7) > 0)
        {
            class'BehaviorBase'.static.RunBehaviors(MyWillowMind.AIClass.OnUsedBehaviors, self, User, MyWillowMind);
            FireOnUsedBehaviors(0, User, ActualUsedComponent, UsedType);            
        }
        else
        {
            class'BehaviorBase'.static.RunBehaviors(MyWillowMind.AIClass.OnUsedBehaviors_NoMission, self, User, MyWillowMind);
            FireOnUsedBehaviors(1, User, ActualUsedComponent, UsedType);
        }
        MyWillowMind.LastUsedTime = WorldInfo.TimeSeconds;
        // End:0x318
        if(AIClass.bWatchPlayerWhenUsed)
        {
            MyWillowMind.AIComponent.ActivateEvent('Scripted');
        }
    }
    return true;
    //return ReturnValue;    
}

function FireOnUsedBehaviors(GearboxFramework.AIDefinition.ENPCOnUsedOutputs OnUsedOutput, Pawn User, ActorComponent UsedComponent, IUsable.EUsabilityType UsedType)
{
    switch(UsedType)
    {
        // End:0xE0
        case 0:
            MyWillowMind.AIClass.OnUsed(ConsumerHandle, OnUsedOutput, User, UsedComponent);
            MyWillowMind.AIClass.AIDef.OnUsed(ConsumerHandle, OnUsedOutput, User, UsedComponent);
            // End:0x1B0
            break;
        // End:0x1AD
        case 1:
            MyWillowMind.AIClass.OnSecondaryUsed(ConsumerHandle, OnUsedOutput, User, UsedComponent);
            MyWillowMind.AIClass.AIDef.OnSecondaryUsed(ConsumerHandle, OnUsedOutput, User, UsedComponent);
            // End:0x1B0
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

