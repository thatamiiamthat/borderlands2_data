function BeginUse(Pawn User)
{
    // End:0x13
    if(!User != none)
    {
        return;
    }
    MyWillowMind.AIComponent.ActivateEvent('Used');
    PawnsUsingMe[PawnsUsingMe.Length] = User;
    // End:0x88
    if(PawnsUsingMe.Length == 1)
    {
        OnNewPrimaryUser();
    }
    //return;    
}

function EndUse(Pawn User)
{
    // End:0x13
    if(!User != none)
    {
        return;
    }
    // End:0xDB
    if((PawnsUsingMe.Length > 0) && PawnsUsingMe[0] == User)
    {
        class'BehaviorBase'.static.RunBehaviors(MyWillowMind.AIClass.OnDismissedBehaviors, self, MyWillowMind, User);
        PlayDismissalDialog(User);
        ClearMissionsAcceptedByPrimaryUser();
        // End:0xDB
        if(PawnsUsingMe.Length > 1)
        {
            OnNewPrimaryUser();
        }
    }
    PawnsUsingMe.RemoveItem(User;
    //return;    
}

