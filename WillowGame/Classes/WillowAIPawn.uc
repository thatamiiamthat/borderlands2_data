simulated event Stagger(optional Pawn StaggerInstigator)
{
    !bTearOff && CanBeStaggered();
    StaggerState.bIsStaggered = true;
    StaggerState.bForced = false;
    StaggerState.StaggerInstigator = StaggerInstigator;
    StaggerState.RestaggeredCount = 0;
    PlayStagger();
    //return;    
}

function UnStagger()
{
    // End:0x7E
    if((int(Role) == int(ROLE_Authority)) && StaggerState.bIsStaggered)
    {
        StaggerState.bIsStaggered = false;
        StaggerState.bForced = true;
        PlayStagger();
    }
    //return;    
}

simulated event PlayStagger()
{
    // End:0x51
    if(StaggerState.bIsStaggered)
    {
        GotoState('Staggered');
        // End:0x47
        if(int(Physics) == int(10))
        {
            SetPhysics(2);
        }
        SetupRagdollPhysics();
    }
    //return;    
}

simulated function StaggerDefinition GetStaggerSettings()
{
    return ((BodyClass != none) ? BodyClass.StaggerSettings : none);
    //return ReturnValue;    
}

simulated function SetupRagdollPhysics()
{
    // End:0x41
    if(int(Role) == int(ROLE_Authority))
    {
        bReplicateMovement = false;
        SMComponent.StopAny(true, true);
    }
    Mesh.MinDistFactorForKinematicUpdate = 0;
    // End:0x114
    if((BodyClass != none) && GetStaggerSettings().StaggeredPhysicalMaterial != none)
    {
        StaggerState.PreviousOverridePhysicalMaterial = Mesh.PhysMaterialOverride;
        Mesh.SetPhysMaterialOverride(GetStaggerSettings().StaggeredPhysicalMaterial);
    }
    Mesh.ForceUpdate(true);
    Mesh.SetHasPhysicsAssetInstance(true);
    PlacePhysicsBody();
    Mesh.SetTickGroup(2);
    StaggerState.State = 0;
    StaggerState.bIsUnstaggering = false;
    StaggerState.StaggerStartTime = WorldInfo.TimeSeconds;
    StaggerState.StaggerEndTime = -1;
    StaggerState.StaggerEndRagdollTime = -1;
    StaggerState.StaggerRecoveryStartTime = -1;
    StaggerState.NextUnstaggerCheckTime = -1;
    StaggerState.PreviousCollisionComponent = CollisionComponent;
    CollisionComponent = Mesh;
    CylinderComponent.SetActorCollision(false, false);
    SetSecondaryCollisionEnabled(false);
    SetPhysics(10);
    Mesh.PhysicsWeight = 1;
    Mesh.SetRBLinearVelocity(Velocity, false);
    Mesh.bUpdateKinematicBonesFromAnimation = false;
    Mesh.SetBlockRigidBody(true);
    Mesh.PhysicsAssetInstance.SetAllBodiesFixed(false);
    Mesh.SetTranslation(GetDefaultMeshOffset());
    StaggerState.PreviousCollisionChannel = Mesh.RBChannel;
    Mesh.SetRBChannel(2);
    Mesh.SetRBCollidesWithChannel(0, true);
    Mesh.SetRBCollidesWithChannel(2, true);
    Mesh.SetRBCollidesWithChannel(3, true);
    Mesh.WakeRigidBody();
    //return;    
}

