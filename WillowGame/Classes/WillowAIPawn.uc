function bool SuggestLeapVelocity(out Vector vecLeapVelocity, Actor Target, float flLeapSpeed)
{
    local Vector vecToEyes;
    local Rotator rotTemp;
    local Vector vecToTarget, vecGravity;

    // End:0x140
    if(Target != none)
    {
        Target.GetActorEyesViewPoint(vecToEyes, rotTemp);
        vecToTarget = vecToEyes - Location;
        vecToTarget.Z = vecToTarget.Z - float(50);
        UnknownLocal_1 = VSize(vecToTarget) / flLeapSpeed;
        vecGravity.Z = WorldInfo.WorldGravityZ;
        vecGravity = UnknownLocal_1 * -vecGravity;
        vecLeapVelocity = (flLeapSpeed * Normal(vecToTarget)) + vecGravity;
        return true;        
    }
    else
    {
        return false;
    }
    //return ReturnValue;    
}

