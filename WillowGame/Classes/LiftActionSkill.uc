simulated function OnActionSkillStarted(WillowPawn TheWillowPawn, Controller TheController, optional WillowPawn TheTargetPawn)
{
    TheWillowPawn
    TheController
    TheTargetPawn    
    UpdateTargetPawn(TheTargetPawn);
    // End:0xC5
    if((int(Role) == int(ROLE_Authority)) && TheTargetPawn != none)
    {
        SkillDuration = LiftDuration + (MyWillowPawn.EvaluateAttributeInitialization(LockDurationFormula) * TheTargetPawn.EvaluateAttributeInitialization(LockDurationScaleFormula));
    }
    MyWillowPawn.GetSMComponent().Play(GetPlayerAnimation(TheTargetPawn));
    SkillStartTime = WorldInfo.TimeSeconds;
    SelectTarget(TheTargetPawn);
    //return;    
}

