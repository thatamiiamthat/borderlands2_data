function Vector GetLiftLocation(float LiftTime)
{
    local Vector SnapLocation;

    SnapLocation = VLerp(LiftStartLocation, LiftEndLocation, LiftSnapHeightPct);
    // End:0xAD
    if(LiftTime <= (LiftDuration * LiftSnapTimePct))
    {
        UnknownLocal_1 = LiftTime / (LiftDuration * LiftSnapTimePct);
        UnknownLocal_3 = UnknownLocal_1 * UnknownLocal_1;
        return VLerp(LiftStartLocation, SnapLocation, UnknownLocal_3);        
    }
    else
    {
        UnknownLocal_1 = (WorldInfo.TimeSeconds - (LiftStartTime + (LiftDuration * LiftSnapTimePct))) / (LiftDuration * (1 - LiftSnapTimePct));
        UnknownLocal_3 = 1 - ((1 - UnknownLocal_1) * (1 - UnknownLocal_1));
        return VLerp(SnapLocation, LiftEndLocation, UnknownLocal_3);
    }
    //return ReturnValue;    
}

function Vector GetBobLocation(float DeltaTime)
{
    local Vector NewLocation, BobLocation;

    BobLocation = LiftEndLocation;
    BobLocation.Z += (Sin(((WorldInfo.TimeSeconds - SkillStartTime) * LiftBobFrequency) * 3.141593) * LiftBobAmplitude);
    BobLocation = VInterpTo(PrevBobLocation, BobLocation, DeltaTime, 1);
    NewLocation = BobLocation;
    PrevBobLocation = NewLocation;
    return NewLocation;
    //return ReturnValue;    
}

function UpdateLiftedPawn(float DeltaTime)
{
    local Vector NewLocation;

    // End:0x157
    if(((LiftedPawn != none) && !bCharmed) && !LiftedPawn.IsDead())
    {
        UnknownLocal_1 = WorldInfo.TimeSeconds - LiftStartTime;
        // End:0xB4
        if(int(CurrentState) == int(4))
        {
            NewLocation = LiftedPawn.Location;            
        }
        else
        {
            // End:0xFE
            if(UnknownLocal_1 < LiftDuration)
            {
                NewLocation = GetLiftLocation(UnknownLocal_1);
                LiftedPawn.SetCollision(true, false, true);                
            }
            else
            {
                NewLocation = GetBobLocation(DeltaTime);
                LiftedPawn.SetCollision(true, true, true);
            }
        }
        LiftedPawn.SetLocation(NewLocation);
    }
    //return;    
}

simulated function UpdateLiftedPawnMeshOffset(float DeltaTime)
{
    local Vector CurrentOffset, DesiredOffset, DesiredTranslation;

    // End:0x46
    if(((LiftedPawn == none) || LiftedPawn.Mesh == none) || bCharmed)
    {
        return;
    }
    // End:0x9C
