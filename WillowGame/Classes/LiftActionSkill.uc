function PlayMissImpact()
{
    local Vector TraceEnd, TraceStart;
    local Rotator POVRotation;

    // End:0xE1
    if((MyWillowPC != none) && MyWillowPawn != none)
    {
        MyWillowPC.GetPlayerViewPoint(TraceStart, POVRotation);
        TraceEnd = TraceStart + (Vector(POVRotation) * MissTraceDistance);
        class'WillowPhysicalMaterialProperty'.static.StaticTraceImpact(MissImpactDefinition, MyWillowPawn, TraceEnd, TraceStart, class'WillowPhysicalMaterialProperty'.default.DefaultResponseParameters, true, true, true);
    }
    //return;    
}

function Fizzled()
{
    // End:0x82
    if(MyWillowPC != none)
    {
        MyWillowPC.ResetSkillCooldown();
        MyWillowPC.ServerDeactivateSkill(MyWillowPC.PlayerSkillTree.GetActionSkill());
    }
    //return;    
}

