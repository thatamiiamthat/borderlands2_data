function Ruin()
{
    // End:0x5C
    if(int(CurrentState) == int(3))
    {
        RuinDamageScalar = 1 - ((WorldInfo.TimeSeconds - StateStartTime) / StateDuration);        
    }
    else
    {
        // End:0x82
        if(int(CurrentState) == int(1))
        {
            RuinDamageScalar = 1;            
        }
        else
        {
            RuinDamageScalar = 0;
        }
    }
    FinishFX();
    CurrentState = 4;
    StateDuration = RuinHoldTime;
    StateStartTime = WorldInfo.TimeSeconds;
    SetTimer(RuinHoldTime, false, 'EndSkill');
    //return;    
}

function ApplyRuin()
{
    WillowAIPawn(LiftedPawn).Stagger(MyWillowPawn);
    OnRuinImpact(ConsumerHandle, MyWillowPawn, LiftedPawn);
    //return;    
}

