function SelectTarget(WillowPawn NewTarget)
{
    // End:0xA4
    if(CanPhaseLockTarget(NewTarget))
    {
        // End:0x8E
        if((NewTarget.DrivenVehicle == none) && (CanLiftTargetIf == none) || CanLiftTargetIf.Evaluate(NewTarget))
        {
            PhaseLockTarget(NewTarget);            
        }
        else
        {
            TargetBlocked(NewTarget);
        }        
    }
    else
    {
        // End:0xD0
        if(CanResurrectTarget(NewTarget))
        {
            ResurrectTarget(NewTarget);            
        }
        else
        {
            FizzleOut();
        }
    }
    //return;    
}

function PhaseLockTarget(WillowPawn NewTarget)
{
    CurrentState = 1;
    StateDuration = LiftDuration;
    StateStartTime = WorldInfo.TimeSeconds;
    bCharmed = false;
    LiftedPawn = NewTarget;
    SubsequenceProjectile = none;
    OnSelectedTarget(ConsumerHandle, MyWillowPawn, NewTarget);
    class'AttributeEffect'.static.ApplyAttributeEffects(NewTarget, PhaselockedAttributeEffects, SavedPhaselockAttributeModifiers);
    SetTimer(LiftDuration, false, 'LockTarget');
    SetTimer(((SkillStartTime + SkillDuration) - LockFadeOutTime) - WorldInfo.TimeSeconds, false, 'StartOutro');
    SetTimer(((SkillStartTime + SkillDuration) + ReleaseBufferTime) - WorldInfo.TimeSeconds, false, 'EndSkill');
    // End:0x19E
    if(CanCharmTarget())
    {
        bCharmed = true;        
    }
    else
    {
        // End:0x1E8
        if(NewTarget.IsStaggered())
        {
            WillowAIPawn(NewTarget).UnStagger();
        }
        LiftTarget(NewTarget);
    }
    // End:0x212
    if(ShouldSpawnHelios())
    {
        SpawnHelios();
    }
    bReplicatedCharmed = bCharmed;
    //return;    
}

function LockTarget()
{
    // End:0x71
    if(int(CurrentState) == int(1))
    {
        CurrentState = 3;
        StateDuration = (SkillDuration - LiftDuration) - LockFadeOutTime;
        StateStartTime = WorldInfo.TimeSeconds;
    }
    // End:0xA6
    if(bCharmed)
    {
        OnCharmTarget(ConsumerHandle, MyWillowPawn, LiftedPawn);        
    }
    else
    {
        SpawnBubbleFX();
        OnTargetBecomesLocked(ConsumerHandle, MyWillowPawn, LiftedPawn);
    }
    //return;    
}

function FinishLifting(bool bDropImmediately)
{
    // End:0x1A
    if(bDropImmediately)
    {
        ReleaseTarget();        
    }
    else
    {
        StartOutro();
    }
    //return;    
}

function StartOutro()
{
    CurrentState = 2;
    StateDuration = LockFadeOutTime;
    StateStartTime = WorldInfo.TimeSeconds;
    OnTargetIsAboutToBecomeUnlocked(ConsumerHandle, MyWillowPawn, LiftedPawn);
    SetTimer(LockFadeOutTime, false, 'ReleaseTarget');
    FinishFX();
    //return;    
}

function ReleaseTarget()
{
    ClearTimer('LockTarget');
    ClearTimer('ReleaseTarget');
    ClearTimer('TransitionToBubbleFXLoop');
    // End:0x4D
    if(LiftedPawn == none)
    {
        return;
    }
    FinishFX();
    LiftedPawn.bCanUse = true;
    OnReleasedTarget(ConsumerHandle, MyWillowPawn, LiftedPawn);
    class'AttributeEffect'.static.RemoveAttributeEffects(LiftedPawn, SavedPhaselockAttributeModifiers);
    // End:0x154
    if((int(CurrentState) != int(4)) && int(CurrentState) != int(5))
    {
        // End:0x111
        if(!bCharmed)
        {
            DropTarget();
        }
        CurrentState = 0;
        StateDuration = 0;
        StateStartTime = WorldInfo.TimeSeconds;
    }
    // End:0x182
    if(PhaselockLight != none)
    {
        PhaselockLight.DetachFromAny();
    }
    // End:0x1CA
    if(!IsLiftedPawnIncapacitated())
    {
        LiftedPawn.SetDefaultPhysics();
        LiftedPawn.SetPhysics(2);
    }
    LiftedPawn = none;
    //return;    
}

simulated function bool IsLiftedPawnIncapacitated()
{
    // End:0x11
    if(LiftedPawn == none)
    {
        return false;
    }
    // End:0x37
    if(!LiftedPawn.IsAliveAndWell())
    {
        return true;
    }
    // End:0x6C
    if(!bCharmed && LiftedPawn.IsStaggered())
    {
        return true;
    }
    return false;
    //return ReturnValue;    
}

