}

simulated function EndSkill()
{
    // End:0x58
    if(FirstPersonPSC != none)
    {
        FirstPersonPSC.DeactivateSystem();
        FirstPersonPSC.DetachFromAny();
        FirstPersonPSC = none;
    }
    // End:0x83
    if(int(WorldInfo.NetMode) == int(NM_Client))
    {
        return;
    }
    // End:0xA1
    if(int(CurrentState) == int(4))
    {
        ApplyRuin();
    }
    // End:0xBA
    if(LiftedPawn != none)
    {
        ReleaseTarget();
    }
    // End:0xD4
    if(DroppedPawn != none)
    {
        CheckLandTarget(true);
    }
    // End:0x10D
    if(SubsequenceProjectile != none)
    {
        SubsequenceProjectile.Detonate();
        SubsequenceProjectile = none;
    }
    CurrentState = 0;
    StateDuration = 0;
    StateStartTime = WorldInfo.TimeSeconds;
    ClearTimer('Fizzled');
    ClearTimer('EndSkill');
    ClearTimer('LockTarget');
    ClearTimer('StartOutro');
    ClearTimer('ReleaseTarget');
    ClearTimer('TransitionToBubbleFXLoop');
    // End:0x251
    if((MyWillowPC != none) && MyWillowPC.PlayerSkillTree != none)
    {
        MyWillowPC.ServerDeactivateSkill(MyWillowPC.PlayerSkillTree.GetActionSkill());
    }
    //return;    
}

