    return CheckLoc;
    //return ReturnValue;    
}

function BeginLifting(WillowPawn BeginLiftTarget, float HeightFromGround)
{
    local Vector HitLocation, HitNormal, CheckLoc;

    LiftedPawn = BeginLiftTarget;
    LiftStartTime = WorldInfo.TimeSeconds;
    ClientLiftedPawnForFX = BeginLiftTarget;
    // End:0xB4
    if(int(LiftedPawn.Physics) == int(9))
    {
        LiftedPawn.EndClimbLadder(LiftedPawn.OnLadder);
    }
    LiftedPawn.bCanUse = false;
    WillowAIPawn(LiftedPawn).DropCombatPerch();
    LiftStartLocation = LiftedPawn.Location;
    CheckLoc = GetLiftCheckLocation();
    LiftEndLocation = CheckLoc;
    UnknownLocal_1 = BeginLiftTarget.Trace(HitLocation, HitNormal, CheckLoc - (vect(0, 0, 1) * HeightFromGround), CheckLoc, true, vect(1, 1, 1),, 8);
    // End:0x2C2
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_3 = LiftedPawn.GetCollisionHeight();
        LiftEndLocation = HitLocation;
        LiftEndLocation.Z += (UnknownLocal_3 + HeightFromGround);
        UnknownLocal_1 = BeginLiftTarget.Trace(HitLocation, HitNormal, LiftEndLocation, CheckLoc, true, vect(1, 1, 1),, 8);
        // End:0x2C2
        if(UnknownLocal_1 != none)
        {
            LiftEndLocation = HitLocation;
            LiftEndLocation.Z -= UnknownLocal_3;
        }
    }
    PrevBobLocation = LiftEndLocation;
    // End:0x35A
    if((PhaselockLight != none) && !PhaselockLight.bAttached)
    {
