function SpawnSubsequenceProjectile()
{
    // End:0x22
    if((LiftedPawn == none) || SubsequenceProjectileDefinition == none)
    {
        return;
    }
    SubsequenceProjectile = MyWillowPawn.Spawn(SubsequenceProjectileDefinition.ProjectileClass, MyWillowPawn,, LiftedPawn.Location,,, true);
    SubsequenceProjectile.InitializeFromDefinition(SubsequenceProjectileDefinition, 0,, true);
    SubsequenceProjectile.Init(vect(0, 0, 1));
    SubsequenceProjectile.DoOnSpawn();
    SubsequenceProjectile.Instigator = MyWillowPawn;
    CurrentState = 5;
    StateDuration = 0;
    StateStartTime = WorldInfo.TimeSeconds;
    //return;    
}

