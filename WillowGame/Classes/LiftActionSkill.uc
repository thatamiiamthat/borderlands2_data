simulated event RunCustomEvent(name EventName, optional Object EventInstigator, optional Object OtherEventParticipantObject, optional BehaviorParameters EventData)
{
    local Vector BoneLoc;

    EventName
    EventInstigator
    OtherEventParticipantObject
    EventData    
    // End:0x222
    if(EventName == 'PlayPhaselockHandFXFirstPerson')
    {
        // End:0x21F
        if(MyWillowPlayerPawn != none)
        {
            FirstPersonPSC = new (MyWillowPlayerPawn) class'ParticleSystemComponent';
            MyWillowPlayerPawn.Arms.AttachComponentToSocket(FirstPersonPSC, FirstPersonAttachmentName);
            FirstPersonPSC.SetDepthPriorityGroup(1);
            FirstPersonPSC.SetInWorldForeground(true);
            FirstPersonPSC.SetOnlyOwnerSee(true);
            FirstPersonPSC.SetTranslation(FirstPersonTranslation);
            FirstPersonPSC.SetScale(FirstPersonScale);
            FirstPersonPSC.SetTemplate(((bFizzled) ? FirstPersonParticleSystem_Fizzled : FirstPersonParticleSystem));
            FirstPersonPSC.ActivateSystem();
            FirstPersonPSC.__OnSystemFinished__Delegate = FirstPersonEffectFinished;
            FirstPersonPSC.bCheckForKillWhileIdle = true;
        }        
    }
    else
    {
        // End:0x414
        if(EventName == 'PlayPhaselockHandFXThirdPerson')
        {
            // End:0x414
            if((MyWillowPawn != none) && MyWillowPawn.Mesh != none)
            {
                BoneLoc = MyWillowPawn.Mesh.GetBoneLocation(ThirdPersonAttachmentName);
                UnknownLocal_1 = MyWillowPawn.Spawn(class'WillowReplicatedEmitter', MyWillowPawn,, BoneLoc);
                UnknownLocal_1.SetBase(none);
                UnknownLocal_1.SetHardAttach(true);
                UnknownLocal_1.SetBase(MyWillowPawn,, MyWillowPawn.Mesh, ThirdPersonAttachmentName);
                UnknownLocal_1.SetRelativeLocation(ThirdPersonTranslation);
                UnknownLocal_1.SetOwnerNoSeeEmitter(true);
                UnknownLocal_1.SetDrawScale(ThirdPersonScale);
                UnknownLocal_1.SetTemplate(((bFizzled) ? ThirdPersonParticleSystem_Fizzled : ThirdPersonParticleSystem));
            }
        }
    }
    //return;    
}

simulated function FirstPersonEffectFinished(ParticleSystemComponent PSC)
{
    // End:0x52
    if((FirstPersonPSC != none) && PSC == FirstPersonPSC)
    {
        FirstPersonPSC.DetachFromAny();
        FirstPersonPSC = none;
    }
    //return;    
}

simulated function SpawnBubbleFX()
{
