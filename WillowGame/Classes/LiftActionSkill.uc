    // End:0xEB
    if(UnknownLocal_1 <= (LiftDuration * LiftSnapTimePct))
    {
        return;
    }
    CurrentOffset = LiftedPawn.Mesh.Bounds.Origin - LiftedPawn.Location;
    DesiredOffset = VInterpTo(CurrentOffset, vect(0, 0, 0), DeltaTime, 5);
    UnknownLocal_3 = DesiredOffset.Z - CurrentOffset.Z;
    DesiredTranslation = LiftedPawn.Mesh.Translation;
    DesiredTranslation.Z += UnknownLocal_3;
    LiftedPawn.Mesh.SetTranslation(DesiredTranslation);
    //return;    
}

