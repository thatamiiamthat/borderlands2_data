    }
    BubbleFXEmitter_FadeIn = UnknownLocal_1.Spawn(class'WillowEmitter', UnknownLocal_1,, LiftEndLocation);
    BubbleFXEmitter_FadeIn.SetRelativeLocation(BubbleFXTranslation);
    BubbleFXEmitter_FadeIn.SetDrawScale(UnknownLocal_1.Mesh.Bounds.SphereRadius / BubbleFXScale);
    BubbleFXEmitter_FadeIn.SetTemplate(BubbleFXParticleSystem_FadeIn);
    SetTimer(BubbleFXIntroTime, false, 'TransitionToBubbleFXLoop');
    //return;    
}

simulated function TransitionToBubbleFXLoop()
{
    // End:0x16
    if(int(CurrentState) != int(3))
    {
        return;
    }
    UnknownLocal_1 = ((LiftedPawn != none) ? LiftedPawn : ClientLiftedPawnForFX);
    // End:0x4E
    if(!UnknownLocal_1 != none)
    {
        return;
    }
    BubbleFXEmitter_Loop = UnknownLocal_1.Spawn(class'WillowEmitter', UnknownLocal_1,, LiftEndLocation);
    BubbleFXEmitter_Loop.SetRelativeLocation(BubbleFXTranslation);
    BubbleFXEmitter_Loop.SetDrawScale(UnknownLocal_1.Mesh.Bounds.SphereRadius / BubbleFXScale);
    BubbleFXEmitter_Loop.SetTemplate(BubbleFXParticleSystem);
    BubbleFXEmitter_Loop.LifeSpan = StateDuration + BubbleFXOutroOverlapTime;
    BubbleFXEmitter_Loop.SetFloatParameter(PhaselockLifeTimeParamName, StateDuration + BubbleFXOutroOverlapTime);
    CollapseStartTime = ((WorldInfo.TimeSeconds + StateDuration) - CollapseDuration) - BubbleFXIntroTime;
    //return;    
}

simulated function TransitionToBubbleFXOutro()
{
    BubbleFXEmitter_Loop.Destroy();
    BubbleFXEmitter_Loop = none;
    UnknownLocal_1 = ((LiftedPawn != none) ? LiftedPawn : ClientLiftedPawnForFX);
    // End:0x5B
    if(!UnknownLocal_1 != none)
    {
        return;
    }
    BubbleFXEmitter_FadeOut = UnknownLocal_1.Spawn(class'WillowEmitter', UnknownLocal_1,, LiftEndLocation);
    BubbleFXEmitter_FadeOut.SetRelativeLocation(BubbleFXTranslation);
    BubbleFXEmitter_FadeOut.SetDrawScale(UnknownLocal_1.Mesh.Bounds.SphereRadius / BubbleFXScale);
    BubbleFXEmitter_FadeOut.SetTemplate(BubbleFXParticleSystem_FadeOut);
    //return;    
}

simulated function FinishFX()
{
    // End:0x11
    if(BubbleFXEmitter_Loop == none)
    {
        return;
    }
    ClearTimer('TransitionToBubbleFXLoop');
    TransitionToBubbleFXOutro();
    //return;    
}

