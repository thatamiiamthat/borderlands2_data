simulated event ReplicatedEvent(name VarName)
{
    // End:0x11A
    if(VarName == 'LiftedPawn')
    {
        // End:0xE9
        if(LiftedPawn != none)
        {
            ClientLiftedPawnForFX = LiftedPawn;
            LiftStartTime = WorldInfo.TimeSeconds;
            // End:0xE6
            if((PhaselockLight != none) && !PhaselockLight.bAttached)
            {
                LightBrightness = PhaselockLight.Brightness;
                LiftedPawn.AttachComponent(PhaselockLight);
            }            
        }
        else
        {
            // End:0x117
            if(PhaselockLight != none)
            {
                PhaselockLight.DetachFromAny();
            }
        }        
    }
    else
    {
        // End:0x147
        if(VarName == 'LiftEndLocation')
        {
            PrevBobLocation = LiftEndLocation;            
        }
        else
        {
            // End:0x19B
            if(VarName == 'CurrentState')
            {
                // End:0x18E
                if(int(CurrentState) == int(3))
                {
                    // End:0x18B
                    if(!bReplicatedCharmed)
                    {
                        SpawnBubbleFX();
                    }                    
                }
                else
                {
                    FinishFX();
                }                
            }
            else
            {
                // End:0x241
                if(VarName == 'bReplicatedCharmed')
                {
                    // End:0x23E
                    if(int(CurrentState) == int(3))
                    {
                        // End:0x20C
                        if(BubbleFXEmitter_FadeIn != none)
                        {
                            BubbleFXEmitter_FadeIn.Destroy();
                            BubbleFXEmitter_FadeIn = none;
                            ClearTimer('TransitionToBubbleFXLoop');
                        }
                        // End:0x23E
                        if(BubbleFXEmitter_Loop != none)
                        {
                            BubbleFXEmitter_Loop.Destroy();
                            BubbleFXEmitter_Loop = none;
                        }
                    }                    
                }
                else
                {
                    super.ReplicatedEvent(VarName);
                }
            }
        }
    }
    //return;    
}

