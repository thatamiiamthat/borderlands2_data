simulated exec function DuckPressed()
{
    // End:0x97
    if(bUsingGamepad && Outer.bDisplayTradeIcon)
    {
        // End:0x97
        if((Outer.TradeManager == none) || int(Outer.TradeManager.Status) == int(2))
        {
            return;
        }
    }
    // End:0x1FF
