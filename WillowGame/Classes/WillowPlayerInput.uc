event PlayerInput(float DeltaTime)
{
    local Vector InputDirection;

    // End:0x3D
    if(bUpdateInputContext && Outer.SelectInputContext())
    {
        bUpdateInputContext = false;
    }
    super.PlayerInput(DeltaTime);
    // End:0xE2
    if(Outer.AutoAimStrategy != none)
    {
        Outer.AutoAimStrategy.ModifyInput(self.Outer, aTurn, aLookUp, aForward, aStrafe);
    }
    UnknownLocal_1 = WillowPlayerPawn(Outer.Pawn);
    InputDirection.X = aStrafe;
    InputDirection.Y = aForward;
    InputDirection.Z = 0;
    bCanSprint = (vect(0, 1, 0) Dot Normal(InputDirection)) >= 0.7071;
    // End:0x24A
    if(bCanSprint && EndCrouchOnNextForwardMovement != 0)
    {
        // End:0x24A
        if(int(Outer.bDuck) > int(0))
        {
            Outer.bDuck = 0;
            // End:0x23F
            if(Outer.bCrouchToggle)
            {
                bHoldDuck = false;
            }
            EndCrouchOnNextForwardMovement = 0;
        }
    }
    // End:0x318
    if((bTryToSprint && UnknownLocal_1 != none) && InputAllowsSprint())
    {
        // End:0x2EB
        if(int(Outer.bDuck) > int(0))
        {
            Outer.bDuck = 0;
            // End:0x2EB
            if(Outer.bCrouchToggle)
            {
                bHoldDuck = false;
            }
        }
        Outer.bPressedSprint = true;
        bTryToSprint = false;
    }
    // End:0x4C7
    if((UnknownLocal_1 != none) && Outer.GFxUIManager != none)
    {
        // End:0x412
        if((((((Abs(aTurn) > 0.0001) || Abs(aLookUp) > 0.0001) || Abs(aForward) > 0.0001) || Abs(aStrafe) > 0.0001) || Outer.bCinematicMode) || Outer.GFxUIManager.IsBlockingMoviePlaying())
        {
            TimeSinceLastMovement = 0;            
        }
        else
        {
            TimeSinceLastMovement += DeltaTime;
            UnknownLocal_3 = class'WillowDialogGlobalsDefinition'.static.Get();
            // End:0x4C4
            if((UnknownLocal_3 != none) && TimeSinceLastMovement >= UnknownLocal_3.IdleTimeOut)
            {
                TimeSinceLastMovement -= UnknownLocal_3.IdleTimeOut;
                Outer.SayIdleTimeOut();
            }
        }        
    }
    else
    {
        TimeSinceLastMovement = 0;
    }
    //return;    
}

exec function RevivePressed()
{
    // End:0x103
    if((((Outer.ReviveTarget == none) && Outer.CurrentInteractionIcon[0].IconDef != none) && int(Outer.CurrentInteractionIcon[0].IconDef.Icon) == int(3)) && Outer.CanPerformReviveTarget())
    {
        bReviveHeld = true;
        Outer.ServerStartRevive();
    }
    //return;    
}

exec function ReviveReleased()
{
    // End:0x52
    if(bReviveHeld && Outer.ReviveTarget != none)
    {
        Outer.ServerStopRevive();
    }
    bReviveHeld = false;
    //return;    
}

