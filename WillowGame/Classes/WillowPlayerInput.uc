    {
        // End:0x1DE
        if(Outer.bCrouchToggle)
        {
            // End:0x134
            if((Outer.WorldInfo.TimeSeconds - LastDuckTime) < DoubleClickTime)
            {
                return;
            }
            // End:0x171
            if(bHoldDuck)
            {
                bHoldDuck = false;
                Outer.bDuck = 0;                
            }
            else
            {
                bHoldDuck = true;
                Outer.bDuck = 1;
            }
            LastDuckTime = Outer.WorldInfo.TimeSeconds;            
        }
        else
        {
            Outer.bDuck = 1;
        }
    }
    //return;    
}

