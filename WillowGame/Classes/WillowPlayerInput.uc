    //return;    
}

exec function Jump()
{
    // End:0x78
    if(int(Outer.bDuck) > int(0))
    {
        Outer.bDuck = 0;
        // End:0x78
        if(Outer.bCrouchToggle)
        {
            bHoldDuck = false;
        }
    }
    // End:0x120
    if(Outer.bConsoleController)
    {
        // End:0x113
        if((aForward < float(0)) || Abs(aStrafe) > (0.7 * Abs(aForward)))
        {
            // End:0xEF
            if(aStrafe == float(0))
            {
                ForcedDoubleClick = 4;                
            }
            else
            {
                ForcedDoubleClick = ((aStrafe < float(0)) ? 1 : 2);
            }            
        }
        else
        {
            super.Jump();
        }        
    }
    else
    {
        super.Jump();
    }
    //return;    
}

function Engine.Actor.EDoubleClickDir CheckForDoubleClickMove(float DeltaTime)
{
    local Engine.Actor.EDoubleClickDir Result;

    // End:0x4E
    if(Outer.bConsoleController)
    {
        Result = ForcedDoubleClick;
        ForcedDoubleClick = 0;
        return Result;        
    }
    else
    {
        return super.CheckForDoubleClickMove(DeltaTime);
    }
    //return ReturnValue;    
}

exec function SetControllerSensitivity(int Sensitivity)
{
