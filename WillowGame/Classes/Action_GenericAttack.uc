// Export UAction_GenericAttack::execInitData(FFrame&, void* const)
native function InitData();

event Init()
{
    super(WillowActionSequencePawn).Init();
    InitData();
    //return;    
}

event name CanRun()
{
    local name TempVal;

    TempVal = super(ActionSequence).CanRun();
    // End:0x35
    if(TempVal != 'None')
    {
        return TempVal;
    }
    // End:0x4E
    if(Target == none)
    {
        return 'NoTarget';
    }
    // End:0x65
    if(IsFlying())
    {
        return 'Flying';
    }
    // End:0x7F
    if(bPathingFailed)
    {
        return 'PathingFailed';        
    }
    else
    {
        // End:0xBB
        if(int(Type) == int(2))
        {
            CheckAttackLocation();
            // End:0xBB
            if(int(Validity) == int(0))
            {
                return 'InvalidLocation';
            }
        }
    }
    // End:0xD4
    if(!TargetReachable())
    {
        return 'NotReachable';
    }
    // End:0x151
    if((bCanBeLimitedByDownedPlayers && WillowGameInfo(MyWillowPawn.WorldInfo.Game).bEnemiesCannotDoCloseAttacksOnDownedPlayers) && TargetIsDownedPlayer())
    {
        return 'TargetIsDownedPlayer';
    }
    return 'None';
    //return ReturnValue;    
}

event Start()
{
    super.Start();
    CheckStateTransition();
    SetPawnMovementSpeed(1);
    MyWillowMind.bWantsToFireWeapon = bShootTarget;
    MyWillowPawn.bWantsFullLOSTrace = bWantsFullLOSTrace;
    MyWillowPawn.SetTimer(CheckRate, true, 'CheckStateTransition', self);
    CheckForNewZone();
    //return;    
}

event Stop()
{
    super(WillowActionSequencePawn).Stop();
    MyWillowPawn.ShouldCrouch(false);
    MyWillowMind.bWantsToFireWeapon = false;
    MyWillowPawn.bWantsFullLOSTrace = false;
    MyWillowPawn.ClearTimer('CheckStateTransition', self);
    // End:0xD1
    if(int(Type) == int(0))
    {
        WillowAI.UnclaimCombatZone(MyZone);
    }
    //return;    
}

event Update()
{
    super(ActionSequence).Update();
    // End:0x21
    if(CanCheckExpiredZone())
    {
        CheckExpiredZone();
    }
    // End:0x9E
    if(int(MyWillowPawn.GetMoveStyle()) == int(0))
    {
        MyWillowPawn.SetAimAtActor(Target);
        MyWillowMind.SetFacingPolicy(2, Target);
    }
    //return;    
}

function bool TargetIsDownedPlayer()
{
    UnknownLocal_1 = WillowPlayerPawn(Target);
    return (UnknownLocal_1 != none) && UnknownLocal_1.IsInjured();
    //return ReturnValue;    
}

function name GetDesiredState()
{
    local name DesiredState;

    // End:0x40
    if(AI.GetAIComponent().MovementOnHold())
    {
        return GetStateName();        
    }
    else
    {
        // End:0x74
        if((ReachedAttackLoc()) || !CanMove())
        {
            DesiredState = 'HoldStill';            
        }
        else
        {
            DesiredState = 'MoveToTarget';
        }
    }
    return DesiredState;
    //return ReturnValue;    
}

function CheckStateTransition()
{
    local name DesiredState;

    CheckAttackLocation();
    DesiredState = GetDesiredState();
    // End:0x3D
    if(DesiredState != GetStateName())
    {
        GotoState(DesiredState);
    }
    //return;    
}

function bool CanMove()
{
    // End:0x11
    if(!bLimitedMovement)
    {
        return true;
    }
    // End:0x22
    if(ParentTargetRec == none)
    {
        return true;
    }
    return EqualEqual_InterfaceInterface(ParentTargetRec.MovingAI, IAIInterface(none)) || EqualEqual_InterfaceInterface(ParentTargetRec.MovingAI, AI);
    //return ReturnValue;    
}

function ClaimMovement()
{
    // End:0x44
    if(bLimitedMovement && CanMove())
    {
        ParentTargetRec.MovingAI = AI;
    }
    //return;    
}

function UnclaimMovement()
{
    // End:0x3C
    if(bLimitedMovement && CanMove())
    {
        ParentTargetRec.MovingAI = none;
    }
    //return;    
}

function CheckAttackLocation()
{
    // End:0x35
    if(Target == none)
    {
        AttackLoc = vect(0, 0, 0);
        Validity = 0;        
    }
    else
    {
        // End:0xB1
        if((IsWalking()) && ValidLocation(MyWillowPawn.Location))
        {
            AttackLoc = MyWillowPawn.Location;
            Validity = 2;
            CheckForNewZone();            
        }
        else
        {
            // End:0x113
            if((int(Type) == int(2)) || !ValidLocation(AttackLoc, int(Validity) == int(2)))
            {
                AttackLoc = vect(0, 0, 0);
                Validity = 0;
            }
        }
    }
    //return;    
}

function bool ValidLocation(const out Vector TestLoc, optional bool bAllAreRequired = true)
{
    WillowAI.IsLocationValid(TestLoc, Limits, int(Type) == int(0), !bAllAreRequired);
    //return ReturnValue;    
}

function bool CanClaimZones()
{
    // End:0x16
    if(int(Type) != int(0))
    {
        return false;
    }
    UnknownLocal_1 = MyWillowPawn.GetStance();
    return (UnknownLocal_1 != none) || UnknownLocal_1.SpeedScale > float(1);
    //return ReturnValue;    
}

function CheckForNewZone()
{
    local CombatZone OldZone;

    // End:0x46
    if(!CanClaimZones())
    {
        // End:0x44
        if(IsRunning())
        {
            WillowAI.UnclaimCombatZone(MyZone);
        }
        return;
    }
    OldZone = MyZone;
    MyZone = WillowAI.GetCombatZoneByLocation(AttackLoc);
    // End:0x113
    if((int(Validity) == int(0)) || !WillowAI.CombatZoneAvailable(MyZone))
    {
        AttackLoc = vect(0, 0, 0);
        Validity = 0;
        MyZone.Index = -1;
    }
    // End:0x170
    if(IsRunning())
    {
        WillowAI.UnclaimCombatZone(OldZone);
        WillowAI.ClaimCombatZone(MyZone);
    }
    //return;    
}

function bool CanCheckExpiredZone()
{
    return true;
    //return ReturnValue;    
}

function bool OnlyExpireMyZone()
{
    return true;
    //return ReturnValue;    
}

function CheckExpiredZone()
{
    // End:0x4C
    if(((IdleTime <= float(0)) || !CanClaimZones()) || MyZone.Index == -1)
    {
        return;
    }
    // End:0xAF
    if((OnlyExpireMyZone()) && MyZone.Index != WillowAI.CurrentZone.Index)
    {
        return;
    }
    // End:0xDD
    if(WillowAI.ZoneTime < IdleTime)
    {
        return;
    }
    WillowAI.MarkCurrentCombatZone();
    Validity = 0;
    //return;    
}

function bool WantsPathFind()
{
    local Vector FinalDest;

    // End:0x27
    if((Target == none) || int(Type) == int(2))
    {
        return false;
    }
    // End:0x4E
    if((int(Type) == int(1)) && !TargetReachable())
    {
        return false;
    }
    // End:0x73
    if((ReachedAttackLoc()) && int(Validity) == int(2))
    {
        return false;
    }
    // End:0x84
    if(!CanMove())
    {
        return false;
    }
    FinalDest = GetFinalDestination();
    return ((int(Validity) == int(0)) || !PathIsValid()) || !ValidLocation(FinalDest, int(Validity) == int(2));
    //return ReturnValue;    
}

event bool PathFind()
{
    bPathingFailed = false;
    // End:0x1D
    if(!WantsPathFind())
    {
        return false;
    }
    InvalidatePath();
    // End:0x55
    if(int(Type) == int(1))
    {
        CreateVectorPath(GetNearestLocationToTarget(true));        
    }
    else
    {
        MyNavHandle.CreateConstrainedPath(PathData, Target.Location, Limits);
    }
    // End:0xC2
    if(!PathIsValid())
    {
        bPathingFailed = true;        
    }
    else
    {
        AttackLoc = GetFinalDestination();
        Validity = ((ValidLocation(AttackLoc)) ? 2 : 1);
        // End:0x11B
        if(int(Type) == int(0))
        {
            CheckForNewZone();
        }
    }
    return true;
    //return ReturnValue;    
}

function Vector GetNearestLocationToTarget(optional bool bCanBeExpensive)
{
    local Vector NearestLoc;
    local BasedPosition BasedNearestLoc;

    UnknownLocal_1
    WillowPawn(Target)
    // End:0x103
    if((UnknownLocal_1 == none) || int(UnknownLocal_1.Physics) == int(2))
    {
        // End:0xE4
        if(bCanBeExpensive)
        {
            MyNavHandle.GetNearestPositionOnNavMesh(512, GetActorFloorLoc(Target), BasedNearestLoc, MyNavHandle.CachedPathParams);
            return class'Actor'.static.BP2Vect(BasedNearestLoc);            
        }
        else
        {
            return Target.Location;
        }
    }
    NearestLoc = class'Actor'.static.BP2Vect(UnknownLocal_1.GetNearestPositionOnNavMesh());
    NearestLoc.Z += UnknownLocal_1.CylinderComponent.CollisionHeight;
    return NearestLoc;
    //return ReturnValue;    
}

function bool TargetReachable()
{
    local Vector NearestLoc;

    // End:0x27
    if((int(Type) != int(1)) || Target == none)
    {
        return true;
    }
    NearestLoc = GetNearestLocationToTarget();
    return ValidLocation(NearestLoc);
    //return ReturnValue;    
}

function float GetDotToTarget()
{
    local Vector ToTarget, AimDirection;

    ToTarget = Target.Location - MyWillowPawn.Location;
    ToTarget.Z = 0;
    ToTarget = Normal(ToTarget);
    AimDirection = MyWillowPawn.GetAimDirection();
    AimDirection.Z = 0;
    AimDirection = Normal(AimDirection);
    UnknownLocal_1 = ToTarget Dot AimDirection;
    return UnknownLocal_1;
    //return ReturnValue;    
}

function bool HalfExposed()
{
    return (TargetRec != none) && int(TargetRec.Exposure) == int(1);
    //return ReturnValue;    
}

function bool ReachedAttackLoc()
{
    return (int(Validity) != int(0)) && MyWillowPawn.ReachedPoint(AttackLoc, none);
    //return ReturnValue;    
}

state MoveToTarget
{
    event Update()
    {
        global.Update();
        MyWillowPawn.ShouldCrouch(bWantsCrouchMove && !HalfExposed());
        //return;        
    }

    function BeginState(name PreviousStateName)
    {
        ClaimMovement();
        bWantsCrouchMove = (CrouchMoveChance > float(0)) && CrouchMoveChance > FRand();
        //return;        
    }

    function EndState(name NextStateName)
    {
        UnclaimMovement();
        //return;        
    }
Begin:

    CheckCloaked(1, !bBurrowAttack);
    WaitForPath();
    FollowPath();
    CheckStateTransition();
    InvalidatePath();
    Sleep(0.1);
    goto 'Begin';
    stop;            
}

state HoldStill
{
    event Update()
    {
        global.Update();
        MyWillowPawn.ShouldCrouch(bWantsCrouchIdle && !HalfExposed());
        //return;        
    }

    function BeginState(name PreviousStateName)
    {
        InvalidatePath();
        CheckForNewZone();
        MyNavHandle.ClearPath();
        bWantsCrouchIdle = (CrouchIdleChance > float(0)) && CrouchIdleChance > FRand();
        //return;        
    }
Begin:

    CheckCloaked(2, !bBurrowAttack);
    MyNavHandle.ClearPath();
    Sleep(0.1);
    goto 'Begin';
    stop;        
}

defaultproperties
{
    bBurrowAttack=true
    bShootTarget=true
    Limits(0)=AttackLocation_Range'Default__Action_GenericAttack.RangeLimit'
    Limits(1)=AttackLocation_LineOfSight'Default__Action_GenericAttack.LOSLimit'
    CheckRate=1
    MyZone=(Index=-1,Bounds=(Min=(X=0,Y=0,Z=0),Max=(X=0,Y=0,Z=0),IsValid=0))
}