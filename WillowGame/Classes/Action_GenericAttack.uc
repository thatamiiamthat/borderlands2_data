class Action_GenericAttack extends Action_Burrow
    native(AI)
    editinlinenew
    hidecategories(Mobile,Object,HideMe,ActionSequence,LoadBalance,Movement);

enum EAttackType
{
    Attack_Far,
    Attack_Close,
    Attack_InPlace,
    Attack_MAX
};

enum EAttackValidity
{
    Validity_None,
    Validity_Partial,
    Validity_Full,
    Validity_MAX
};

var(Attack) const bool bLimitedMovement;
var(Attack) const bool bBurrowAttack;
var(Attack) const bool bShootTarget;
var transient bool bPathingFailed;
var transient bool bWantsCrouchIdle;
var transient bool bWantsCrouchMove;
var transient bool bCanBeLimitedByDownedPlayers;
var transient bool bWantsFullLOSTrace;
var(Attack) const export editinline array<export editinline AttackLocation> Limits;
var(Crouch) const float CrouchIdleChance;
var(Crouch) const float CrouchMoveChance;
var float CheckRate;
var transient Action_GenericAttack.EAttackType Type;
var transient Action_GenericAttack.EAttackValidity Validity;
var transient Vector AttackLoc;
var transient CombatZone MyZone;
