class Behavior_StatusEffectSwitch extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

enum EStatusEffectSwitchValues
{
    OUTPUT_None,
    OUTPUT_Ignite,
    OUTPUT_Corrosive,
    OUTPUT_Shock,
    OUTPUT_Amp,
    OUTPUT_Slow,
    OUTPUT_Healing,
    OUTPUT_MAX
};

var(Action) StatusEffectDefinition.EStatusEffectType StatusEffectType;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IStatusEffectTarget StatusEffectContext;
    local editinline StatusEffectsComponent SEComponent;
    local StatusEffectDefinition.EStatusEffectType ActiveType;
    local array<StatusEffectDefinition.EStatusEffectType> ActiveTypes;

    // End:0x25C
    if(ContextObject != none)
    {
        StatusEffectContext = ContextObject.QueryInterface(class'IStatusEffectTarget');
        // End:0x25C
        if(NotEqual_InterfaceInterface(StatusEffectContext, IStatusEffectTarget(none)))
        {
            SEComponent = StatusEffectContext.GetStatusEffectsComponent();
            // End:0x25C
            if(SEComponent != none)
            {
                ActiveTypes = SEComponent.GetActiveStatusEffectTypes();
                // End:0xFF
                if(ActiveTypes.Length == 0)
                {
                    class'BehaviorKernel'.static.ActivateBehaviorOutputLink(KernelInfo, 0);                    
                }
                else
                {
                    // End:0x25B
                    foreach ActiveTypes(ActiveType,)
                    {
                        switch(ActiveType)
                        {
                            // End:0x15A
                            case 1:
                                class'BehaviorKernel'.static.ActivateBehaviorOutputLink(KernelInfo, 1);
                                // End:0x25A
                                break;
                            // End:0x18C
                            case 2:
                                class'BehaviorKernel'.static.ActivateBehaviorOutputLink(KernelInfo, 2);
                                // End:0x25A
                                break;
                            // End:0x1BE
                            case 3:
                                class'BehaviorKernel'.static.ActivateBehaviorOutputLink(KernelInfo, 3);
                                // End:0x25A
                                break;
                            // End:0x1F0
                            case 4:
                                class'BehaviorKernel'.static.ActivateBehaviorOutputLink(KernelInfo, 4);
                                // End:0x25A
                                break;
                            // End:0x222
                            case 5:
                                class'BehaviorKernel'.static.ActivateBehaviorOutputLink(KernelInfo, 5);
                                // End:0x25A
                                break;
                            // End:0x254
                            case 6:
                                class'BehaviorKernel'.static.ActivateBehaviorOutputLink(KernelInfo, 6);
                                // End:0x25A
                                break;
                            // End:0xFFFF
                            default:
                                // End:0x25A
                                break;
                                break;
                        }                        
                    }                    
                }
            }
        }
    }
    //return;    
}

