simulated event UnselectActionButtons()
{
    ActionScript("UnselectActionButtons");
    SingleArgInvokeS("trading.offers.readyPlayer.gotoAndStop", "notReady");
    TradingPanel.OffersPanel.bSelectedTradeAction = false;
    TradingPanel.OffersPanel.bSelectedDuelAction = false;
    GetTradeManager().UpdateStance(0);
    CachedMyStance = 0;
    UpdateTimer();
    //return;    
}

simulated function extSetTrade(bool bNewTrade)
{
    UpdateMoneyOfferFromTextbox();
    // End:0x48
    if(bNewTrade)
    {
        GetTradeManager().UpdateStance(1);
        CachedMyStance = 1;        
    }
    else
    {
        GetTradeManager().UpdateStance(0);
        CachedMyStance = 0;
    }
    SingleArgInvokeS("trading.offers.readyPlayer.gotoAndStop", ((bNewTrade) ? "ready" : "notReady"));
    UpdateTimer();
    TradingPanel.OffersPanel.bSelectedTradeAction = bNewTrade;
    //return;    
}

simulated function extSetDuel(bool bNewDuel)
{
    // End:0x22
    if(!!bNewDuel || bDuelingAllowed)
    {
        return;
    }
    UpdateMoneyOfferFromTextbox();
    // End:0x6A
    if(bNewDuel)
    {
        GetTradeManager().UpdateStance(2);
        CachedMyStance = 2;        
    }
    else
    {
        GetTradeManager().UpdateStance(0);
        CachedMyStance = 0;
    }
    SingleArgInvokeS("trading.offers.readyPlayer.gotoAndStop", ((bNewDuel) ? "ready" : "notReady"));
    UpdateTimer();
    TradingPanel.OffersPanel.bSelectedDuelAction = bNewDuel;
    //return;    
}

