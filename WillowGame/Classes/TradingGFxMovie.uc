function extGenericButtonClicked(string ActionName)
{
    local name Action;

    Action = name(ActionName);
    switch(Action)
    {
        // End:0x41
        case 'Close':
            BeginClosing();
            // End:0xA4
            break;
        // End:0x71
        case 'arrowleft':
            TradingPanel.SwitchFocus(0);
            // End:0xA4
            break;
        // End:0xA1
        case 'arrowright':
            TradingPanel.SwitchFocus(1);
            // End:0xA4
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

function bool UpdateMoneyOfferFromTextbox()
{
    local string MoneyOfferString;

    UnknownLocal_1 = false;
    // End:0xD3
    if(bUseTextboxForMoney)
    {
