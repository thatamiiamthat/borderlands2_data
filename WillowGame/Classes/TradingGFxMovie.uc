    SetPlayerMoneyOffer(0);
    SetPartnerMoneyOffer(0);
    SetVariableBool("trading.offers.popup._visible", false);
    SingleArgInvokeS("trading.offers.readyPlayer.gotoAndStop", "notReady");
    SingleArgInvokeS("trading.offers.readyPartner.gotoAndStop", "notReady");
    SetVariableBool("trading.offers.playerDuelButton.disabled", true);
    SetVariableBool("trading.offers.playerDuelButton._visible", false);
