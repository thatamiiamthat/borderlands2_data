        {
            UpdateMoneyOffer(int(MoneyOfferString));
            LastMoneyOfferString = GetVariableString("trading.offers.PCPlayerMoneyOffer.textField.text");
            UnknownLocal_1 = true;
        }
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

