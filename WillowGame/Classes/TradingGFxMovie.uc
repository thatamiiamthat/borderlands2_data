function SetTooltips()
{
    local string S;

    // End:0x117
    if(!class'Engine'.static.IsSplitScreen())
    {
        S = TooltipString;
        S = Repl(S, "%1", ColorizeTooltipText(Localize("InvBar", "SortBar", "WillowMenu"), TradingPanel.GetSelectedThing() == none));
        S = Repl(S, "%2", ColorizeTooltipText(Localize("InvBar", "InspectBar", "WillowMenu"), TradingPanel.GetSelectedThing() == none));        
    }
    else
    {
        S = ToolTipString_Split;
        S = Repl(S, "%1", ColorizeTooltipText(Localize("InvBar", "SortBar", "WillowMenu"), TradingPanel.GetSelectedThing() == none));
    }
    SetVariableString("tooltips.tooltips.htmlText", ResolveDataStoreMarkup(S));
    //return;    
}

