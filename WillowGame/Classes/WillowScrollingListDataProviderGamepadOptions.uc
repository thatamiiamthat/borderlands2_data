function bool HandleExitWarnDlgInputKey(WillowGFxDialogBox Dlg, int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0x146
    if(int(uevent) == int(1))
    {
        // End:0xB8
        if((ukey == 'XboxTypeS_A') || ukey == 'Enter')
        {
            UnknownLocal_1 = 0;
            J0x4B:

            // End:0x76 [Loop If]
            if(UnknownLocal_1 < 16)
            {
                RemappedButtonIndexes[UnknownLocal_1] = -1;
                ++ UnknownLocal_1;
                // [Loop Continue]
                goto J0x4B;
            }
            MyOptionsGFxMovie.CloseMovie();
            Dlg.Close();            
        }
        else
        {
            // End:0x146
            if((ukey == 'XboxTypeS_B') || ukey == 'Escape')
            {
                CurrentSelectedPresetIndex = CustomPresetIndex;
                bIsInWarnExitMode = true;
                MyWillowScrollingList.Refresh();
                Dlg.Close();
            }
        }
    }
    return true;
    //return ReturnValue;    
}

