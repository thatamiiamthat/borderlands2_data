                }
                else
                {                    
                    WillowSentinelPC.ConsoleCommand("playerselectclass GD_Mercenary.Character.CharClass_Mercenary");
                }
            }
        }
        Sleep(1.5);        
        WillowSentinelPC.ConsoleCommand("BalanceMe");
        Sleep(5);
        J0x263:

        // End:0x342 [Loop If]
        if(!bFinishedTraversal)
        {
            TestBackMenu(5, 30);
            Sleep(50);
            Sleep(10);
            TestBackMenu(2, 30);
            Sleep(50);
            Sleep(10);
            TestBackMenu(3, 30);
            Sleep(50);
            Sleep(10);
            TestBackMenu(0, 30);
            Sleep(50);
            Sleep(10);
            TestBackMenu(1, 30);
            Sleep(50);
            Sleep(10);
            WorldInfo.ForceGarbageCollection(true);
            Sleep(1);
            // [Loop Continue]
            goto J0x263;
        }
    }    
    ConsoleCommand("exit");
    stop;                
}

