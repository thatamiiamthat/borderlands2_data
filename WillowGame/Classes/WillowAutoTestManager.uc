            // End:0x60
            break;            
        }        
        WillowSentinelPC.bIsUsingStreamingVolumes = false;
        //return;        
    }

    function bool DownTrace()
    {
        local Vector downVect;

        downVect = SentinelTravelArray[SentinelNavigationIdx] + (Normal(vect(0, 0, -1)) * float(1024));
        // End:0x60
        if(FastTrace(downVect, SentinelTravelArray[SentinelNavigationIdx]))
        {
            return false;            
        }
        else
        {
            return true;
        }
        //return ReturnValue;        
    }
Begin:

    ConsoleCommand("unsuppress DevGBXMemTrack");
    bFinishedTraversal = false;
    bIsMenuActive = false;
    ++ TotalLevelLoads;
    // End:0x8A
    if(WorldInfo.GetStreamingPersistentMapName() == 'Glacial_P')
    {
        Sleep(120);        
    }
    else
    {
        Sleep(10);
    }
    DisableTrainingMessages();
    SentinelIdx = 0;
    J0xA7:

    // End:0x1D4 [Loop If]
    if(SentinelIdx < WorldInfo.StreamingLevels.Length)
    {
        WillowSentinelPC.ClientUpdateLevelStreamingStatus(WorldInfo.StreamingLevels[SentinelIdx].PackageName, true, true, true);
        Sleep(1);
        GetTravelLocations(WorldInfo.StreamingLevels[SentinelIdx].PackageName, WillowSentinelPC, SentinelTravelArray);
        DoSentinelActionPerLoadedMap();
        Sleep(1);
        WorldInfo.ForceGarbageCollection(true);
        ++ SentinelIdx;
        // [Loop Continue]
        goto J0xA7;
    }
    // End:0x284
    if(WorldInfo.StreamingLevels.Length == 0)
    {
        GetTravelLocations(WorldInfo.StreamingLevels[SentinelIdx].PackageName, WillowSentinelPC, SentinelTravelArray);
        DoSentinelActionPerLoadedMap();
        Sleep(1);
        WorldInfo.ForceGarbageCollection(true);
    }
    SetIncrementsForLoops(float(SentinelTravelArray.Length));
    SentinelIdx = 0;
    J0x2A5:

    // End:0x376 [Loop If]
    if(SentinelIdx < WorldInfo.StreamingLevels.Length)
    {
        // End:0x368
        if(LevelStreamingAlwaysLoaded(WorldInfo.StreamingLevels[SentinelIdx]) != none)
        {
            WillowSentinelPC.ClientUpdateLevelStreamingStatus(WorldInfo.StreamingLevels[SentinelIdx].PackageName, true, true, true);
        }
        ++ SentinelIdx;
        // [Loop Continue]
        goto J0x2A5;
    }
    // End:0xB0B
    if(WorldInfo.GetStreamingPersistentMapName() != 'menumap')
    {
        WillowSentinelPC.bIsUsingStreamingVolumes = true;
        // End:0x441
        if(SelectedCharacterClass == "Soldier")
        {            
            WillowSentinelPC.ConsoleCommand("playerselectclass GD_Soldier.Character.CharClass_Soldier");            
        }
        else
        {
            // End:0x4C1
            if(SelectedCharacterClass == "Assassin")
            {                
                WillowSentinelPC.ConsoleCommand("playerselectclass GD_Assassin.Character.CharClass_Assassin");                
            }
            else
            {
                // End:0x538
                if(SelectedCharacterClass == "Siren")
                {                    
                    WillowSentinelPC.ConsoleCommand("playerselectclass GD_Siren.Character.CharClass_Siren");                    
                }
                else
                {                    
                    WillowSentinelPC.ConsoleCommand("playerselectclass GD_Mercenary.Character.CharClass_Mercenary");
                }
            }
        }
        Sleep(1);        
        WillowSentinelPC.ConsoleCommand("BalanceMe");
        Sleep(1);        
        WillowSentinelPC.ConsoleCommand("DemiGodAll 1");
        WillowSentinelPC.StartFire();
        Sleep(5);
        WillowSentinelPC.StopFire();
        Sleep(5);
        WillowSentinelPC.NextWeapon();
        Sleep(1);
        WillowSentinelPC.StartFire();
        Sleep(1);
        WillowSentinelPC.StopFire();
        Sleep(1);
        WillowSentinelPC.PrevWeapon();
        Sleep(3);
        WillowSentinelPC.PlayerInput.Jump();
        Sleep(3);        
        WillowSentinelPC.ConsoleCommand("ToggleDuck");
        Sleep(2);        
        WillowSentinelPC.ConsoleCommand("ToggleDuck");
        Sleep(5);
        TestBackMenu(5, 5);
        Sleep(6);
        WillowSentinelPC.Sentinel_PostAcquireTravelTheWorldPoints();
        Sleep(6);
        SentinelTravelArray.AddItem(SentinelTravelArray[0];
        SentinelNavigationIdx = 0;
        J0x821:

        // End:0xB0B [Loop If]
        if(SentinelNavigationIdx < SentinelTravelArray.Length)
        {
            // End:0x84B
            if(!DownTrace())
            {                
            }
            else
            {
                WillowSentinelPC.SetLocation(SentinelTravelArray[SentinelNavigationIdx]);
                WillowSentinelPC.Pawn.SetLocation(SentinelTravelArray[SentinelNavigationIdx]);
                WillowSentinelPC.SetRotation(rot(0, 0, 0));
                WillowSentinelPC.Pawn.SetRotation(rot(0, 0, 0));
                // End:0x927
                if(!DownTrace())
                {                    
                }
                else
                {
                    Sleep(1.5);
                    J0x92F:

                    bSentinelStreamingLevelStillLoading = false;
                    SentinelIdx = 0;
                    J0x946:

                    // End:0x9DC [Loop If]
                    if(SentinelIdx < WorldInfo.StreamingLevels.Length)
                    {
                        // End:0x9CE
                        if(WorldInfo.StreamingLevels[SentinelIdx].bHasLoadRequestPending == true)
                        {
                            bSentinelStreamingLevelStillLoading = true;
                            Sleep(1);
                            // [Explicit Break]
                            goto J0x9DC;
                        }
                        ++ SentinelIdx;
                        // [Loop Continue]
                        goto J0x946;
                    }
                    J0x9DC:

                    // End:0x92F
                    if(!(bSentinelStreamingLevelStillLoading == false))
                        goto J0x92F;
                    WorldInfo.ForceGarbageCollection(true);
                    Sleep(0.1);
                    SentinelIdx = 0;
                    J0xA1F:

                    // End:0xAC6 [Loop If]
                    if(SentinelIdx < 8)
                    {
                        WillowSentinelPC.SetRotation(rot(0, 1, 0) * float(8192 * SentinelIdx));
                        Sleep(1);                        
                        WillowSentinelPC.ConsoleCommand("KillEnemies");
                        Sleep(1);
                        SentinelIdx += NumRotationsIncrement;
                        // [Loop Continue]
                        goto J0xA1F;
                    }
                    // End:0xAFB
                    foreach CommandsToRunAtEachTravelTheWorldNode(CommandStringToExec,)
                    {                        
                        ConsoleCommand(CommandStringToExec);                        
                    }                    
                }
            }
            SentinelNavigationIdx += 1;
            // [Loop Continue]
            goto J0x821;
        }
    }    
    ConsoleCommand("mem dumpinfo");
    bFinishedTraversal = true;
    SentinelTravelArray.Remove(0, SentinelTravelArray.Length;
    Sleep(10);
    AutomatedTravelToNextMap();
    stop;            
}
