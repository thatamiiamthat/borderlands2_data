function string GetNextAutomatedTestingMap()
{
    local string MapName;

    // End:0x2EF
    if(bUsingAutomatedTestingMapList)
    {
        // End:0x62
        if((AutomatedTestingMapIndex >= 0) && Len(AutomatedMapTestingTransitionMap) > 0)
        {
            ++ AutomatedTestingMapIndex;
            AutomatedTestingMapIndex *= float(-1);
            MapName = AutomatedMapTestingTransitionMap;            
        }
        else
        {
            // End:0x85
            if(Len(AutomatedMapTestingTransitionMap) > 0)
            {
                AutomatedTestingMapIndex *= float(-1);
            }
            // End:0xBC
            if(++ AutomatedTestingMapIndex >= AutomatedMapTestingList.Length)
            {
                AutomatedTestingMapIndex = 0;
                ++ NumMapListCyclesDone;
                UnknownLocal_1 = true;
            }
            MapName = AutomatedMapTestingList[AutomatedTestingMapIndex];
        }
        // End:0x18F
        if(AutomatedTestingTravelType == "open")
        {
            // End:0x18C
            if((NumMapListCyclesDone >= NumAutomatedMapTestingCycles) && NumAutomatedMapTestingCycles != 0)
            {
                // End:0x159
                if(bCheckingForMemLeaks)
                {                    
                    ConsoleCommand("DEFERRED_STOPMEMTRACKING_AND_DUMP");
                }
                // End:0x18C
                if(bExitOnCyclesComplete)
                {
                    EndSentinelRun(2);                    
                    ConsoleCommand("EXIT");
                }
            }            
        }
        else
        {
            // End:0x2E4
            foreach WorldInfo.AllControllers(class'PlayerController', UnknownLocal_3)
            {
                // End:0x20B
                if(UnknownLocal_1)
                {
                    ++ UnknownLocal_3.PlayerReplicationInfo.AutomatedTestingData.NumMapListCyclesDone;
                }
                // End:0x2E3
                if((UnknownLocal_3.PlayerReplicationInfo.AutomatedTestingData.NumMapListCyclesDone >= NumAutomatedMapTestingCycles) && NumAutomatedMapTestingCycles != 0)
                {
                    // End:0x2B0
                    if(bCheckingForMemLeaks)
                    {                        
                        ConsoleCommand("DEFERRED_STOPMEMTRACKING_AND_DUMP");
                    }
                    // End:0x2E3
                    if(bExitOnCyclesComplete)
                    {
                        EndSentinelRun(2);                        
                        ConsoleCommand("EXIT");
                    }
                }                
            }            
        }
        return MapName;
    }
    return "";
    //return ReturnValue;    
}

function AutomatedTravelToNextMap()
{
    local string MapName, TransitionMapCmdLine, URLString;

    MapName = GetNextAutomatedTestingMap();
    // End:0x15F
    if(AutomatedTestingTravelType == "open")
    {
        URLString = WorldInfo.GetLocalURL();
        UnknownLocal_1 = Len(URLString);
        UnknownLocal_3 = InStr(URLString, "?");
        // End:0xA9
        if(UnknownLocal_3 != -1)
        {
            URLString = Right(URLString, UnknownLocal_1 - UnknownLocal_3);
        }
        TransitionMapCmdLine = (((("?AutomatedTestingMapIndex=" $ string(AutomatedTestingMapIndex)) $ "?NumberOfMatchesPlayed=") $ string(NumberOfMatchesPlayed)) $ "?NumMapListCyclesDone=") $ string(NumMapListCyclesDone);        
        ConsoleCommand(("open " $ MapName) $ TransitionMapCmdLine);        
    }
    else
    {
        // End:0x1AD
        if(AutomatedTestingTravelType == "debug")
        {
            WorldInfo.Game.RestartGame();
            return;            
        }
        else
        {
            // End:0x4CC
            if(AutomatedTestingTravelType == "willow")
            {
                // End:0x22F
                if(WorldInfo.GetStreamingPersistentMapName() == 'menumap')
                {
                    WillowGameInfo(WorldInfo.Game).TestStartGame();
                    return;
                }
                // End:0x38E
                if(Len(AutomatedMapTestingTransitionMap) > 0)
                {
                    // End:0x38B
                    if(AutomatedTestingMapIndex < 0)
                    {
                        UnknownLocal_5 = class'WillowGlobals'.static.GetWillowGlobals();
                        // End:0x38B
                        if(UnknownLocal_5 != none)
                        {
                            UnknownLocal_7 = UnknownLocal_5.GetFastTravelStationsLookup();
                            // End:0x38B
                            if(UnknownLocal_7 != none)
                            {
                                UnknownLocal_9 = UnknownLocal_7.FindTravelStationLookupObject(StationDefName);
                                // End:0x38B
                                if(UnknownLocal_9 != none)
                                {
                                    // End:0x38B
                                    if(!UnknownLocal_9.IsA('FastTravelStationDefinition') || !WillowSentinelPC.Pawn.IsA('WillowVehicle'))
                                    {
                                        WillowGameInfo(WorldInfo.Game).InitiateTravel(WillowSentinelPC,,,, UnknownLocal_9);
                                    }
                                }
                            }
                        }
                    }                    
                }
                else
                {
                    UnknownLocal_5 = class'WillowGlobals'.static.GetWillowGlobals();
                    // End:0x4CC
                    if(UnknownLocal_5 != none)
                    {
                        UnknownLocal_7 = UnknownLocal_5.GetFastTravelStationsLookup();
                        // End:0x4CC
                        if(UnknownLocal_7 != none)
                        {
                            UnknownLocal_9 = UnknownLocal_7.FindTravelStationLookupObject(name(MapName));
                            // End:0x4CC
                            if(UnknownLocal_9 != none)
                            {
                                // End:0x4CC
                                if(!UnknownLocal_9.IsA('FastTravelStationDefinition') || !WillowSentinelPC.Pawn.IsA('WillowVehicle'))
                                {
                                    WillowGameInfo(WorldInfo.Game).InitiateTravel(WillowSentinelPC,,,, UnknownLocal_9);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    DoTravelTheWorld();
    //return;    
}

