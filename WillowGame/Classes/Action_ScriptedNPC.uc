function SetupLoadBalanceDefaults()
{
    local editinline WillowAIComponent AIComp;

    AIComp = WillowAIComponent(AI.GetAIComponent());
    MyWillowPawn.SetPhysics(0);
    AIComp.UpdateRate = 0.5;
    AIComp.TickThrottleTime = 0.5 + (0.5 * FRand());
    //return;    
}

function SetupLoadBalancePathing()
{
    local editinline WillowAIComponent AIComp;

    // End:0xDD
    if(!MyWillowPawn.IsDead())
    {
        AIComp = WillowAIComponent(AI.GetAIComponent());
        AIComp.TickThrottleTime = 0.1;
        AIComp.UpdateRate = 0.2;
        // End:0xDD
        if(MyWillowPawn.CurrentPerch == none)
        {
            MyWillowPawn.SetPhysics(12);
        }
    }
    //return;    
}

function SetMoveFacingPolicy()
{
    // End:0xD1
    if(int(MyWillowPawn.GetMoveStyle()) == int(0))
    {
        // End:0x91
        if(MyWillowMind.ScriptedFocus != none)
        {
            MyWillowMind.SetFacingPolicy(2, MyWillowMind.ScriptedFocus);            
        }
        else
        {
            MyWillowMind.SetFacingPolicy(2, MyWillowMind.ScriptedMoveTarget);
        }
    }
    //return;    
}

