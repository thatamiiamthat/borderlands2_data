function CheckStateTransition()
{
    local name DesiredState;

    // End:0xA7
    if((MyWillowMind.ScriptedMoveTarget == none) && MyWillowMind.LastPatrolNode != none)
    {
        MyWillowMind.ForceMoveToActor(MyWillowMind.LastPatrolNode);
        MyWillowMind.LastPatrolNode = none;
    }
    DesiredState = GetDesiredStateName();
    // End:0xE5
    if(DesiredState == 'None')
    {
        DesiredState = 'ScriptedHold';
    }
    // End:0x104
    if(DesiredState != GetStateName())
    {
        GotoState(DesiredState);
    }
    //return;    
}

