class SeqAct_PrimaryPlayerBusyDelay extends SeqAct_Latent
    native(Sequence)
    forcescriptorder(true)
    hidecategories(Mobile,Object);

var WillowPlayerController PrimaryPlayer;

event bool Update(float DeltaTime)
{
    UnknownLocal_1 = false;
    // End:0x93
    if((PrimaryPlayer != none) && PrimaryPlayer.GFxUIManager != none)
    {
        UnknownLocal_1 = !PrimaryPlayer.CanReceiveTrainingMessage();
        // End:0x90
        if(!UnknownLocal_1)
        {
            PrimaryPlayer.LatentActions.RemoveItem(self;
        }        
    }
    else
    {
        bAborted = true;
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

defaultproperties
{
    ObjName="Primary Player Busy Delay"
    ObjCategory="Misc"
}