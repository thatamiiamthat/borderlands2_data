        ContentDims=(X=0,Y=0)
        ParticleDepth=0
        ScalingMode=ScreenParticleScalingMode.ESPSM_FitToHorizontal
        StopParamsOT=(ScalarParams=none,VectorParams=none)
        StopTime=0
    }
};

