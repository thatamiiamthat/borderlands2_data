interface IScreenParticle extends Interface
    abstract
    native
    hidecategories(Mobile);

enum ScreenParticleScalingMode
{
    ESPSM_FitToHorizontal,
    ESPSM_FitToVertical,
    ESPSM_FitToExterior,
    ESPSM_FitToInterior,
    ESPSM_FitToViewport,
    ESPSM_MAX
};

struct native ScreenParticleModifier
{
    var() array<AttributeScalarParam> ScalarParams;
    var() float CachedValue;

    structdefaultproperties
    {
        ScalarParams=none
        CachedValue=-100000
    }
};

struct native ScreenParticleScalarParamOverTime
{
    var() name ParameterName;
    var() float TotalTime;
    var() float StartValue;
    var() float EndValue;
    var transient float LastValue;

    structdefaultproperties
    {
        ParameterName=None
        TotalTime=0
        StartValue=0
        EndValue=0
        LastValue=0
    }
};

struct native ScreenParticleVectorParamOverTime
{
    var() name ParameterName;
    var() float TotalTime;
    var() Vector VectorStartValue;
    var() Vector VectorEndValue;
    var transient Vector LastValue;

    structdefaultproperties
    {
        ParameterName=None
        TotalTime=0
        VectorStartValue=(X=0,Y=0,Z=0)
        VectorEndValue=(X=0,Y=0,Z=0)
        LastValue=(X=0,Y=0,Z=0)
    }
};

struct native ScreenParticleParamOverTime
{
    var() array<ScreenParticleScalarParamOverTime> ScalarParams;
    var() array<ScreenParticleVectorParamOverTime> VectorParams;

    structdefaultproperties
    {
        ScalarParams=none
        VectorParams=none
