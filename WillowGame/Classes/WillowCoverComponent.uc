}

function ClearCover()
{
    local CoverInfo EmptyCover;

    // End:0x13
    if(GetStateName() == 'WillowCoverComponent')
    {
        return;
    }
    AIPawn.MyWillowMind.AIComponent.ReleaseMovement('Cover', self);
    AIPawn.SMComponent.StopLocal(LastAction);
    AIPawn.SetCoverSlot(EmptyCover);
    AIPawn.SetCoverAction('None');
    AIPawn.SetCoverStance(none);
    AIPawn.SetDefaultPhysics();
    GotoState('Auto');
    //return;    
}

