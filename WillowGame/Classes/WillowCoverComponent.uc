state Enter
{
    ignores UpdateAction;

    function BeginState(name PreviousStateName)
    {
        AIPawn.SetPhysics(0);
        PlayTimedAction(GetStance().Enter);
        AIPawn.MyWillowMind.AIComponent.HoldMovement('Cover', self);
        AIPawn.InterpRotation(GetCoverRotation(AIPawn.MyCoverState.Cover), 0.2, true, true);
        AIPawn.InterpLocation(GetCoverLocation(AIPawn.MyCoverState.Cover), 0.2, true, true);
        //return;        
    }

    function ActionFinished()
    {
        // End:0x29
        if((GetAction()) == 'None')
        {
            GotoState('Exit');            
        }
        else
        {
            // End:0x52
            if((GetAction()) == 'Idle')
            {
                GotoState('Idle');                
            }
            else
            {
                // End:0x78
                if((GetAction()) == 'Fire')
                {
                    GotoState('FireEnter');
                }
            }
        }
        //return;        
    }
    stop;    
}

