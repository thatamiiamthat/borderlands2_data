function PlayTimedAction(SpecialMove_Cover Action)
{
    LastAction = Action;
    UnknownLocal_1 = AIPawn.SMComponent.PlayLocal(Action);
    AIPawn.SetTimer(UnknownLocal_1, false, 'ActionFinished', self);
