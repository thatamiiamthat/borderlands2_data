function SetActivePanelSortConfiguration(SortFilterConfiguration NewConfiguration)
{
    // End:0x38
    if(bOnLeftPanel)
    {
        StoragePanel.ApplySortConfiguration(NewConfiguration);        
    }
    else
    {
        PlayerPanel.ApplySortConfiguration(NewConfiguration);
    }
    //return;    
}

function SetActivePanelSelectIndexByThing(WillowInventory Thing)
{
    // End:0x38
    if(bOnLeftPanel)
    {
        StoragePanel.SetSelectedIndexByThing(Thing);        
    }
    else
    {
        PlayerPanel.SetSelectedIndexByThing(Thing);
    }
    //return;    
}

function int GetInspectedItemOverridePrice(WillowInventory Thing)
{
    return TwoPanelInterface.GetOverridePriceForInventory(Thing);
    //return ReturnValue;    
}

function Engine.WillowInventoryDefinition.ECurrencyType GetInspectedItemCurrencyType(WillowInventory Thing)
{
    return TwoPanelInterface.GetCurrencyTypeForInventory(Thing);
    //return ReturnValue;    
}

function InventoryListPanelGFxObject GetCurrentPanel()
{
    return ((bOnLeftPanel) ? StoragePanel : PlayerPanel);
    //return ReturnValue;    
}

final function GFxObject GetCurrentCellObject()
{
    return GetCurrentPanel().GetCellObject();
    //return ReturnValue;    
}

function bool OnValidCell()
{
    return GetCurrentPanel().IsCurrentCellValid();
    //return ReturnValue;    
}

function InitForPC()
{
    GetObject("header").GetObject("lb").SetBool("_visible", false);
    GetObject("header").GetObject("rb").SetBool("_visible", false);
    GetObject("header").GetObject("pcCloseButton").SetBool("_visible", true);
    //return;    
}

function InitForConsole()
{
    GetObject("header").GetObject("lb").SetBool("_visible", true);
    GetObject("header").GetObject("rb").SetBool("_visible", true);
    GetObject("header").GetObject("pcCloseButton").SetBool("_visible", false);
    //return;    
}

function OnCellPressed(BaseInventoryPanelGFxObject Panel)
{
    super.OnCellPressed(Panel);
    // End:0x4C
    if(bOwningMovieHandlesCellPress)
    {
        TwoPanelInterface.OnCellPressed(Panel);        
    }
    else
    {
        // End:0x6F
        if(IsTransferring())
        {
            ConfirmTransfer('None');            
        }
        else
        {
            StartTransfer('None');
        }
    }
    //return;    
}

