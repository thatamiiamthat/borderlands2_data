function ConfirmTransfer(name ukey)
{
    local IWillowStorable SwappableStorage, TransferableStorage;

    SwappableStorage = TwoPanelInterface.GetStorageReferenceForSwapping();
    TransferableStorage = TwoPanelInterface.GetStorageReferenceForTransferring();
    TwoPanelInterface.SetItemLocation(TransferringThing);
    UnknownLocal_1 = GetSelectedThingThroughInterface();
    // End:0x154
    if(UnknownLocal_1 != none)
    {
        TwoPanelInterface.SetItemLocation(UnknownLocal_1);
        // End:0xFB
        if(bOnLeftPanel)
        {
            SwappableStorage.Swap(UnknownLocal_1, TransferringThing);            
        }
        else
        {
            SwappableStorage.Swap(TransferringThing, UnknownLocal_1);
        }
        ParentMovie.PlayUISound('Swap');        
    }
    else
    {
        // End:0x1B5
        if(bOnLeftPanel)
        {
            TransferableStorage.Put(TransferringThing);
            ParentMovie.PlayUISound('Deposit');            
        }
        else
        {
            TransferableStorage.Get(TransferringThing);
            ParentMovie.PlayUISound('Withdrawl');
        }
    }
    StoragePanel.FlourishActiveCell();
    PlayerPanel.FlourishActiveCell();
    Refresh();
    FinishTransfer(ukey, true);
    //return;    
}

function CancelTransfer(name ukey)
{
    FinishTransfer(ukey, false);
    ParentMovie.PlayUISound('CancelTransfer');
    //return;    
}

function FinishTransfer(name TriggerKey, bool bCompleted)
{
    local name FocusPanelName, UnFocusPanelName;

    TransferringThing = none;
    QueueNewInputHandler(NormalInputKey, TriggerKey);
    DynamicCardName = 'Main';
    // End:0xA1
    if(bStartedOnLeftPanel)
    {
        SwitchToLeftPanel();
        FocusPanelName = 'Storage';
        UnFocusPanelName = 'Player';
        UnknownLocal_1 = StoragePanel;
        UnknownLocal_3 = PlayerPanel;        
    }
    else
    {
        SwitchToRightPanel();
        FocusPanelName = 'Player';
        UnFocusPanelName = 'Storage';
        UnknownLocal_1 = PlayerPanel;
        UnknownLocal_3 = StoragePanel;
    }
    TweenPanelToPosition(FocusPanelName, 0);
    TweenPanelToPosition(UnFocusPanelName, 1);
    UnknownLocal_1.OnSettingPanelForTransferring(true, false);
    UnknownLocal_3.OnSettingPanelForTransferring(false, false);
    TweenCards(false, bStartedOnLeftPanel);
    ItemCards[0].ItemCard.SetBackgroundStyle("highlight");
    StoragePanel.bCanRolloverEmptyCells = false;
    PlayerPanel.bCanRolloverEmptyCells = false;
    //return;    
}

