class Behavior_DamageClassSwitch extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

enum EDamageClassSwitchValues
{
    DCSV_Player,
    DCSV_Pawn,
    DCSV_Vehicle,
    DCSV_InteractiveObject,
    DCSV_MAX
};

var(Action) Object HitObject;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    // End:0x44
    if(WillowPlayerPawn(HitObject) != none)
    {
        class'BehaviorKernel'.static.ActivateBehaviorOutputLink(KernelInfo, 0);        
    }
    else
    {
        // End:0x88
        if(Pawn(HitObject) != none)
        {
            class'BehaviorKernel'.static.ActivateBehaviorOutputLink(KernelInfo, 1);            
        }
        else
        {
            // End:0xCD
            if(Vehicle(HitObject) != none)
            {
                class'BehaviorKernel'.static.ActivateBehaviorOutputLink(KernelInfo, 2);                
            }
            else
            {
                // End:0x112
                if(WillowInteractiveObject(HitObject) != none)
                {
                    class'BehaviorKernel'.static.ActivateBehaviorOutputLink(KernelInfo, 3);                    
                }
                else
                {
                    // End:0x11A
                    if(!false)
                    {
                        return;
                    }
                }
            }
        }
    }
    //return;    
}

defaultproperties
{
    Context=(bSupportsDefaultOutputLink=0)
    OutputLinks(0)=(LinkId=0,LinkDesc="Player")
    OutputLinks(1)=(LinkId=1,LinkDesc="Pawn")
    OutputLinks(2)=(LinkId=2,LinkDesc="Vehicle")
    OutputLinks(3)=(LinkId=3,LinkDesc="InteractiveObject")
