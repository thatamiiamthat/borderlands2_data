class SeqAct_ExecuteSkill extends SequenceAction
    native(Sequence)
    forcescriptorder(true)
    hidecategories(Mobile,Object);

enum EExecuteSkillSequenceInput
{
    SEQUENCE_ActivateSkill,
    SEQUENCE_DeactivateSkill,
    SEQUENCE_ToggleSkill,
    SEQUENCE_MAX
};

var(Action) bool bAllowMultipleInstancesOfSkill;
var bool bIsSkillActive;
var(Action) editinline SkillDefinition SkillEffect;

event bool ExecuteSkill(Controller SkillInstigator, SkillDefinition Definition, SeqAct_ExecuteSkill.EExecuteSkillSequenceInput SequenceInput)
{
    // End:0x2C7
    if(((SkillInstigator != none) && int(SkillInstigator.Role) == int(ROLE_Authority)) && Definition != none)
    {
        // End:0x212
        if(WillowGameInfo(SkillInstigator.WorldInfo.Game).GetSkillManager().IsSkillActive(SkillInstigator, Definition))
        {
            switch(SequenceInput)
            {
                // End:0x17D
                case 0:
                    // End:0x173
                    if(bAllowMultipleInstancesOfSkill)
                    {
                        UnknownLocal_1 = WillowGameInfo(SkillInstigator.WorldInfo.Game).GetSkillManager().ActivateSkill(SkillInstigator, Definition);                        
                    }
                    else
                    {
                        UnknownLocal_1 = true;
                    }
                    // End:0x20F
                    break;
                // End:0x182
                case 1:
                // End:0x20C
                case 2:
                    WillowGameInfo(SkillInstigator.WorldInfo.Game).GetSkillManager().DeactivateSkill(SkillInstigator, Definition);
                    UnknownLocal_1 = false;
                    // End:0x20F
                    break;
                // End:0xFFFF
                default:
                    break;
            }            
        }
        else
        {
            switch(SequenceInput)
            {
                // End:0x22A
                case 0:
                // End:0x2B5
                case 2:
                    UnknownLocal_1 = WillowGameInfo(SkillInstigator.WorldInfo.Game).GetSkillManager().ActivateSkill(SkillInstigator, Definition);
                    // End:0x2C7
                    break;
                // End:0x2C4
                case 1:
                    UnknownLocal_1 = false;
                    // End:0x2C7
                    break;
                // End:0xFFFF
                default:
                    break;
            }
        }
    }
    else
    {
        return UnknownLocal_1;
        //return ReturnValue;        
    }
}

