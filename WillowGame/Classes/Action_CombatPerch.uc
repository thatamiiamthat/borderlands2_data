class Action_CombatPerch extends Action_FollowPath
    editinlinenew
    hidecategories(Mobile,Object,HideMe,ActionSequence,LoadBalance,Movement);

var(Perch) const bool bMustHaveTarget;
var(Perch) const bool bTeleport;
var(Perch) const bool bPickClosestPerch;

event name CanRun()
{
    local name SuperVal;

    SuperVal = super(ActionSequence).CanRun();
    // End:0x35
    if(SuperVal != 'None')
    {
        return SuperVal;
    }
    // End:0x5D
    if(bMustHaveTarget && Target == none)
    {
        return 'NoTarget';
    }
    MyWillowMind.CheckForPerch(true, bPickClosestPerch);
    MyWillowPawn.CurrentPerch = MyWillowMind.CombatPerch;
    // End:0xF2
    if(MyWillowPawn.CurrentPerch == none)
    {
        return 'NoPerch';
    }
    // End:0x186
    if(!MyWillowPawn.CurrentPerch.PerchDef.GetPerchData(MyWillowPawn.BodyClass.BodyTag, PerchData))
    {
        return 'InvalidPerch';
    }
    // End:0x1B0
    if(!bTeleport && !PathIsValid())
    {
        return 'NoPathToPerch';
    }
    return 'None';
    //return ReturnValue;    
}

event Start()
{
    super(Action_Burrow).Start();
    InvalidatePath();
    // End:0x113
    if(bTeleport)
    {
        MyWillowPawn.SetLocation(MyWillowPawn.CurrentPerch.Location);
        MyWillowPawn.SetRotation(MyWillowPawn.CurrentPerch.Rotation);
        MyWillowMind.SetRotation(MyWillowPawn.CurrentPerch.Rotation);
        GotoState('DoPerch');        
    }
    else
    {
        GotoState('MoveToPerch');
    }
    SetPawnMovementSpeed(1);
    //return;    
}

event Stop()
{
    super.Stop();
    // End:0x83
    if(MyWillowMind.CombatPerch != none)
    {
        MyWillowMind.CombatPerch.User = none;
        MyWillowMind.CombatPerch = none;
    }
    //return;    
}

event bool PathFind()
{
    // End:0x51
    if(((MyWillowMind.CombatPerch == none) || bTeleport) || ReachedDestination())
    {
        InvalidatePath();
        return false;        
    }
    else
    {
        // End:0x63
        if(PathIsValid())
        {
            return false;            
        }
        else
        {
            CreateActorPath(MyWillowMind.CombatPerch, MyWillowMind.CombatPerch.PawnArrivalRadius);
            return true;
        }
    }
    //return ReturnValue;    
}

state MoveToPerch
{Begin:

    CheckCloaked(1);
    J0x0D:

    WaitForPath();
    FollowPath();
    Sleep(0);
    // End:0x0D
    if(!(ReachedDestination()))
        goto J0x0D;
    InvalidatePath();
    MyNavHandle.ClearPath();
    GotoState('DoPerch');
    stop;        
}

state DoPerch
{
    ignores PathFind;

    function BeginState(name PreviousStateName)
    {
        StartAtomic();
        //return;        
    }

    function EndState(name NextStateName)
    {
        StopAtomic();
        //return;        
    }
Begin:

    CheckCloaked(2);
    MoveNode = MyWillowPawn.CurrentPerch;
    // End:0xB9
    if(!bTeleport)
    {
        MyWillowMind.SetFacingPolicy(3,, MyWillowPawn.Location + (Vector(MoveNode.Rotation) * float(1000)));
        WaitForPawnToTurn();
    }
    MyWillowMind.SetFacingPolicy(1);
    J0xDC:

    // End:0x125 [Loop If]
    if(MyWillowPawn.SMComponent.IsPlayingAny())
    {
        Sleep(0);
        // [Loop Continue]
        goto J0xDC;
    }
    SetPerch();
    J0x12F:

    // End:0x14E [Loop If]
    if(bWaitingOnPerch)
    {
        Sleep(0);
        // [Loop Continue]
        goto J0x12F;
    }
    Finish();
    stop;            
}

defaultproperties
{
    bMustHaveTarget=true
}