    //return;    
}

function OnMissionFilteredChanged()
{
    // End:0xE5
    if(((int(CurrentScreen) == int(1)) && bShowWorldMissions) && (int(WPCOwner.Role) < int(ROLE_Authority)) || !WPCOwner.IsPrimaryPlayer())
    {
