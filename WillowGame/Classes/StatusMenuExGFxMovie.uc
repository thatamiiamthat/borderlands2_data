}

function bool CanShowWorldMissionView()
{
    // End:0x12
    if(WorldMissions.Length > 0)
    {
        return true;
    }
    return false;
    //return ReturnValue;    
}

function bool CanToggleMissionView()
{
    // End:0x50
    if(!IsPrimaryHostPlayer())
    {
        // End:0x30
        if(bShowWorldMissions && CanShowClientMissionView())
        {
            return true;            
        }
        else
        {
            // End:0x50
            if(!bShowWorldMissions && CanShowWorldMissionView())
            {
                return true;
            }
        }
    }
    return false;
    //return ReturnValue;    
}

