function extSetCurrentScreen(string ScreenName)
{
    local WillowPlayerController.EBackButtonScreen NewCurrentScreen;

    NewCurrentScreen = GetScreenByName(ScreenName);
    // End:0x4E
    if(int(NewCurrentScreen) == int(CurrentScreen))
    {
        // End:0x4E
        if(int(CurrentScreen) == int(3))
        {
            return;
        }
    }
    // End:0x6E
    if(bHasScreenToCleanup)
    {
        CleanupScreen(CurrentScreen);
    }
    bHasScreenToCleanup = true;
    CurrentScreen = NewCurrentScreen;
    CurrentScreenTime = 0;
    UpdateDesiredCameraPosition();
    switch(ScreenName)
    {
        // End:0xE0
        case "inventory":
            SetupInventoryScreen();
            bDisplayMarketingUnlockDialogOnNextTick = true;
            // End:0x133
            break;
        // End:0xFC
        case "challenges":
            SetupChallengesScreen();
            // End:0x133
            break;
        // End:0x118
        case "missionlog":
            extSetupMissionLogScreen();
            // End:0x133
            break;
        // End:0x130
        case "skills":
            SetupSkillTree();
            // End:0x133
            break;
        // End:0xFFFF
        default:
            break;
    }
    SetVariableString("header.lb.text", "$<StringAliasMap:Tab_Left>");
    SetVariableString("header.rb.text", "$<StringAliasMap:Tab_Right>");
    TryDisplayRewardPanel();
    //return;    
}

function CleanupScreen(WillowPlayerController.EBackButtonScreen Screen)
{
    ClearSplitscreenPanningCache();
    switch(Screen)
    {
        // End:0x101
        case 3:
            // End:0x43
            if(IsComparing())
            {
                extQuitCompare();
                CleanupCompare();
            }
            ClearInventoryRefreshTimer();
            StopMovingHighlight();
            EquippedLabels.Length = 0;
            UsedWeaponTypes.Length = 0;
            UsedManufacturers.Length = 0;
            UsedInvTypes.Length = 0;
            BackpackThings.Length = 0;
            AllThings.Length = 0;
            CachedInventory.Length = 0;
            FreeCellData();
            InventoryPanel.SaveBackpackSortPreference();
            InventoryPanel.FreeCellData();
            InventoryPanel = none;
            // End:0x250
            break;
        // End:0x1AC
        case 2:
            StopMouseDrag();
            // End:0x164
            if(!WPCOwner.GFxUIManager.bPassAxisInputToScreenMovies)
            {
                __OnInputAxis__Delegate = HandleInputAxisPlayerCameraRotation;
            }
            StatusMenuMap.OnClose();
            PlayUISound('ZoomInLoopStop');
            PlayUISound('ZoomOutLoopStop');
            // End:0x250
            break;
        // End:0x1E9
        case 1:
            MissionCategories.Length = 0;
            MissionLogTextList.EmptyData();
            StopMovingHighlight();
            // End:0x250
            break;
        // End:0x21B
        case 5:
            ChallengesPanel.Deinit();
            ChallengesPanel = none;
            // End:0x250
            break;
        // End:0x24D
        case 4:
            SkillTreePanel.HandleClose();
            SkillTreePanel = none;
            // End:0x250
            break;
        // End:0xFFFF
        default:
            break;
    }
    __OnInputKey__Delegate = HandleInputKey;
    //return;    
}

