function MoveHighlight()
{
    local string currentButton;

    currentButton = GetVariableString("currentButton");
    // End:0x7F
    if(currentButton == "moreup")
    {
        // End:0x5E
        if(int(CurrentScreen) == int(3))
        {
            extInventoryListMove("Up");            
        }
        else
        {
            // End:0x7C
            if(int(CurrentScreen) == int(1))
            {
                LogUp();
            }
        }        
    }
    else
    {
        // End:0xDD
        if(currentButton == "moredn")
        {
            // End:0xBC
            if(int(CurrentScreen) == int(3))
            {
                extInventoryListMove("Down");                
            }
            else
            {
                // End:0xDA
                if(int(CurrentScreen) == int(1))
                {
                    LogDown();
                }
            }            
        }
        else
        {
            // End:0x104
            if(currentButton == "sideup")
            {
                ScrollSidePanel("Up");                
            }
            else
            {
                // End:0x12D
                if(currentButton == "sidedn")
                {
                    ScrollSidePanel("Down");                    
                }
                else
                {
                    StopMovingHighlight();
                }
            }
        }
    }
    //return;    
}

function ConditionallyScroll(string Direction)
{
    // End:0x39
    if(int(CurrentScreen) == int(3))
    {
        // End:0x36
        if(!bContextMenuUp)
        {
            extInventoryListMove(Direction);
        }        
    }
    else
    {
        // End:0x1B5
        if(int(CurrentScreen) == int(1))
        {
            UnknownLocal_1 = GetVariableBool("missions.missionSummary.bHovering");
            // End:0x18C
            if(UnknownLocal_1)
            {
                // End:0x10E
                if(Direction == "Up")
                {
                    SetVariableNumber("missions.missionSummary.description.scroll", GetVariableNumber("missions.missionSummary.description.scroll") - float(1));                    
                }
                else
                {
                    SetVariableNumber("missions.missionSummary.description.scroll", GetVariableNumber("missions.missionSummary.description.scroll") + float(1));
                }
                SetScrollArrows();                
            }
            else
            {
                // End:0x1AB
                if(Direction == "Up")
                {
                    LogUp();                    
                }
                else
                {
                    LogDown();
                }
            }
        }
    }
    //return;    
}

