event OnClose()
{
    PlayUISound('StatusMenuClosed');
    CleanupScreen(CurrentScreen);
    ClearInventoryRefreshTimer();
    StopMovingHighlight();
    // End:0xB6
    if((int(WPCOwner.QuickAccessScreen) == int(0)) && int(WPCOwner.ContextualPromptScreen) == int(0))
    {
        WPCOwner.LastActiveStatusMenuScreen = CurrentScreen;
    }
    WPCOwner.QuickAccessScreen = 0;
    WPCOwner.ClearContextualPromptScreen();
    UnknownLocal_1 = WillowPlayerReplicationInfo(WPCOwner.PlayerReplicationInfo);
    UnknownLocal_1.UnregisterCurrencyChangedDelegate(HandleCurrencyChanged);
    FreeCellData();
    ClientMissions.Length = 0;
    WorldMissions.Length = 0;
    WPCOwner.GetInventoryPawn().ClearTimer('RegisterMissionDelegates', self);
    // End:0x31B
    if(WPCOwner.WorldInfo.GRI != none)
    {
        UnknownLocal_3 = WillowGameReplicationInfo(WPCOwner.WorldInfo.GRI).MissionTracker;
        // End:0x31B
        if((UnknownLocal_3 != none) && UnknownLocal_3.IsDataValid())
        {
            UnknownLocal_3.ClearActiveMissionChangedDelegate(OnActiveMissionChanged);
            UnknownLocal_3.ClearMissionStatusChangedDelegate(OnMissionStatusChanged);
            UnknownLocal_3.ClearMissionObjectivesChangedDelegate(OnMissionObjectivesChanged);
            UnknownLocal_3.ClearMissionFilteredChangedDelegate(OnMissionFilteredChanged);
        }
    }
    super.OnClose();
    //return;    
}

