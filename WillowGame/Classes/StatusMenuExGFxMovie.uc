    }
    //return;    
}

function extGenericButtonClicked(string ActionName)
{
    local name Action;

    Action = name(ActionName);
    switch(Action)
    {
        // End:0x41
        case 'Close':
            Hide();
            // End:0x52F
            break;
        // End:0x14E
        case 'Sort':
            switch(CurrentScreen)
            {
                // End:0x85
                case 1:
                    PlayUISound('HorizontalMovement');
                    ChangeMissionLogSorting();
                    // End:0x14B
                    break;
                // End:0xC1
                case 5:
                    ChallengesPanel.ChallengesPanel.ChangeSort();
                    // End:0x14B
                    break;
                // End:0x148
                case 3:
                    // End:0x145
                    if(InventoryPanel.BackpackPanel.bCanChangeSort)
                    {
                        PlayUISound('HorizontalMovement');
                        InventoryPanel.BackpackPanel.extOnChangeSort(1);
                    }
                    // End:0x14B
                    break;
                // End:0xFFFF
                default:
                    break;
            }
            // End:0x52F
            break;
        // End:0x169
        case 'missionlog':
            TrySwitchToScreen(1);
            // End:0x52F
            break;
        // End:0x184
        case 'Map':
            TrySwitchToScreen(2);
            // End:0x52F
            break;
        // End:0x19F
        case 'Inventory':
            TrySwitchToScreen(3);
            // End:0x52F
            break;
        // End:0x1BA
        case 'Skills':
            TrySwitchToScreen(4);
            // End:0x52F
            break;
        // End:0x1D5
        case 'Challenges':
            TrySwitchToScreen(5);
            // End:0x52F
            break;
        // End:0x2D8
        case 'arrowleft':
            switch(CurrentScreen)
            {
                // End:0x21E
                case 3:
                    InventoryPanel.SwitchFocus(1, true);
                    // End:0x2D5
                    break;
                // End:0x248
                case 5:
                    ChallengesPanel.SwitchFocus(0, true);
                    // End:0x2D5
                    break;
                // End:0x2D2
                case 4:
                    SkillTreePanel.OverrideBranchNum = SkillTreePanel.GetEffectiveCurrentBranchNumber() - 1;
                    SkillTreePanel.UpdateBranchDepths();
                    SkillTreePanel.UpdateBranchLocations(false, 4);
                    // End:0x2D5
                    break;
                // End:0xFFFF
                default:
                    break;
            }
            // End:0x52F
            break;
        // End:0x3DB
        case 'arrowright':
            switch(CurrentScreen)
            {
                // End:0x321
                case 3:
                    InventoryPanel.SwitchFocus(0, true);
                    // End:0x3D8
                    break;
                // End:0x34B
                case 5:
                    ChallengesPanel.SwitchFocus(1, true);
                    // End:0x3D8
                    break;
                // End:0x3D5
                case 4:
                    SkillTreePanel.OverrideBranchNum = SkillTreePanel.GetEffectiveCurrentBranchNumber() + 1;
                    SkillTreePanel.UpdateBranchDepths();
                    SkillTreePanel.UpdateBranchLocations(false, 4);
                    // End:0x3D8
                    break;
                // End:0xFFFF
                default:
                    break;
            }
            // End:0x52F
            break;
        // End:0x44B
        case 'selecttree1':
            SkillTreePanel.OverrideBranchNum = 0;
            SkillTreePanel.UpdateBranchDepths();
            SkillTreePanel.UpdateBranchLocations(false, 4);
            // End:0x52F
            break;
        // End:0x4BB
        case 'selecttree2':
            SkillTreePanel.OverrideBranchNum = 1;
            SkillTreePanel.UpdateBranchDepths();
            SkillTreePanel.UpdateBranchLocations(false, 4);
            // End:0x52F
            break;
        // End:0x52C
        case 'selecttree3':
            SkillTreePanel.OverrideBranchNum = 2;
            SkillTreePanel.UpdateBranchDepths();
            SkillTreePanel.UpdateBranchLocations(false, 4);
            // End:0x52F
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

function extChallLogUp()
{
    ChallengesPanel.ChallengesPanel.ScrollLog(0);
    //return;    
}

function extChallLogDown()
{
    ChallengesPanel.ChallengesPanel.ScrollLog(1);
    //return;    
}

function TrySwitchToScreen(WillowPlayerController.EBackButtonScreen DesiredScreen)
{
    // End:0x18B
    if(TicksUntilPanelSwitchAllowed == 0)
    {
        TicksUntilPanelSwitchAllowed = 1;
        switch(DesiredScreen)
        {
            // End:0x8A
            case 1:
                // End:0x87
                if((WorldMissions.Length > 0) || ClientMissions.Length > 0)
                {
                    InvalidateQuickAccess();
                    GotoAndStop("missionlog");
                    PlayUISound('TabMovement');
                }
                // End:0x18B
                break;
            // End:0xBE
            case 2:
                InvalidateQuickAccess();
                GotoAndStop("map");
                PlayUISound('TabMovement');
                // End:0x18B
                break;
            // End:0x107
            case 3:
                // End:0x104
                if(!HasVehicleRestrictions())
                {
                    InvalidateQuickAccess();
                    GotoAndStop("inventory");
                    PlayUISound('TabMovementInventory');
                }
                // End:0x18B
                break;
            // End:0x14D
            case 4:
                // End:0x14A
                if(!HasVehicleRestrictions())
                {
                    InvalidateQuickAccess();
                    GotoAndStop("skills");
                    PlayUISound('TabMovementSkills');
                }
                // End:0x18B
                break;
            // End:0x188
            case 5:
                InvalidateQuickAccess();
                GotoAndStop("challenges");
                PlayUISound('TabMovement');
                // End:0x18B
                break;
            // End:0xFFFF
            default:
                break;
        }
    }
    else
    {
        //return;        
    }
}

