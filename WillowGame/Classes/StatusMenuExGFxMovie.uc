function bool HandleMapInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0x3F5
    if(!HandleInputKey(ControllerId, ukey, uevent))
    {
        // End:0x169
        if(ukey == 'LeftMouseButton')
        {
            // End:0x146
            if(int(uevent) == int(0))
            {
                // End:0x143
                if(((Abs(StatusMenuMap.CursorPos.X) * 2) < StatusMenuMap.ViewSize.X) && (Abs(StatusMenuMap.CursorPos.Y) * 2) < StatusMenuMap.ViewSize.Y)
                {
                    bDraggingMouse = true;
                }                
            }
            else
            {
                // End:0x164
                if(int(uevent) == int(1))
                {
                    StopMouseDrag();
                }
            }
            return false;            
        }
        else
        {
            // End:0x1A9
            if(ukey == 'MouseScrollUp')
            {
                // End:0x1A6
                if(int(uevent) == int(1))
                {
                    HandleMapZoom(2);
                    return true;
                }                
            }
            else
            {
                // End:0x1E6
                if(ukey == 'MouseScrollDown')
                {
                    // End:0x1E6
                    if(int(uevent) == int(1))
                    {
                        HandleMapZoom(-2);
                        return true;
                    }
                }
            }
        }
        // End:0x324
        if((int(uevent) == int(0)) || int(uevent) == int(2))
        {
            switch(ukey)
            {
                // End:0x244
                case 'Up':
                    return PanMap(0, -1);
                // End:0x265
                case 'Down':
                    return PanMap(0, 1);
                // End:0x286
                case 'Left':
                    return PanMap(-1, 0);
                // End:0x2A7
                case 'Right':
                    return PanMap(1, 0);
                // End:0x2B3
                case 'PageUp':
                // End:0x2BF
                case 'Underscore':
                // End:0x2DD
                case 'Subtract':
                    HandleMapZoom(-2);
                    return true;
                // End:0x2E9
                case 'PageDown':
                // End:0x2F5
                case 'Equals':
                // End:0x313
                case 'Add':
                    HandleMapZoom(2);
                    return true;
                // End:0x321
                case 'RightMouseButton':
                    return true;
                // End:0xFFFF
                default:
                    break;
                }
        }
        else
        {
            // End:0x3F2
            if(int(uevent) == int(1))
            {
                switch(ukey)
                {
                    // End:0x357
                    case 'XboxTypeS_Y':
                    // End:0x397
                    case 'Q':
                        PlayUISound('HorizontalMovement');
                        StatusMenuMap.ToggleLegend();
                        return true;
                    // End:0x3A3
                    case 'XboxTypeS_A':
                    // End:0x3AF
                    case 'Enter':
                    // End:0x3EF
                    case 'RightMouseButton':
                        PlayUISound('Confirm');
                        StatusMenuMap.PlaceCustomObjective();
                        return true;
                    // End:0xFFFF
                    default:
                        break;
                    }
            }
            else
            {                
            }/* !MISMATCHING REMOVE, tried If got Type:Else Position:0x3F2! */
            else
            {
                return true;
            }
            return false;
            //return ReturnValue;            
        }
    }/* !MISMATCHING REMOVE, tried Else got Type:If Position:0x000! */
}

function bool HandleMapInputAxis(int ControllerId, name ukey, float Delta, float DeltaTime)
{
    // End:0x104
    if(!WPCOwner.GFxUIManager.IsMoviePlaying(StatusDef.LatentRewardDef))
    {
        switch(ukey)
        {
            // End:0x8F
            case 'XboxTypeS_LeftX':
                return PanMap(Delta, 0);
            // End:0xBB
            case 'XboxTypeS_LeftY':
                return PanMap(0, -1 * Delta);
            // End:0xDD
            case 'XboxTypeS_RightTriggerAxis':
                HandleMapZoom(Delta, true);
                return true;
            // End:0x101
            case 'XboxTypeS_LeftTriggerAxis':
                HandleMapZoom(-Delta, true);
                return true;
            // End:0xFFFF
            default:
                break;
            }
    }
    else
    {
        return HandleInputAxisPlayerCameraRotation(ControllerId, ukey, Delta, DeltaTime);
        //return ReturnValue;        
    }
}

function HandleMapZoom(float Delta, optional bool bLoopingAudio = false)
{
    UnknownLocal_1
    StatusMenuMap.AnalogScale(Delta);
    StatusMenuMap.UpdateObjects(true);
    StatusMenuMap.ApplyFlash();
    // End:0x100
    if(UnknownLocal_1)
    {
        // End:0xEC
        if(!bLoopingAudio)
        {
            // End:0xE9
            if(MapZoomAudioRefireDelay <= 0)
            {
                MapZoomAudioRefireDelay = MapZoomAudioRefireDuration;
                // End:0xD6
                if(Delta >= float(0))
                {
                    PlayUISound('ZoomIn');                    
                }
                else
                {
                    PlayUISound('ZoomOut');
                }
            }            
        }
        else
        {
            CurrMapZoomAudioLoopCounter += Delta;
        }
    }
    //return;    
}

function StopMouseDrag()
{
    super(WillowGFxThirdPersonMovie).StopMouseDrag();
    bDraggingMouse = false;
    DragMouseLoc.X = -1;
    DragMouseLoc.Y = -1;
    //return;    
}

event HandleMouseDrag(int dx, int DY)
{
    // End:0xAF
    if(bDraggingMouse)
    {
        PanMap((MouseDragScale * float(dx)) / GetPC().WorldInfo.DeltaSeconds, (MouseDragScale * float(DY)) / GetPC().WorldInfo.DeltaSeconds);
    }
    //return;    
}

function bool PanMap(float X, float Y)
{
    // End:0x40
    if(X != float(0))
    {
        StatusMenuMap.PanHorz(X);
        UnknownLocal_1 = true;
    }
    // End:0x80
    if(Y != float(0))
    {
        StatusMenuMap.PanVert(Y);
        UnknownLocal_1 = true;
    }
    // End:0xC9
    if(UnknownLocal_1)
    {
        StatusMenuMap.UpdateObjects(true);
        StatusMenuMap.ApplyFlash();
        return true;
    }
    return false;
    //return ReturnValue;    
}

function SetupSkillTree()
{
    // End:0x3D
    if(SkillTreePanel == none)
    {
        SkillTreePanel = SkillTreeGFxObject(GetVariableObject("skills", class'SkillTreeGFxObject'));
    }
    SkillTreePanel.HandleOpen(WPCOwner, self, SkillDef);
    __OnInputKey__Delegate = HandleSkillsInputKey;
    SetTooltipsText();
    //return;    
}

function InvalidateQuickAccess()
{
    WPCOwner.QuickAccessScreen = 0;
    WPCOwner.ClearContextualPromptScreen();
    //return;    
}

function NotifySkillPointsChanged()
{
    SetTooltipsText();
    //return;    
}

