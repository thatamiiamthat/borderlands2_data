function InventoryContextMenuActivated(string Action)
{
    // End:0x40
    if(Action == "Drop")
    {
        InventoryPanel.DropSelectedThing();
        SetTooltipsText();        
    }
    else
    {
        // End:0x82
        if(Action == "Select")
        {
            InventoryPanel.StartEquip('None', false);            
        }
        else
        {
            // End:0xB8
            if(Action == "Inspect")
            {
                InventoryPanel.InspectSelectedItem();
            }
        }
    }
    //return;    
}

function InventoryContextMenuClosed()
{
    bIgnoreMouseInput = false;
    PCContextMenu = none;
    SendMousePos();
    //return;    
}

function ShowInventoryContextMenu(optional bool bIsCompareMode = false)
{
    local array<PCContextMenuItem> MenuItems;

    (InventoryPanel.GetSelectedThing() != none) && InventoryPanel.GetCurrentCellObject().MouseHitTest();
    // End:0xC1
    if(!IsComparing())
    {
        class'PCContextMenuObject'.static.AddToMenuItemList(MenuItems, class'PCContextMenuObject'.default.Str_SelectCompare, "Select");
    }
    // End:0x11C
    if(!IsComparing())
    {
        class'PCContextMenuObject'.static.AddToMenuItemList(MenuItems, class'PCContextMenuObject'.default.Str_Drop, "Drop");
    }
    class'PCContextMenuObject'.static.AddToMenuItemList(MenuItems, class'PCContextMenuObject'.default.Str_Inspect, "Inspect");
    // End:0x267
    if(MenuItems.Length > 0)
    {
        PCContextMenu = new class'PCContextMenuObject';
        PCContextMenu.Init();
        PCContextMenu.__OnMenuClosed__Delegate = InventoryContextMenuClosed;
        PCContextMenu.__OnMenuItemClicked__Delegate = InventoryContextMenuActivated;
        PCContextMenu.AddMenuItems(MenuItems);
        PCContextMenu.ShowFor(self);
        bIgnoreMouseInput = true;
    }
    //return;    
}

function bool InventoryPanelInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0x38
    if(ukey == 'RightMouseButton')
    {
        // End:0x36
        if(int(uevent) == int(1))
        {
            ShowInventoryContextMenu();
        }
        return true;
    }
    return InventoryPanel.PanelOnInputKey(ControllerId, ukey, uevent);
    //return ReturnValue;    
}

function SetupInventoryScreen()
{
    MaxReadiedWeapons = WInvMgr.GetWeaponReadyMax();
    PrepareListOfAllInventory();
    InitCellData();
    SetInventoryRefreshTimer();
    // End:0x9B
    if(InventoryPanel == none)
    {
        InventoryPanel = StatusMenuInventoryPanelGFxObject(GetVariableObject(StatusDef.InventoryPanelPath, class'StatusMenuInventoryPanelGFxObject'));
    }
    InventoryPanel.Init(self);
    __OnInputKey__Delegate = InventoryPanelInputKey;
    InventoryPanel.ConfigureForPlayer(float(((WPCOwner.IsPrimaryPlayer()) ? 0 : 1)));
    InventoryPanel.SetBackpackCapacity(SlotsUsed, MaxCapacity);
    InventoryPanel.AwardNewQuickSlots(MaxReadiedWeapons, (MaxReadiedWeapons - WPCOwner.NumQuickSlotsFlourished) - 2, WPCOwner.PlayerClass.bNeedsDualWieldInventoryGuides);
    // End:0x23F
    if(WPCOwner.NumQuickSlotsFlourished < (MaxReadiedWeapons - 2))
    {
        WPCOwner.NumQuickSlotsFlourished = MaxReadiedWeapons - 2;
        bShouldSaveGame = true;
    }
    CachedMaxReadied = MaxReadiedWeapons;
    SetTooltipsText();
    //return;    
}

event bool IsComparing()
{
    // End:0x46
    if(InventoryPanel != none)
    {
        return (InventoryPanel.EquippingThing != none) || ChangingCard == 2;        
    }
    else
    {
        return false;
    }
    //return ReturnValue;    
}

function PrepareListOfAllInventory()
{
    local WillowDeclarations.EEquipmentLoc EquipmentLocation;
    local array<WillowWeapon> ReadiedWeapons, UnReadiedWeapons;
    local array<WillowItem> AllItems;

    BackpackThings.Length = 0;
    AllThings.Length = 0;
    bHasReadiableWeapon = false;
    bHasReadiableShield = false;
    bHasReadiableGrenadeMod = false;
    bHasReadiableClassMod = false;
    bHasReadiableArtifact = false;
    MaxCapacity = WInvMgr.GetUnreadiedInventoryMaxSize();
    // End:0xAA
    if(CachedMaxCapacity > 0)
    {
        NewSlots = MaxCapacity - CachedMaxCapacity;
    }
    CachedMaxCapacity = MaxCapacity;
    WPCOwner.GetInventoryLists(ReadiedWeapons, UnReadiedWeapons, AllItems, 2);
    // End:0x26A
    foreach ReadiedWeapons(UnknownLocal_1,)
    {
        switch(UnknownLocal_1.QuickSelectSlot)
        {
            // End:0x179
            case 1:
                EquippedContents[StatusDef.ReadyWeaponUpIdx].Inv = UnknownLocal_1;
                // End:0x257
                break;
            // End:0x1C2
            case 2:
                EquippedContents[StatusDef.ReadyWeaponDownIdx].Inv = UnknownLocal_1;
                // End:0x257
                break;
            // End:0x20B
            case 3:
                EquippedContents[StatusDef.ReadyWeaponLeftIdx].Inv = UnknownLocal_1;
                // End:0x257
                break;
            // End:0x254
            case 4:
                EquippedContents[StatusDef.ReadyWeaponRightIdx].Inv = UnknownLocal_1;
                // End:0x257
                break;
            // End:0xFFFF
            default:
                break;
        }
        AllThings.AddItem(UnknownLocal_1;        
