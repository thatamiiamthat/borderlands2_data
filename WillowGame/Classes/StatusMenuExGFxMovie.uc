function GotoPrevTab()
{
    switch(CurrentScreen)
    {
        // End:0x3D
        case 3:
            GotoAndStop("map");
            PlayUISound('TabMovement');
            // End:0x19E
            break;
        // End:0x9F
        case 4:
            UnknownLocal_1 = HasVehicleRestrictions();
            GotoAndStop(((UnknownLocal_1) ? "map" : "inventory"));
            PlayUISound(((UnknownLocal_1) ? 'TabMovement' : 'TabMovementInventory'));
            // End:0x19E
            break;
        // End:0xFE
        case 5:
            UnknownLocal_1 = HasVehicleRestrictions();
            GotoAndStop(((UnknownLocal_1) ? "map" : "skills"));
            PlayUISound(((UnknownLocal_1) ? 'TabMovement' : 'TabMovementSkills'));
            // End:0x19E
            break;
        // End:0x12F
        case 1:
            GotoAndStop("challenges");
            PlayUISound('TabMovement');
            // End:0x19E
            break;
        // End:0x19B
        case 2:
            // End:0x16F
            if((WorldMissions.Length > 0) || ClientMissions.Length > 0)
            {
                GotoAndStop("missionlog");                
            }
            else
            {
                GotoAndStop("challenges");
            }
            PlayUISound('TabMovement');
            // End:0x19E
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

