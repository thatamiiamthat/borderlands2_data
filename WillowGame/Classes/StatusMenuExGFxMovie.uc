        {
            UnknownLocal_3.super(StatusMenuExGFxMovie).ToggleMissionFiltered(UnknownLocal_1);
        }
        WPCOwner.ToggleMissionFiltered(UnknownLocal_1);
        UnknownLocal_5 = true;        
    }
    else
    {
        // End:0x165
        if(!bShowWorldMissions)
        {
            WPCOwner.ToggleMissionFiltered(UnknownLocal_1);
