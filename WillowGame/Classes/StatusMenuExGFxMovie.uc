function string GetInitialScreen()
{
    local WillowPlayerController.EBackButtonScreen DesiredScreen;

    WPCOwner.GFxUIManager.UpdatePause();
    // End:0x88
    if(int(WPCOwner.QuickAccessScreen) != int(0))
    {
        DesiredScreen = WPCOwner.QuickAccessScreen;        
    }
    else
    {
        // End:0xDC
        if(int(WPCOwner.ContextualPromptScreen) != int(0))
        {
            DesiredScreen = WPCOwner.ContextualPromptScreen;            
        }
        else
        {
            // End:0x130
            if(int(WPCOwner.LastActiveStatusMenuScreen) != int(0))
            {
                DesiredScreen = WPCOwner.LastActiveStatusMenuScreen;                
            }
            else
            {
                DesiredScreen = 2;
            }
        }
    }
    // End:0x1AC
    if(WPCOwner.Pawn.IsA('Vehicle') && (int(DesiredScreen) == int(4)) || int(DesiredScreen) == int(3))
    {
        DesiredScreen = 2;
    }
    switch(DesiredScreen)
    {
        // End:0x1D0
        case 3:
            return "inventory";
        // End:0x1EE
        case 1:
            CurrentScreen = 1;
            return "missionlog";
        // End:0x205
        case 2:
            CurrentScreen = 2;
            return "map";
        // End:0x21F
        case 4:
            CurrentScreen = 4;
            return "skills";
        // End:0x23D
        case 5:
            CurrentScreen = 5;
            return "challenges";
        // End:0xFFFF
        default:
            //return ReturnValue;
            break;
    }    
}

