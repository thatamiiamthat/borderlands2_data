    //return;    
}

function extArtifactSelect(int IdxSelected)
{
    SkillTreePanel.ArtifactSelect(IdxSelected);
    //return;    
}

function extArtifactClose()
{
    SkillTreePanel.Nav_Back(-1);
    //return;    
}

function EnableControl(bool bEnable)
{
    // End:0x43
    if(!bEnable && int(CurrentScreen) == int(2))
    {
        __OnInputAxis__Delegate = HandleMapInputAxis;        
    }
    else
    {
        super(WillowGFxThirdPersonMovie).EnableControl(bEnable);
    }
    //return;    
}

