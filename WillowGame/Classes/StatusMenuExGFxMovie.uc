function name TryToFindNextValidCell(name Direction, name NewCell)
{
    local name TestCell;

    UnknownLocal_1 = StatusDef.Directions.Find('This', NewCell;
    // End:0x147
    if((NewCell == 'cel4') && MaxReadiedWeapons < 4)
    {
        // End:0xB5
        if(Direction == 'Down')
        {
            return StatusDef.Directions[UnknownLocal_1].Down;            
        }
        else
        {
            // End:0x147
            if(Direction == 'Up')
            {
                TestCell = StatusDef.Directions[UnknownLocal_1].Up;
                UnknownLocal_1 = StatusDef.Directions.Find('This', TestCell;
            }
        }
    }
    // End:0x295
    if(((NewCell == 'cel3') || TestCell == 'cel3') && MaxReadiedWeapons < 3)
    {
        // End:0x1DB
        if(Direction == 'Up')
        {
            return StatusDef.Directions[UnknownLocal_1].Up;            
        }
        else
        {
            // End:0x292
            if(Direction == 'Down')
            {
                UnknownLocal_1 = StatusDef.Directions.Find('This', StatusDef.Directions[UnknownLocal_1].Down;
                return StatusDef.Directions[UnknownLocal_1].Down;
            }
        }        
    }
    else
    {
        // End:0x2BF
        if(TestCell != 'None')
        {
            NewCell = TestCell;
        }
    }
    return NewCell;
    //return ReturnValue;    
}

function bool IsCellValid(name NewCell)
{
    // End:0x19
    if(NewCell == 'None')
    {
        return false;
    }
    // End:0x44
    if((NewCell == 'cel3') && MaxReadiedWeapons < 3)
    {
        return false;
    }
    // End:0x6F
    if((NewCell == 'cel4') && MaxReadiedWeapons < 4)
    {
        return false;
    }
    return true;
    //return ReturnValue;    
}

