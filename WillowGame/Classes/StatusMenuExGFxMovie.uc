function OnMissionStatusChanged()
{
    // End:0xB5
    if(int(CurrentScreen) == int(1))
    {
        UnknownLocal_1 = MissionDefinition(MissionLogTextList.GetHighlightedObject());
        UnknownLocal_3 = bShowWorldMissions;
        extSetupMissionLogScreen();
        // End:0xAB
        if((UnknownLocal_1 != none) && bShowWorldMissions == UnknownLocal_3)
        {
            RepositionMissionLog(MissionLogTextList.FindObjectIndex(UnknownLocal_1));
        }
        SetTooltipsText();
