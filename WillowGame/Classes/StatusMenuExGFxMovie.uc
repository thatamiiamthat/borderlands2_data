function SetTooltipsText()
{
    local string TooltipBar, TooltipSpacer;

    SetVariableString("header.rb.text", "$<StringAliasMap:Tab_Right>");
    SetVariableString("header.lb.text", "$<StringAliasMap:Tab_Left>");
    switch(CurrentScreen)
    {
        // End:0x87
        case 5:
            return;
        // End:0x331
        case 1:
            TooltipSpacer = "     ";
            // End:0x10C
            if(CanToggleHighlightedMissionFilter())
            {
                // End:0xE3
                if(IsHighlightedMissionFiltered())
                {
                    TooltipBar = (MissionLogTooltip_Unignore $ TooltipSpacer) $ TooltipBar;                    
                }
                else
                {
                    TooltipBar = (MissionLogTooltip_Ignore $ TooltipSpacer) $ TooltipBar;
                }
            }
            TooltipBar = (MissionLogTooltip_Cancel $ TooltipSpacer) $ TooltipBar;
            // End:0x1D3
            if(!IsPrimaryHostPlayer())
            {
                // End:0x18E
                if(!bShowWorldMissions && CanShowWorldMissionView())
                {
                    TooltipBar = (MissionLogTooltip_ViewWorldMissions $ TooltipSpacer) $ TooltipBar;                    
                }
                else
                {
                    // End:0x1D3
                    if(bShowWorldMissions && CanShowClientMissionView())
                    {
                        TooltipBar = (MissionLogTooltip_ViewMyMissions $ TooltipSpacer) $ TooltipBar;
                    }
                }
            }
            TooltipBar = (MissionLogTooltip_Sort $ TooltipSpacer) $ TooltipBar;
            // End:0x232
            if(CanTrackHighlightedMission())
            {
                TooltipBar = (MissionLogTooltip_Track $ TooltipSpacer) $ TooltipBar;
            }
            UnknownLocal_1 = GetVariableNumber("missions.missionSummary.description.scroll");
            UnknownLocal_3 = GetVariableNumber("missions.missionSummary.description.maxscroll");
            // End:0x2F6
            if((UnknownLocal_1 > 1) || UnknownLocal_1 < UnknownLocal_3)
            {
                TooltipBar = (MissionLogTooltip_Scroll $ TooltipSpacer) $ TooltipBar;
            }
            SetVariableString("tooltips.tooltips.htmlText", ResolveDataStoreMarkup(TooltipBar));
            return;
        // End:0x338
        case 4:
            return;
        // End:0xFFFF
        default:
            //return;
            break;
    }    
}

function SetInventoryTooltipsText(WillowInventory WInv)
{
    local string S;
    local name CurrentMainAction;

    SetVariableString("header.rb.text", "$<StringAliasMap:Tab_Right>");
    SetVariableString("header.lb.text", "$<StringAliasMap:Tab_Left>");
    S = Localize("InvBar", "MainButtonBar", "WillowMenu");
    UnknownLocal_1 = GetCurrentMainAction(WInv, CurrentMainAction);
    switch(CurrentMainAction)
    {
        // End:0x13D
        case 'Select':
            S = Repl(S, "%s1", ColorizeTooltipText(Localize("InvBar", "SelectBar", "WillowMenu"), !UnknownLocal_1));
            // End:0x2CB
            break;
        // End:0x1A0
        case 'equip':
            S = Repl(S, "%s1", ColorizeTooltipText(Localize("InvBar", "EquipBar", "WillowMenu"), !UnknownLocal_1));
            // End:0x2CB
            break;
        // End:0x205
        case 'UnEquip':
            S = Repl(S, "%s1", ColorizeTooltipText(Localize("InvBar", "UnequipBar", "WillowMenu"), !UnknownLocal_1));
            // End:0x2CB
            break;
        // End:0x267
        case 'Swap':
            S = Repl(S, "%s1", ColorizeTooltipText(Localize("InvBar", "SwapBar", "WillowMenu"), !UnknownLocal_1));
            // End:0x2CB
            break;
        // End:0x2C8
        case 'Use':
            S = Repl(S, "%s1", ColorizeTooltipText(Localize("InvBar", "UseBar", "WillowMenu"), !UnknownLocal_1));
            // End:0x2CB
            break;
        // End:0xFFFF
        default:
            break;
    }
    // End:0x34A
    if(!InventoryPanel.bInEquippedView)
    {
        S = Repl(S, "%s3", ColorizeTooltipText(Localize("InvBar", "SortBar", "WillowMenu"), !CanSort()));        
    }
    else
    {
        S = Repl(S, "%s3", "");
    }
    S = Repl(S, "%s4", ColorizeTooltipText(Localize("InvBar", "DropBar", "WillowMenu"), !CanDrop(WInv)));
    // End:0x44A
    if(!class'Engine'.static.IsSplitScreen())
    {
        S = Repl(S, "%s2", ColorizeTooltipText(Localize("InvBar", "InspectBar", "WillowMenu"), WInv == none));        
    }
    else
    {
        S = Repl(S, "%s2", "");
    }
    // End:0x52A
    if((int(class'GearboxGlobals'.static.GetPlatform()) != int(0)) || WPCOwner.PlayerInput.bUsingGamepad)
    {
        S = Repl(S, "%s5", ColorizeTooltipText(Localize("InvBar", "TrashFaveBar", "WillowMenu"), WInv == none));        
    }
    else
    {
        S = Repl(S, "%s5", "");
    }
    // End:0x598
    if(IsComparing())
    {
        S = Repl(S, "%s6", Localize("InvBar", "Cancel", "WillowMenu"));        
    }
    else
    {
        S = Repl(S, "%s6", Localize("InvBar", "Close", "WillowMenu"));
    }
    InventoryPanel.SetTooltipText(ResolveDataStoreMarkup(S));
    //return;    
}

