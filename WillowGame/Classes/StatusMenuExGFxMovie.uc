        Points[UnknownLocal_1] = Points[UnknownLocal_1] << MapRotation;
        ++ UnknownLocal_1;
        // [Loop Continue]
        goto J0x18E;
    }
    Top = -FMax(FMax(FMax(Points[0].X, Points[1].X), Points[2].X), Points[3].X);
    Bottom = -FMin(FMin(FMin(Points[0].X, Points[1].X), Points[2].X), Points[3].X);
    Left = FMin(FMin(FMin(Points[0].Y, Points[1].Y), Points[2].Y), Points[3].Y);
    Right = FMax(FMax(FMax(Points[0].Y, Points[1].Y), Points[2].Y), Points[3].Y);
    StatusMenuMap.MapClipRect.Top = Top;
    StatusMenuMap.MapClipRect.Right = Right;
    StatusMenuMap.MapClipRect.Bottom = Bottom;
    StatusMenuMap.MapClipRect.Left = Left;
    StatusMenuMap.PostMapMovieLoad();
    // End:0x58D
    foreach WPCOwner.DiscoveredWorldAreas(WDA,)
    {
        StatusMenuMap.ToggleFogOfWarBlob(string(WDA.DiscoveryName), WDA.HasBeenUncovered);        
    }    
    //return;    
}

function bool CanToggleHighlightedMissionFilter()
{
    local IMission.EMissionStatus MissionStatus;
    local array<StatusMenuMissionEligibilityData> MissionSet;

    UnknownLocal_1 = MissionDefinition(MissionLogTextList.GetHighlightedObject());
    // End:0xE1
    if(UnknownLocal_1 != none)
    {
        // End:0x5C
        if(bShowWorldMissions)
        {
            MissionSet = WorldMissions;            
        }
        else
        {
            MissionSet = ClientMissions;
        }
        UnknownLocal_3 = MissionSet.Find('MissionDef', UnknownLocal_1;
        // End:0xE1
        if(UnknownLocal_3 != -1)
        {
            MissionStatus = MissionSet[UnknownLocal_3].MissionStatus;
            // End:0xE1
            if(int(MissionStatus) == int(4))
            {
                return false;
            }
        }
    }
    // End:0x141
    if(!bShowWorldMissions || (int(WPCOwner.Role) == int(ROLE_Authority)) && WPCOwner.IsPrimaryPlayer())
    {
        return true;
    }
    return false;
    //return ReturnValue;    
}

function bool IsHighlightedMissionFiltered()
