    //return;    
}

function extSetupMissionLogScreen()
{
    local string MissionHeader;

    WorldMissions.Length = 0;
    ClientMissions.Length = 0;
    GetAllWorldMissions(WorldMissions);
    WPCOwner.GetPlayerAllMissions(ClientMissions, ClientActiveMissionIndex);
    StaticFilterMissions(WorldMissions);
    StaticFilterMissions(ClientMissions);
    Flash_SetMissionLogEnabled((ClientMissions.Length > 0) || WorldMissions.Length > 0);
    SetupGenericLogs(WPCOwner);
    // End:0xF7
    if((WorldMissions.Length == 0) && ClientMissions.Length == 0)
    {
        GotoNoMissions();
        UpdateGeneralDetails();        
    }
    else
    {
        // End:0x124
        if(bShowWorldMissions && !CanShowWorldMissionView())
        {
            bShowWorldMissions = false;            
        }
        else
        {
            // End:0x150
            if(!bShowWorldMissions && !CanShowClientMissionView())
            {
                bShowWorldMissions = true;
            }
        }
        GotoRegularMissions();
        UpdateListOfMissionTitles();
        // End:0x203
        if((WPCOwner != none) && WPCOwner.ContextualPromptContextObject != none)
        {
            RepositionMissionLog(MissionLogTextList.FindObjectIndex(WPCOwner.ContextualPromptContextObject));
            WPCOwner.ContextualPromptContextObject = none;            
        }
        else
        {
            UpdateMissionDetails();
        }
    }
    // End:0x27D
    if(bShowWorldMissions && !IsPrimaryHostPlayer())
    {
        MissionHeader = Localize("StatusMenuExGFxMovie", "MissionLogWorldMissions", "WillowGame");        
    }
    else
    {
        MissionHeader = Localize("StatusMenuExGFxMovie", "MissionLogMyMissions", "WillowGame");
    }
    MissionHeader = Caps(MissionHeader);
    MissionHeader = ((MissionHeader @ "<font size=\"22\">(") $ (GetSortString(MissionSortType))) $ ")</font>";
    SetVariableString("missions.selections.missionHeaderText.htmlText", MissionHeader);
    SetTooltipsText();
    //return;    
}

function bool IsPrimaryHostPlayer()
{
    return (int(WPCOwner.WorldInfo.NetMode) != int(NM_Client)) && WPCOwner.IsPrimaryPlayer();
    //return ReturnValue;    
}

function SetupChallengesScreen()
{
    // End:0x41
    if(ChallengesPanel == none)
    {
        ChallengesPanel = ChallengesScreenGFxObject(GetVariableObject("challenges", class'ChallengesScreenGFxObject'));
    }
    ChallengesPanel.Init(self);
    __OnInputKey__Delegate = ChallengesPanel.PanelOnInputKey;
    ChallengesPanel.ConfigureForPlayer(float(((WPCOwner.IsPrimaryPlayer()) ? 0 : 1)));
    ChallengesPanel.Refresh();
    //return;    
}

