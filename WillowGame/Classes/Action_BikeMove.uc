function CalcDests()
{
    local Vector OffsetFwd, OffsetRight, NewDest;

    CachedTargetLoc = GetActorFloorLoc(Target);
    UnknownLocal_1 = 0;
    J0x24:

    // End:0x1B2 [Loop If]
    if(UnknownLocal_1 < TargetOffsets.Length)
    {
        OffsetFwd = CachedTargetLoc - MyWillowPawn.Location;
        OffsetFwd.Z = 0;
        OffsetFwd = Normal(OffsetFwd);
        OffsetRight = OffsetFwd Cross vect(0, 0, 1);
        NewDest = (CachedTargetLoc + (OffsetFwd * TargetOffsets[UnknownLocal_1].X)) + (OffsetRight * TargetOffsets[UnknownLocal_1].Y);
        NewDest.Z = CachedTargetLoc.Z + TargetOffsets[UnknownLocal_1].Z;
        Dests.AddItem(NewDest;
        ++ UnknownLocal_1;
        // [Loop Continue]
        goto J0x24;
    }
    //return;    
}

function bool HasDests()
{
    return Dests.Length != 0;
    //return ReturnValue;    
}

function ResetDests()
{
    DestIdx = 0;
    Dests.Length = 0;
    NumFailedDests = 0;
    //return;    
}

function bool CanMove()
{
    // End:0x11
    if(!bLimitedMovement)
    {
        return true;
    }
    // End:0x22
    if(ParentTargetRec == none)
    {
        return true;
    }
    return EqualEqual_InterfaceInterface(ParentTargetRec.MovingAI, IAIInterface(none)) || EqualEqual_InterfaceInterface(ParentTargetRec.MovingAI, AI);
    //return ReturnValue;    
}

function ClaimMovement()
{
    // End:0x44
    if(bLimitedMovement && CanMove())
    {
        ParentTargetRec.MovingAI = AI;
    }
    //return;    
}

function UnclaimMovement()
{
    // End:0x3C
    if(bLimitedMovement && CanMove())
    {
        ParentTargetRec.MovingAI = none;
    }
    //return;    
}

function bool IsDestClose()
{
    // End:0x77
    if(VSizeSq2D(class'Actor'.static.BP2Vect(PathData.FinalDest) - MyWillowPawn.Location) < Square(ReachDistance))
    {
        return true;
    }
    return false;
    //return ReturnValue;    
}

function bool ShouldRecalcDests()
{
    // End:0x56
    if((Target != none) && VSizeSq2D(Target.Location - CachedTargetLoc) > Square(RecalcDestTargetMoveDist))
    {
        return true;
    }
    return false;
    //return ReturnValue;    
}

function bool WantsPathFind()
{
    // End:0x42
    if(!HasDests() || (PathIsValid() && !IsDestClose()) && !ShouldRecalcDests())
    {
        return false;
    }
    // End:0x53
    if(!CanMove())
    {
        return false;
    }
    return true;
    //return ReturnValue;    
}

state MoveToPoint
{
    event Update()
    {
        global.Update();
        // End:0x24
        if(!CanMove())
        {
            Finish();
        }
        // End:0x73
        if(!MyNavHandle.IsFollowingPath())
        {
            InvalidatePath();
            MyNavHandle.ClearPath();
        }
        // End:0x8A
        if(ShouldRecalcDests())
        {
            ResetDests();
        }
        // End:0xB7
        if(!HasDests() && Target != none)
        {
            CalcDests();            
        }
        else
        {
            // End:0x1DA
            if(bPathingFailed || VSizeSq2D(class'Actor'.static.BP2Vect(PathData.FinalDest) - MyWillowPawn.Location) < Square(ReachDistance))
            {
                ++ DestIdx;
                // End:0x1AF
                if(DestIdx > (Dests.Length - 1))
                {
                    // End:0x198
                    if((NumFailedDests == Dests.Length) || Target == none)
                    {
                        Finish();                        
                    }
                    else
                    {
                        ResetDests();
                        CalcDests();
                    }                    
                }
                else
                {
                    InvalidatePath();
                    MyNavHandle.ClearPath();
                }
            }
        }
        //return;        
    }

    event bool PathFind()
    {
        local Vector Dest;
        local BasedPosition BasedDest;

        // End:0x11
        if(!WantsPathFind())
        {
            return false;
        }
        bPathingFailed = false;
        InvalidatePath();
        MyNavHandle.ClearPath();
        // End:0x72
        if(DestIdx > (Dests.Length - 1))
        {
            bPathingFailed = true;            
        }
        else
        {
            Dest = Dests[DestIdx];
            // End:0x11A
            if(MyNavHandle.GetNearestPositionOnNavMesh(256, Dest, BasedDest, MyNavHandle.CachedPathParams))
            {
                Dest = class'Actor'.static.BP2Vect(BasedDest);
            }
            // End:0x177
            if(VSizeSq2D(MyWillowPawn.Location - Dest) < Square(MinTravelDistance))
            {
                bPathingFailed = true;
                ++ NumFailedDests;                
            }
            else
            {
                CreateVectorPath(Dest);
                // End:0x1B2
                if(!PathIsValid())
                {
                    bPathingFailed = true;
                    ++ NumFailedDests;
                }
            }
        }
        return true;
        //return ReturnValue;        
    }

    function BeginState(name PreviousStateName)
    {
        ClaimMovement();
        //return;        
    }

    function EndState(name NextStateName)
    {
        UnclaimMovement();
        //return;        
    }
    stop;    
}
