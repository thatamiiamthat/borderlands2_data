function OnAIProvoke(WillowSeqAct_AIProvoke inAction)
{
    local EncounterWaveData Wave;

    // End:0x83
    foreach Waves(Wave,)
    {
        // End:0x81
        foreach Wave.MemberOpportunities(UnknownLocal_1,)
        {
            UnknownLocal_3 = PopulationOpportunityDen(UnknownLocal_1);
            // End:0x80
            if(UnknownLocal_3 != none)
            {
                UnknownLocal_3.OnAIProvoke(inAction);
            }            
        }                
    }    
    //return;    
}

