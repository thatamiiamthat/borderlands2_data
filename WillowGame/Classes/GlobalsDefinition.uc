function MarketingUnlockDefinition FindUnlockDefinitionForUnlockCode(int UnlockCode)
{
    // End:0x43
    foreach MarketingUnlocks(UnknownLocal_1,)
    {
        // End:0x42
        if(UnknownLocal_1.UnlockCode == UnlockCode)
        {            
            return UnknownLocal_1;
        }        
    }    
    return none;
    //return ReturnValue;    
}

event string GetDLCCharacterIconSwfMoviePath()
{
    return DLCCharacterIconSwfMovie.GetPathForLoadMovie();
    //return ReturnValue;    
}

