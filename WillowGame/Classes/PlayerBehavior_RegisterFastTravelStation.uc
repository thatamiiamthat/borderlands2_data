class PlayerBehavior_RegisterFastTravelStation extends PlayerBehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IPlayerBehavior ContextInterface;

    ContextInterface = ContextObject.QueryInterface(class'IPlayerBehavior');
    // End:0xD2
    if(EqualEqual_InterfaceInterface(ContextInterface, IPlayerBehavior(none)))
    {
        ContextObject = class'UIInteraction'.static.GetLocalPlayer(0).Actor;
        // End:0xD2
        if(ContextObject != none)
        {
            ContextInterface = ContextObject.QueryInterface(class'IPlayerBehavior');
        }
    }
    // End:0x125
    if(NotEqual_InterfaceInterface(ContextInterface, IPlayerBehavior(none)))
    {
        ContextInterface.Behavior_RegisterStation(TravelStation(SelfObject));
    }
    //return;    
}
