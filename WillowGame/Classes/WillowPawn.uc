simulated function PlayDying(class<DamageType> DamageType, DamageTypeDefinition DamageTypeDefinition, ImpactDefinition ImpactDefinition, Vector HitLoc)
{
    local TraceHitInfo HitInfo;
    local WillowDamageTypeDefinition.EDamageType DamageTypeOfFatalBlow;

    bCanTeleport = false;
    bPlayedDeath = true;
    Velocity += TearOffMomentum;
    UnknownLocal_1 = VSize(TearOffMomentum);
    // End:0x77
    if((UnknownLocal_1 > float(0)) && UnknownLocal_1 < 10)
    {
        TearOffMomentum = Normal(TearOffMomentum) * 10;
    }
    HitDamageType = DamageType;
    HitDamageTypeDefinition = DamageTypeDefinition;
    HitImpactDefinition = ImpactDefinition;
    TakeHitLocation = HitLoc;
    // End:0x11D
    if((DamageTypeDefinition != none) && WillowDamageTypeDefinition(DamageTypeDefinition) != none)
    {
        DamageTypeOfFatalBlow = WillowDamageTypeDefinition(DamageTypeDefinition).DamageType;
    }
    // End:0x162
    if(int(WorldInfo.NetMode) == int(NM_DedicatedServer))
    {
        bTearOff = true;
        GotoState('Dying');
        return;
    }
    DeathImpactAngle = GetHeadingAngle(Vector(Rotator(TearOffMomentum * vect(-1, -1, 0)) - Rotation)) * 57.29578;
    CheckHitInfo(HitInfo, Mesh, Normal(TearOffMomentum), TakeHitLocation);
    UnknownLocal_3 = MyHitRegionHelper.GetHitRegionFromBoneName(HitInfo.BoneName, BodyClass.DefaultHitRegion, BodyClass.HitRegionList);
    // End:0x2A4
    if((UnknownLocal_3 != none) && UnknownLocal_3.OverrideDeathDef != none)
    {
        SetDeathDefinition(UnknownLocal_3.OverrideDeathDef);
    }
    // End:0x2F7
    if((!bGibbed && MyDeathDef != none) && MyDeathDef.bTearOffAfterDeath)
    {
        bTearOffAfterDeath = true;        
    }
    else
    {
        bTearOff = true;
    }
    // End:0x377
    if(Mesh != none)
    {
        Mesh.SetRBChannel(2);
        Mesh.SetRBCollidesWithChannel(0, true);
        Mesh.SetRBCollidesWithChannel(2, true);
    }
    UnknownLocal_5 = WillowMind(Controller);
    // End:0x3C6
    if(MyDeathDef != none)
    {
        MyDeathDef.OnPlayDeathPizazz(ConsumerHandle);
    }
    // End:0x434
    if(BodyClass.CustomDeathBehaviors.Length > 0)
    {
        class'BehaviorBase'.static.RunBehaviors(BodyClass.CustomDeathBehaviors, self, UnknownLocal_5, UnknownLocal_5);
    }
    CheckHitInfo(HitInfo, Mesh, Normal(TearOffMomentum), TakeHitLocation);
    DialogComponent.StopTalking();
    StopSounds();
    // End:0xBAA
    if(!bGibbed)
    {
        // End:0x4C3
        if(int(DamageTypeOfFatalBlow) == int(1))
        {
            PostPlayerEvent(21);            
        }
        else
        {
            // End:0x4E8
            if(int(DamageTypeOfFatalBlow) == int(2))
            {
                PostPlayerEvent(22);                
            }
            else
            {
                PostPlayerEvent(20);
            }
        }
        // End:0x6F4
        if(CurrentDeathAnimation == none)
        {
            // End:0x60C
            if(!PlayTechDeath(DamageTypeDefinition, HitInfo))
            {
                // End:0x609
                if((MyDeathDef.NonRagdollDeathSpecialMove != none) && int(Physics) != int(10))
                {
                    CurrentDeathAnimation = MyDeathDef.NonRagdollDeathSpecialMove;
                    bShouldRagdollAfterDeathAnim = MyDeathDef.bDeathAnimRagdoll;
                    PlayDeathAnim(CurrentDeathAnimation, HitInfo.BoneName, TakeHitLocation, MyDeathDef.bMotorizeRagdollOnNormalDeath);
                }                
            }
            else
            {
                // End:0x680
                if(int(DamageTypeOfFatalBlow) == int(1))
                {
                    DialogComponent.TriggerEvent(class'WillowDialogGlobalsDefinition'.static.Get().DET_DeathByFire);
                    UnknownLocal_7 = true;                    
                }
                else
                {
                    // End:0x6F1
                    if(int(DamageTypeOfFatalBlow) == int(2))
                    {
                        DialogComponent.TriggerEvent(class'WillowDialogGlobalsDefinition'.static.Get().DET_DeathByShock);
                        UnknownLocal_7 = true;
                    }
                }
            }            
        }
        else
        {
            PlayDeathAnim(CurrentDeathAnimation, HitInfo.BoneName, TakeHitLocation, MyDeathDef.bMotorizeRagdollOnNormalDeath);
        }
        // End:0x7AB
        if(!UnknownLocal_7)
        {
            DialogComponent.TriggerEvent(class'WillowDialogGlobalsDefinition'.static.Get().DET_Death);
        }
        // End:0xBAA
        if(CurrentDeathAnimation == none)
        {
            bTearOffAfterDeath = false;
            bTearOff = true;
            // End:0x802
            if(Mesh != none)
            {
                Mesh.bPauseAnims = true;
            }
            MyDeathDef.OnDeathNonGib(ConsumerHandle, UnknownLocal_5);
            // End:0x88E
            if(((MyDeathDef != none) && MyDeathDef.bDestroyOnDeath) || !InitRagdoll())
            {
                TellOpportunityPawnIsDead(false);
                PlayDyingSound();
                Destroy();                
            }
            else
            {
                bUnderFullRagdollControl = true;
                Mesh.SetRBChannel(16);
                Mesh.SetRBCollidesWithChannel(16, true);
                Mesh.SetRBCollidesWithChannel(0, true);
                CollisionComponent = Mesh;
                CollisionComponent.SetBlockRigidBody(true);
                // End:0xB92
                if(TearOffMomentum != vect(0, 0, 0))
                {
                    CheckHitInfo(HitInfo, Mesh, Normal(TearOffMomentum), TakeHitLocation);
                    // End:0xB92
                    if(HitInfo.BoneName != 'None')
                    {
                        // End:0xAA0
                        if(DamageTypeDefinition != none)
                        {
                            DeathRagDollMomentum = TearOffMomentum * DamageTypeDefinition.GetRigidBodyMomentumScale();
                            // End:0xA9D
                            if((Velocity.Z > float(-10)) && DamageTypeDefinition.ApplyUpwardMomentum())
                            {
                                DeathRagDollMomentum.Z = FMax(DeathRagDollMomentum.Z, DamageTypeDefinition.GetUpwardMomentumScale() * VSize(DeathRagDollMomentum));
                            }                            
                        }
                        else
                        {
                            DeathRagDollMomentum = Normal(DeathRagDollMomentum) * DamageType.default.KDamageImpulse;
                            // End:0xB35
                            if(Velocity.Z > float(-10))
                            {
                                DeathRagDollMomentum += (vect(0, 0, 1) * DamageType.default.KDeathUpKick);
                            }
                        }
                        // End:0xB92
                        if(Mesh != none)
                        {
                            Mesh.AddImpulse(DeathRagDollMomentum, TakeHitLocation, HitInfo.BoneName, true);
                        }
                    }
                }
                ApplyExtraRagdollDeathImpulsesAndStatusEffect();
                GotoState('Dying');
            }
        }
    }
    //return;    
}

