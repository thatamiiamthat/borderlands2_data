function ActionSkillStarted(SkillDefinition Skill)
{
    // End:0x2A
    if(Controller != none)
    {
        UnknownLocal_1 = WillowPlayerController(Controller);        
    }
    else
    {
        // End:0x66
        if(DrivenVehicle != none)
        {
            UnknownLocal_1 = WillowPlayerController(DrivenVehicle.Controller);
        }
    }
    EnableActionSkill(true, Skill, UnknownLocal_1.CurrentActionSkillTarget);
    //return;    
}

function ActionSkillEnded()
{
    // End:0x1E
    if(int(Role) == int(ROLE_Authority))
    {
        EndActionSkill();
    }
    //return;    
}

simulated function EndActionSkill()
{
    EnableActionSkill(false);
    // End:0x2B
    if(int(Role) == int(ROLE_Authority))
    {
        ClientEndActionSkill();
    }
    //return;    
}

reliable client simulated function ClientEndActionSkill()
{
    // End:0x1E
    if(int(Role) < int(ROLE_Authority))
    {
        EndActionSkill();
    }
    //return;    
}

simulated function EnableActionSkill(bool bEnable, optional SkillDefinition Skill, optional WillowPawn TargetPawn)
{
    bEnable
    UnknownLocal_1 = Controller;
    // End:0x5E
    if((UnknownLocal_1 == none) && DrivenVehicle != none)
    {
        UnknownLocal_1 = DrivenVehicle.Controller;
    }
    // End:0xED
    if(!IsActionSkillRunning() && int(Role) == int(ROLE_Authority))
    {
        MyActionSkill = Spawn(Skill.ActionSkillArchetype.Class, self,,,, Skill.ActionSkillArchetype);
    }
    // End:0x1E2
    if(!MyActionSkill.bInitialized)
    {
        CurrentActionSkillActiveAbilityCount = 0;
        NextActionSkillActiveAbilityTime = WorldInfo.TimeSeconds;
        CurrentActionSkillCooldownAbilityCount = 0;
        NextActionSkillCooldownAbilityTime = WorldInfo.TimeSeconds;
        MyActionSkill.EnableDebug(bDebugActionSkill);
        MyActionSkill.OnActionSkillStarted(self, UnknownLocal_1, TargetPawn);
        NotifyHUDOfEnableActionSkill(MyActionSkill, true);
    }
    goto J0x24C;
    // End:0x24C
    if(!bEnable)
    {
        NotifyHUDOfEnableActionSkill(MyActionSkill, false);
        // End:0x24C
        if((int(Role) == int(ROLE_Authority)) && MyActionSkill != none)
        {
            MyActionSkill.TearOff();
        }
    }
    J0x24C:

    //return;    
}

simulated function NotifyHUDOfEnableActionSkill(ActionSkill Skill, bool bEnable)
{
    UnknownLocal_1 = PlayerController(Controller);
    // End:0x61
    if((UnknownLocal_1 == none) && DrivenVehicle != none)
    {
        UnknownLocal_1 = PlayerController(DrivenVehicle.Controller);
    }
    // End:0xFA
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_3 = WillowHUD(UnknownLocal_1.myHUD);
        // End:0xFA
        if(UnknownLocal_3 != none)
        {
            UnknownLocal_5 = UnknownLocal_3.GetHUDMovie();
            // End:0xFA
            if(UnknownLocal_5 != none)
            {
                UnknownLocal_5.EnableActionSkill(Skill, bEnable);
            }
        }
    }
    //return;    
}

