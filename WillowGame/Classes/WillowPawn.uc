simulated function SetupSkeletalMeshPhysicsForPhysXEffects()
{
    local editinline NxForceFieldRadialComponent LeftFootFF, RightFootFF;

    // End:0x1D9
    if(class'Engine'.static.GetPhysXLevel() > 0)
    {
        // End:0x69
        if((Mesh.SkeletalMesh == SkeletalMesh'Skel_BugMorph') && int(Role) != int(ROLE_Authority))
        {
            return;
        }
        Mesh.SetHasPhysicsAssetInstance(true);
        Mesh.SetRBChannel(1);
        Mesh.SetRBCollidesWithChannel(11, true);
        // End:0x101
        if(!IsPlayerPawn())
        {
            Mesh.SetRBCollidesWithChannel(7, true);            
        }
        else
        {
            LeftFootFF = new class'NxFootForceFieldComponent';
            GetSkelMesh().AttachComponent(LeftFootFF, 'L_Foot');
            LeftFootFF.DoInitRBPhys();
            RightFootFF = new class'NxFootForceFieldComponent';
            GetSkelMesh().AttachComponent(RightFootFF, 'R_Foot');
            RightFootFF.DoInitRBPhys();
        }
    }
    //return;    
}

simulated function SetupSkeletalMeshPhysics()
{
    Mesh.SetRBChannel(1);
    Mesh.SetBlockRigidBody(true);
    Mesh.SetActorCollision(true, false);
    Mesh.SetTraceBlocking(true, true);
    Mesh.bUpdateJointsFromAnimation = true;
    // End:0x154
    if(((Mesh != none) && BodyClass != none) && BodyClass.RD_EffectsThreshold > 0)
    {
        Mesh.ScriptRigidBodyCollisionThresholdCompiled = byte(BodyClass.RD_EffectsThreshold / float(4));
        Mesh.SetNotifyRigidBodyCollision(true);
    }
    // End:0x218
    if(((BodyClass != none) && BodyClass.MinimumRecognizedImpact > 0) && BodyClass.RagdollImpact != none)
    {
        Mesh.ScriptRigidBodyCollisionThresholdCompiled = byte(BodyClass.MinimumRecognizedImpact / float(4));
        Mesh.SetNotifyRigidBodyCollision(true);
    }
    // End:0x280
    if((BodyClass != none) && BodyClass.bUseMeshForCollision)
    {
        CollisionComponent = Mesh;
        Mesh.SetActorCollision(true, true);
    }
    InitializeRBPhysics();
    SetupSkeletalMeshPhysicsForPhysXEffects();
    //return;    
}

