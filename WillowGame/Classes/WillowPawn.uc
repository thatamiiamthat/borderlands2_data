    {
        UnknownLocal_3 = BodyClass.GetFirstPersonWeaponHoldDef(WeaponHoldName, FromEnvironmentTag, true, true);
        UnknownLocal_5 = BodyClass.GetFirstPersonWeaponHoldDef(WeaponHoldName, ToEnvironmentTag, true, true);        
    }
    else
