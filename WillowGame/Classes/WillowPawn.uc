simulated function OnInterpPawn(WillowSeqAct_InterpPawn Action)
{
    Velocity = vect(0, 0, 0);
    Acceleration = vect(0, 0, 0);
    InterpLocation(Action.Goal.Location, Action.InterpSpeed, Action.bLinear);
    InterpRotation(Action.Goal.Rotation, Action.InterpSpeed, Action.bLinear, false);
    //return;    
}

event StuckOnPawn(Pawn OtherPawn)
{
    // End:0x68
    if(Location.Z >= OtherPawn.Location.Z)
    {
        GetOutTheWay(OtherPawn);        
    }
    else
    {
        WillowPawn(OtherPawn).GetOutTheWay(self);
    }
    //return;    
}

function GetOutTheWay(Pawn OtherPawn)
{
    local Vector GoalLoc;

    SetPhysics(0);
    GoalLoc = Location;
    GoalLoc.Z = ((OtherPawn.Location.Z + OtherPawn.CylinderComponent.CollisionHeight) + CylinderComponent.CollisionHeight) + float(10);
    InterpLocation(GoalLoc, 0.25);
    SetTimer(0.25, false, 'SetDefaultPhysics');
    //return;    
}

