simulated event ReplicatedEvent(name VarName)
{
    // End:0x42
    if(VarName == 'bMeleeWeaponAttached')
    {
        // End:0x33
        if(bMeleeWeaponAttached)
        {
            AttachMeleeWeaponMesh(true, false);            
        }
        else
        {
            DetachMeleeWeaponMesh(true, false);
        }        
    }
    else
    {
        // End:0x66
        if(VarName == 'EquippedItemDefs')
        {
            OnEquippedItemsChange();            
        }
        else
        {
            // End:0x8A
            if(VarName == 'EquippedItems')
            {
                RefreshPawnGearLikenessComponents();                
            }
            else
            {
                // End:0xAE
                if(VarName == 'HolsteredWeaponSlots')
                {
                    RefreshPawnGearLikenessComponents();                    
                }
                else
                {
                    // End:0x12A
                    if(VarName == 'ReplicatedGearHiddenState')
                    {
                        // End:0xF9
                        if(bEquippedWeaponsHidden != ((int(ReplicatedGearHiddenState) & 1) != 0))
                        {
                            SetWeaponVisibility(bEquippedWeaponsHidden);
                        }
                        SetHolsteredGearVisibility((int(ReplicatedGearHiddenState) & 2) == 0, (int(ReplicatedGearHiddenState) & 4) == 0);                        
                    }
                    else
                    {
                        // End:0x1A2
                        if(VarName == 'InjuredState')
                        {
                            switch(InjuredState)
                            {
                                // End:0x166
                                case 0:
                                    GoFromInjuredToHealthyClient();
                                    // End:0x19F
                                    break;
                                // End:0x178
                                case 1:
                                    GoFromHealthToInjuredClient();
                                    // End:0x19F
                                    break;
                                // End:0x18A
                                case 2:
                                    GoToInjuredAndTargetedClient();
                                    // End:0x19F
                                    break;
                                // End:0x19C
                                case 3:
                                    GoFromInjuredToMostlyDeadClient();
                                    // End:0x19F
                                    break;
                                // End:0xFFFF
                                default:
                                    break;
                            }                            
                        }
                        else
                        {
                            // End:0x1C6
                            if(VarName == 'CurrentStance')
                            {
                                ClientStanceUpdated();                                
                            }
                            else
                            {
                                // End:0x25A
                                if(VarName == 'ReplicatedBloodSplatter')
                                {
                                    PlayBloodSplatter(ReplicatedBloodSplatter.HitRegion, ReplicatedBloodSplatter.HitLocation, ReplicatedBloodSplatter.Momentum, ReplicatedBloodSplatter.DamageSeverityPercent);                                    
                                }
                                else
                                {
                                    // End:0x30B
                                    if(VarName == 'ReplicatedGoreEffect')
                                    {
                                        PlayReplicatedDamage(ReplicatedGoreEffect.HitRegion, ReplicatedGoreEffect.GoreDataIndex, ReplicatedGoreEffect.InstigatedBy, ReplicatedGoreEffect.HitLocation, ReplicatedGoreEffect.Momentum);                                        
                                    }
                                    else
                                    {
                                        // End:0x32F
                                        if(VarName == 'ShieldVar')
                                        {
                                            UpdateShieldVars();                                            
                                        }
                                        else
                                        {
                                            // End:0x38A
                                            if(VarName == 'bDidServerGibPawn')
                                            {
                                                TryFullBodyGib(0, Instigator.Controller, none, none, TakeHitLocation, TearOffMomentum);                                                
                                            }
                                            else
                                            {
                                                // End:0x3AE
                                                if(VarName == 'MatScalarFadeInfo')
                                                {
                                                    StartReplicatedMaterialScalarFade();                                                    
                                                }
                                                else
                                                {
                                                    // End:0x427
                                                    if(VarName == 'MyActionSkill')
                                                    {
                                                        // End:0x424
                                                        if(IsActionSkillRunning())
                                                        {
                                                            // End:0x3F1
                                                            if(!IsLocallyControlled())
                                                            {
                                                                EnableActionSkill(true);                                                                
                                                            }
                                                            else
                                                            {
                                                                EnableActionSkill(true,, WillowPlayerController(Controller).CurrentActionSkillTarget);
                                                            }
                                                        }                                                        
                                                    }
                                                    else
                                                    {
                                                        // End:0x4D5
                                                        if(VarName == 'ReplicatedBehaviorConsumerState')
                                                        {
                                                            ReplicatedBehaviorConsumerState.bNeedToApplyThisState = true;
                                                            // End:0x4D2
                                                            if(ConsumerHandle.PID != -1)
                                                            {
                                                                ReplicatedBehaviorConsumerState.bNeedToApplyThisState = class'BehaviorKernel'.static.ProcessReplicatedBehaviorConsumerState(ConsumerHandle, ReplicatedBehaviorConsumerState);
                                                            }                                                            
                                                        }
                                                        else
                                                        {
                                                            // End:0x520
                                                            if(VarName == 'ReplicatedBehaviorEvent')
                                                            {
                                                                class'BehaviorKernel'.static.ProcessReplicatedBehaviorEvent(ConsumerHandle, ReplicatedBehaviorEvent);                                                                
                                                            }
                                                            else
                                                            {
                                                                // End:0x5D6
                                                                if(VarName == 'ReplicatedInstanceDataState')
                                                                {
                                                                    ReplicatedInstanceDataState.bNeedToApplyThisState = true;
                                                                    // End:0x5D3
                                                                    if(BodyClass != none)
                                                                    {
                                                                        ReplicatedInstanceDataState.bNeedToApplyThisState = class'InstanceDataHelper'.static.ApplyReplicatedInstanceDataState(ReplicatedInstanceDataState, self, BodyClass.BodyComposition, InstanceDataState);
                                                                    }                                                                    
                                                                }
                                                                else
                                                                {
                                                                    // End:0x622
                                                                    if(VarName == 'ReplicatedCFX')
                                                                    {
                                                                        class'WillowEffectCoordinator'.static.StaticHandleReplicatedEffect(self, ReplicatedCFX, 'None');                                                                        
                                                                    }
                                                                    else
                                                                    {
                                                                        // End:0x646
                                                                        if(VarName == 'bCloakedReplicated')
                                                                        {
                                                                            CheckReplicatedCloak();                                                                            
                                                                        }
                                                                        else
                                                                        {
                                                                            // End:0x692
                                                                            if(VarName == 'RepSimpleAnimState')
                                                                            {
                                                                                class'WillowAnimNode_Simple'.static.UpdateSimpleAnims(ISimpleAnimPlayer(self), RepSimpleAnimState);                                                                                
                                                                            }
                                                                            else
                                                                            {
                                                                                // End:0x765
                                                                                if(VarName == 'InjuredDeadState')
                                                                                {
                                                                                    // End:0x6CA
                                                                                    if(int(InjuredDeadState) == int(1))
                                                                                    {
                                                                                        StartInjuredDeathSequence();                                                                                        
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        // End:0x701
                                                                                        if(int(InjuredDeadState) == int(2))
                                                                                        {
                                                                                            bCausePlayerDeath = true;
                                                                                            InjuredDeadInitRagdoll();
                                                                                            StartInjuredDeathSequence();                                                                                            
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            // End:0x744
                                                                                            if(int(InjuredDeadState) == int(3))
                                                                                            {
                                                                                                bCausePlayerDeath = true;
                                                                                                bPlayerFellIntoPlayerKillVolume = true;
                                                                                                InjuredDeadInitRagdoll();
                                                                                                StartInjuredDeathSequence();                                                                                                
                                                                                            }
                                                                                            else
                                                                                            {
                                                                                                // End:0x762
                                                                                                if(int(InjuredDeadState) == int(4))
                                                                                                {
                                                                                                    InjuredDeadInitRagdoll();
                                                                                                }
                                                                                            }
                                                                                        }
                                                                                    }                                                                                    
                                                                                }
                                                                                else
                                                                                {
                                                                                    // End:0x7D4
                                                                                    if(VarName == 'MyDeathDef')
                                                                                    {
                                                                                        // End:0x7D1
                                                                                        if(MyDeathDef != none)
                                                                                        {
                                                                                            class'BehaviorKernel'.static.IntializeBehaviorProviderForConsumer(ConsumerHandle, MyDeathDef.BehaviorProviderDefinition);
                                                                                        }                                                                                        
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        // End:0x801
                                                                                        if(VarName == 'CurrentEnvironmentTag')
                                                                                        {
                                                                                            SetEnvironmentTag(CurrentEnvironmentTag);                                                                                            
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            // End:0x872
                                                                                            if(VarName == 'bTearOffAfterDeath')
                                                                                            {
                                                                                                // End:0x86F
                                                                                                if(bTearOffAfterDeath && !bPlayedDeath)
                                                                                                {
                                                                                                    PlayDying(HitDamageType, HitDamageTypeDefinition, HitImpactDefinition, TakeHitLocation);
                                                                                                    TellOpportunityPawnIsDead(false);
                                                                                                }                                                                                                
                                                                                            }
                                                                                            else
                                                                                            {
                                                                                                // End:0x89F
                                                                                                if(VarName == 'ReplicatedEmoteAnim')
                                                                                                {
                                                                                                    SetEmoteAnim(ReplicatedEmoteAnim);                                                                                                    
                                                                                                }
                                                                                                else
                                                                                                {
                                                                                                    // End:0x905
                                                                                                    if(VarName == 'RepMeshScale')
                                                                                                    {
                                                                                                        // End:0x902
                                                                                                        if((Mesh != none) && RepMeshScale != -1)
                                                                                                        {
                                                                                                            Mesh.SetScale(RepMeshScale);
                                                                                                        }                                                                                                        
                                                                                                    }
                                                                                                    else
                                                                                                    {
                                                                                                        super.ReplicatedEvent(VarName);
                                                                                                    }
                                                                                                }
                                                                                            }
                                                                                        }
                                                                                    }
                                                                                }
                                                                            }
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    //return;    
}

simulated function PostBeginPlay()
{
    // End:0x68
    if(int(Role) == int(ROLE_Authority))
    {
        ShieldColor = class'WillowGlobals'.static.GetWillowGlobals().GetGlobalsDefinition().DefaultShieldColor;
    }
    // End:0x8A
    if(FacialAudioComp != none)
    {
        AttachComponent(FacialAudioComp);
    }
    // End:0xAC
    if(BodyClass != none)
    {
        BodySelectClass(BodyClass);
    }
    super.PostBeginPlay();
    CrouchRadius = float(Max(int(CrouchRadius), int(GetCollisionRadius())));
    MyHitRegionHelper = new (self) class'HitRegionHelper';
    class'WillowGlobals'.static.GetWillowGlobals().TheObstacleUtility.RegisterObstacle(self);
    SpawnDefaultController();
    // End:0x16F
    if(int(Role) == int(ROLE_Authority))
    {
        SetTimer(0.01, false, 'AddDefaultInventory');
    }
    SetTimer(FRand() * 6, false, 'TryBlink');
    //return;    
}

