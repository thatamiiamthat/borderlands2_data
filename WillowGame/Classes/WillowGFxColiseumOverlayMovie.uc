}

function ShowResultsScreen(WillowGFxColiseumOverlayMovie.EColiseumLatentScreen ScreenType, bool bEnableGamerCardUI)
{
    LatentScreenType = ScreenType;
    bDismissable = false;
    bSuppressHUD = true;
    bEveryoneSignedInOn360 = bEnableGamerCardUI;
    switch(ScreenType)
    {
        // End:0x6E
        case 1:
            RoundResult = "victory";
            // End:0x8D
            break;
        // End:0x8A
        case 0:
            RoundResult = "defeated";
            // End:0x8D
            break;
        // End:0xFFFF
        default:
            break;
    }
    WillowHUD(WPCOwner.myHUD).CloseStatusMenu(none);
    HighlightedResultsLine = 1;
    ShowResults_Wrapper();
    //return;    
}

