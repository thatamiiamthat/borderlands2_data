function BeginRoundAnnounce()
{
    local string HealthModifierText, DamageModifierText, ShieldModifierText;

    HealthModifierText = OverlayDef.EvaluateBalanceFormula(OverlayDef.HealthModifier, 1);
    DamageModifierText = OverlayDef.EvaluateBalanceFormula(OverlayDef.DamageModifier, 100);
    ShieldModifierText = OverlayDef.EvaluateBalanceFormula(OverlayDef.ShieldModifier, 100);
    // End:0x1DB
    foreach WPCOwner.WorldInfo.AllControllers(class'WillowPlayerController', UnknownLocal_1)
    {
        UnknownLocal_1.ClientRoundAnnounce(int(OverlayDef.CurrentRoundCounter.GetValue(self)), int(OverlayDef.CurrentWaveCounter.GetValue(self)), CachedMaxRound, HealthModifierText, DamageModifierText, ShieldModifierText);        
    }    
    //return;    
}

function string GetFilledInRoundSummary(int Round, int MaxRound)
{
    local string FilledRoundSummary;

    FilledRoundSummary = Repl(RoundSummary, "%X", string(Round));
    FilledRoundSummary = Repl(FilledRoundSummary, "%Y", string(CachedMaxRound));
    return FilledRoundSummary;
    //return ReturnValue;    
}

function RoundAnnounce(int Round, int Wave, int MaxRound, string HealthModText, string DamageModTex, string ShieldModTex)
{
    local string FilledRoundSummary, HordeStrongerText, FlavorLookupKey;

    CachedRound = Round;
    CachedWave = Wave;
    CachedMaxRound = MaxRound;
    FilledRoundSummary = GetFilledInRoundSummary(CachedRound, CachedMaxRound);
    // End:0x92
    if(Round < 10)
    {
        FlavorLookupKey = "Flavor0" $ string(Round);        
    }
    else
    {
        FlavorLookupKey = "Flavor" $ string(Round);
    }
    HordeStrongerText = Localize("FlavorText", FlavorLookupKey, "dlc2_Menus");
    UnknownLocal_1 = 0;
    J0xED:

    // End:0x130 [Loop If]
    if(UnknownLocal_1 < PlayerLines.Length)
    {
        PlayerLines[UnknownLocal_1].bUpdatedThisRound = false;
        ++ UnknownLocal_1;
        // [Loop Continue]
        goto J0xED;
    }
    RoundAnnounce_Wrapper(RoundPrefix $ string(Round), WavePrefix $ string(Wave), OverlayDef.WaveLabels[Wave - 1], FilledRoundSummary, Wave, HordeStrongerText, HealthModText $ EnemyHealth, DamageModTex $ EnemyDamage, ShieldModTex $ EnemyShields);
    //return;    
}

