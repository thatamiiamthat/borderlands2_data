function bool OnResultsScreenInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0xAA
    if((int(uevent) == int(0)) || int(uevent) == int(2))
    {
        switch(ukey)
        {
            // End:0x49
            case 'Gamepad_LeftStick_Up':
            // End:0x55
            case 'XboxTypeS_DPad_Up':
            // End:0x72
            case 'Up':
                MoveResultsHighlight(5);
                return true;
                // End:0xAA
                break;
            // End:0x7E
            case 'Gamepad_LeftStick_Down':
            // End:0x8A
            case 'XboxTypeS_DPad_Down':
            // End:0xA7
            case 'Down':
                MoveResultsHighlight(6);
                return true;
                // End:0xAA
                break;
            // End:0xFFFF
            default:
                break;
        }
    }
    else
    {
        // End:0x236
        if(int(uevent) == int(0))
        {
            // End:0xF7
            if((ukey == 'XboxTypeS_Y') && bEveryoneSignedInOn360)
            {
                ShowGamerTagCard(ControllerId);
            }
            // End:0x234
            if(bDismissable)
            {
                switch(ukey)
                {
                    // End:0x123
                    case 'XboxTypeS_A':
                    // End:0x12F
                    case 'Enter':
                    // End:0x13B
                    case 'XboxTypeS_Start':
                    // End:0x1BF
                    case 'SpaceBar':
                        CloseResultsScreen();
                        // End:0x194
                        if(RoundResult == "defeated")
                        {
                            WPCOwner.ServerResultsScreenClosed('TryAgain');                            
                        }
                        else
                        {
                            WPCOwner.ServerResultsScreenClosed('VictoryScreenClosed');
                        }
                        // End:0x234
                        break;
                    // End:0x1CB
                    case 'XboxTypeS_B':
                    // End:0x231
                    case 'Escape':
                        // End:0x1FC
                        if(RoundResult == "defeated")
                        {
                            ShowColiseumToLobbyConfirm();                            
                        }
                        else
                        {
                            CloseResultsScreen();
                            WPCOwner.ServerResultsScreenClosed('VictoryScreenClosed');
                        }
                        // End:0x234
                        break;
                    // End:0xFFFF
                    default:
                        break;
                }
            }
            else
            {
                return true;
            }/* !MISMATCHING REMOVE, tried If got Type:Else Position:0x234! */
            return false;
            //return ReturnValue;            
        }/* !MISMATCHING REMOVE, tried Else got Type:If Position:0x0AA! */
    }
}

function bool OnCertificateInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0x4C
    if(int(uevent) == int(0))
    {
        // End:0x4A
        if(bDismissable)
        {
            CloseCertificateScreen();
            WPCOwner.ServerCertificateClosed();
        }
        return true;
    }
    return false;
    //return ReturnValue;    
}

function bool OnConfirmInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0xC5
    if(int(uevent) == int(0))
    {
        switch(ukey)
        {
            // End:0x33
            case 'XboxTypeS_A':
            // End:0x3F
            case 'Enter':
            // End:0x9B
            case 'XboxTypeS_Start':
                SetInput(None);
                CloseResultsScreen();
                WPCOwner.ServerResultsScreenClosed('Lobby');
                // End:0xC3
                break;
            // End:0xA7
            case 'XboxTypeS_B':
            // End:0xC0
            case 'Escape':
                CloseConfirm();
                // End:0xC3
                break;
            // End:0xFFFF
            default:
                break;
        }
        return true;
    }
    return false;
    //return ReturnValue;    
}

