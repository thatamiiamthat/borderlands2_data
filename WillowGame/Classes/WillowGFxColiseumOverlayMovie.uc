function CatchupNewPlayer(WillowPlayerController NewPlayer)
{
    NewPlayer.ClientCatchUpColiseumOverlay(OverlayDef, CachedRound, CachedWave, CachedMaxRound, CurrentRules[0], CurrentRules[1], CurrentRules[2], CurrentRules[3]);
    //return;    
}

function CatchupColiseumOverlay(int CurrRound, int CurrWave, int CurrMaxRound, ColiseumRuleDefinition Rule1, ColiseumRuleDefinition Rule2, ColiseumRuleDefinition Rule3, ColiseumRuleDefinition Rule4)
{
    local string FilledInRoundSummary, WaveTitle;

    CachedRound = CurrRound;
    CachedWave = CurrWave;
    CachedMaxRound = CurrMaxRound;
    FilledInRoundSummary = GetFilledInRoundSummary(CachedRound, CachedMaxRound);
    // End:0xA3
    if(CachedWave >= 0)
    {
        WaveTitle = OverlayDef.WaveLabels[CachedWave - 1];
    }
    CurrentRules[0] = Rule1;
    CurrentRules[1] = Rule2;
    CurrentRules[2] = Rule3;
    CurrentRules[3] = Rule4;
    CatchupColiseum_Wrapper(RoundPrefix $ string(CachedRound), WavePrefix $ string(CachedWave), WaveTitle, FilledInRoundSummary, CachedWave);
    // End:0x1BE
    if(Rule1 != none)
    {
        CatchupColiseumRule_Wrapper(1, Rule1.RuleTitle, Rule1.RuleDescription, Rule1.FrameLabel);
    }
    // End:0x233
    if(Rule2 != none)
    {
        CatchupColiseumRule_Wrapper(2, Rule2.RuleTitle, Rule2.RuleDescription, Rule2.FrameLabel);
    }
    // End:0x2A8
    if(Rule3 != none)
    {
        CatchupColiseumRule_Wrapper(3, Rule3.RuleTitle, Rule3.RuleDescription, Rule3.FrameLabel);
    }
    // End:0x31D
    if(Rule4 != none)
    {
        CatchupColiseumRule_Wrapper(4, Rule4.RuleTitle, Rule4.RuleDescription, Rule4.FrameLabel);
    }
    //return;    
}

function UpdateVisibilityForStatusMenu(bool bMenuVisible)
{
    SetVariableBool("_visible", !bMenuVisible);
    //return;    
}

function MoveResultsHighlight(Engine.Actor.EMoveDir MoveDir)
{
    switch(MoveDir)
    {
        // End:0x3C
        case 5:
            // End:0x39
            if(HighlightedResultsLine > 1)
            {
                -- HighlightedResultsLine;
                UnknownLocal_1 = true;
            }
            // End:0x71
            break;
        // End:0x6E
        case 6:
            // End:0x6B
            if(HighlightedResultsLine < PlayerLines.Length)
            {
                ++ HighlightedResultsLine;
                UnknownLocal_1 = true;
            }
            // End:0x71
            break;
        // End:0xFFFF
        default:
            break;
    }
    // End:0x8C
    if(UnknownLocal_1)
    {
        HighlightGotoFrame(HighlightedResultsLine);
    }
    //return;    
}

function SetInput(delegate<OnInputKey> Del)
{
    UnknownLocal_1 = Del == none != __OnInputKey__Delegate == none;
    __OnInputKey__Delegate = Del;
    // End:0x93
    if(UnknownLocal_1)
    {
        GetPC().IgnoreMoveInput(__OnInputKey__Delegate != none);
        GetPC().IgnoreLookInput(__OnInputKey__Delegate != none);
    }
    //return;    
}

