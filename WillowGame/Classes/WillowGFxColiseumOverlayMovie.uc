function OnResultsScreenDismissable()
{
    local string ButtonBar;

    ButtonBar = "<font color='#CCCCCC'>";
    // End:0x8A
    if((int(Platform) == int(1)) && bEveryoneSignedInOn360)
    {        
        ButtonBar $= (Localize("ButtonBar", "viewGamerCard", "dlc2_Menus"));
    }
    bDismissable = true;
    WPCOwner.ClearTimer('OnResultsScreenDismissable');
    switch(LatentScreenType)
    {
        // End:0x124
        case 1:            
            ButtonBar $= (ResolveDataStoreMarkup("<StringAliasMap:training_okay>") $ "</font>");
            // End:0x188
            break;
        // End:0x185
        case 0:            
            ButtonBar $= (ResolveDataStoreMarkup(Localize("ButtonBar", "coliseumDead", "dlc2_Menus")) $ "</font>");
            // End:0x188
            break;
        // End:0xFFFF
        default:
            break;
    }
    SetVariableString("results.content.tooltips.htmlText", ButtonBar);
    //return;    
}

