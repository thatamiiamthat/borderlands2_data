function extSetupCertificate()
{
    local string SubbedCertText, Map;

    Map = WPCOwner.WorldInfo.GetStreamingPersistentWorldInfo().Title;
    // End:0xAD
    if(Len(Map) == 0)
    {
        Map = "FIX: " $ string(WPCOwner.WorldInfo.GetStreamingPersistentMapName());
    }
    // End:0xC9
    if(CachedRound > 5)
    {
        CertificateGotoAndStop(2);
    }
    SubbedCertText = Repl(CertificateText, "%G", WPCOwner.PlayerReplicationInfo.PlayerName);
    SubbedCertText = Repl(SubbedCertText, "%L", Map);
    SubbedCertText = Repl(SubbedCertText, "%R", string(CachedRound));
    SubbedCertText = Repl(SubbedCertText, "%W", string(CachedWave));
    SetVariableString("certificate.content.certificateDesc.text", SubbedCertText);
    SetInput(OnCertificateInputKey);
    SetVariableString("certificate.content.tooltips.htmlText", ("<font color='#777777'>" $ ResolveDataStoreMarkup("<StringAliasMap:training_okay>")) $ "</font>");
    WPCOwner.SetTimer(6, false, 'OnCertificateScreenDismissable', self);
    //return;    
}

function extConfirmIsOpen()
{
    SetInput(OnConfirmInputKey);
    //return;    
}

