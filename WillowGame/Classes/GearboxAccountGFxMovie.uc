function UpdateTooltips()
{
    local string Tooltips;

    // End:0x443
    if(GearboxAccountObj != none)
    {
        // End:0x7B
        if(GearboxAccountObj.SelectIsEnabled() == 1)
        {
            Tooltips = ResolveDataStoreMarkup(Localize("GearboxAccount", "Tooltips", "WillowMenu"));            
        }
        else
        {
            Tooltips = ResolveDataStoreMarkup(Localize("GearboxAccount", "Tooltips_SelectDisabled", "WillowMenu"));
        }
        // End:0x2F8
        if(((((WPCOwner != none) && WPCOwner.PlayerInput != none) && WPCOwner.PlayerInput.bUsingGamepad) && ScreenStack.Length > 0) && ScreenStack[ScreenStack.Length - 1] == "offers")
        {            
            Tooltips $= "    ";
            // End:0x211
            if(GearboxAccountObj.IsDisplayingOffers() == 1)
            {                
                Tooltips $= ResolveDataStoreMarkup(Localize("GearboxAccount", "Tooltips_RedeemCode", "WillowMenu"));                
            }
            else
            {
                // End:0x27B
                if(OfferCount > 0)
                {                    
                    Tooltips $= ResolveDataStoreMarkup(Localize("GearboxAccount", "Tooltips_MyOffers", "WillowMenu"));                    
                }
                else
                {                    
                    Tooltips $= ResolveDataStoreMarkup(("<font color='#808080'>" $ (Localize("GearboxAccount", "Tooltips_MyOffers", "WillowMenu"))) $ "</font>");
                }
            }
        }
        // End:0x3A7
        if((ScreenStack.Length > 0) && ScreenStack[ScreenStack.Length - 1] == "offers")
        {            
            Tooltips $= "    ";            
            Tooltips $= ResolveDataStoreMarkup(Localize("GearboxAccount", "Tooltips_TermsOfService", "WillowMenu"));
        }        
        Tooltips $= "    ";        
        Tooltips $= ResolveDataStoreMarkup(Localize("GearboxAccount", "Tooltips_SupportID", "WillowMenu"));
        GearboxAccountObj.SetTooltips(Tooltips);
    }
    //return;    
}

function bool ValidateAge(int Month, int Day, int Year)
{
    // End:0x53
    if((Month > 0) && Month < 13)
    {
        // End:0x53
        if((Day > 0) && Day < 32)
        {
            // End:0x53
            if(Year > 0)
            {
                return true;
            }
        }
    }
    WPCOwner.GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgGearboxAccountAgeGateFailureInvalidDate");
    return false;
    //return ReturnValue;    
}

function bool ValidateEmail()
{
    local string Email;

    Email = GearboxAccountObj.GetEmail();
    // End:0x61
    if(InStr(Email, "@") != -1)
    {
        // End:0x61
        if(InStr(Email, ".") != -1)
        {
            return true;
        }
    }
    WPCOwner.GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgGearboxAccountInvalidEmail");
    return false;
    //return ReturnValue;    
}

function bool ValidatePassword()
{
    local string Password;

    Password = GearboxAccountObj.GetPassword();
    // End:0x82
    if(Len(Password) >= 8)
    {
        // End:0x82
        if(Password != (Localize("GearboxAccount", "DefaultPassword", "WillowMenu")))
        {
            return true;
        }
    }
    WPCOwner.GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgGearboxAccountInvalidPassword");
    return false;
    //return ReturnValue;    
}

function bool ValidateConfirmPassword()
{
    // End:0x45
    if(GearboxAccountObj.GetPassword() == GearboxAccountObj.GetConfirmPassword())
    {
        return true;
    }
    WPCOwner.GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgGearboxAccountPasswordsMustMatch");
    return false;
    //return ReturnValue;    
}

