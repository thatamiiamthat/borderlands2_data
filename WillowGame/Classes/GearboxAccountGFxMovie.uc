function HandleBack()
{
    // End:0x6F
    if(!PopScreen())
    {
        UnknownLocal_1 = ((WPCOwner != none) ? WPCOwner.GetFrontendMovie() : none);
        // End:0x6C
        if(UnknownLocal_1 != none)
        {
            UnknownLocal_1.HideAccountMovie();
        }        
    }
    else
    {
        // End:0x9B
        if(ScreenStack[ScreenStack.Length - 1] == "eula")
        {
            UpdateLegal();
        }
    }
    //return;    
}

function PushScreen(string Screen)
{
    ScreenStack.AddItem(Screen;
    GearboxAccountObj.DisplayScreen(Screen);
    UpdateTooltips();
    //return;    
}

function bool PopScreen()
{
    // End:0x8F
    if(ScreenStack.Length > 1)
    {
        // End:0x3E
        if(ScreenStack[ScreenStack.Length - 1] == "eula")
        {
            bViewingEula = false;
        }
        ScreenStack.Remove(ScreenStack.Length - 1, 1;
        GearboxAccountObj.DisplayScreen(ScreenStack[ScreenStack.Length - 1]);
        return true;
    }
    return false;
    //return ReturnValue;    
}

function ReturnToWelcomeScreen()
{
    ScreenStack.Length = 0;
    // End:0x31
    if((IsSignedIn()) == 1)
    {
        PushScreen("offers");        
    }
    else
    {
        PushScreen("welcome");
    }
    //return;    
}

function UpdatePlayerName()
{
    local string PlayerName;

    PlayerName = ResolveDataStoreMarkup(Localize("GearboxAccount", "PlayerNameFormat", "WillowMenu"));
    PlayerName = Repl(PlayerName, "%playername%", WPCOwner.PlayerReplicationInfo.GetHumanReadableHTMLName());
    GearboxAccountObj.SetPlayerName(PlayerName);
    //return;    
}

function UpdateShiftUrl()
{
    local SparkInterface Spark;
    local string ShiftUrlCaption;

    Spark = class'GearboxEngine'.static.GetSparkInterface();
    UnknownLocal_1 = Spark.GetGearboxAccountData(WPCOwner.GetMyControllerId());
    // End:0x1CD
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_3 = UnknownLocal_1.GetService('Archway');
        // End:0xDF
        if(UnknownLocal_3 != none)
        {
            ShiftUrlString = UnknownLocal_3.GetStringParameter("ShiftUrl", "");
        }
        ShiftUrlCaption = ResolveDataStoreMarkup(Localize("GearboxAccount", "ChangeAccountSettingsLabel", "WillowMenu"));
        ShiftUrlCaption = Repl(ShiftUrlCaption, "%shiftUrl%", ShiftUrlString);
        ShiftUrlString = ShiftUrlCaption;
        ShiftUrlCaption = ("<font size='12'>" $ ShiftUrlString) $ "</font>";
