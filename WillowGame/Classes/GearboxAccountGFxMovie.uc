        // End:0xE4
        if((Len(Result) == 5) || Len(Result) == 25)
        {
            GearboxAccountObj.TrySetKeyCode(Result);            
        }
        else
        {
            WPCOwner.GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgGearboxAccountCodePasteInvalid");
        }
    }
    //return;    
}

