    {
        provisionalDisplayName = WPCOwner.OnlineSub.PlayerInterface.GetPlayerNickname(WPCOwner.GetMyControllerId());
        Spark = class'GearboxEngine'.static.GetSparkInterface();
        Spark.SetDisplayNameThroughBifrost(provisionalDisplayName);        
    }
    WPCOwner.HandleSignInChange();
    return true;
    //return ReturnValue;    
}

