function TryPasteKeyCode()
{
    local array<string> CodeSegments;
    local string Result;

    // End:0x15F
    if(GearboxAccountObj != none)
    {
        Result = WPCOwner.PasteFromClipboard();
        // End:0x93
        if(InStr(Result, "-") != -1)
