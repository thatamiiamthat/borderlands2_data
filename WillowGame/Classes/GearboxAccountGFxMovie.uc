                    UnknownLocal_3.bNoCancel = true;
                    UnknownLocal_3.ReplaceDialogText("%SIGNEDINNAME%", SignedInDisplayName);
                    UnknownLocal_3.ReplaceDialogText("%PROVISIONALNAME%", provisionalDisplayName);
                    UnknownLocal_3.ApplyLayout();                    
                }
                else
                {
                    WPCOwner.HandleSignInChange();
                }
            }
            // End:0x730
            break;
        // End:0x467
        case 3:
            WPCOwner.GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgGearboxAccountLoginFailSignInFailure");
            // End:0x730
            break;
        // End:0x4FB
        case 1:
