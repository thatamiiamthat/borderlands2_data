            // End:0x730
            break;
        // End:0x58E
        case 2:
            WPCOwner.GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgGearboxAccountPlatformTakenBySelfSignInFailure");
            // End:0x730
            break;
