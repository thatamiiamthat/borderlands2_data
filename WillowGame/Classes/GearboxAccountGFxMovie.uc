    GearboxAccountObj.SetFunction("IsFirstWelcome", self, 'IsFirstWelcome');
    GearboxAccountObj.SetFunction("OnBackButtonClick", self, 'OnBackButtonClick');
    GearboxAccountObj.SetFunction("OnEmailButtonClick", self, 'OnEmailButtonClick');
    GearboxAccountObj.SetFunction("OnPasswordButtonClick", self, 'OnPasswordButtonClick');
    GearboxAccountObj.SetFunction("OnConfirmPasswordButtonClick", self, 'OnConfirmPasswordButtonClick');
    GearboxAccountObj.SetFunction("OnWelcomeScreenSignInButtonClick", self, 'OnWelcomeScreenSignInButtonClick');
    GearboxAccountObj.SetFunction("OnWelcomeScreenSignUpButtonClick", self, 'OnWelcomeScreenSignUpButtonClick');
    GearboxAccountObj.SetFunction("OnSignInScreenSignInButtonClick", self, 'OnSignInScreenSignInButtonClick');
    GearboxAccountObj.SetFunction("OnSignInScreenResetPasswordButtonClick", self, 'OnSignInScreenResetPasswordButtonClick');
    GearboxAccountObj.SetFunction("OnResetPasswordScreenResetPasswordButtonClick", self, 'OnResetPasswordScreenResetPasswordButtonClick');
    GearboxAccountObj.SetFunction("OnEULAScreenAcceptButtonClick", self, 'OnEULAScreenAcceptButtonClick');
    GearboxAccountObj.SetFunction("OnSignUpScreenSignUpButtonClick", self, 'OnSignUpScreenSignUpButtonClick');
    GearboxAccountObj.SetFunction("OnAgeGateConfirmAgeButtonClick", self, 'OnAgeGateConfirmAgeButtonClick');
    GearboxAccountObj.SetFunction("OnRedeemCodeButtonClick", self, 'OnRedeemCodeButtonClick');
    //return;    
}

