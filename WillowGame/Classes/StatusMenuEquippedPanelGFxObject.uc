}

function OnStartDrag(GFxObject StartingCell, GFxObject OutDragData)
{
    ParentPanel.OnStartDrag(StartingCell, OutDragData);
    //return;    
}

function bool CanFinishDragOnCell(int CellSuffix)
{
    local WillowDeclarations.EQuickWeaponSlot QuickWeaponSlot;

    UnknownLocal_1 = StatusMenuInventoryPanelGFxObject(ParentPanel).EquippingThing;
    UnknownLocal_3 = WillowWeapon(UnknownLocal_1);
    // End:0xCF
    if(UnknownLocal_3 != none)
    {
        QuickWeaponSlot = GetWeaponSlotFromSuffix(CellSuffix);
        // End:0x7F
        if(int(QuickWeaponSlot) == int(0))
        {
            return false;
        }
        // End:0xCD
        if(((int(QuickWeaponSlot) == int(3)) && !bReadyWeaponLeftUnlocked) || (int(QuickWeaponSlot) == int(4)) && !bReadyWeaponRightUnlocked)
        {
            return false;
        }
        return true;
    }
    // End:0xFB
    if((UnknownLocal_1 != none) && (GetTypeCellSuffixBasedOnThing(UnknownLocal_1)) == CellSuffix)
    {
        return true;
    }
    return false;
    //return ReturnValue;    
}

function PrepareForFinishDrag(int CellSuffix)
{
    SelectedCellSuffix = CellSuffix;
    //return;    
}

