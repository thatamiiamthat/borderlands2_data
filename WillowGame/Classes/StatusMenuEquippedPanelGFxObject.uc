}

function ShowDualWieldInventoryGuides(bool bShow, int SlotsUnlocked)
{
    GetObject("gunzerker1").SetVisible(bShow);
    GetObject("gunzerker2").SetVisible(bShow && SlotsUnlocked == 4);
    //return;    
}
