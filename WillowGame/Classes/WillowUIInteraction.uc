function RunStatusMenu(WillowPlayerController PC)
{
    OwnerPC = PC;
    // End:0x76
    if(OwnerPC != none)
    {
        UnknownLocal_1 = WillowHUD(OwnerPC.myHUD);
        // End:0x76
        if(UnknownLocal_1 != none)
        {
            UnknownLocal_1.RunStatusMenu(self);
        }
    }
    //return;    
}

function CloseStatusMenu(WillowPlayerController PC)
{
    // End:0x63
    if(PC != none)
    {
        UnknownLocal_1 = WillowHUD(PC.myHUD);
        // End:0x63
        if(UnknownLocal_1 != none)
        {
            UnknownLocal_1.CloseStatusMenu(self);
        }
    }
    //return;    
}

function CloseMenu(optional bool bOnGameSessionEnded)
{
    bOpened
    J0x0E:

    // End:0x3A [Loop If]
    if(MenuStack.Length > 0)
    {
        MenuStack.Remove(MenuStack.Length - 1, 1;
        // [Loop Continue]
        goto J0x0E;
    }
    // End:0xDE
    if((OwnerPC != none) && OwnerPC.myHUD != none)
    {
        UnknownLocal_1 = WillowHUD(OwnerPC.myHUD);
        // End:0xDE
        if(UnknownLocal_1 != none)
        {
            UnknownLocal_1.bShowHUD = UnknownLocal_1.bShowHUDRestoreValue;
        }
    }
    LastWeaponIndex = -1;
    LastMerchantWeaponIndex = -1;
    LastItemIndex = -1;
    OwnerPC = none;
    bOpened = false;
    ClearUIInputBlocks();
    //return;    
}

function HandleClientMessage(coerce string S, optional name Type, optional float MsgLifeTime)
{
    UnknownLocal_1
    LocalPlayer(OwnerPC.Player)
    // End:0xDC
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_1.ViewportClient.ClearProgressMessages();
        UnknownLocal_1.ViewportClient.SetProgressTime(2);
        UnknownLocal_1.ViewportClient.SetProgressMessage(1, S);
    }
    //return;    
}

