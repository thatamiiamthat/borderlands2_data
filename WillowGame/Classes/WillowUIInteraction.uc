event BlockUIInput(bool bBlock)
{
    // End:0x1B
    if(bBlock)
    {
        ++ BlockUIInputSemaphore;        
    }
    else
    {
        // End:0x35
        if(BlockUIInputSemaphore > 0)
        {
            -- BlockUIInputSemaphore;
        }
    }
    //return;    
}

