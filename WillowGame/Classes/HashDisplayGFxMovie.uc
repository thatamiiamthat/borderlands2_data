    __OnStatefulInputKey__Delegate = NormalStateInputKey;
    ConfigureForPlayer(float(((WPCOwner.IsPrimaryPlayer()) ? 0 : 1)));
    LeftSideTextList.EmptyData();
    LeftSideTextList.ResetState();
    SetAllAmmoCounts();
    WPCOwner.GetFullInventory(TempArray);
    LeftSideTextList.UpdateEntriesPerPage(HashDisplayDef.LeftSideDef.InitialEntryCount);
    SetupContainerWithData(LeftSideTextList, TempArray);
    LeftSideTextList.SetHighlightBarNormal();
    UpdateCardPanelWithCurrentActiveListEntry();
    SetVariableString("hash.tab.text", Localize("Labels", "hashdisplay", "dlc2_Menus"));
    SetVariableString("hash.rightSideLabel.text", Localize("Labels", "hashheader", "dlc2_Menus"));
    SetVariableString("hash.hashDesc.text", Localize("Labels", "hashtext", "dlc2_Menus"));
    SetVariableString("hash.tooltips.htmlText", ResolveDataStoreMarkup(Localize("ButtonBar", "hashdisplay_bar", "dlc2_Menus")));
    SetCredits(WillowPlayerReplicationInfo(WPCOwner.PlayerReplicationInfo).GetCurrencyOnHand(0));
    //return;    
}

