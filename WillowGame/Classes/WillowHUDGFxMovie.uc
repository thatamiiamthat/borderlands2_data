event AddTrainingText(string MessageString, string TitleString, float Duration, Color DrawColor, string HUDInitializationFrame, bool PausesGame, float PauseContinueDelay, PlayerReplicationInfo Related_PRI1, optional bool bIsntActuallyATrainingMessage, optional WillowPlayerController.EBackButtonScreen StatusMenuTab, optional bool bMandatory)
{
    local CriticalTextMessage TextMessage;

    UnknownLocal_1
    WillowGameReplicationInfo(WPCOwner.WorldInfo.GRI)
    // End:0x476
    if((Duration > 0) && ((WPCOwner.IsTrainingEnabled() && (UnknownLocal_1 == none) || UnknownLocal_1.GetCurrPlaythrough() == 0) || bIsntActuallyATrainingMessage) || bMandatory)
    {
        UnknownLocal_3 = true;
        // End:0x150
        if(PausesGame)
        {
            UnknownLocal_5 = WPCOwner.WorldInfo.Game;
            // End:0x149
            if(UnknownLocal_5 != none)
            {
                UnknownLocal_3 = UnknownLocal_5.GetNumPlayers() == 1;                
            }
            else
            {
                UnknownLocal_3 = false;
            }
        }
        // End:0x2DC
        if(!PausesGame || !UnknownLocal_3)
        {
            // End:0x19B
            if(TrainingTextMessages.MessageArray.Length == 0)
            {
                OpenTrainingTextBox();                
            }
            else
            {
                TrainingTextMessages.MessageArray.Remove(0, 1;
            }
            TextMessage.Message = ResolveDataStoreMarkup(MessageString);
            TextMessage.Title = ResolveDataStoreMarkup(TitleString);
            TextMessage.DestroyTime = Duration;
            TextMessage.DrawColor = DrawColor;
            TrainingTextMessages.MessageArray.AddItem(TextMessage;
            DrawTrainingText();
            // End:0x2D9
            if(int(StatusMenuTab) != int(0))
            {
                WPCOwner.ShowContextualPrompt(StatusMenuTab);
            }            
        }
        else
        {
            // End:0x389
            if((int(StatusMenuTab) == int(0)) || WPCOwner.CanShowModalMenu(UnknownLocal_7))
            {
                WPCOwner.GFxUIManager.ShowTrainingDialog(ResolveDataStoreMarkup(MessageString), ResolveDataStoreMarkup(TitleString), PauseContinueDelay, StatusMenuTab);                
            }
            else
            {
                RetryTrainingTime = RetryTrainingDuration;
                RetryTraining_MessageString = MessageString;
                RetryTraining_TitleString = TitleString;
                RetryTraining_Duration = Duration;
                RetryTraining_DrawColor = DrawColor;
                RetryTraining_HUDInitializationFrame = HUDInitializationFrame;
                RetryTraining_PausesGame = PausesGame;
                RetryTraining_PauseContinueDelay = PauseContinueDelay;
                RetryTraining_Related_PRI1 = Related_PRI1;
                RetryTraining_bIsntActuallyATrainingMessage = bIsntActuallyATrainingMessage;
                RetryTraining_StatusMenuTab = StatusMenuTab;
                RetryTraining_bMandatory = bMandatory;
            }
        }        
    }
    else
    {
        // End:0x489
        if(Duration <= 0)
        {
        }
    }
    // End:0x562
    if((HUDInitializationFrame != "") && !class'Engine'.static.IsSplitScreen())
    {
        MyHUDOwner.QueuedInitFrame = HUDInitializationFrame;
        // End:0x55F
        if(EchoVersionMovie != none)
        {
            EchoVersionMovie.GotoAndStop("active");
            EchoVersionMovie.SingleArgInvokeS("echo_version.gotoAndPlay", HUDInitializationFrame);
        }        
    }
    else
    {
        // End:0x5BA
        if(class'Engine'.static.IsSplitScreen() && EchoVersionMovie != none)
        {
            EchoVersionMovie.GotoAndStop("none");
        }
    }
    //return;    
}

