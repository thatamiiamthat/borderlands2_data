function AddTrackedSkill(SkillDefinition SkillDef)
{
    local AvailableTrackedSkill NewSkill;

    // End:0x108
    if((((int(SkillDef.TrackedSkillType) == int(2)) || int(SkillDef.TrackedSkillType) == int(6)) || int(SkillDef.TrackedSkillType) == int(3)) || int(SkillDef.TrackedSkillType) == int(5))
    {
        NewSkill.SkillDef = SkillDef;
        NewSkill.RemappedSlot = -1;
        AvailableTrackedSkills.AddItem(NewSkill;
    }
    //return;    
}

event InitSkillIconsAvailability()
{
    local SkillTreeSkillStateData SkillState;

    AvailableTrackedSkills.Length = 0;
    UnknownLocal_1 = WPCOwner.PlayerSkillTree;
    // End:0x11D
    if(UnknownLocal_1 != none)
    {
        // End:0x11C
        foreach UnknownLocal_1.AllSkills(UnknownLocal_3)
        {
            // End:0x11B
            if(UnknownLocal_1.GetSkillState(UnknownLocal_3, SkillState))
            {
                // End:0x11B
                if(SkillState.SkillGrade > 0)
                {
                    AddTrackedSkill(UnknownLocal_3);
                    UnknownLocal_5 = 0;
                    J0xC2:

                    // End:0x11B [Loop If]
                    if(UnknownLocal_5 < UnknownLocal_3.TrackedActiveSkills.Length)
                    {
                        AddTrackedSkill(UnknownLocal_3.TrackedActiveSkills[UnknownLocal_5]);
                        ++ UnknownLocal_5;
                        // [Loop Continue]
                        goto J0xC2;
                    }
                }
            }            
        }        
    }
    SortAvailableTrackedSkills();
    //return;    
}

