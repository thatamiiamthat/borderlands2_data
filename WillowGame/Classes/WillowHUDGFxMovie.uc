event ToggleKillSkills(bool bEnable)
{
    local SkillTreeSkillStateData SkillState;
    local string KillSkillPrefix;

    // End:0x1D9
    if(bEnable && WPCOwner != none)
    {
        // End:0x1D9
        if(WPCOwner.Pawn != none)
        {
            // End:0x12D
            if(WPCOwner.Pawn.IsA('WillowVehicle') || WPCOwner.Pawn.IsA('WillowWeaponPawn') && !WillowWeaponPawn(WPCOwner.Pawn).IsAttachedRiderSeat())
            {
                // End:0x12A
                if(!WPCOwner.CanKillSkillIconsBeDisplayedFromVehicles(true, false))
                {
                    bEnable = false;
                }                
            }
            else
            {
                // End:0x1D9
                if(WPCOwner.Pawn.IsA('WillowWeaponPawn') && WillowWeaponPawn(WPCOwner.Pawn).IsAttachedRiderSeat())
                {
                    // End:0x1D9
                    if(!WPCOwner.CanKillSkillIconsBeDisplayedFromVehicles(false, true))
                    {
                        bEnable = false;
                    }
                }
            }
        }
    }
    // End:0x4C3
    if(int(bCachedKillSkillsEnabled) != int(byte(bEnable)))
    {
        bCachedKillSkillsEnabled = byte(bEnable);
        UnknownLocal_1 = WPCOwner;
        // End:0x22B
        if(!UnknownLocal_1 != none)
        {
            return;
        }
        // End:0x24F
        if(!UnknownLocal_1.PlayerSkillTree != none)
        {
            return;
        }
        UnknownLocal_3 = 1;
        KillSkillPrefix = "p1.instinctbar.rush";
        // End:0x3FA
        if(bEnable)
        {
            // End:0x3E7
            foreach UnknownLocal_1.PlayerSkillTree.AllSkillsOfType(3, UnknownLocal_5)
            {
                // End:0x3E6
                if((UnknownLocal_3 <= 5) && UnknownLocal_1.PlayerSkillTree.GetSkillState(UnknownLocal_5, SkillState))
                {
                    // End:0x3E6
                    if(SkillState.SkillGrade > 0)
                    {
                        // End:0x353
                        if(!UnknownLocal_5.SkillIcon != none)
                        {
                            continue;                            
                        }
                        SingleArgInvokeS((KillSkillPrefix $ string(UnknownLocal_3)) $ ".gotoAndStop", "on");
                        SingleArgInvokeS((KillSkillPrefix $ string(UnknownLocal_3)) $ ".setIconClip", UnknownLocal_5.SkillIcon.GetPathForLoadMovie());
                        ++ UnknownLocal_3;
                    }
                }                
            }            
            NumSkillSkillsVisible = UnknownLocal_3 - 1;
        }
        J0x3FA:

        // End:0x4A9 [Loop If]
        if(UnknownLocal_3 <= 5)
        {
            SingleArgInvokeS((KillSkillPrefix $ string(UnknownLocal_3)) $ ".gotoAndStop", "none");
            // End:0x49F
            if(!bEnable)
            {
                // End:0x49F
                if((UnknownLocal_3 - 1) < NumSkillSkillsVisible)
                {
                    SingleArgInvokeS((KillSkillPrefix $ string(UnknownLocal_3)) $ ".killSkillPulseOut.gotoAndPlay", "go");
                }
            }
            ++ UnknownLocal_3;
            // [Loop Continue]
            goto J0x3FA;
        }
        // End:0x4C3
        if(!bEnable)
        {
            NumSkillSkillsVisible = 0;
        }
    }
    //return;    
}

