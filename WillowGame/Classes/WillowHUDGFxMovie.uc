event AddCriticalText(string MessageString, float Duration, Color DrawColor, PlayerReplicationInfo Related_PRI1)
{
    local CriticalTextMessage TextMessage;

    // End:0xC5
    if(Duration > 0)
    {
        TextMessage.Message = ResolveDataStoreMarkup(MessageString);
        TextMessage.DestroyTime = Duration;
        TextMessage.DrawColor = DrawColor;
        CriticalTextMessages.MessageArray.AddItem(TextMessage;
        DrawCriticalText();        
    }
    //return;    
}

