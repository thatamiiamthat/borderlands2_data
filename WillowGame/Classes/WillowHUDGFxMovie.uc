function OpenQuickSelectWeaponMenuForPlayer(bool bPrimaryPlayer, int UpStatus, int DownStatus, int LeftStatus, int RightStatus, WillowInventory UpThing, WillowInventory DownThing, WillowInventory LeftThing, WillowInventory RightThing, int PlatformNumber)
{
    // End:0x65
    if(bPrimaryPlayer)
    {
        SetResourcesInArray(WeaponSelect, MyHUDDefinition.P1QuickSlotTextures, UpThing, DownThing, LeftThing, RightThing);        
    }
    else
    {
        SetResourcesInArray(WeaponSelect, MyHUDDefinition.P2QuickSlotTextures, UpThing, DownThing, LeftThing, RightThing);
    }
    PrivateOpenQuickSelectWeaponMenuForPlayer(bPrimaryPlayer, UpStatus, DownStatus, LeftStatus, RightStatus, PlatformNumber);
    //return;    
}

private final function SetResourcesInArray(out array<CellContentData> Resources, const out array<name> TextureNames, WillowInventory UpThing, WillowInventory DownThing, WillowInventory LeftThing, WillowInventory RightThing)
{
    Resources.Length = 4;
    Resources[0].Mesh = class'CellsNavigator'.static.ConstructInvMesh(UpThing);
    Resources[1].Mesh = class'CellsNavigator'.static.ConstructInvMesh(DownThing);
