event ShowRewardPopup(WillowDeclarations.ERewardPopup Type)
{
    SingleArgInvokeS("p1.badassToken.gotoAndStop", "stop");
    SingleArgInvokeS("p1.badassToken.gotoAndPlay", "go");
    switch(Type)
    {
        // End:0xEE
        case 0:
            PlayUISound('RewardToken');
            SingleArgInvokeS("p1.badassToken.inner.gotoAndStop", "token");
            SetVariableString("p1.badassToken.inner.dispText.text", BadassTokenGet);
            // End:0x28A
            break;
        // End:0x172
        case 1:
            PlayUISound('RewardCustomization');
            SingleArgInvokeS("p1.badassToken.inner.gotoAndStop", "head");
            SetVariableString("p1.badassToken.inner.dispText.text", CharacterHeadGet);
            // End:0x28A
            break;
        // End:0x1FC
        case 2:
            PlayUISound('RewardCustomization');
            SingleArgInvokeS("p1.badassToken.inner.gotoAndStop", "playerSkin");
            SetVariableString("p1.badassToken.inner.dispText.text", CharacterSkinGet);
            // End:0x28A
            break;
        // End:0x287
        case 3:
            PlayUISound('RewardCustomization');
            SingleArgInvokeS("p1.badassToken.inner.gotoAndStop", "vehicleSkin");
            SetVariableString("p1.badassToken.inner.dispText.text", VehicleSkinGet);
            // End:0x28A
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

