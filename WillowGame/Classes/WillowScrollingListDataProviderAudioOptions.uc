class WillowScrollingListDataProviderAudioOptions extends WillowScrollingListDataProviderOptionsBase
    hidecategories(Mobile);

function Populate(WillowScrollingList TheList)
{
    super.Populate(TheList);
    // End:0x2B1
    if(TheList.MyOwnerMovie.WPCOwner.IsPrimaryPlayer())
    {
        AddProfileSettingListItem(TheList, 107, "$WillowMenu.MenuOptionDisplayNames.MusicVolume", "$WillowMenu.MenuOptionDisplayNames.MusicVolumeDesc");
        AddProfileSettingListItem(TheList, 108, "$WillowMenu.MenuOptionDisplayNames.SFXVolume", "$WillowMenu.MenuOptionDisplayNames.SFXVolumeDesc");
        AddProfileSettingListItem(TheList, 127, "$WillowMenu.MenuOptionDisplayNames.VOVolume", "$WillowMenu.MenuOptionDisplayNames.VOVolumeDesc");
        AddProfileSettingListItem(TheList, 111, "$WillowMenu.MenuOptionDisplayNames.Subtitles", "$WillowMenu.MenuOptionDisplayNames.SubtitlesDesc");
        AddProfileSettingListItem(TheList, 117, "$WillowMenu.MenuOptionDisplayNames.OptionalVO", "$WillowMenu.MenuOptionDisplayNames.OptionalVODesc");
    }
    // End:0x4A5
    if(int(class'GearboxGlobals'.static.GetPlatform()) == int(0))
    {
        // End:0x424
        if(class'GameEngine'.static.GetOnlineSubsystem().Class.Name == 'OnlineSubsystemSteamworks')
        {
            AddProfileSettingListItem(TheList, 125, "$WillowMenu.MenuOptionDisplayNames.PushToTalk", "$WillowMenu.MenuOptionDisplayNames.PushToTalkDesc");
            AddProfileSettingListItem(TheList, 124, "$WillowMenu.MenuOptionDisplayNames.VoiceVolume", "$WillowMenu.MenuOptionDisplayNames.VoiceVolumeDesc");
        }
        AddSystemSettingListItem(TheList, 'AudioFocus', "$WillowMenu.MenuOptionDisplayNames.AudioFocus", "$WillowMenu.MenuOptionDisplayNames.AudioFocusDesc");
    }
    //return;    
}

function Cleanup(WillowScrollingList TheList)
{
    StopAllVolumeSounds(TheList);
    //return;    
}

function OnPop(WillowScrollingList TheList)
{
    StopAllVolumeSounds(TheList);
    super.OnPop(TheList);
    //return;    
}

function bool HandleClick(int EventID, WillowScrollingList TheList)
{
    CheckStopVolumeSound(EventID, TheList);
    return super(WillowScrollingListDataProviderBase).HandleClick(EventID, TheList);
    //return ReturnValue;    
}

function bool HandleSelectionChange(int EventID, WillowScrollingList TheList)
{
    CheckStopVolumeSound(EventID, TheList);
    return super.HandleSelectionChange(EventID, TheList);
    //return ReturnValue;    
}

function bool HandleSliderChange(int EventID, int NewSliderValue, WillowScrollingList TheList)
{
    CheckStopVolumeSound(EventID, TheList);
    return super.HandleSliderChange(EventID, NewSliderValue, TheList);
    //return ReturnValue;    
}

function bool HandleSpinnerChange(int EventID, int NewChoiceIndex, string NewChoiceValue, WillowScrollingList TheList)
{
    CheckStopVolumeSound(EventID, TheList);
    return super.HandleSpinnerChange(EventID, NewChoiceIndex, NewChoiceValue, TheList);
    //return ReturnValue;    
}

function CheckStopVolumeSound(int EventID, WillowScrollingList TheList)
{
    // End:0x59
    if(EventID != 127)
    {
        TheList.MyOwnerMovie.WPCOwner.StopVOVolumeSound();
    }
    // End:0xB2
    if(EventID != 108)
    {
        TheList.MyOwnerMovie.WPCOwner.StopSFXVolumeSound();
    }
    // End:0x10B
    if(EventID != 107)
    {
        TheList.MyOwnerMovie.WPCOwner.StopMusicVolumeSound();
    }
    //return;    
}

function StopAllVolumeSounds(WillowScrollingList TheList)
{
    TheList.MyOwnerMovie.WPCOwner.StopVOVolumeSound();
    TheList.MyOwnerMovie.WPCOwner.StopSFXVolumeSound();
    TheList.MyOwnerMovie.WPCOwner.StopMusicVolumeSound();
    //return;    
}

function UpdateRealtimeSetting(int EventID, WillowPlayerController WPCOwner)
{
    super.UpdateRealtimeSetting(EventID, WPCOwner);
    // End:0x4E
    if(EventID == 127)
    {
        WPCOwner.PlayVOVolumeSound();        
    }
    else
    {
        // End:0x80
        if(EventID == 108)
        {
            WPCOwner.PlaySFXVolumeSound();            
        }
        else
        {
            // End:0xAF
            if(EventID == 107)
            {
                WPCOwner.PlayMusicVolumeSound();
            }
        }
    }
    //return;    
}

defaultproperties
{
    MenuDisplayName="AUDIO"
}