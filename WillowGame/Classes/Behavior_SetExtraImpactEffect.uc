class Behavior_SetExtraImpactEffect extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) WillowLightProjectileManager.EBulletFromClip BulletFromClip;
var(Action) WillowImpactDefinition ImpactDefinition;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IExtraImpactEffects ContextInterface;

    ContextInterface = ContextObject.QueryInterface(class'IExtraImpactEffects');
    // End:0x84
    if(NotEqual_InterfaceInterface(ContextInterface, IExtraImpactEffects(none)))
    {
        ContextInterface.SetExtraImpactEffect(BulletFromClip, ImpactDefinition);
    }
    //return;    
}
