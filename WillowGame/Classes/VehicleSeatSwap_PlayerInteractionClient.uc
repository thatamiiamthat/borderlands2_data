class VehicleSeatSwap_PlayerInteractionClient extends PlayerInteractionClient within WillowPlayerController
    hidecategories(Mobile);

var() const localized string MsgTitle;
var private bool bIsInstigator;

simulated function Initialize(int MessageData)
{
    super.Initialize(MessageData);
    switch(MessageData)
    {
        // End:0xAC
        case 0:
            bIsInstigator = true;
            Outer.DisplayHUDMessage(0, ("<StringAliasMap:SwitchSeatsWaiting>" $ ":::") $ MsgTitle, 200, MakeColor(255, 255, 255, 255));
            // End:0x14A
            break;
        // End:0x131
        case 1:
            bIsInstigator = false;
            Outer.DisplayHUDMessage(0, ("<StringAliasMap:SwitchSeatsAccept>" $ ":::") $ MsgTitle, 200, MakeColor(255, 255, 255, 255));
            // End:0x14A
            break;
        // End:0xFFFF
        default:
            super.Initialize(MessageData);
            // End:0x14A
            break;
            break;
    }
    //return;    
}

simulated function bool HandleSeatSwapCommand()
{
    // End:0x57
    if(WillowGameInfo(Outer.WorldInfo.Game).TravelCountdownInProcess())
    {
        return false;
    }
    SendMessage(((bIsInstigator) ? 4 : 2), none);
    return true;
    //return ReturnValue;    
}

simulated function ShutDown()
{
    Outer.ClearHUDMessage(0);
    //return;    
}

defaultproperties
{
    MsgTitle="Seat Exchange"
}