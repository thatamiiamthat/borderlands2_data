class Behavior_VectorToLocalSpace extends BehaviorBase
    native
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) Vector WorldSpaceVector;
var(Action) const name AttachmentPointName;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IWorldBody WorldBody;
    local Matrix BodyTranslateRotate;
    local Vector BodyLocation;
    local Rotator BodyRotation;
    local Vector LocalSpaceVector;

    WorldBody = ContextObject.QueryInterface(class'IWorldBody');
    // End:0x54
    if(EqualEqual_InterfaceInterface(WorldBody, IWorldBody(none)))
    {
        return;
    }
    // End:0xE8
    if(!WorldBody.GetWorldBodyAttachmentLocationAndRotation(AttachmentPointName, BodyLocation, BodyRotation))
    {
        BodyLocation = WorldBody.GetWorldBodyLocation();
        BodyRotation = WorldBody.GetWorldBodyRotation();
    }
    BodyTranslateRotate = MakeRotationTranslationMatrix(BodyLocation, BodyRotation);
    LocalSpaceVector = InverseTransformVector(BodyTranslateRotate, WorldSpaceVector);
    PublishBehaviorOutput(KernelInfo, LocalSpaceVector);
    //return;    
}

protected event PublishBehaviorOutput(out BehaviorKernelInfo KernelInfo, Vector VectorResult)
{
    UnknownLocal_1 = class'WillowGlobals'.static.GetBehaviorKernel();
    UnknownLocal_1.PublishVectorOutputVariable(KernelInfo, VectorResult);
    //return;    
}
