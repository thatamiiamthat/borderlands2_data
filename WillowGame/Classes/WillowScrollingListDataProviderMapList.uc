function bool HandleClick(int EventID, WillowScrollingList TheList)
{
    // End:0xEC
    foreach TheList.MyOwnerMovie.WPCOwner.WorldInfo.AllControllers(class'WillowPlayerController', UnknownLocal_1)
    {
        UnknownLocal_1.ClientFindPlayMovie(MapListDef.ListItems[EventID].MapName);
        UnknownLocal_1.SetCinematicMode(false, false, true, true, true, true, true, true);        
    }    
    // End:0x1D4
    if(MapListDef.ListItems[EventID].bUseLoader)
    {        
        TheList.MyOwnerMovie.WPCOwner.ConsoleCommand(("openl " $ string(MapListDef.ListItems[EventID].MapName)) $ "?listen");        
    }
    else
    {
        TheList.MyOwnerMovie.WPCOwner.WorldInfo.ServerTravel(string(MapListDef.ListItems[EventID].MapName) $ "?listen", true, false);
    }
    TheList.MyOwnerMovie.Close();
    return true;
    //return ReturnValue;    
}

