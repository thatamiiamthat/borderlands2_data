    else
    {
        WPCOwner.SetTimer(0.5, false, 'ShowDeferredFailureMessage', self);
        ShowMarketplaceElements(false);
        SetShoppingTooltips(false, false, false, false, true);
    }
    bDelegateFired = true;
    //return;    
}

