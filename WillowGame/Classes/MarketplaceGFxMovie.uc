function bool ShopInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    local OnlinePlayerInterfaceEx PlayerInt;

    // End:0x31
    if(ControllerId != int(WPCOwner.GetMyControllerId()))
    {
        return true;
    }
    // End:0x94
    if(class'GameEngine'.static.GetOnlineSubsystem() != none)
    {
        PlayerInt = class'GameEngine'.static.GetOnlineSubsystem().PlayerInterfaceEx;
    }
    // End:0x450
    if(int(uevent) == int(1))
    {
        switch(ukey)
        {
            // End:0xC7
            case 'XboxTypeS_A':
            // End:0xD3
            case 'Enter':
            // End:0x26E
            case 'XboxTypeS_Start':
                // End:0x26B
                if(NotEqual_InterfaceInterface(PlayerInt, OnlinePlayerInterfaceEx(none)))
                {
                    // End:0x1C5
                    if(int(class'GearboxGlobals'.static.GetPlatform()) == int(2))
                    {
                        WarningDlg = WPCOwner.GFxUIManager.ShowDialog();
                        WarningDlg.DisplayYesNoBox("WillowMenu", "dlgWarnPlaystationStoreExit", OnClickShowMarketplaceOffer);                        
                    }
                    else
                    {
                        PlayerInt.ShowContentMarketplaceUI(WPCOwner.GetMyControllerId(), -1, int(GetSelectedObject().GetString(Prop_offeringId)));
                        WPCOwner.GetFrontendMovie().HideMarketplaceMovie();
                    }
                    return true;
                }
                // End:0x450
                break;
            // End:0x27A
            case 'XboxTypeS_B':
            // End:0x2BD
            case 'Escape':
                WPCOwner.GetFrontendMovie().HideMarketplaceMovie();
                return true;
            // End:0x2C9
            case 'XboxTypeS_Y':
            // End:0x2E1
            case 'Q':
                CycleFilter();
                return true;
            // End:0x2ED
            case 'XboxTypes_X':
            // End:0x44D
            case 'E':
                // End:0x44A
                if(NotEqual_InterfaceInterface(PlayerInt, OnlinePlayerInterfaceEx(none)))
                {
                    // End:0x385
                    if(int(class'GearboxGlobals'.static.GetPlatform()) == int(1))
                    {
                        PlayerInt.ShowRedeemCodeUI(WPCOwner.GetMyControllerId());                        
                    }
                    else
                    {
                        // End:0x448
                        if(int(class'GearboxGlobals'.static.GetPlatform()) == int(2))
                        {
                            WarningDlg = WPCOwner.GFxUIManager.ShowDialog();
                            WarningDlg.DisplayYesNoBox("WillowMenu", "dlgWarnPlaystationStoreExit", OnClickShowMarketplace);
                        }
                    }
                    return true;
                }
                // End:0x450
                break;
            // End:0xFFFF
            default:
                break;
        }
    }
    else
    {
        // End:0x4DA
        if((int(uevent) == int(0)) || int(uevent) == int(2))
        {
            switch(ukey)
            {
                // End:0x499
                case 'PageUp':
                // End:0x4B2
                case 'XboxTypeS_LeftTrigger':
                    ScrollDescription(true);
                    return true;
                // End:0x4BE
                case 'PageDown':
                // End:0x4D7
                case 'XboxTypeS_RightTrigger':
                    ScrollDescription(false);
                    return true;
                // End:0xFFFF
                default:
                    break;
                }
        }
        else
        {
            return false;
            //return ReturnValue;            
        }
    }
}

