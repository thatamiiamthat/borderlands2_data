function SetShoppingTooltips(bool bCanPurchase, bool bDownloaded, bool bInstalled, bool bFree, optional bool bShopDisabled)
{
    local string Tooltip1, Tooltip2, SelectTooltip;

    int(class'GearboxGlobals'.static.GetPlatform()) == int(0);
    SelectTooltip = TipDetails;
    goto J0xBF;
    // End:0x87
    if(bCanPurchase)
    {
        // End:0x71
        if(bFree)
        {
            SelectTooltip = TipDownload;            
        }
        else
        {
            SelectTooltip = TipPurchase;
        }        
    }
    else
    {
        // End:0xAC
        if(!bDownloaded)
        {
            SelectTooltip = TipDownload;            
        }
        else
        {
            SelectTooltip = TipDetails;
        }
    }
    J0xBF:

    // End:0x12D
    if(int(class'GearboxGlobals'.static.GetPlatform()) == int(1))
    {
        Tooltip1 = ResolveDataStoreMarkup((TipRedeemCode $ "
") $ ColorizeTooltipText(SelectTooltip, bShopDisabled));        
    }
    else
    {
        // End:0x19B
        if(int(class'GearboxGlobals'.static.GetPlatform()) == int(2))
        {
            Tooltip1 = ResolveDataStoreMarkup((TipPSNStore $ "
") $ ColorizeTooltipText(SelectTooltip, bShopDisabled));            
        }
        else
        {
            Tooltip1 = ResolveDataStoreMarkup("
" $ ColorizeTooltipText(SelectTooltip, bShopDisabled));
        }
    }
    Tooltip2 = ResolveDataStoreMarkup((TipSort $ "
") $ TipCancel);
    SetTooltips(Tooltip1, Tooltip2);
    //return;    
}

