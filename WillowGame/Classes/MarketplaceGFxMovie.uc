    // End:0x25A
    if(HiddenOffersToEnumerate.Length == 0)
    {
        PostContentLoaded(DLCList.Length > 0);        
    }
    else
    {
        GetHiddenDLCList(HiddenOffersToEnumerate);
    }
    //return;    
}

function bool IsOfferOwned(int OfferId, const out array<MarketplaceContent> ContentList)
{
    local MarketplaceContent Content;

    // End:0x61
    foreach ContentList(Content,)
    {
        // End:0x60
        if(Content.OfferId == OfferId)
        {            
            return Content.bUserHasPurchased;
        }        
    }    
    return false;
    //return ReturnValue;    
}

function OnHiddenDownloadableContentListRead(bool bWasSuccessful)
{
    local array<MarketplaceContent> DLCList;
