function string FormatCost(int PlatformCost)
{
    local string fmt;

    switch(class'GearboxGlobals'.static.GetPlatform())
    {
        // End:0x5E
        case 1:
            fmt = ((PlatformCost == 0) ? CostFormat360Free : CostFormat360);
            // End:0xBB
            break;
        // End:0x93
        case 2:
            fmt = ((PlatformCost == 0) ? CostFormatPS3Free : CostFormatPS3);
            // End:0xBB
            break;
        // End:0xA7
        case 0:
            fmt = "";
            // End:0xBB
            break;
        // End:0xFFFF
        default:
            fmt = "%1";
            // End:0xBB
            break;
            break;
    }
    return Repl(fmt, "%1", string(PlatformCost));
    //return ReturnValue;    
}

function string GetOfferingStatusMessage(bool IsPurchased, bool IsDownloaded, bool IsInstalled)
{
    // End:0x24
    if(IsInstalled)
    {
        return ResolveDataStoreMarkup(StatusInstalled);        
    }
    else
    {
        // End:0x48
        if(IsDownloaded)
        {
            return ResolveDataStoreMarkup(StatusDownloaded);            
        }
        else
        {
            // End:0x69
            if(IsPurchased)
            {
                return ResolveDataStoreMarkup(StatusPurchased);
            }
        }
    }
    return "";
    //return ReturnValue;    
}

