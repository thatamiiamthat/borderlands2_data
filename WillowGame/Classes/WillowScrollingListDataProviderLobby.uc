class WillowScrollingListDataProviderLobby extends WillowScrollingListDataProviderBase
    hidecategories(Mobile);

const EVENT_ID_PLAY = 0;
const EVENT_ID_EXIT = 1;
const EVENT_ID_OPTIONS = 2;
const EVENT_ID_CHARSELECT = 3;

function bool HandleClick(int EventID, WillowScrollingList TheList)
{
    switch(EventID)
    {
        // End:0x8E
        case 0:
            UnknownLocal_1 = LobbyGFxMovie(TheList.MyOwnerMovie);
            // End:0x8C
            if((UnknownLocal_1 != none) && !UnknownLocal_1.IsOverlayMenuOpen())
            {
                UnknownLocal_1.PromptConfirmCharacters();
            }
            return true;
        // End:0x153
        case 2:
            UnknownLocal_1 = LobbyGFxMovie(TheList.MyOwnerMovie);
            // End:0x151
            if((UnknownLocal_1 != none) && !UnknownLocal_1.IsOverlayMenuOpen())
            {
                UnknownLocal_1.ShowOptions(TheList.MyOwnerMovie.WPCOwner.GetPlayerIndex());
            }
            return true;
        // End:0x1AC
        case 1:
            UnknownLocal_1 = LobbyGFxMovie(TheList.MyOwnerMovie);
            // End:0x1AA
            if(UnknownLocal_1 != none)
            {
                UnknownLocal_1.ShowConfirmQuitDialog();
            }
            return true;
        // End:0x206
        case 3:
            UnknownLocal_1 = LobbyGFxMovie(TheList.MyOwnerMovie);
            // End:0x204
            if(UnknownLocal_1 != none)
            {
                UnknownLocal_1.OpenCharacterSelectFromList();
            }
            return true;
        // End:0xFFFF
        default:
            return super.HandleClick(EventID, TheList);
            break;
    }
    //return ReturnValue;    
}

function Populate(WillowScrollingList TheList)
{
    TheList.AddListItem(0, "$WillowMenu.WillowScrollingListDataProviderLobby.Play", false);
    TheList.AddListItem(3, Caps(Localize("FESelChar", "Caption", "WillowMenu")), false);
    TheList.AddListItem(2, "$WillowMenu.WillowScrollingListDataProviderLobby.Options", false);
    TheList.AddListItem(1, "$WillowMenu.WillowScrollingListDataProviderLobby.Exit", false);
    //return;    
}
