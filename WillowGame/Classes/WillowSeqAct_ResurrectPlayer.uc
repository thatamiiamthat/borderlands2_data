class WillowSeqAct_ResurrectPlayer extends SequenceAction
    native(Sequence)
    forcescriptorder(true)
    hidecategories(Mobile,Object);

event OnActivated(WillowPlayerController aWPC)
{
    // End:0xA0
    if(aWPC != none)
    {
        UnknownLocal_1 = WillowVehicle(aWPC.Pawn);
        aWPC.ServerResurrect(4);
        // End:0xA0
        if(UnknownLocal_1 != none)
        {
            UnknownLocal_1.Died(none, none, UnknownLocal_1.Location);
        }
    }
    //return;    
}

defaultproperties
{
    ObjName="Teleport To Resurrect"
    ObjCategory="Willow Seq"
}