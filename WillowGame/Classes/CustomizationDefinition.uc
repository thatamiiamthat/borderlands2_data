simulated event bool IsCharacterHeadCustomization()
{
    local array< Class > PlayerUsageFlags;

    PlayerUsageFlags[PlayerUsageFlags.Length] = class'CustomizationUsage_Player';
    return ClassIsChildOf(CustomizationType, class'CustomizationType_Head') && MatchRequiredUsageFlags(PlayerUsageFlags, UsageFlags);
    //return ReturnValue;    
}

simulated event bool IsCharacterSkinCustomization()
{
    local array< Class > PlayerUsageFlags;

    PlayerUsageFlags[PlayerUsageFlags.Length] = class'CustomizationUsage_Player';
    return ClassIsChildOf(CustomizationType, class'CustomizationType_Skin') && MatchRequiredUsageFlags(PlayerUsageFlags, UsageFlags);
    //return ReturnValue;    
}

simulated event bool IsVehicleSkinCustomization()
{
    local array< Class > VehicleUsageFlags;

    VehicleUsageFlags[VehicleUsageFlags.Length] = class'CustomizationUsage_Vehicle';
    return ClassIsChildOf(CustomizationType, class'CustomizationType_Skin') && MatchRequiredUsageFlags(VehicleUsageFlags, UsageFlags);
    //return ReturnValue;    
}

