class Behavior_SetUsableIcon extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) InteractionIconDefinition Icon;
var(Action) IUsable.EUsabilityType UsabilityType;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IUsable ContextInterface;
    local IPickupable PickupableInterface;

    ContextInterface = ContextObject.QueryInterface(class'IUsable');
    // End:0x87
    if(NotEqual_InterfaceInterface(ContextInterface, IUsable(none)))
    {
        ContextInterface.SetInteractionIcon(Icon, UsabilityType);        
    }
    else
    {
        PickupableInterface = ContextObject.QueryInterface(class'IPickupable');
        // End:0x102
        if(NotEqual_InterfaceInterface(PickupableInterface, IPickupable(none)))
        {
            PickupableInterface.SetInteractionIcon(Icon);
        }
    }
    //return;    
}
