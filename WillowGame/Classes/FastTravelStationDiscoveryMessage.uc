class FastTravelStationDiscoveryMessage extends LocalMessage
    hidecategories(Mobile);

var const localized string StationDiscoveredSolo;
var const localized string StationDiscoveredTeam;

static function string GetString(optional int Switch, optional bool bPRI1HUD, optional PlayerReplicationInfo RelatedPRI_1, optional PlayerReplicationInfo RelatedPRI_2, optional Object OptionalObject)
{
    local string rslt;

    UnknownLocal_1
    FastTravelStationDefinition(OptionalObject)
    // End:0x15C
    if(UnknownLocal_1 != none)
    {
        // End:0x102
        if((RelatedPRI_1 == RelatedPRI_2) || (RelatedPRI_1.WorldInfo.GRI != none) && RelatedPRI_1.WorldInfo.GRI.PRIArray.Length <= 1)
        {
            rslt = Repl(default.StationDiscoveredSolo, "%s", UnknownLocal_1.StationDisplayName);            
        }
        else
        {
            rslt = Repl(Repl(default.StationDiscoveredTeam, "%s1", RelatedPRI_2.PlayerName), "%s", UnknownLocal_1.StationDisplayName);
        }
    }
    return rslt;
    //return ReturnValue;    
}

defaultproperties
{
    StationDiscoveredSolo="You Have Discovered Fast Travel Station %s"
    StationDiscoveredTeam="%s1 Discovered Fast Travel Station %s"
    Lifetime=7
}