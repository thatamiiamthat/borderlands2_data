class MontageGFxObject extends GFxObject within GFxMoviePlayer
    native(GFx)
    hidecategories(Mobile);

var WillowPlayerController WPCOwner;
var CreditsGFxDefinition CreditsDef;
var string LinkageName;
var int MontageIdx;
var bool bShouldShowImages;
var transient bool bMontageTexturesLoaded;
var array<Texture2D> MontageTextures;

// Export UMontageGFxObject::execAddMontageTextures(FFrame&, void* const)
native function AddMontageTextures();

// Export UMontageGFxObject::execClearMontageTextures(FFrame&, void* const)
native function ClearMontageTextures();

function SetShouldShowImages()
{
    // End:0xAC
    if(WPCOwner != none)
    {
        UnknownLocal_1 = class'WillowGlobals'.static.GetWillowGlobals().GetWillowSaveGameManager().GetCachedPlayerSaveGame(WPCOwner.GetMyControllerId());
        UnknownLocal_3 = WillowPlayerReplicationInfo(WPCOwner.PlayerReplicationInfo);
    }
    bShouldShowImages = (UnknownLocal_3.HighestCompletedPlayThrough > 0) || ((UnknownLocal_1 != none) && UnknownLocal_1.SaveGameId != -1) && UnknownLocal_1.PlaythroughsCompleted > 0;
    //return;    
}

function Init(CreditsGFxDefinition CreditsDefinition, string TextureLinkageName)
{
    WPCOwner = WillowGFxMovie(Outer).WPCOwner;
    CreditsDef = CreditsDefinition;
    LinkageName = TextureLinkageName;
    SetFunction("extFadeInComplete", self, 'extFadeInComplete');
    SetFunction("extFadeOutComplete", self, 'extFadeOutComplete');
    MontageIdx = 0;
    SetShouldShowImages();
    // End:0x121
    if(bShouldShowImages)
    {
        bMontageTexturesLoaded = false;
        AddMontageTextures();
        WPCOwner.SetTimer(float(CreditsDef.InitialBlankSpace), false, 'StartNextTexture', self);
    }
    //return;    
}

event OnMontageTexturesLoaded()
{
    bMontageTexturesLoaded = true;
    // End:0x44
    if(!WPCOwner.IsTimerActive('StartNextTexture', self))
    {
        StartNextTexture();
    }
    //return;    
}

function Close()
{
    ClearMontageTextures();
    WPCOwner.ClearTimer('FadeOut', self);
    WPCOwner.ClearTimer('StartNextTexture', self);
    //return;    
}

function bool StartNextTexture()
{
    // End:0x8A
    if(bMontageTexturesLoaded)
    {
        // End:0x80
        if(MontageIdx < MontageTextures.Length)
        {
            StartNewTexture();
            ++ MontageIdx;
            // End:0x7B
            if(CreditsDef.bLoopMontageImages)
            {
                MontageIdx = __NFUN_253__(MontageIdx, MontageTextures.Length);
            }
            return true;            
        }
        else
        {
            ClearMontageTextures();
        }
    }
    return false;
    //return ReturnValue;    
}

function StartNewTexture()
{
    // End:0x61
    if(MontageTextures[MontageIdx] != none)
    {
        Outer.SetExternalTexture(LinkageName, MontageTextures[MontageIdx]);
        FadeIn();        
    }
    else
    {
        WPCOwner.SetTimer(float(CreditsDef.ImageDuration), false, 'StartNextTexture', self);
    }
    //return;    
}

function FadeIn()
{
    ActionScriptVoid("FadeIn");
    //return;    
}

function FadeOut()
{
    ActionScriptVoid("FadeOut");
    //return;    
}

function extFadeInComplete()
{
    WPCOwner.SetTimer(float(CreditsDef.ImageDuration), false, 'FadeOut', self);
    //return;    
}

function extFadeOutComplete()
{
    // End:0x50
    if(bShouldShowImages)
    {
        WPCOwner.SetTimer(float(CreditsDef.ImageBlankSpace), false, 'StartNextTexture', self);
    }
    //return;    
}
