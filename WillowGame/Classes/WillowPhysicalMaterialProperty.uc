static function ApplyParametersToEmitter(Emitter EmitterActor, const out ImpactResponseParameters ResponseParameters)
{
    local ParticleSysParam Parameter;
    local Vector Value;

    // End:0x292
    if(EmitterActor != none)
    {
        // End:0x291
        foreach ResponseParameters.ParticleParameters(Parameter,)
        {
            switch(Parameter.ParamType)
            {
                // End:0xBE
                case 1:
                    EmitterActor.SetFloatParameter(Parameter.Name, Parameter.Scalar);
                    // End:0x290
                    break;
                // End:0x1C7
                case 3:
                    // End:0x1C4
                    if(EmitterActor.ParticleSystemComponent != none)
                    {
                        // End:0x1C4
                        if(EmitterActor.ParticleSystemComponent.GetVectorParameter(Parameter.Name, Value))
                        {
                            // End:0x1C4
                            if(Value != Parameter.Vector)
                            {
                                EmitterActor.SetVectorParameter(Parameter.Name, Parameter.Vector);
                            }
                        }
                    }
                    // End:0x290
                    break;
                // End:0x226
                case 5:
                    EmitterActor.SetColorParameter(Parameter.Name, Parameter.Color);
                    // End:0x290
                    break;
                // End:0x285
                case 6:
                    EmitterActor.SetActorParameter(Parameter.Name, Parameter.Actor);
                    // End:0x290
                    break;
                // End:0x28D
                case 7:
                    // End:0x290
                    break;
                // End:0xFFFF
                default:
                    break;
            }            
        }        
    }
    //return;    
}

