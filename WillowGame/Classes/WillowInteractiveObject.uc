simulated event string GetMapDisplayHeader()
{
    local string retVal;

    retVal = InteractiveObjectDefinition.StatusMenuMapInfoBoxHeader;
    // End:0x8C
    if((retVal == "") && !class'WillowGameInfo'.static.IsShippingBuild())
    {
        retVal = ("FIX ME (" $ PathName(InteractiveObjectDefinition)) $ ")";
    }
    return retVal;
    //return ReturnValue;    
}

simulated event string GetMapDisplayName()
{
    local string retVal;

    retVal = InteractiveObjectDefinition.StatusMenuMapInfoBoxDescription;
    // End:0x8C
    if((retVal == "") && !class'WillowGameInfo'.static.IsShippingBuild())
    {
        retVal = ("FIX ME (" $ PathName(InteractiveObjectDefinition)) $ ")";
    }
    return retVal;
    //return ReturnValue;    
}

