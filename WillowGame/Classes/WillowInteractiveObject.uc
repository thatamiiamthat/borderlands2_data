{
    bCanBeUsed=1
    NumberInChallengeGroup=1
    ConsumerHandle=(PID=-1)
    AlwaysRelevantDistanceSquared=6.4E+07
    SoundGroup=none
    Components(0)=none
    Components(1)=none
    RemoteRole=ENetRole.ROLE_SimulatedProxy
    CollisionType=ECollisionType.COLLIDE_CustomDefault
    TickGroup=ETickingGroup.TG_DuringAsyncWork
