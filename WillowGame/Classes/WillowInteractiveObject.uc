function CleanupKilledInteractiveObject()
{
    local editinline array<editinline WaypointComponent> Waypoints;
    local editinline WaypointComponent Waypoint;

    // End:0x77
    if(WorldInfo.GRI != none)
    {
        WillowGameReplicationInfo(WorldInfo.GRI).MissionTracker.NotifyActorDied(self);
    }
    // End:0xAD
    foreach ComponentList(class'WaypointComponent', Waypoint)
    {
        Waypoints.AddItem(Waypoint;        
    }    
    // End:0xE5
    foreach Waypoints(Waypoint,)
    {
        Waypoint.RemoveWaypoint();        
    }    
    //return;    
}

simulated event Destroyed()
{
    TriggerEventClass(class'SeqEvent_Destroyed', self);
    DestroyOwnedInstanceData();
    ConditionalAddToCompass(true);
    // End:0x6E
    if(int(Role) == int(ROLE_Authority))
    {
        // End:0x6E
        if(StatusEffectComp != none)
        {
            StatusEffectComp.OwnerDied();
        }
    }
    // End:0xED
    foreach LocalPlayerControllers(class'PlayerController', UnknownLocal_1)
    {
        // End:0xEC
        if(WillowHUD(UnknownLocal_1.myHUD) != none)
        {
            WillowHUD(UnknownLocal_1.myHUD).RemovePostRenderedActor(self);
        }        
    }    
    // End:0x115
    if(LightProjMgr != none)
    {
        LightProjMgr.Destroy();
    }
    class'PawnAllegiance'.static.RemoveParent(QueryInterface(class'ITargetable'));
    class'PawnAllegiance'.static.RemoveChildren(QueryInterface(class'ITargetable'));
    LastUsedComponent = none;
    CleanupKilledInteractiveObject();
    super.Destroyed();
    //return;    
}

