function AddMissionLoot(ItemPoolDefinition MissionPool)
{
    local LootConfigurationData MissionLootConfiguration;
    local LootAttachmentData MissionLoot;

    UnknownLocal_1 = 0;
    J0x07:

    // End:0xAE [Loop If]
    if(UnknownLocal_1 < Loot.Length)
    {
        UnknownLocal_3 = 0;
        J0x22:

        // End:0xA4 [Loop If]
        if(UnknownLocal_3 < Loot[UnknownLocal_1].ItemAttachments.Length)
        {
            // End:0x9A
            if(Loot[UnknownLocal_1].ItemAttachments[UnknownLocal_3].ItemPool == MissionPool)
            {
                return;
            }
            ++ UnknownLocal_3;
            // [Loop Continue]
            goto J0x22;
        }
        ++ UnknownLocal_1;
        // [Loop Continue]
        goto J0x07;
    }
    MissionLoot.ItemPool = MissionPool;
    MissionLoot.PoolProbability.BaseValueConstant = 1;
    // End:0x170
    if(Loot.Length > 0)
    {
        UnknownLocal_1 = 0;
        J0x120:

        // End:0x16D [Loop If]
        if(UnknownLocal_1 < Loot.Length)
        {
            Loot[UnknownLocal_1].ItemAttachments.AddItem(MissionLoot;
            ++ UnknownLocal_1;
            // [Loop Continue]
            goto J0x120;
        }        
    }
    else
    {
        MissionLootConfiguration.ConfigurationName = 'MissionLoot';
        MissionLootConfiguration.Weight.BaseValueConstant = 100;
        MissionLootConfiguration.ItemAttachments.AddItem(MissionLoot;
        Loot.AddItem(MissionLootConfiguration;
    }
    //return;    
}

