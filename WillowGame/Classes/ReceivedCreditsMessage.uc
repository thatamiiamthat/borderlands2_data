class ReceivedCreditsMessage extends WillowLocalMessage
    config(Game)
    hidecategories(Mobile);

var const localized string ReceivedCredits;
var const localized string SelfReceivedCredits;
var const localized string NumberOfCredits;
var const localized string OneCredit;
var const localized string MoreCredits;
var config int CreditsFakedRarityLevelForItemColor;

static function ClientCreditReceive(PlayerController P, optional int Switch, optional PlayerReplicationInfo RelatedPRI_1, optional PlayerReplicationInfo RelatedPRI_2, optional int GainedAmount)
{
    local string MessageString;

    MessageString
    GetCreditString(Switch, RelatedPRI_1 == P.PlayerReplicationInfo, RelatedPRI_1, RelatedPRI_2, GainedAmount);
    // End:0x261
    if(MessageString != "")
    {
        P.DisplayHUDMessage(GetMsgType(Switch, RelatedPRI_1 == P.PlayerReplicationInfo, RelatedPRI_1, RelatedPRI_2, none), MessageString, GetLifeTime(Switch), GetColor(Switch, RelatedPRI_1, RelatedPRI_2, none), default.Class, Switch, RelatedPRI_1, none);
        // End:0x261
        if((((IsConsoleMessage(Switch)) && LocalPlayer(P.Player) != none) && LocalPlayer(P.Player).ViewportClient != none) && !class'WorldInfo'.static.IsConsoleBuild())
        {
            LocalPlayer(P.Player).ViewportClient.ViewportConsole.OutputText(MessageString);
        }
    }
    //return;    
}

static function string GetCreditString(optional int Switch, optional bool bPRI1HUD, optional PlayerReplicationInfo RelatedPRI_1, optional PlayerReplicationInfo RelatedPRI_2, optional int GainedAmount)
{
    local string NumberOfCreditsString;

    NumberOfCreditsString
    GetNumberOfCreditsString(Switch, bPRI1HUD, RelatedPRI_1, RelatedPRI_2, GainedAmount);
    // End:0xD2
    if((RelatedPRI_1 != none) && GainedAmount > 0)
    {
        // End:0x91
        if(bPRI1HUD)
        {
            return Repl(default.SelfReceivedCredits, "%s", NumberOfCreditsString);            
        }
        else
        {
            return Repl(Repl(default.ReceivedCredits, "%s1", RelatedPRI_1.GetHumanReadableName()), "%s", NumberOfCreditsString);
        }
    }
    return "";
    //return ReturnValue;    
}

static function string GetNumberOfCreditsString(optional int Switch, optional bool bPRI1HUD, optional PlayerReplicationInfo RelatedPRI_1, optional PlayerReplicationInfo RelatedPRI_2, optional int GainedAmount)
{
    local string NumberOfCreditsString;
    local Color CreditsColor;

    CreditsColor
    GetCreditsColor();
    NumberOfCreditsString = (class'WillowLocalMessage'.static.OpenFontColorTag(CreditsColor) $ Repl(Repl(default.NumberOfCredits, "%s", ((GainedAmount > 1) ? default.MoreCredits : default.OneCredit)), "%d", string(GainedAmount))) $ class'WillowLocalMessage'.static.CloseFontColorTag();
    return NumberOfCreditsString;
    //return ReturnValue;    
}

static function Color GetCreditsColor()
{
    UnknownLocal_1 = class'WillowGlobals'.static.GetWillowGlobals().GetGlobalsDefinition();
    return UnknownLocal_1.GetRarityColorForLevel(default.CreditsFakedRarityLevelForItemColor);
    //return ReturnValue;    
}

defaultproperties
{
    ReceivedCredits="%s1 received %s."
    SelfReceivedCredits="You received %s."
    NumberOfCredits="%d %s"
    OneCredit="dollar"
    MoreCredits="dollars"
    CreditsFakedRarityLevelForItemColor=180
    Lifetime=7
    MsgType=ELocalMessageType.LMT_OpenedChest
}