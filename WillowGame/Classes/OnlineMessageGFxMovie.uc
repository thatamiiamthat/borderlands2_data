class OnlineMessageGFxMovie extends WillowGFxMovie
    native(GFx)
    config(Game)
    hidecategories(Mobile);

const TitleFormat = "<font size='13' color='#FFFFFF'>%message%</font>";
const SubtitleFormat = "<font size='11' color='#CCCCCC'>%message%</font>";

var transient GFxObject BlockingMessageClip;
var transient GFxObject NonBlockingMessageClip;
var const localized string BlockingSubtitle;

event bool Start(optional bool StartPaused = false)
{
    UnknownLocal_1
    super.Start(StartPaused);
    // End:0x36
    if(UnknownLocal_1)
    {
        Advance(0);
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

event OnClose()
{
    BlockingMessageClip = none;
    NonBlockingMessageClip = none;
    super.OnClose();
    //return;    
}

function DisplayBlockingMessage(string Message)
{
    AppendSubtitle(Message, BlockingSubtitle);
    DisplayMessageInternal(Message, true);
    //return;    
}

function DisplayMessage(string Message)
{
    DisplayMessageInternal(Message, false);
    //return;    
}

function DisplayMessageAndSubtitle(string Message, string Subtitle)
{
    AppendSubtitle(Message, Subtitle);
    DisplayMessageInternal(Message, false);
    //return;    
}

private final function AppendSubtitle(out string Message, string Subtitle)
{
    Message = Repl("<font size='13' color='#FFFFFF'>%message%</font>", "%message%", Message);
    Subtitle = Repl("<font size='11' color='#CCCCCC'>%message%</font>", "%message%", Subtitle);
    Message = (Message $ "<br>") $ Subtitle;
    //return;    
}

function Hide()
{
    // End:0x34
    if(NonBlockingMessageClip != none)
    {
        NonBlockingMessageClip.ActionScriptVoid("Hide");
    }
    //return;    
}

function HideBlocking()
{
    // End:0x34
    if(BlockingMessageClip != none)
    {
        BlockingMessageClip.ActionScriptVoid("Hide");
    }
    SetBlocking(false);
    //return;    
}

private final function DisplayMessageInternal(string Message, bool bShowBusyIndicator)
{
    UpdateAspectRatio();
    // End:0x63
    if(bShowBusyIndicator)
    {
        SetBlocking(true);
        // End:0x60
        if(BlockingMessageClip != none)
        {
            BlockingMessageClip.ActionScriptVoid("DisplayMessage");
        }        
    }
    else
    {
        // End:0xA1
        if(NonBlockingMessageClip != none)
        {
            NonBlockingMessageClip.ActionScriptVoid("DisplayMessage");
        }
    }
    //return;    
}

private final function bool IsBlocking()
{
    return bInputAllKeys;
    //return ReturnValue;    
}

private final function SetBlocking(bool bBlocking)
{
    bInputAllKeys = bBlocking;
    SetMovieCanReceiveFocus(bBlocking);
    //return;    
}

function HACK_DontActuallyBlock()
{
    SetBlocking(false);
    //return;    
}

private final function UpdateAspectRatio()
{
    UnknownLocal_1 = WPCOwner.GetPlayerViewportClient();
    // End:0x72
    if(UnknownLocal_1 != none)
    {
        // End:0x62
        if(!UnknownLocal_1.IsWidescreen())
        {
            GotoAndStop("4_3");            
        }
        else
        {
            GotoAndStop("16_9");
        }
    }
    //return;    
}

function extOnlineMessageOnLoad(string blockingPath, string nonBlockingPath)
{
    BlockingMessageClip = GetVariableObject(blockingPath);
    NonBlockingMessageClip = GetVariableObject(nonBlockingPath);
    //return;    
}

function extOnHideBegin(GFxObject Clip)
{
    // End:0x22
    if(Clip == BlockingMessageClip)
    {
        SetBlocking(false);
    }
    //return;    
}

defaultproperties
{
    BlockingSubtitle="Please wait..."
    Priority=255
}