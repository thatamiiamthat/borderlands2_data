class Behavior_SpawnLootAroundPoint extends Behavior_SpawnLoot
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

enum ESpawnAroundPointBasis
{
    SPAWNAROUNDPOINTBASIS_SpawnPoint,
    SPAWNAROUNDPOINTBASIS_WorldSpace,
    SPAWNAROUNDPOINTBASIS_CustomLocation,
    SPAWNAROUNDPOINTBASIS_ContextActor,
    SPAWNAROUNDPOINTBASIS_MAX
};

var(Action) AttachmentLocationData CustomLocation;
var(Action) float CircularScatterRadius;
var(Action) Vector SpawnVelocity;
var(Action) Behavior_SpawnLootAroundPoint.ESpawnAroundPointBasis SpawnVelocityRelativeTo;

protected function PlaceSpawnedItems(array<SpawnedDroppedLootData> SpawnedLoot, Object ContextObject)
{
    local Vector CenterPoint;
    local Rotator CustomLocationOrientation, ContextActorOrientation;
    local SpawnedDroppedLootData Loot;

    CenterPoint = CustomLocation.Location;
    // End:0x51
    if(IsZero(CenterPoint))
    {
        GetLocationFromContextObject(ContextObject, CenterPoint);
    }
    class'BehaviorHelpers'.static.GetRotationFromAttachmentLocationData(CustomLocation, CustomLocationOrientation);
    GetOrientationFromContextObject(ContextObject, ContextActorOrientation);
    // End:0x11F
    foreach SpawnedLoot(Loot,)
    {
        UnknownLocal_1 = ScatterItem(Loot, CenterPoint, CustomLocationOrientation, ContextActorOrientation);
        // End:0x11E
        if(!UnknownLocal_1)
        {
            Loot.Inv.Destroy();
        }        
    }    
    //return;    
}

protected function bool ScatterItem(const out SpawnedDroppedLootData Loot, Vector CenterPoint, Rotator CustomLocationOrientation, Rotator ContextActorOrientation)
{
    local Vector TransformedSpawnVelocity, SpawnLocation;
    local Rotator ScatterRotation;

    ScatterRotation.Roll = 0;
    ScatterRotation.Pitch = 0;
    ScatterRotation.Yaw = Rand(32768) * 2;
    SpawnLocation.X = CircularScatterRadius;
    SpawnLocation = CenterPoint + (SpawnLocation >> ScatterRotation);
    switch(SpawnVelocityRelativeTo)
    {
        // End:0xEE
        case 0:
            TransformedSpawnVelocity = SpawnVelocity >> ScatterRotation;
            // End:0x15A
            break;
        // End:0x115
        case 2:
            TransformedSpawnVelocity = SpawnVelocity >> CustomLocationOrientation;
            // End:0x15A
            break;
        // End:0x13C
        case 3:
            TransformedSpawnVelocity = SpawnVelocity >> ContextActorOrientation;
            // End:0x15A
            break;
        // End:0x141
        case 1:
        // End:0xFFFF
        default:
            TransformedSpawnVelocity = SpawnVelocity;
            // End:0x15A
            break;
            break;
    }
    class'WillowLeviathanService'.static.RecordItemSpawnedEventForAllPlayers(2, Loot.Inv, Loot.Inv.SourceResponsibleName, Loot.Inv.SourceDefinitionName);
    Loot.Inv.ItemLocation = 2;
    Loot.Inv.DropFrom(SpawnLocation, TransformedSpawnVelocity, Loot.bDisableRigidBodyPhysics, bTorque, Torque);
    return true;
    //return ReturnValue;    
}
