class WillowSeqAct_SetInteractionProxyState extends SequenceAction
    native(Sequence)
    forcescriptorder(true)
    hidecategories(Mobile,Object);

var(Action) bool bPassEventsToKismet;

event OnActivated(WillowMind aWMind)
{
    // End:0x38
    if(aWMind != none)
    {
        aWMind.PassInteractionProxyEventsToKismet(bPassEventsToKismet);
    }
    //return;    
}

defaultproperties
{
    ObjName="Set Interaction State"
    ObjCategory="Willow Seq"
}