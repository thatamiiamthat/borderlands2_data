class ChallengeFeedbackMessage extends LocalMessage
    native
    hidecategories(Mobile);

enum EChallengeFeedback
{
    CHAL_FEEDBACK_Completed,
    CHAL_FEEDBACK_Received,
    CHAL_FEEDBACK_MAX
};

var const localized string ChallengeCompleted;
var const localized string ChallengeReceived;

static function string GetString(optional int Switch, optional bool bPRI1HUD, optional PlayerReplicationInfo RelatedPRI_1, optional PlayerReplicationInfo RelatedPRI_2, optional Object OptionalObject)
{
    local string rslt;

    UnknownLocal_1
    ChallengeDefinition(OptionalObject)
    switch(byte(Switch))
    {
        // End:0xE1
        case 0:
            rslt = Repl(default.ChallengeCompleted, "%s", class'WillowLocalMessage'.static.TrimWhitespace(UnknownLocal_1.ChallengeName));
            rslt = Repl(rslt, "%1", "?");
            rslt = Repl(rslt, "%2", string(UnknownLocal_1.Levels.Length));
            // End:0x14B
            break;
        // End:0x13C
        case 1:
            rslt = Repl(default.ChallengeReceived, "%s", class'WillowLocalMessage'.static.TrimWhitespace(UnknownLocal_1.ChallengeName));
            // End:0x14B
            break;
        // End:0xFFFF
        default:
            rslt = "";
            break;
    }
    return rslt;
    //return ReturnValue;    
}

defaultproperties
{
    ChallengeCompleted="Challenge Completed: \"%s\" level %1/%2"
    ChallengeReceived="Received new challenge: %s"
    Lifetime=7
    MsgType=ELocalMessageType.LMT_Player
}