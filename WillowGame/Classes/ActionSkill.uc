simulated event ReplicatedEvent(name VarName)
{
    // End:0x43
    if(VarName == 'CustomEventReplication')
    {
        RunCustomEvent(CustomEventReplication.EventName);        
    }
    else
    {
        // End:0xF1
        if(VarName == 'ReplicatedBehaviorConsumerState')
        {
            ReplicatedBehaviorConsumerState.bNeedToApplyThisState = true;
            // End:0xEE
            if(ConsumerHandle.PID != -1)
            {
                ReplicatedBehaviorConsumerState.bNeedToApplyThisState = class'BehaviorKernel'.static.ProcessReplicatedBehaviorConsumerState(ConsumerHandle, ReplicatedBehaviorConsumerState);
            }            
        }
        else
        {
            // End:0x13C
            if(VarName == 'ReplicatedBehaviorEvent')
            {
                class'BehaviorKernel'.static.ProcessReplicatedBehaviorEvent(ConsumerHandle, ReplicatedBehaviorEvent);                
            }
            else
            {
                super.ReplicatedEvent(VarName);
            }
        }
    }
    //return;    
}

simulated function OnActionSkillStarted(WillowPawn TheWillowPawn, Controller TheController, optional WillowPawn TheTargetPawn)
{
    !ConsumerHandle.PID != -1;
    MyWillowPawn = TheWillowPawn;
    MyController = TheController;
    // End:0x76
    if(int(Role) == int(ROLE_Authority))
    {
        TargetPawn = TheTargetPawn;
    }
    MyWillowPC = WillowPlayerController(TheController);
    MyWillowPlayerPawn = WillowPlayerPawn(TheWillowPawn);
    MyWillowMind = WillowMind(TheController);
    TimeStarted = class'WorldInfo'.static.GetWorldInfo().GRI.ElapsedTime;
    OnActionSkillActivated(ConsumerHandle, TheWillowPawn, TargetPawn);
    bInitialized = true;
    //return;    
}

