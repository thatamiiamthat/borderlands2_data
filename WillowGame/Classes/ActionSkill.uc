simulated function OnActionSkillEnded()
{
    OnActionSkillDeactivated(ConsumerHandle, MyWillowPawn);
    MyWillowPC.NotifyActionSkillRunTime(class'WorldInfo'.static.GetWorldInfo().GRI.ElapsedTime - TimeStarted);
    MyController = none;
    MyWillowPawn = none;
    MyWillowPC = none;
    MyWillowPlayerPawn = none;
    MyWillowMind = none;
    bInitialized = false;
    class'BehaviorKernel'.static.ForceUnregisterBehaviorConsumer(ConsumerHandle);
    //return;    
}

