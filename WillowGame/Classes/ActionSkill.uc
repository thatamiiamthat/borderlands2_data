simulated event bool GetInstanceData(name DataName, out array<InstanceDataUnion> InstanceData)
{
    local InstanceDataUnion Datum;

    switch(DataName)
    {
        // End:0xA2
        case 'ActionSkillTarget':
            Datum.Name = DataName;
            Datum.Type = 6;
            Datum.Object = TargetPawn;
            InstanceData.AddItem(Datum;
            return true;
        // End:0xFFFF
        default:
            return class'InstanceDataHelper'.static.GetInstanceDataState(InstanceState, DataName, InstanceData);
            break;
    }
    //return ReturnValue;    
}

