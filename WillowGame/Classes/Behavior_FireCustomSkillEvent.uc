class Behavior_FireCustomSkillEvent extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) const name EventName;
var(Action) const SkillDefinition Skill;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IPlayerMaster PlayerMaster;
    local IBodyPawn BodyPawn;

    PlayerMaster = GetBehaviorContextInterface(class'IPlayerMaster', Context, SelfObject, MyInstigatorObject, OtherEventParticipantObject, EventData);
    // End:0xBF
    if(NotEqual_InterfaceInterface(PlayerMaster, IPlayerMaster(none)))
    {
        Skill.FireCustomEvent(EventName, PlayerMaster.GetPlayerMasterPlayerController(), SelfObject);        
    }
    else
    {
        BodyPawn = GetBehaviorContextInterface(class'IBodyPawn', Context, SelfObject, MyInstigatorObject, OtherEventParticipantObject, EventData);
        // End:0x190
        if(NotEqual_InterfaceInterface(BodyPawn, IBodyPawn(none)))
        {
            Skill.FireCustomEvent(EventName, BodyPawn.GetAWillowPawn().Controller, SelfObject);
        }
    }
    //return;    
}
