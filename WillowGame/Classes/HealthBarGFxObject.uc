class HealthBarGFxObject extends GFxObject within GFxMoviePlayer
    hidecategories(Mobile);

var int CachedCurrentHealth;

function SetHealth(int CurrentHealth, int MaxHealth)
{
    // End:0x46
    if(CurrentHealth != CachedCurrentHealth)
    {
        CachedCurrentHealth = CurrentHealth;
        __SetHealth(CurrentHealth, MaxHealth);
    }
    //return;    
}

function __SetHealth(int CurrentHealth, int MaxHealth)
{
    ActionScriptVoid("SetHealth");
    //return;    
}

defaultproperties
{
    CachedCurrentHealth=-1
}