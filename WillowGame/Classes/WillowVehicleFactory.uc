function Deactivate()
{
    local Vector HitLocation, HitNormal;

    GotoState('None');
    TeamNum = 255;
    // End:0x186
    if(((ChildVehicle != none) && !ChildVehicle.bDeleteMe) && ChildVehicle.bTeamLocked)
