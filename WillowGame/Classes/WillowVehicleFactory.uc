        ChildVehicle.TearOffMomentum = vect(0, 0, 1);
        TraceComponent(HitLocation, HitNormal, ChildVehicle.Mesh, ChildVehicle.Location, Location);
        ChildVehicle.Died(none, none, HitLocation);
    }
    //return;    
}

