        // End:0x1F9
        case 3:
            Widget.AddEventListener('CLIK_focusIn', OnWidget3Focused);
            Widget.AddEventListener('CLIK_click', OnWidget3Clicked);
            // End:0x276
            break;
        // End:0x273
        case 4:
            Widget.AddEventListener('CLIK_focusIn', OnWidget4Focused);
            Widget.AddEventListener('CLIK_click', OnWidget4Clicked);
            // End:0x276
            break;
        // End:0xFFFF
        default:
            break;
    }
