class Action_FlyAnimAttack extends Action_Burrow
    editinlinenew
    hidecategories(Mobile,Object,HideMe,ActionSequence,LoadBalance,Movement);

var(Attack) const Action_AnimAttack.EAimType AimType;
var(Attack) const float VisionAngle;
var(Attack) const AIRange Range;
var(Attack) const bool bShootTarget;
var(Attack) const bool bAttackFromOppositeSideOfMaster;
var transient bool bTargetHeld;
var(Attack) const SpecialMoveDefinition AttackAnim;
var float CheckRate;
var transient float Aim;
var transient AIRange ActualRange;

event Init()
{
    super(WillowActionSequencePawn).Init();
    ActualRange = Range;
    Aim = Cos(FClamp(VisionAngle, 0, 180) * 0.01745329);
    //return;    
}

event name CanRun()
{
    local name SuperVal;

    SuperVal = super(ActionSequence).CanRun();
    // End:0x35
    if(SuperVal != 'None')
    {
        return SuperVal;
    }
    // End:0x4E
    if(Target == none)
    {
        return 'NoTarget';
    }
    // End:0x67
    if(!IsFlying())
    {
        return 'NotFlying';
    }
    return 'None';
    //return ReturnValue;    
}

event Start()
{
    super.Start();
    CheckStateTransition();
    MyWillowMind.bWantsToFireWeapon = bShootTarget;
    MyWillowPawn.SetTimer(CheckRate, true, 'CheckStateTransition', self);
    //return;    
}

event Stop()
{
    super(WillowActionSequencePawn).Stop();
    MyWillowMind.bWantsToFireWeapon = false;
    MyWillowPawn.ClearTimer('CheckStateTransition', self);
    //return;    
}

event ActivateEvent(name EventName)
{
    super(WillowActionSequencePawn).ActivateEvent(EventName);
    ActualRange = Range;
    UnknownLocal_1 = Pawn(Target);
    // End:0x105
    if((UnknownLocal_1 != none) && UnknownLocal_1.CylinderComponent != none)
    {
        ActualRange.MinVal += UnknownLocal_1.CylinderComponent.CollisionRadius;
        ActualRange.MaxVal += UnknownLocal_1.CylinderComponent.CollisionRadius;
    }
    //return;    
}

function name GetDesiredState()
{
    local name DesiredState;

    // End:0x40
    if(AI.GetAIComponent().MovementOnHold())
    {
        return GetStateName();        
    }
    else
    {
        // End:0x81
        if(ValidAttackLoc(MyWillowPawn.Location))
        {
            DesiredState = 'RotateToTarget';            
        }
        else
        {
            DesiredState = 'MoveToTarget';
        }
    }
    return DesiredState;
    //return ReturnValue;    
}

function CheckStateTransition()
{
    local name DesiredState;

    DesiredState = GetDesiredState();
    // End:0x33
    if(DesiredState != GetStateName())
    {
        GotoState(DesiredState);
    }
    //return;    
}

function AttackFinished()
{
    Finish();
    //return;    
}

function float GetDotToTarget()
{
    local Vector ToTarget, AimDirection;

    ToTarget = Target.Location - MyWillowPawn.Location;
    ToTarget = Normal(ToTarget);
    AimDirection = MyWillowPawn.GetAimDirection();
    AimDirection = Normal(AimDirection);
    UnknownLocal_1 = ToTarget Dot AimDirection;
    return UnknownLocal_1;
    //return ReturnValue;    
}

function bool IsAimed()
{
    return (GetDotToTarget()) >= Aim;
    //return ReturnValue;    
}

function Vector GetAttackLoc()
{
    return TargetRec.Targetable.GetTargetableLocation();
    //return ReturnValue;    
}

function bool ValidAttackLoc(Vector TestLoc)
{
    local Vector TargetToTest, MasterToTarget;

    UnknownLocal_1 = VSize((GetAttackLoc()) - TestLoc);
    // End:0x45
    if(UnknownLocal_1 > ActualRange.MaxVal)
    {
        return false;
    }
    // End:0x6D
    if(UnknownLocal_1 < ActualRange.MinVal)
    {
        return false;
    }
    // End:0x169
    if(bAttackFromOppositeSideOfMaster && MyWillowPawn.PlayerMaster != none)
    {
        MasterToTarget = Normal(Target.Location - MyWillowPawn.PlayerMaster.Pawn.Location);
        TargetToTest = Normal(TestLoc - Target.Location);
        // End:0x169
        if((MasterToTarget Dot TargetToTest) <= 0)
        {
            return false;
        }
    }
    return true;
    //return ReturnValue;    
}

state MoveToTarget
{
    event bool PathFind()
    {
        local Vector GoalLoc, PawnToTarget, MasterToTarget;

        // End:0x28
        if(PathIsValid() && ValidAttackLoc(GetFinalDestination()))
        {
            return false;
        }
        GoalLoc = GetAttackLoc();
        UnknownLocal_1 = 0.5 * (ActualRange.MinVal + ActualRange.MaxVal);
        // End:0x133
        if(bAttackFromOppositeSideOfMaster && MyWillowPawn.PlayerMaster != none)
        {
            MasterToTarget = Normal(GoalLoc - MyWillowPawn.PlayerMaster.Pawn.Location);
            GoalLoc += (UnknownLocal_1 * MasterToTarget);            
        }
        else
        {
            PawnToTarget = Normal(MyWillowPawn.Location - GoalLoc);
            GoalLoc += (UnknownLocal_1 * PawnToTarget);
        }
        CreateVectorPath(GoalLoc);
        return true;
        //return ReturnValue;        
    }
Begin:

    CheckCloaked(1);
    InvalidatePath();
    WaitForPath();
    FollowPath();
    Sleep(0);
    goto 'Begin';
    stop;                
}

state RotateToTarget
{Begin:

    FinishPath();
    InvalidatePath();
    MyWillowMind.StopMovement();
    // End:0x87
    if(IsAimed())
    {
        CheckCloaked(2);
        Sleep(0);
        // End:0x7A
        if(IsAimed())
        {
            GotoState('Attack');            
        }
        else
        {
            goto 'Begin';
        }        
    }
    else
    {
        MyWillowMind.SetFacingPolicy(2, Target);
        Sleep(0);
        goto 'Begin';
    }
    stop;                    
}

state Attack
{
    ignores CheckStateTransition;

    function BeginState(name PreviousStateName)
    {
        TriggerBehavior('Attack');
        StartAtomic();
        MyNavHandle.ClearPath();
        MyWillowMind.bWantsToFireWeapon = false;
        switch(AimType)
        {
            // End:0x15C
            case 2:
                // End:0xF6
                if(MyWillowPawn.CanUseAimOffsets())
                {
                    MyWillowPawn.InterpRotation(MyWillowPawn.AimOffset.GetCurrentAim(), 0.1, true, false);                    
                }
                else
                {
                    MyWillowPawn.InterpRotation(Rotator(Target.Location - MyWillowPawn.Location), 0.1, true, false);
                }
            // End:0x1B0
            case 0:
                MyWillowMind.SetFacingPolicy(1);
                WillowAI.HoldMovement('Attack', self);
                // End:0x1BB
                break;
            // End:0x1B8
            case 1:
                // End:0x1BB
                break;
            // End:0xFFFF
            default:
                break;
        }
        //return;        
    }

    function EndState(name NextStateName)
    {
        StopAtomic();
        // End:0x5E
        if(int(AimType) != int(1))
        {
            AI.GetAIComponent().ReleaseMovement('Attack', self);
        }
        //return;        
    }
Begin:

    MyWillowPawn.SMComponent.Play(AttackAnim,,, 'AttackFinished', self);
    J0x4A:

    // End:0x9C [Loop If]
    if(MyWillowPawn.SMComponent.IsPlaying(AttackAnim))
    {
        Sleep(0);
        // [Loop Continue]
        goto J0x4A;
    }
    Finish();
    stop;                    
}

defaultproperties
