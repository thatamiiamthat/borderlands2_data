function Init(Controller Spawner, WillowProjectile SpawnedProjectile)
{
    local AttributeBaseValueData BaseValueData;
    local IBehaviorConsumer ProjectileConsumer;
    local BehaviorConsumerHandle ProjectileConsumerHandle;
    local GrenadeModBehaviorSequenceStateData GrenModProjectileSequenceStateData;
    local GrenadeModPartBehaviorSequenceStateData GrenModPartProjectileSequenceStateData;

    UnknownLocal_1 = GrenadeModDefinition(DefinitionData.ItemDefinition);
    // End:0xC9
    if(UnknownLocal_1 != none)
    {
        // End:0xC8
        foreach UnknownLocal_1.ProjectileBaseValues(BaseValueData,)
        {
            class'AttributeInitializationDefinition'.static.SetBaseValue(BaseValueData.Attribute, BaseValueData.BaseValue, Spawner, SpawnedProjectile);            
        }        
    }
    ProjectileConsumer = SpawnedProjectile.QueryInterface(class'IBehaviorConsumer');
    // End:0x298
    if(NotEqual_InterfaceInterface(ProjectileConsumer, IBehaviorConsumer(none)))
    {
        ProjectileConsumerHandle = ProjectileConsumer.GetBehaviorConsumerHandle();
        // End:0x1CF
        foreach UnknownLocal_1.SetProjectileSequenceState(GrenModProjectileSequenceStateData,)
        {
            class'BehaviorKernel'.static.ChangeBehaviorSequenceActivationStatus(ProjectileConsumerHandle, none, GrenModProjectileSequenceStateData.SequenceName, GrenModProjectileSequenceStateData.Action);            
        }        
        // End:0x297
        foreach AllParts(DefinitionData, UnknownLocal_3, false)
        {
            UnknownLocal_5 = GrenadeModPartDefinition(UnknownLocal_3);
            // End:0x296
            if(UnknownLocal_5 != none)
            {
                // End:0x295
                foreach UnknownLocal_5.SetProjectileSequenceState(GrenModPartProjectileSequenceStateData,)
                {
                    class'BehaviorKernel'.static.ChangeBehaviorSequenceActivationStatus(ProjectileConsumerHandle, none, GrenModPartProjectileSequenceStateData.SequenceName, GrenModPartProjectileSequenceStateData.Action);                    
                }                
            }            
        }        
    }
    //return;    
}

