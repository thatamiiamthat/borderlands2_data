function DroppedPickup GetPickup(bool bDisableRigidBody, bool bEnablePickup)
{
    SetGrenadeStorage(!ClassIsChildOf(Owner.Class, class'WillowPlayerPawn'));
    return super(WillowInventory).GetPickup(bDisableRigidBody, bEnablePickup);
    //return ReturnValue;    
}

function DroppedPickup CreatePickup(bool bDroppedPickup, bool bEnablePickup, optional Vector StartLocation)
{
