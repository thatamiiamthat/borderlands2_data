function NotifySkillActorDied(Actor SkillActor)
{
    // End:0x2D
    if(SkillActor == GeminiSpawnedActor)
    {
        RemoveInstanceData('Gemini');        
    }
    else
    {
        // End:0x57
        if(SkillActor == ScorpioSpawnedActor)
        {
            RemoveInstanceData('Scorpio');
        }
    }
    // End:0x102
    if((((GeminiSpawnedActor == none) && ScorpioSpawnedActor == none) && MyWillowPC != none) && MyWillowPC.PlayerSkillTree != none)
    {
        MyWillowPC.ServerDeactivateSkill(MyWillowPC.PlayerSkillTree.GetActionSkill());
    }
    //return;    
}

