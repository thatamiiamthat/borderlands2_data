simulated function DeployScorpio()
{
    // End:0x69
    if(((ScorpioSpawnedActor == none) || GeminiSpawnedActor == none) && ActiveProjectile == none)
    {
        // End:0x5F
        if(!MyWillowPawn.IsLocallyControlled())
