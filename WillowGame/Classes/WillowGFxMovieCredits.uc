class WillowGFxMovieCredits extends WillowGFxMovie3D
    native(GFx)
    config(Game)
    hidecategories(Mobile);

var() const editconst string ceStarted;
var() const editconst string ceFinished;
var CreditsGFxObject Credits;
var MontageGFxObject Montage;
var CreditsDataProviderGFxObject DataProvider;
var CreditsGFxDefinition CreditsDef;
var CreditsGFxDefinition NewCreditsDef;
var Texture2D MiddlewareTexture;
var string MiddlewareTextureLinkageName;
var transient bool bMiddlewareTextureLoaded;
var transient bool bSplatTextureLoaded;
var transient bool bClosing;
var Texture2D SplatTexture;
var string SplatTextureLinkageName;
var transient float ClosingTimeRemaining;
var transient int AxisResetCounter;

// Export UWillowGFxMovieCredits::execGetNewCreditsDef(FFrame&, void* const)
native function CreditsGFxDefinition GetNewCreditsDef();

event bool Start(optional bool StartPaused = false)
{
    UnknownLocal_1
    GetPC();
    // End:0x44
    if((UnknownLocal_1 == none) || !UnknownLocal_1.IsPrimaryPlayer())
    {
        return false;
    }
    UnknownLocal_3 = super.Start(StartPaused);
    // End:0xE5
    if(UnknownLocal_3)
    {
        CreditsDef = CreditsGFxDefinition(MyDefinition);
        NewCreditsDef = GetNewCreditsDef();
        ConsoleCommand("ce" @ ceStarted);
        __OnInputKey__Delegate = HandleInputKey;
        __OnInputAxis__Delegate = HandleInputAxis;
    }
    PlayUISound('CreditsStart');
    bMiddlewareTextureLoaded = false;
    LoadMiddlewareTexture();
    bSplatTextureLoaded = false;
    LoadSplatTexture();
    return UnknownLocal_3;
    //return ReturnValue;    
}

event OnClose()
{
    local DlcContentId MapContentId;

    MapContentId = class'WillowDownloadableContentManager'.static.StaticGetDlcContentIdForCurrentMap();
    ConsoleCommand("ce" @ ceFinished);
    // End:0x113
    if((!class'WorldInfo'.static.IsMenuLevel() && MapContentId.ContentId == 0) && MapContentId.PackageId == 0)
    {
        // End:0x112
        foreach GetPC().WorldInfo.LocalPlayerControllers(class'WillowPlayerController', UnknownLocal_1)
        {
            UnknownLocal_1.TryShowNewPlaythroughNotification();            
        }        
    }
    // End:0x1B1
    foreach GetPC().WorldInfo.LocalPlayerControllers(class'WillowPlayerController', UnknownLocal_1)
    {
        // End:0x1B0
        if(UnknownLocal_1.GetFrontendMovie() != none)
        {
            UnknownLocal_1.GetFrontendMovie().bCreditsMovieOpen = false;
            // End:0x1B0
            continue;
        }        
    }    
    ClearMiddlewareTexture();
    ClearSplatTexture();
    Credits = none;
    DataProvider = none;
    Montage.Close();
    Montage = none;
    PlayUISound('CreditsEnd');
    super(WillowGFxMovie).OnClose();
    //return;    
}

event OnTick()
{
    // End:0x4E
    if(-- AxisResetCounter == 0)
    {
        Credits.UpdateDelta(CreditsDef.DefaultSpeed);
    }
    // End:0xBA
    if(bClosing)
    {
        ClosingTimeRemaining -= WPCOwner.WorldInfo.DeltaSeconds;
        // End:0xB7
        if(ClosingTimeRemaining <= 0)
        {
            Close();
        }        
    }
    else
    {
        // End:0x125
        if(!WPCOwner.WorldInfo.IsMenuLevel() && !WPCOwner.bCinematicMode)
        {
            Close();
        }
    }
    //return;    
}

// Export UWillowGFxMovieCredits::execHasAppendedNewCredits(FFrame&, void* const)
native function bool HasAppendedNewCredits();

// Export UWillowGFxMovieCredits::execSetHasAppendedNewCredits(FFrame&, void* const)
native function SetHasAppendedNewCredits(bool appended);

// Export UWillowGFxMovieCredits::execSetLegacyCreditsLength(FFrame&, void* const)
native function SetLegacyCreditsLength(int Length);

// Export UWillowGFxMovieCredits::execGetLegacyCreditsLength(FFrame&, void* const)
native function int GetLegacyCreditsLength();

function extInitCredits(string PathToCreditsObject, GFxObject DataProviderObject)
{
    Credits = CreditsGFxObject(GetVariableObject(PathToCreditsObject, class'CreditsGFxObject'));
    Credits.Init(CreditsDef);
    DataProvider = CreditsDataProviderGFxObject(GetVariableObject(PathToCreditsObject $ ".dataProvider", class'CreditsDataProviderGFxObject'));
    // End:0x110
    if((HasAppendedNewCredits()) == false)
    {
        SetLegacyCreditsLength(CreditsDef.CreditData.Length);
        DataProvider.Init(CreditsDef, NewCreditsDef, true);
        SetHasAppendedNewCredits(true);        
    }
    else
    {
        DataProvider.Init(CreditsDef, NewCreditsDef, CreditsDef.CreditData.Length == (GetLegacyCreditsLength()));
    }
    Credits.StartCreditScroll();
    //return;    
}

function extInitMontage(string PathToMontageObject, string TextureLinkageName)
{
    Montage = MontageGFxObject(GetVariableObject(PathToMontageObject, class'MontageGFxObject'));
    Montage.Init(CreditsDef, TextureLinkageName);
    //return;    
}

// Export UWillowGFxMovieCredits::execLoadMiddlewareTexture(FFrame&, void* const)
native function LoadMiddlewareTexture();

// Export UWillowGFxMovieCredits::execClearMiddlewareTexture(FFrame&, void* const)
native function ClearMiddlewareTexture();

event OnMiddlewareTextureLoaded()
{
    bMiddlewareTextureLoaded = true;
    // End:0x2F
    if(MiddlewareTextureLinkageName != "")
    {
        extOnMiddlewareClipOnLoad(MiddlewareTextureLinkageName);
    }
    //return;    
}

function extOnMiddlewareClipOnLoad(string TextureLinkageName)
{
    MiddlewareTextureLinkageName = TextureLinkageName;
    // End:0x4D
    if(bMiddlewareTextureLoaded && MiddlewareTexture != none)
    {
        SetExternalTexture(MiddlewareTextureLinkageName, MiddlewareTexture);
    }
    //return;    
}

// Export UWillowGFxMovieCredits::execLoadSplatTexture(FFrame&, void* const)
native function LoadSplatTexture();

// Export UWillowGFxMovieCredits::execClearSplatTexture(FFrame&, void* const)
native function ClearSplatTexture();

event OnSplatTextureLoaded()
{
    bSplatTextureLoaded = true;
    // End:0x2F
    if(SplatTextureLinkageName != "")
    {
        extOnSplatClipOnLoad(SplatTextureLinkageName);
    }
    //return;    
}

function extOnSplatClipOnLoad(string TextureLinkageName)
{
    SplatTextureLinkageName = TextureLinkageName;
    // End:0x4D
    if(bSplatTextureLoaded && SplatTexture != none)
    {
        SetExternalTexture(SplatTextureLinkageName, SplatTexture);
    }
    //return;    
}

function extCreditsFinished()
{
    BeginClosing();
    //return;    
}

function BeginClosing()
{
    // End:0xA5
    if(!bClosing)
    {
        PlayUISound('CreditsEnd');
        // End:0x8A
        if(Montage.GetObject("clip").GetBool("_visible"))
        {
            Montage.FadeOut();
        }
        bClosing = true;
        ClosingTimeRemaining = 0.5;
    }
    //return;    
}

function bool HandleInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0x1B8
    if(!bClosing)
    {
        switch(ukey)
        {
            // End:0x2E
            case 'XboxTypeS_B':
            // End:0x5D
            case 'Escape':
                // End:0x58
                if(int(uevent) == int(1))
                {
                    BeginClosing();
                }
                return true;
                // End:0x1B8
                break;
            // End:0x69
            case 'Down':
            // End:0x109
            case 'XboxTypeS_DPad_Down':
                // End:0xC9
                if(int(uevent) == int(1))
                {
                    Credits.UpdateDelta(CreditsDef.DefaultSpeed);                    
                }
                else
                {
                    Credits.UpdateDelta(CreditsDef.MaxFastForwardSpeed);
                }
                // End:0x1B8
                break;
            // End:0x115
            case 'Up':
            // End:0x1B5
            case 'XboxTypeS_DPad_Up':
                // End:0x175
                if(int(uevent) == int(1))
                {
                    Credits.UpdateDelta(CreditsDef.DefaultSpeed);                    
                }
                else
                {
                    Credits.UpdateDelta(CreditsDef.MaxRewindSpeed);
                }
                // End:0x1B8
                break;
            // End:0xFFFF
            default:
                break;
        }
    }
    else
    {
        return false;
        //return ReturnValue;        
    }
}

function bool HandleInputAxis(int ControllerId, name ukey, float Delta, float DeltaTime)
{
    UnknownLocal_1 = false;
    // End:0x19B
    if(!bClosing)
    {
        Delta = (Delta * Delta) * Delta;
        switch(ukey)
        {
            // End:0x198
            case 'XboxTypeS_LeftY':
                AxisResetCounter = 3;
                // End:0x106
                if(Delta < float(0))
                {
                    Credits.UpdateDelta(CreditsDef.DefaultSpeed - (Delta * (CreditsDef.MaxFastForwardSpeed - CreditsDef.DefaultSpeed)));                    
                }
                else
                {
                    Credits.UpdateDelta(CreditsDef.DefaultSpeed + (Delta * (CreditsDef.MaxRewindSpeed - CreditsDef.DefaultSpeed)));
                }
                UnknownLocal_1 = true;
                // End:0x19B
                break;
            // End:0xFFFF
            default:
                break;
        }
    }
    else
    {
        return UnknownLocal_1;
        //return ReturnValue;        
    }
}

defaultproperties
{
    ceStarted="CreditsStarted"
    ceFinished="CreditsFinished"
    bFullscreenMovie=true
    TickRateSeconds=0.001
    bTickScript=true
}