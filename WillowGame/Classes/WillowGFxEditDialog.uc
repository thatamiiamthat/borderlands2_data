function DisplayOkBox(string CaptionFile, string CaptionSection, string InitialEditValue, delegate<OnMenuItemClicked> OnClicked, optional bool bAutoFocusEditBox)
{
    ((("$" $ CaptionFile) $ ".") $ CaptionSection) $ ".Caption";    
    SetDialogueText(((("$" $ CaptionFile) $ ".") $ CaptionSection) $ ".Prompt");
    AddMenuItem("$WillowMenu.dlg.Ok", 'OK', OnClicked);
    AddEditItem(((("$" $ CaptionFile) $ ".") $ CaptionSection) $ ".EditPrompt", 'EditPrompt', InitialEditValue, OnClicked);
    ApplyLayout();
    // End:0x142
    if(bAutoFocusEditBox)
    {
        Tools.inPrev(0);
        Tools.inSelect(0);
    }
    //return;    
}

function string GetDefaultEditBoxValue()
{
    return Tools.menuGetValue(0, "EditPrompt");
    //return ReturnValue;    
}

