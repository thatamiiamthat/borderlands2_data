function AddEditItem(string Label, name Tag, string InitialText, delegate<OnMenuItemClicked> OnClicked)
{
    local MenuItemCallback MIC;

    MIC.Tag = Tag;
    MIC.OnClicked = OnClicked;
    MenuItemCallbacks.AddItem(MIC;
    Tools.menuAddEditItem(Label, "" $ string(Tag), InitialText, "Change:extMenuItemClicked");
    //return;    
}

function AddMenuItem(string Label, name Tag, delegate<OnMenuItemClicked> OnClicked)
{
    local MenuItemCallback MIC;

    MIC.Tag = Tag;
    MIC.OnClicked = OnClicked;
    MenuItemCallbacks.AddItem(MIC;
    Tools.menuAddItem(0, Label, "" $ string(Tag), "extMenuItemClicked");
    //return;    
}

