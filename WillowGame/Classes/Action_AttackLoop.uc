class Action_AttackLoop extends Action_BasicAttack
    editinlinenew
    hidecategories(Mobile,Object,HideMe,ActionSequence,LoadBalance,Movement,Animation);

var(Loop) const AIRange LoopCount;
var(Loop) const SpecialMoveDefinition StartSMD;
var(Loop) const SpecialMoveDefinition StopSMD;
var(Loop) const SpecialMoveDefinition LoopSMD;
var(Loop) const editinline ExpressionEvaluator LoopCondition;
var transient int NumLoops;
var transient int MaxLoops;

function bool PlayAnim(SpecialMoveDefinition Anim, name CallbackName)
{
    MyWillowPawn.SMComponent.Play(Anim,,, CallbackName, self);
    return MyWillowPawn.SMComponent.IsPlaying(Anim);
    //return ReturnValue;    
}

state Attack
{
    function BeginState(name PreviousStateName)
    {
        super.BeginState(PreviousStateName);
        NumLoops = 0;
        MaxLoops = int(GetRangeValue(LoopCount));
        TriggerBehavior('StartAnim');
        // End:0x7B
        if(!PlayAnim(StartSMD, 'AnimFinished'))
        {
            PlayLoopAnim();
        }
        //return;        
    }

    function AnimFinished(bool bInterrupted)
    {
        // End:0x1B
        if(bInterrupted)
        {
            Finish(true);            
        }
        else
        {
            PlayLoopAnim();
        }
        //return;        
    }

    function PlayLoopAnim()
    {
        // End:0x22
        if(NumLoops == 0)
        {
            TriggerBehavior('LoopAnim');
        }
        // End:0xC7
        if((NumLoops < MaxLoops) && (LoopCondition == none) || LoopCondition.Evaluate(AI.GetAIActor()))
        {
            ++ NumLoops;
            // End:0xC4
            if(!PlayAnim(LoopSMD, 'AnimFinished'))
            {
                PlayStopAnim();
            }            
        }
        else
        {
            PlayStopAnim();
        }
        //return;        
    }

    function PlayStopAnim()
    {
        TriggerBehavior('StopAnim');
        // End:0x3F
        if(!PlayAnim(StopSMD, 'Finish'))
        {
            Finish();
        }
        //return;        
    }
Begin:

    stop;                
}

defaultproperties
{
    Limits(0)=AttackLocation_Range'Default__Action_AttackLoop.RangeLimit'
    Limits(1)=AttackLocation_LineOfSight'Default__Action_AttackLoop.LOSLimit'
    BehaviorOutputs=/* Array type was not detected. */
}