function ContextMenuActivated(string Action)
{
    // End:0x26
    if(Action == "SellTrash")
    {
        SellAllTrash();        
    }
    else
    {
        // End:0x54
        if(Action == "SellItem")
        {
            ConditionalStartTransfer('None');            
        }
        else
        {
            // End:0x81
            if(Action == "BuyItem")
            {
                ConditionalStartTransfer('None');                
            }
            else
            {
                // End:0xB2
                if(Action == "BuyBackItem")
                {
                    ConditionalStartTransfer('None');                    
                }
                else
                {
                    // End:0xDF
                    if(Action == "Compare")
                    {
                        StartCompare('None');                        
                    }
                    else
                    {
                        // End:0x109
                        if(Action == "Inspect")
                        {
                            InspectItem(CurrentSelectionItem);
                        }
                    }
                }
            }
        }
    }
    //return;    
}

function ContextMenuClosed()
{
    bIgnoreMouseInput = false;
    PCContextMenu = none;
    SendMousePos();
    //return;    
}

