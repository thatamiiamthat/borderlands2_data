    ItemOfTheDayPanel.SetSelected(true);
    TwoPanelInterface.SetActive(false);
    TwoPanelInterface.SetUpCard('Main', ItemOfTheDayData.Item, GetEquippedAnalogue(ItemOfTheDayData.Item), ItemOfTheDayData.Price);
    OnDynamicCardUpdated(ItemOfTheDayData.Item);
    FocusOn(ItemOfTheDayPanel.GetObject("cell"));
    PlayUISound('HorizontalMovement');
    //return;    
}

