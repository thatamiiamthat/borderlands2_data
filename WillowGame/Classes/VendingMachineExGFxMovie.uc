    {
        // End:0x556
        if(int(uevent) == int(0))
        {
            switch(ukey)
            {
                // End:0x4D9
                case 'XboxTypeS_B':
                // End:0x4F9
                case 'Escape':
                    UnknownLocal_1 = true;
                    BeginClosing();
                    // End:0x556
                    break;
                // End:0x505
                case 'Gamepad_LeftStick_Right':
                // End:0x511
