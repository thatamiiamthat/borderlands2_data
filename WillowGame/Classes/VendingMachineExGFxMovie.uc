    UnknownLocal_1 = false;
    // End:0x1B2
    if(VMGFxDef.bShouldPollShopItems)
    {
        CachedStorageThings = ShopItems;
        ShopItems.Length = 0;
        VM.GetInventoryList(ShopItems, WPCOwner);
        // End:0x127
        if(ShopItems.Length != CachedStorageThings.Length)
        {
            RefreshStoragePanelItems(ShopItems);
            UnknownLocal_1 = true;            
        }
        else
        {
            UnknownLocal_3 = 0;
            J0x12E:

            // End:0x1B2 [Loop If]
            if(UnknownLocal_3 < ShopItems.Length)
            {
                // End:0x1A8
                if(ShopItems[UnknownLocal_3].Item != CachedStorageThings[UnknownLocal_3].Item)
                {
                    RefreshStoragePanelItems(ShopItems);
                    UnknownLocal_1 = true;
                    // [Explicit Break]
                    goto J0x1B2;
                }
                ++ UnknownLocal_3;
                // [Loop Continue]
                goto J0x12E;
            }
        }
    }
    J0x1B2:

    CachedItemOfTheDayData = ItemOfTheDayData;
    ItemOfTheDayData = VM.GetFeaturedItem(WPCOwner);
    // End:0x276
    if(ItemOfTheDayData.Item != CachedItemOfTheDayData.Item)
    {
        ItemOfTheDayPanel.SetItemOfTheDayItem(ItemOfTheDayData.Item);
        UnknownLocal_1 = true;
    }
    AmmoPanel.RefreshTransientData();
    // End:0x2BC
    if(UnknownLocal_1)
    {
        TwoPanelInterface.RefreshItemCards();
    }
    //return;    
}

