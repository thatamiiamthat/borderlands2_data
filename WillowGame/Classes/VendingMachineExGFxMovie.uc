        if((int(class'GearboxGlobals'.static.GetPlatform()) != int(0)) || WPCOwner.PlayerInput.bUsingGamepad)
        {            
            S $= (ColorizeTooltipText(Localize("InvBar", "TrashFaveBar", "WillowMenu"), TwoPanelInterface.bOnLeftPanel) $ Spacing);
        }
    }
    // End:0x33C
    if(VMGFxDef.bShouldAllowCompare)
    {        
        S $= (ColorizeTooltipText(Localize("vending", "CompareBar", "WillowMenu"), TwoPanelInterface.TransferringThing != none) $ Spacing);
    }
    // End:0x3E0
    if(VMGFxDef.bShouldAllowSorting)
    {        
        S $= (ColorizeTooltipText(Localize("vending", "SortBar", "WillowMenu"), bOnItemOfTheDay || TwoPanelInterface.TransferringThing != none) $ Spacing);
    }
    // End:0x465
    if(!class'Engine'.static.IsSplitScreen())
    {        
        S $= (ColorizeTooltipText(Localize("InvBar", "InspectBar", "WillowMenu"), (GetSelectedThing()) == none) $ Spacing);
    }    
    S $= (Localize("vending", "CancelBar", "WillowMenu"));
    TwoPanelInterface.SetTooltipText(ResolveDataStoreMarkup(S));
    //return;    
}

function BeginClosing()
{
    TweenOut();
    super(WillowGFxThirdPersonMovie).BeginClosing();
    //return;    
}

function TweenOut()
{
    ActionScript("TweenOut");
    //return;    
}

function RefreshHealthBar()
{
    HealthBar.SetHealth(int(OwnerInventoryPawn.GetHealth()), int(OwnerInventoryPawn.GetMaxHealth()));
    //return;    
}

function RefreshShieldBar()
{
    UnknownLocal_1 = Round(OwnerInventoryPawn.GetShieldStrength());
    UnknownLocal_3 = Round(OwnerInventoryPawn.GetMaxShieldStrength());
    ShieldBar.SetShield(UnknownLocal_1, UnknownLocal_3);
    //return;    
}

function InitForPC()
{
    // End:0x2E
    if(TwoPanelInterface != none)
    {
        TwoPanelInterface.InitForPC();
    }
    //return;    
}

function InitForConsole()
{
    TwoPanelInterface.InitForConsole();
    //return;    
}

function extGenericButtonClicked(string ActionName)
{
    local name Action;

    Action = name(ActionName);
    switch(Action)
    {
        // End:0x41
        case 'Close':
            BeginClosing();
            // End:0x33B
            break;
        // End:0x173
        case 'Sort':
            // End:0xF1
            if(TwoPanelInterface.bOnLeftPanel)
            {
                // End:0xEE
                if(TwoPanelInterface.StoragePanel.bCanChangeSort)
                {
                    PlayUISound('HorizontalMovement');
                    TwoPanelInterface.StoragePanel.extOnChangeSort(1);
                }                
            }
            else
            {
                // End:0x170
                if(TwoPanelInterface.PlayerPanel.bCanChangeSort)
                {
                    PlayUISound('HorizontalMovement');
                    TwoPanelInterface.PlayerPanel.extOnChangeSort(1);
                }
            }
            // End:0x33B
            break;
        // End:0x1CE
        case 'nav1':
            // End:0x1CB
            if(TwoPanelInterface.TrySwitchToRightPanel())
            {
                ItemOfTheDayPanel.SetVisibility(false);
                Refresh();
            }
            // End:0x33B
            break;
        // End:0x26C
        case 'nav2':
            // End:0x269
            if(TwoPanelInterface.TrySwitchToLeftPanel() || bIsStoragePanelShowingBuyback)
            {
                ItemOfTheDayPanel.SetVisibility(true);
                bIsStoragePanelShowingBuyback = false;
                TwoPanelInterface.SetHeaderLabel(StoragePanelLabel);
                Refresh();
            }
            // End:0x33B
            break;
        // End:0x338
        case 'nav3':
            // End:0x335
            if(CanSwitchToBuyback())
            {
                // End:0x335
                if(TwoPanelInterface.TrySwitchToLeftPanel() || !bIsStoragePanelShowingBuyback)
                {
                    TwoPanelInterface.TrySwitchToLeftPanel();
                    ItemOfTheDayPanel.SetVisibility(true);
                    bIsStoragePanelShowingBuyback = true;
                    TwoPanelInterface.SetHeaderLabel(BuybackPanelLabel);
                    Refresh();
                }
            }
            // End:0x33B
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

function PressedHotkeyNumber(int HotkeyNum)
{
    // End:0x31
    if(NumHeaderButtons == 1)
    {
        // End:0x2E
        if(HotkeyNum == 1)
        {
            extGenericButtonClicked("nav2");
        }        
    }
    else
    {
        // End:0x83
        if((HotkeyNum >= 1) && HotkeyNum <= NumHeaderButtons)
        {
            extGenericButtonClicked("nav" $ string((NumHeaderButtons - HotkeyNum) + 1));
        }
    }
    //return;    
}

