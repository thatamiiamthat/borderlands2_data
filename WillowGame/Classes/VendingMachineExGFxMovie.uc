function RefreshTransientData()
{
    local array<ShopItemData> CachedStorageThings;
    local ShopItemData CachedItemOfTheDayData;

    // End:0x6E
    if((((TwoPanelInterface == none) || ItemOfTheDayPanel == none) || TwoPanelInterface.StoragePanel == none) || TwoPanelInterface.PlayerPanel == none)
    {
        return;
    }
