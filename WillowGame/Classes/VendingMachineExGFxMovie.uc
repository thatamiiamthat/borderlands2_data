function OnPanelRollOver(InventoryListPanelGFxObject Panel, int ControllerId)
{
    // End:0x1B8
    if(TwoPanelInterface.IsTransferring())
    {
        // End:0xFE
        if(TwoPanelInterface.bOnLeftPanel)
        {
            // End:0xFB
            if(Panel == TwoPanelInterface.PlayerPanel)
            {
                TwoPanelInterface.bOnLeftPanel = false;
                TwoPanelInterface.PlayerPanel.SetActive(true);
                TwoPanelInterface.StoragePanel.SetActive(false);
            }            
        }
        else
        {
            // End:0x1B5
            if(Panel == TwoPanelInterface.StoragePanel)
            {
                TwoPanelInterface.bOnLeftPanel = true;
                TwoPanelInterface.StoragePanel.SetActive(true);
                TwoPanelInterface.PlayerPanel.SetActive(false);
            }
        }        
    }
    else
    {
        // End:0x1CF
        if(bOnItemOfTheDay)
        {
            SwitchToPanels();
        }
    }
    //return;    
}

function SwitchToPanels()
{
