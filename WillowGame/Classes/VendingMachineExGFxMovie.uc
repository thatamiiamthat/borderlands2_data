    // End:0xD1 [Loop If]
    if(UnknownLocal_1 < ShopItems.Length)
    {
        // End:0xC7
        if(ShopItems[UnknownLocal_1].Item == Thing)
        {
            return ShopItems[UnknownLocal_1].ItemStatus;
        }
        ++ UnknownLocal_1;
        // [Loop Continue]
        goto J0x60;
    }
    return 0;
    //return ReturnValue;    
}

