function Refresh()
{
    local ShopItemData NewShopItemData;

    UnknownLocal_1 = bOnItemOfTheDay;
    TwoPanelInterface.Refresh();
    // End:0x65
    if(TwoPanelInterface.bOnLeftPanel && UnknownLocal_1)
    {
        SwitchToItemOfTheDay();
    }
    // End:0xE3
    if(TwoPanelInterface.bOnLeftPanel && bIsStoragePanelShowingBuyback)
    {
        TwoPanelInterface.SetHeaderLabel(BuybackPanelLabel);
        TwoPanelInterface.SetActiveTab("left");
    }
    NewShopItemData = VM.GetFeaturedItem(WPCOwner);
    // End:0x1CC
    if((NewShopItemData.Item != ItemOfTheDayData.Item) || NewShopItemData.Price != ItemOfTheDayData.Price)
    {
        ItemOfTheDayPanel.SetItemOfTheDayItem(NewShopItemData.Item);
    }
    // End:0x27E
    if(TwoPanelInterface.bOnLeftPanel && bOnItemOfTheDay)
    {
        TwoPanelInterface.SetUpCard('Main', NewShopItemData.Item, none, NewShopItemData.Price);
        TwoPanelInterface.SetActive(false);
    }
    ItemOfTheDayData = NewShopItemData;
    SetCreditsDisplay();
    EvaluateCurrentSelection();
    //return;    
}

function ConfigureShopForType(IShop.EShopType InShopType)
{
    switch(InShopType)
    {
        // End:0xB6
        case 0:
            ShopIconBase = "weapons";
            TwoPanelInterface.StoragePanel.SetBackground(2);
            TwoPanelInterface.SetHeader(ShopIconBase, WeaponsShopTitle);
            ItemOfTheDayPanel.SetBackground(2);
            // End:0x2BC
            break;
        // End:0x156
        case 1:
            ShopIconBase = "ammo";
            TwoPanelInterface.StoragePanel.SetBackground(3);
            TwoPanelInterface.SetHeader(ShopIconBase, ItemsShopTitle);
            ItemOfTheDayPanel.SetBackground(3);
            // End:0x2BC
            break;
        // End:0x1FA
        case 2:
            ShopIconBase = "medicine";
            TwoPanelInterface.StoragePanel.SetBackground(1);
            TwoPanelInterface.SetHeader(ShopIconBase, HealthShopTitle);
            ItemOfTheDayPanel.SetBackground(1);
            // End:0x2BC
            break;
        // End:0x2B9
        case 3:
            ShopIconBase = "eridium";
            TwoPanelInterface.SetPlayerPanelHidden();
            TwoPanelInterface.StoragePanel.SetBackground(6);
            TwoPanelInterface.SetHeader(ShopIconBase, BlackMarketTitle);
            ItemOfTheDayPanel.SetBackground(6);
        // End:0xFFFF
        default:
            break;
    }
    HealthBar.SetVisible(int(InShopType) == int(2));
    ShieldBar.SetVisible(int(InShopType) == int(2));
    // End:0x344
    if(int(InShopType) == int(2))
    {
        RefreshHealthBar();
        RefreshShieldBar();
    }
    // End:0x40D
    if((int(InShopType) == int(1)) || VMGFxDef.bShouldShowAmmoPanel)
    {
        AmmoPanel.SetVisible(true);
        AmmoPanel.Init();
        AmmoPanel.SetAllAmmoCounts();
        TwoPanelInterface.__OnDynamicCardUpdated__Delegate = OnDynamicCardUpdated;        
    }
    else
    {
        AmmoPanel.SetVisible(false);
    }
    //return;    
}

