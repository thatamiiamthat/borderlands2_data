    ShopItems.Length = 0;
    BuyBackItems.Length = 0;
    VM.GetInventoryList(ShopItems, WPCOwner);
    VM.GetBuyBackList(BuyBackItems, WPCOwner);
    // End:0xCB
    if(BuyBackItems.Length == 0)
    {
        TwoPanelInterface.SetTabIconFrame(0, "gray");
        bIsStoragePanelShowingBuyback = false;        
    }
    else
    {
        TwoPanelInterface.SetTabIconFrame(0, ShopIconBase);
    }
    // End:0x158
    if(bIsStoragePanelShowingBuyback)
    {
        UnknownLocal_1 = 0;
        J0x108:

        // End:0x155 [Loop If]
        if(UnknownLocal_1 < BuyBackItems.Length)
        {
            Things.AddItem(BuyBackItems[UnknownLocal_1].Item;
            ++ UnknownLocal_1;
            // [Loop Continue]
            goto J0x108;
        }        
    }
    else
    {
        UnknownLocal_1 = 0;
        J0x15F:

        // End:0x1AC [Loop If]
        if(UnknownLocal_1 < ShopItems.Length)
        {
            Things.AddItem(ShopItems[UnknownLocal_1].Item;
            ++ UnknownLocal_1;
            // [Loop Continue]
            goto J0x15F;
        }
    }
    //return;    
}

