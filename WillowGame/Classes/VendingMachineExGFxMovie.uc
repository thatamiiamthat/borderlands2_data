function ShowContextMenu(optional bool bIsCompareMode = false)
{
    local array<PCContextMenuItem> MenuItems;
    local VendingMachineExGFxMovie.EShopMode Mode;

    UnknownLocal_1
    GetSelectedThing();
    // End:0x23F
    if((UnknownLocal_1 != none) && GetCurrentCellObject().MouseHitTest())
    {
        EvaluateCurrentSelection();
        GetCurrentShopMode(Mode, UnknownLocal_3);
        // End:0x192
        if(UnknownLocal_3 != 0)
        {
            switch(Mode)
            {
                // End:0xDD
                case 0:
                    class'PCContextMenuObject'.static.AddToMenuItemList(MenuItems, class'PCContextMenuObject'.default.Str_Sell, "SellItem");
                    // End:0x192
                    break;
                // End:0x134
                case 1:
                    class'PCContextMenuObject'.static.AddToMenuItemList(MenuItems, class'PCContextMenuObject'.default.Str_Buy, "BuyItem");
                    // End:0x192
                    break;
                // End:0x18F
                case 2:
                    class'PCContextMenuObject'.static.AddToMenuItemList(MenuItems, class'PCContextMenuObject'.default.Str_BuyBack, "BuyBackItem");
                    // End:0x192
                    break;
                // End:0xFFFF
                default:
                    break;
            }
        }
        else
        {
            // End:0x1F0
            if(!bIsCompareMode)
            {
                class'PCContextMenuObject'.static.AddToMenuItemList(MenuItems, class'PCContextMenuObject'.default.Str_Compare, "Compare");
            }
            class'PCContextMenuObject'.static.AddToMenuItemList(MenuItems, class'PCContextMenuObject'.default.Str_Inspect, "Inspect");
        }/* !MISMATCHING REMOVE, tried If got Type:Else Position:0x192! */
        // End:0x2AE
        if((CanSellAllTrash()) && !bIsCompareMode)
        {
            class'PCContextMenuObject'.static.AddToMenuItemList(MenuItems, class'PCContextMenuObject'.default.Str_SellTrash, "SellTrash");
        }
        // End:0x3AA
        if(MenuItems.Length > 0)
        {
            PCContextMenu = new class'PCContextMenuObject';
            PCContextMenu.Init();
            PCContextMenu.__OnMenuClosed__Delegate = ContextMenuClosed;
            PCContextMenu.__OnMenuItemClicked__Delegate = ContextMenuActivated;
            PCContextMenu.AddMenuItems(MenuItems);
            PCContextMenu.ShowFor(self);
            bIgnoreMouseInput = true;
        }
        //return;        
    }/* !MISMATCHING REMOVE, tried Else got Type:If Position:0x015! */
}

