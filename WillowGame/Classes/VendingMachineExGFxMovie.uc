event OnClose()
{
    VM.InteractiveObjectDefinition.OnClosing(VM.ConsumerHandle, WPCOwner);
    PlayUISound('MenuClose');
    WPCOwner.bUsingVendingMachine = false;
    WPCOwner.ServerStoppedShopping();
    WPCOwner.ClearTimer('CheckShopOpStatus', self);
    FreeTextures();
    TwoPanelInterface.Cleanup();
    ItemOfTheDayPanel.Cleanup();
    Feedback = none;
    OwnerInventoryPawn = none;
    HealthBar = none;
    ShieldBar = none;
    AmmoPanel = none;
    ClearVendingMachineRefreshTimer();
    super.OnClose();
    //return;    
}

