            break;
    }
    // End:0x22B
    if(VMGFxDef.bCustomStoragePanelTint)
    {
        LeftPanel.SetBackground(7);
        LeftPanel.SetBackgroundTint(VMGFxDef.CustomStoragePanelTint);
    }
    // End:0x2B9
    if(int(VMGFxDef.bUseAdvancedCustomStoragePanelTint) > int(0))
    {
        UnknownLocal_1 = LeftPanel.GetObject("bkgd");
        UnknownLocal_1.SetColorTransform(VMGFxDef.AdvancedCustomTint);
    }
    // End:0x31A
    if(VMGFxDef.CustomStoragePanelHeaderIcon != none)
    {
        LeftPanel.SetHeaderIconClip(VMGFxDef.CustomStoragePanelHeaderIcon);
    }
    SetTooltips();
    bCanAcceptInput = 1;
    //return;    
}

