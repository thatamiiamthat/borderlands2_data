            HeaderTitle = ItemsShopTitle;
            // End:0xE8
            break;
        // End:0x9B
        case 2:
            ShopIconBase = "medicine";
            HeaderTitle = HealthShopTitle;
            // End:0xE8
            break;
        // End:0xE5
        case 3:
            ShopIconBase = "eridium";
            HeaderTitle = BlackMarketTitle;
            TwoPanelInterface.SetPlayerPanelHidden();
        // End:0xFFFF
        default:
            break;
    }
    HeaderFrame = ShopIconBase;
    // End:0x148
    if(VMGFxDef.CustomHeaderStyle != "")
    {
        HeaderFrame = VMGFxDef.CustomHeaderStyle;
    }
    TwoPanelInterface.SetHeader(HeaderFrame, HeaderTitle);
    // End:0x1E1
