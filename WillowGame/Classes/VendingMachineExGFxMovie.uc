{
    return CurrentSelectionItem.Owner == WPCOwner.GetInventoryPawn();
    //return ReturnValue;    
}

function bool IsCurrentSelectionBuyBack()
{
    UnknownLocal_1 = WPCOwner.GetInventoryPawn();
    UnknownLocal_3 = WillowInventoryManager(UnknownLocal_1.InvManager);
    return UnknownLocal_3.BuybackInventory.Find(CurrentSelectionItem >= 0;
