function GetSortConfigDataForPanel(InventoryListPanelGFxObject Panel, out SortFilterConfiguration SortConfigData)
{
    // End:0xDD
    if(TwoPanelInterface.TransferringThing != none)
    {
        // End:0xDD
        if((TwoPanelInterface.bOnLeftPanel && Panel == TwoPanelInterface.StoragePanel) || !TwoPanelInterface.bOnLeftPanel && Panel == TwoPanelInterface.PlayerPanel)
        {
            SortConfigData = CompareConfiguration;
            return;
        }
    }
    // End:0x129
    if(Panel == TwoPanelInterface.PlayerPanel)
    {
        SortConfigData = GenericSortConfigurations[PlayerPanelSortConfigIndex];        
    }
    else
    {
        switch(ShopType)
        {
            // End:0x161
            case 0:
                SortConfigData = WeaponsSortConfigurations[StoragePanelSortConfigIndex];
                // End:0x1D3
                break;
            // End:0x186
            case 1:
                SortConfigData = GrenadesSortConfigurations[StoragePanelSortConfigIndex];
                // End:0x1D3
                break;
            // End:0x1AB
            case 3:
                SortConfigData = BlackMarketSortConfigurations[StoragePanelSortConfigIndex];
                // End:0x1D3
                break;
            // End:0x1B0
            case 2:
            // End:0xFFFF
            default:
                SortConfigData = HealthSortConfigurations[StoragePanelSortConfigIndex];
                // End:0x1D3
                break;
                break;
        }
    }
    //return;    
}

function int GetOverridePriceForInventory(WillowInventory WInv)
{
    // End:0x11
    if(WInv == none)
    {
        return 0;
    }
    // End:0x96
    if((WInv.Owner != none) && WInv.Owner == VM)
    {
        return VM.GetSellingPriceForInventory(WInv, WPCOwner);
    }
    // End:0x10E
    if((WInv.Owner == OwnerInventoryPawn) || WInv.Owner == OwnerInventoryPawn.InvManager)
    {
        return -1;        
    }
    else
    {
        return VM.GetSellingPriceForInventory(WInv, WPCOwner);
    }
    //return ReturnValue;    
}

function Engine.WillowInventoryDefinition.ECurrencyType GetCurrencyTypeForInventory(WillowInventory WInv)
{
    // End:0x12
    if(WInv == none)
    {
        return 0;
    }
    // End:0x6F
    if((WInv.Owner != none) && WInv.Owner == VM)
    {
        return GetCurrencyType();
    }
    // End:0xE4
    if((WInv.Owner == OwnerInventoryPawn) || WInv.Owner == OwnerInventoryPawn.InvManager)
    {
        return 0;        
    }
    else
    {
        return GetCurrencyType();
    }
    //return ReturnValue;    
}

