function extInitVendingMachine()
{
    local Engine.WillowInventoryDefinition.ECurrencyType CurrencyType;

    HealthBar = HealthBarGFxObject(GetVariableObject("vendingMachine.healthBar", class'HealthBarGFxObject'));
    ShieldBar = ShieldBarGFxObject(GetVariableObject("vendingMachine.shieldBar", class'ShieldBarGFxObject'));
    AmmoPanel = AmmoPanelGFxObject(GetVariableObject("vendingMachine.ammo", class'AmmoPanelGFxObject'));
    Feedback = VendingMachineFeedbackGFxObject(GetVariableObject("vendingMachine.feedback", class'VendingMachineFeedbackGFxObject'));
    CurrencyType = GetCurrencyType();
    // End:0x163
    if(int(CurrencyType) != int(0))
    {
        PlayerMoney = ValueGFxObject(GetVariableObject("vendingMachine.eridium", class'EridiumValueGFxObject'));        
    }
    else
    {
        PlayerMoney = ValueGFxObject(GetVariableObject("vendingMachine.credits", class'ValueGFxObject'));
    }
    SetCreditsDisplay();
    SetVendingMachineRefreshTimer();
    ConfigureForType_Shop();
    //return;    
}

function extInitItemOfTheDayPanel(string ItemOfTheDayPanelPath)
