function bool GetCurrentShopMode(out VendingMachineExGFxMovie.EShopMode ShopMode, out int bCanActivate)
{
    // End:0x7A
    if(CurrentSelectionItem == none)
    {
        // End:0x38
        if(bOnItemOfTheDay)
        {
            ShopMode = 1;
            bCanActivate = 0;
            return true;            
        }
        else
        {
            // End:0x75
            if(!TwoPanelInterface.bOnLeftPanel)
            {
                ShopMode = 0;
                bCanActivate = 0;
                return true;
            }
        }
        return false;        
    }
    else
    {
        // End:0xC6
        if(IsCurrentSelectionSell())
        {
            ShopMode = 0;
            bCanActivate = ((VMGFxDef.bDisableSelling) ? 0 : 1);            
        }
        else
        {
            // End:0xE2
            if(IsCurrentSelectionBuyBack())
            {
                ShopMode = 2;                
            }
            else
            {
                ShopMode = 1;
            }
            bCanActivate = ((int(CurrentSelectionShopStatus) == int(0)) ? 1 : 0);
        }
    }
    return true;
    //return ReturnValue;    
}

function ConditionalStartTransfer(name ukey)
{
    // End:0xD6
    if(IsCurrentSelectionSell())
    {
        // End:0x31
        if(VMGFxDef.bDisableSelling)
        {
            return;
        }
        VM.PlayerSellItem(CurrentSelectionItem, WPCOwner);
        PlayUISound('Sell');
        Feedback.TriggerSold();
        TwoPanelInterface.PlayerPanel.FlourishActiveCell();
        Refresh();        
    }
    else
    {
        // End:0x2AB
        if(int(CurrentSelectionShopStatus) == int(0))
        {
            // End:0x1AB
            if(IsCurrentSelectionBuyBack())
            {
                // End:0x19E
                if(VM.PlayerBuyBackItem(CurrentSelectionItem, WPCOwner))
                {
                    PlayUISound('Buy');
                    Feedback.TriggerPurchased();
                    TwoPanelInterface.StoragePanel.FlourishActiveCell();
                    Refresh();                    
                }
                else
                {
                    PlayFeedback_CannotAfford();
                }                
            }
            else
            {
                VM.PlayerBuyItem(CurrentSelectionItem, WPCOwner, 1, bOnItemOfTheDay);
                PlayUISound('Buy');
                Feedback.TriggerPurchased();
                TwoPanelInterface.StoragePanel.FlourishActiveCell();
                AmmoPanel.RefreshTransientData();
                RefreshHealthBar();
                RefreshShieldBar();
                WPCOwner.SetTimer(0.1, true, 'CheckShopOpStatus', self);
            }            
        }
        else
        {
            // End:0x2CC
            if(int(CurrentSelectionShopStatus) == int(2))
            {
                PlayFeedback_CannotAfford();                
            }
            else
            {
                // End:0x300
                if((int(CurrentSelectionShopStatus) == int(1)) || int(CurrentSelectionShopStatus) == int(3))
                {
                    PlayFeedback_CannotCarryOrUse();
                }
            }
        }
    }
    // End:0x32A
    if(__OnInputKey__Delegate == )
    {
        FinishCompare(ukey);
    }
    //return;    
}

function PlayFeedback_CannotAfford()
{
    PlayUISound('VendingNoMoney');
    Feedback.TriggerCannotAfford();
    //return;    
}

function PlayFeedback_CannotCarryOrUse()
{
