function StartCompare(name ukey)
{
    // End:0x37
    if((CurrentSelectionItem == none) || !VMGFxDef.bShouldAllowCompare)
    {
        return;
    }
    __OnInputKey__Delegate = CompareInputKey;
    FrozenThingType = class'InventoryListPanelGFxObject'.static.GetInventoryType(CurrentSelectionItem);
    TwoPanelInterface.StartTransfer(ukey);
    TwoPanelInterface.SetActivePanelSortConfiguration(CompareConfiguration);
    TwoPanelInterface.SetActivePanelSelectIndexByThing(GetEquippedAnalogue(CurrentSelectionItem));
    TwoPanelInterface.SetHeaderLabel(ComparePanelLabel);
    ItemOfTheDayPanel.SetVisibility(false);
    class'WillowLeviathanService'.static.RecordMinorActionEventForPlayer(WPCOwner, 6);
    //return;    
}

function FinishCompare(name ukey)
{
    TwoPanelInterface.FinishTransfer(ukey, false);
    FrozenThingType = 5;
    // End:0xDF
    if(TwoPanelInterface.bOnLeftPanel)
    {
        // End:0xB4
        if(bIsStoragePanelShowingBuyback)
        {
            TwoPanelInterface.SetHeaderLabel(BuybackPanelLabel);
            TwoPanelInterface.SetActiveTab("left");            
        }
        else
        {
            TwoPanelInterface.SetHeaderLabel(StoragePanelLabel);
        }        
    }
    else
    {
        TwoPanelInterface.SetHeaderLabel(PlayerPanelLabel);
    }
    ItemOfTheDayPanel.SetVisibility(TwoPanelInterface.bOnLeftPanel);
    __OnInputKey__Delegate = MainInputKey;
    Refresh();
    //return;    
}

