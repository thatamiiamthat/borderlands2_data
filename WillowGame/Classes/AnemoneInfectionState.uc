{
    UnknownLocal_1 = false;
    // End:0x3E
    if((WPC == none) || WPC.Pawn == none)
    {
        return true;
    }
    UnknownLocal_3 = 0;
    J0x45:

    // End:0xE3 [Loop If]
    if(UnknownLocal_3 < LargeZones.Length)
    {
        UnknownLocal_5 = LargeZones[UnknownLocal_3];
        // End:0xD9
        if((UnknownLocal_5 == none) || !UnknownLocal_5.IsOverlapping(WPC.Pawn))
        {
            LargeZones.RemoveItem(UnknownLocal_5;
            -- UnknownLocal_3;
            UnknownLocal_1 = true;
        }
        ++ UnknownLocal_3;
        // [Loop Continue]
        goto J0x45;
    }
    UnknownLocal_3 = 0;
    J0xEA:

    // End:0x188 [Loop If]
    if(UnknownLocal_3 < SmallZones.Length)
    {
        UnknownLocal_5 = SmallZones[UnknownLocal_3];
        // End:0x17E
        if((UnknownLocal_5 == none) || !UnknownLocal_5.IsOverlapping(WPC.Pawn))
        {
            SmallZones.RemoveItem(UnknownLocal_5;
            -- UnknownLocal_3;
            UnknownLocal_1 = true;
        }
        ++ UnknownLocal_3;
        // [Loop Continue]
        goto J0xEA;
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

function SetAnemoneInfectionState(WillowPlayerController OwnerController, bool bIsInfected, bool bLargeZone, Actor Zone, AnemoneInfectionDefinition NewInfectionDefinition, HeightFog NewHeightFog)
{
    InfectionDefinition = NewInfectionDefinition;
    DisplayTimer.Speed = 1 / InfectionDefinition.DisplaySpeed;
    // End:0x65
    if(bIsInfected)
    {        
    }
    // End:0x76
    if(OwnerController == none)
    {
        return;
    }
    bIsImmune = CheckImmunity();
    WPC = OwnerController;
    bIsLocalPlayer = LocalPlayer(WPC.Player) != none;
    // End:0x1CA
    if(bIsInfected)
    {
        // End:0x13C
        if(AddZone(bLargeZone, Zone))
        {
            InfectionRate = 1 / InfectionDefinition.FullInfectionTime;
            EnterInfectionVolume();            
        }
        else
        {
            ShowAmbientFX(true);
        }
        // End:0x1CA
        if((bIsLocalPlayer && NewHeightFog != none) && HeightFog != NewHeightFog)
        {
            HeightFog = NewHeightFog;
            HeightFog.Component.UpdateDensity(0);
        }
    }
    //return;    
}

function bool IsInfected()
{
    return IsInState('Infected') || IsInState('Healing');
    //return ReturnValue;    
}

function HideBarTemporarily()
{
    TemporarilyHiddenTimer = InfectionDefinition.DiscoveryTextHiddenTime;
    //return;    
}

function SetModalMenuOpen(bool bOpen)
{
    // End:0x71
    if((TimerMovie != none) && bOpen)
    {
        DisplayTimer.Value = 0;
        TimerMovie.SingleArgInvokeF("gotoAndStop", 0);
    }
    //return;    
}

function EnterInfectionVolume()
{
    GotoState('Infected');
    //return;    
}

function ExitInfectionVolume(bool bForceInstantHeal)
{
    WillowPlayerPawn(WPC.Pawn).ClientExitInfectionVolume(bForceInstantHeal);
    // End:0x90
    if((WPC != none) && !WPC.IsLocalPlayerController())
    {
        ExitInfectionVolumeImpl(bForceInstantHeal);
    }
    //return;    
}

function ExitInfectionVolumeImpl(bool bForceInstantHeal)
{
    LargeZones.Length = 0;
    SmallZones.Length = 0;
    InfectionRate = 1 / InfectionDefinition.FullHealingTime;
    // End:0x63
    if(bForceInstantHeal)
    {
        CurrentInfection = 0;
    }
    GotoState('Healing');
    //return;    
}

function StopInfected()
{
    WillowPlayerPawn(WPC.Pawn).ClientStopInfected();
    // End:0x7C
    if((WPC != none) && !WPC.IsLocalPlayerController())
    {
        StopInfectedImpl();
    }
    //return;    
}

function StopInfectedImpl()
{
    GotoState('NotInfected');
    //return;    
}

function ActivateSkill()
{
    WPC.Behavior_ActivateSkill(InfectionDefinition.GasCloudSkill);
    //return;    
}

function DeactivateSkill()
{
    WPC.Behavior_DeactivateSkill(InfectionDefinition.GasCloudSkill);
    //return;    
}

function ShowInfectionFX(bool bShow)
{
    local ScreenParticleInitParams SPParams;

    // End:0x11
    if(!bIsLocalPlayer)
    {
        return;
    }
    UnknownLocal_1 = WPC.FindScreenParticleRecordIndexByTemplate(InfectionDefinition.InfectionFXTemplate);
    // End:0x397
    if(bShow == true)
    {
        StartInfectionSound();
        DisplayTimer.bShowing = true;
        // End:0x2FC
        if(TimerMovie == none)
        {
            TimerMovie = GFxMovieInteractiveObject(InfectionDefinition.MovieDefinition.SpawnPlayerMovie(WPC, none, none));
            TimerMovie.Init(LocalPlayer(WPC.Player));
            TimerMovie.bOnlyOwnerFocusable = true;
            TimerMovie.Start(InfectionDefinition.MovieDefinition.bStartPaused);
            TimerMovie.Advance(0);
            // End:0x221
            if(bIsImmune)
            {
                TimerMovie.SingleArgInvokeS("creepTimerBar.shield.gotoAndPlay", "on");                
            }
            else
            {
                TimerMovie.SingleArgInvokeS("creepTimerBar.shield.gotoAndStop", "off");
            }
            TimerMovie.SingleArgInvokeF("creepTimerBar.gotoAndStop", 0);
            TimerMovie.GetVariableObject("creepTimerBar.shield").SetVisible(bIsImmune);
        }
        // End:0x394
        if((UnknownLocal_1 == -1) && InfectionDefinition.InfectionFXTemplate != none)
        {
            SPParams.Template = InfectionDefinition.InfectionFXTemplate;
            WPC.ShowScreenParticle(SPParams);
        }        
    }
    else
    {
        StopInfectionSound();
        DisplayTimer.bShowing = false;
        // End:0x408
        if(DisplayTimer.Value > 1)
        {
            DisplayTimer.Value = 1;
        }
        // End:0x456
        if(UnknownLocal_1 != -1)
        {
            WPC.HideScreenParticle(InfectionDefinition.InfectionFXTemplate,, false);
        }
    }
    //return;    
}

function UpdateInfectionFX(float CurrentValue)
{
    local editinline ParticleSystemComponent PSC;

    // End:0x136
    if(bIsLocalPlayer && !bIsImmune)
    {
        TimerMovie.SingleArgInvokeF("creepTimerBar.gotoAndStop", CurrentValue * 500);
        UnknownLocal_1 = WPC.FindScreenParticleRecordIndexByTemplate(InfectionDefinition.InfectionFXTemplate);
        // End:0x12C
        if(UnknownLocal_1 != -1)
        {
            PSC = WPC.ScreenParticleRecords[UnknownLocal_1].Component;
            PSC.SetFloatParameter('InfectionRatio', CurrentInfection);
        }
        UpdateInfectionSound();
    }
    //return;    
}

function ShowSkillFX(bool bShow)
{
    local ScreenParticleInitParams SPParams;

    // End:0x11
    if(!bIsLocalPlayer)
    {
        return;
    }
    UnknownLocal_1 = WPC.FindScreenParticleRecordIndexByTemplate(InfectionDefinition.SkillFXTemplate);
    // End:0x13D
    if(bShow == true)
    {
        SkillFXSpeed = 1 / InfectionDefinition.SkillFXInTime;
        // End:0x13A
        if((UnknownLocal_1 == -1) && InfectionDefinition.SkillFXTemplate != none)
        {
            CurrentSkillFXValue = 0.001;
            SPParams.Template = InfectionDefinition.SkillFXTemplate;
            WPC.ShowScreenParticle(SPParams);
        }        
    }
    else
    {
        // End:0x18B
        if(UnknownLocal_1 != -1)
        {
            WPC.HideScreenParticle(InfectionDefinition.SkillFXTemplate,, false);
        }
    }
    //return;    
}

function UpdateSkillFXValue(float DeltaTime)
{
    // End:0xA0
    if((CurrentSkillFXValue > 0) && CurrentSkillFXValue < 1)
    {
        CurrentSkillFXValue += (DeltaTime * SkillFXSpeed);
        // End:0x74
        if(CurrentSkillFXValue <= 0)
        {
            CurrentSkillFXValue = 0;
            ShowSkillFX(false);
        }
        // End:0x96
        if(CurrentSkillFXValue > 1)
        {
            CurrentSkillFXValue = 1;
        }
        UpdateSkillFX();
    }
    //return;    
}

function UpdateSkillFX()
{
    local editinline ParticleSystemComponent PSC;

    // End:0xD1
    if(bIsLocalPlayer)
    {
        UnknownLocal_1 = WPC.FindScreenParticleRecordIndexByTemplate(InfectionDefinition.SkillFXTemplate);
        // End:0xD1
        if(UnknownLocal_1 != -1)
        {
            PSC = WPC.ScreenParticleRecords[UnknownLocal_1].Component;
            PSC.SetFloatParameter('CurrentRatio', CurrentSkillFXValue);
        }
    }
    //return;    
}

function ShowParticleSystem(bool bShow, ParticleSystem FXSystemTemplate)
{
    local ScreenParticleInitParams SPParams;
    local editinline ParticleSystemComponent PSC;

    UnknownLocal_1 = WPC.FindScreenParticleRecordIndexByTemplate(FXSystemTemplate);
    // End:0xFF
    if(bShow)
    {
        // End:0x9B
        if(UnknownLocal_1 == -1)
        {
            SPParams.Template = FXSystemTemplate;
            WPC.ShowScreenParticle(SPParams);            
        }
        else
        {
            PSC = WPC.ScreenParticleRecords[UnknownLocal_1].Component;
            PSC.ActivateSystem();
        }        
    }
    else
    {
        // End:0x138
        if(UnknownLocal_1 != -1)
        {
            WPC.HideScreenParticle(FXSystemTemplate,, true);
        }
    }
    //return;    
}

function ShowAmbientFX(bool bShow)
{
    // End:0x11
    if(!bIsLocalPlayer)
    {
        return;
    }
    UnknownLocal_1 = bShow && LargeZones.Length > 0;
    ShowParticleSystem(UnknownLocal_1, InfectionDefinition.LargeAmbientFXTemplate);
    UnknownLocal_3 = bShow && !UnknownLocal_1;
    ShowParticleSystem(UnknownLocal_3, InfectionDefinition.SmallAmbientFXTemplate);
    ToggleInfectionEffects(UnknownLocal_1 || UnknownLocal_3, WPC);
    //return;    
}

function UpdateHeightFog(float DeltaTime)
{
    // End:0x110
    if(HeightFog != none)
    {
        HeightFogValue -= (DeltaTime * (1 / InfectionDefinition.FogRampUpTime));
        // End:0xB3
        if(HeightFogValue < 0)
        {
            HeightFogValue = 0;
            HeightFog.Component.UpdateDensity(0);
            HeightFog = none;            
        }
        else
        {
            HeightFog.Component.UpdateDensity(HeightFogValue * InfectionDefinition.FogDensityValue);
        }
    }
    //return;    
}

function UpdateDisplay(float DeltaTime)
{
    // End:0x1B3
    if(DisplayTimer.bShowing && TemporarilyHiddenTimer <= 0)
    {
        UnknownLocal_1 = 1;
        // End:0x79
        if(bIsImmune)
        {
            UnknownLocal_1 += (1 / InfectionDefinition.DisplaySpeed);
        }
        // End:0x1B0
        if(DisplayTimer.Value < UnknownLocal_1)
        {
            DisplayTimer.Value += (DeltaTime * DisplayTimer.Speed);
            TimerMovie.SingleArgInvokeF("gotoAndStop", FMax(DisplayTimer.Value * 20, 1));
            // End:0x1B0
            if(bIsImmune && DisplayTimer.Value >= UnknownLocal_1)
            {
                DisplayTimer.Value = 1;
                DisplayTimer.bShowing = false;
            }
        }        
    }
    else
    {
        // End:0x348
        if(DisplayTimer.Value > 0)
        {
            DisplayTimer.Value -= (DeltaTime * DisplayTimer.Speed);
            // End:0x2F9
            if(DisplayTimer.Value < 0)
            {
                DisplayTimer.Value = 0;
                // End:0x2F6
                if(TimerMovie != none)
                {
                    // End:0x2C5
                    if(!DisplayTimer.bShowing)
                    {
                        TimerMovie.Close();
                        TimerMovie = none;                        
                    }
                    else
                    {
                        TimerMovie.SingleArgInvokeF("gotoAndStop", 0);
                    }
                }                
            }
            else
            {
                TimerMovie.SingleArgInvokeF("gotoAndStop", DisplayTimer.Value * 20);
            }
        }
    }
    //return;    
}

function StateTick(float DeltaTime)
{
    //return;    
}

function Tick(float DeltaTime)
{
    UpdateSkillFXValue(DeltaTime);
    // End:0x46
    if(bIsLocalPlayer)
    {
        UpdateHeightFog(DeltaTime);
        UpdateDisplay(DeltaTime);
    }
    UpdateZone();
    StateTick(DeltaTime);
    // End:0x8A
    if(TemporarilyHiddenTimer > 0)
    {
        TemporarilyHiddenTimer -= DeltaTime;
    }
    //return;    
}

function UpdateZone()
{
    // End:0x2B
    if(int(WPC.Role) < int(ROLE_Authority))
    {
        return;
    }
    // End:0x89
    if((SmallZones.Length + LargeZones.Length) > 0)
    {
        // End:0x89
        if(CheckZoneCollision())
        {
            // End:0x7E
            if((SmallZones.Length + LargeZones.Length) == 0)
            {
                ExitInfectionVolume(false);                
            }
            else
            {
                ShowAmbientFX(true);
            }
        }
    }
    //return;    
}

function NotifyPawnDied()
{
    ExitInfectionVolume(true);
    //return;    
}

function DoInfectionDamage()
{
    UnknownLocal_1 = GetDamagePipeline();
    WPC.TakeDamage(GetStatusEffectDamage(), WPC, Location, vect(0, 0, 1), InfectionDefinition.DamageType,, IDamageCauser(self), UnknownLocal_1);
    ReleaseDamagePipeline(UnknownLocal_1);
    //return;    
}

state Infected
{
    function BeginState(name PreviousStateName)
    {
        // End:0x28
        if(CurrentInfection <= 0)
        {
            ActivateSkill();
            ShowInfectionFX(true);
        }
        ShowAmbientFX(true);
        ShowSkillFX(true);
        DamageTimer = InfectionDefinition.DamageFrequency;
        //return;        
    }

    function UpdateHeightFog(float DeltaTime)
    {
        // End:0xDC
        if(HeightFog != none)
        {
            // End:0xDC
            if(HeightFogValue < 1)
            {
                HeightFogValue += (DeltaTime * (1 / InfectionDefinition.FogRampUpTime));
                // End:0x7F
                if(HeightFogValue > 1)
                {
                    HeightFogValue = 1;
                }
                HeightFog.Component.UpdateDensity(HeightFogValue * InfectionDefinition.FogDensityValue);
            }
        }
        //return;        
    }

    function StateTick(float DeltaTime)
    {
        // End:0xFF
        if(!bIsImmune)
        {
            CurrentInfection += (InfectionRate * DeltaTime);
            UpdateInfectionFX(CurrentInfection);
            // End:0xFF
            if(CurrentInfection >= 1)
            {
                CurrentInfection = 1;
                DamageTimer += DeltaTime;
                // End:0xFF
                if(DamageTimer > InfectionDefinition.DamageFrequency)
                {
                    DamageTimer -= InfectionDefinition.DamageFrequency;
                    // End:0xFF
                    if(int(WPC.Role) == int(ROLE_Authority))
                    {
                        DoInfectionDamage();
                    }
                }
            }
        }
        //return;        
    }

    function NotifyPawnDied()
    {
        ExitInfectionVolume(true);
        //return;        
    }

    function EndState(name NextStateName)
    {
        ShowAmbientFX(false);
        SkillFXSpeed = -1 / InfectionDefinition.SkillFXOutTime;
        CurrentSkillFXValue = 0.999;
        //return;        
    }
    stop;    
}

state Healing
{
    function StateTick(float DeltaTime)
    {
        CurrentInfection -= (InfectionRate * DeltaTime);
        UpdateInfectionFX(CurrentInfection);
        // End:0x4F
        if(CurrentInfection <= 0)
        {
            StopInfected();
        }
        //return;        
    }

    function NotifyPawnDied()
    {
        StopInfected();
        CurrentInfection = 0;
        //return;        
    }

    function EndState(name NextStateName)
    {
        ShowAmbientFX(false);
        SkillFXSpeed = -1 / InfectionDefinition.SkillFXOutTime;
        //return;        
    }
    stop;    
}

state NotInfected
{
    function BeginState(name PreviousStateName)
    {
        ShowInfectionFX(false);
        DeactivateSkill();
        CurrentInfection = 0;
        //return;        
    }
    stop;    
}

defaultproperties
{
    CollisionType=ECollisionType.COLLIDE_CustomDefault
    bHidden=true
}