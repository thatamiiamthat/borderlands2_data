function bool AddZone(bool bLargeZone, Actor Zone)
{
    // End:0x26
    if(bLargeZone)
    {
        LargeZones.AddItem(Zone;        
    }
    else
    {
        SmallZones.AddItem(Zone;
    }
    return (SmallZones.Length + LargeZones.Length) == 1;
    //return ReturnValue;    
}

