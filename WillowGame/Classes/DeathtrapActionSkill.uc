function WillowPawn GetAutoAimPawn()
{
    local ITargetable AutoAimTarget;

    // End:0x11
    if(MyWillowPC == none)
    {
        return none;
    }
    // End:0x37
    if(MyWillowPC.AutoAimStrategy == none)
    {
        return none;
    }
    AutoAimTarget = MyWillowPC.AutoAimStrategy.GetPreferredTarget(MyWillowPC,, true);
    // End:0xA3
    if(EqualEqual_InterfaceInterface(AutoAimTarget, ITargetable(none)))
    {
        return none;
    }
    return WillowPawn(AutoAimTarget.GetTargetableActor());
    //return ReturnValue;    
}

