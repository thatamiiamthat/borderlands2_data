function TryToShareShields(WillowPawn TheWillowPawn, Controller TheController)
{
    // End:0x6C
    if(int(WorldInfo.NetMode) != int(NM_Client))
    {
        UnknownLocal_1 = WillowGameInfo(WorldInfo.Game).GetSkillManager();
    }
    // End:0xCF
    if((((UnknownLocal_1 == none) || TheController == none) || ShareShieldsSkill == none) || !UnknownLocal_1.IsSkillActive(TheController, ShareShieldsSkill))
    {
        return;
    }
    // End:0xE0
    if(DeathTrap == none)
    {
        return;
    }
    UnknownLocal_3 = WillowShield(TheWillowPawn.EquippedItems[0]);
    // End:0x11C
    if(UnknownLocal_3 == none)
    {
        return;
    }
    UnknownLocal_5 = UnknownLocal_3.CreateClone();
    // End:0x14A
    if(UnknownLocal_5 == none)
    {
        return;
    }
    UnknownLocal_5.bDropOnDeath = false;
    UnknownLocal_5.GiveTo(DeathTrap, true);
    //return;    
}

function bool IsValidMedicBeamTarget(WillowPawn TheTargetPawn)
{
    // End:0x11
    if(TheTargetPawn == none)
    {
        return false;
    }
    // End:0x40
    if(!MyWillowPawn.IsFriendly(TheTargetPawn))
    {
        return false;
    }
    // End:0x64
    if(TheTargetPawn.IsDead())
    {
        return false;
    }
    return true;
    //return ReturnValue;    
}

function bool IsValidCurrentMedicBeamTarget(WillowPawn TheTargetPawn)
{
    // End:0x11
    if(TheTargetPawn == none)
    {
        return false;
    }
    UnknownLocal_1 = VSize(TheTargetPawn.Location - MyWillowPawn.Location);
    // End:0x6C
    if(UnknownLocal_1 > MedicBeamMaxDistance)
    {
        return false;
    }
    UnknownLocal_3 = class'GearboxGlobals'.static.GetGearboxGlobals().GetExposureUtility();
    // End:0xB6
    if(!UnknownLocal_3 != none)
    {
        return false;
    }
    UnknownLocal_5 = UnknownLocal_3.CalculateTargetExposure(MyWillowPawn, TheTargetPawn);
    // End:0xFA
    if(UnknownLocal_5 == 0)
    {
        return false;
    }
    return true;
    //return ReturnValue;    
}

function TryToActivateMedicBeam(WillowPawn TheTargetPawn)
{
    // End:0x16
    if(int(MedicBeamState) == int(1))
    {
        return;
    }
    // End:0x82
    if(int(WorldInfo.NetMode) != int(NM_Client))
    {
        UnknownLocal_1 = WillowGameInfo(WorldInfo.Game).GetSkillManager();
    }
    // End:0xD4
    if(((UnknownLocal_1 == none) || MedicBeamSkill == none) || !UnknownLocal_1.IsSkillActive(MyController, MedicBeamSkill))
    {
        return;
    }
    // End:0xEE
    if(!IsValidMedicBeamTarget(TheTargetPawn))
    {
        return;
    }
    // End:0x108
    if(!IsValidCurrentMedicBeamTarget(TheTargetPawn))
    {
        return;
    }
    MedicBeamTarget = TheTargetPawn;
    ActivateMedicBeam();
    //return;    
}

function ActivateMedicBeam()
{
    local BeamDamageData DamageData;
    local BeamLocationData SourceData, TargetData;

    // End:0x13
    if(!MedicBeamTarget != none)
    {
        return;
    }
    // End:0x2B
    if(!int(MedicBeamState) != int(1))
    {
        return;
    }
    MedicBeamState = 1;
    DamageData.Source = none;
    DamageData.Amount = 0;
    DamageData.Radius = 0;
    DamageData.Momentum = 0;
    DamageData.TypeDefinition = none;
    SourceData.Socket = MedicBeamSourceSocket;
    SourceData.Offset = vect(0, 0, 0);
    SourceData.Actor = MyWillowPawn;
    SourceData.WorldBody = MyWillowPawn.QueryInterface(class'IWorldBody');
    TargetData.Socket = MedicBeamTargetSocket;
    TargetData.Offset = vect(0, 0, 0);
    TargetData.Actor = MedicBeamTarget;
    TargetData.WorldBody = MedicBeamTarget.QueryInterface(class'IWorldBody');
    MyWillowPawn.GetLightProjMgrFor(none).AddBeam(MedicBeamFiringMode, DamageData, none, SourceData, true, TargetData);
    MedicBeamTarget.QueryInterface(class'ISkillBehavior').Behavior_ActivateSkill(MedicBeamTargetSkill);
    //return;    
}

function BlockMedicBeam()
{
    // End:0x13
    if(!MedicBeamTarget != none)
    {
        return;
    }
    // End:0x2B
    if(!int(MedicBeamState) == int(1))
    {
        return;
    }
    MyWillowPawn.GetLightProjMgrFor(none).DeleteBeamsFor(MedicBeamTarget);
    MedicBeamTarget.QueryInterface(class'ISkillBehavior').Behavior_DeactivateSkill(MedicBeamTargetSkill);
    MedicBeamState = 2;
    //return;    
}

function DeactivateMedicBeam()
{
    // End:0x16
    if(int(MedicBeamState) == int(0))
    {
        return;
    }
    // End:0xB8
    if(MedicBeamTarget != none)
    {
        MedicBeamTarget.QueryInterface(class'ISkillBehavior').Behavior_DeactivateSkill(MedicBeamTargetSkill);
        MyWillowPawn.GetLightProjMgrFor(none).DeleteBeamsFor(MedicBeamTarget);
        MedicBeamTarget = none;
    }
    MedicBeamState = 0;
    //return;    
}

