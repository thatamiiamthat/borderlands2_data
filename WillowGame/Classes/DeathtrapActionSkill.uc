simulated event OnActionSkillTick(float DeltaTime)
{
    super.OnActionSkillTick(DeltaTime);
    // End:0xB0
    if(((int(Role) == int(ROLE_Authority)) && DeathTrap != none) && DeathTrap.IsDead())
    {
        MyWillowPC.ServerDeactivateSkill(MyWillowPC.PlayerSkillTree.GetActionSkill());
    }
    // End:0x10E
    if(int(MedicBeamState) == int(1))
    {
        // End:0xE9
        if(!IsValidMedicBeamTarget(MedicBeamTarget))
        {
            DeactivateMedicBeam();            
        }
        else
        {
            // End:0x10B
            if(!IsValidCurrentMedicBeamTarget(MedicBeamTarget))
            {
                BlockMedicBeam();
            }
        }        
    }
    else
    {
        // End:0x181
        if(int(MedicBeamState) == int(2))
        {
            // End:0x147
            if(!IsValidMedicBeamTarget(MedicBeamTarget))
            {
                DeactivateMedicBeam();                
            }
            else
            {
                // End:0x181
                if(((GetAutoAimPawn()) == MedicBeamTarget) && IsValidCurrentMedicBeamTarget(MedicBeamTarget))
                {
                    ActivateMedicBeam();
                }
            }
        }
    }
    //return;    
}

