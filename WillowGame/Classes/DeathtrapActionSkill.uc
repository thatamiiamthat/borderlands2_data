    {
        UnknownLocal_1 = DeathTrap.MyWillowMind.AIComponent.AddTarget(TheTargetPawn);
        UnknownLocal_1.BonusPriority += float(10);
        DeathTrap.MyWillowMind.AIComponent.NotifyAttackedBy(TheTargetPawn);
    }
    //return;    
}

