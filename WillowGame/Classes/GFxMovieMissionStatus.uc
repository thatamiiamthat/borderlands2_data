class GFxMovieMissionStatus extends WillowGFxMovie
    config(Game)
    hidecategories(Mobile);

var transient bool bHasEligibleMissions;
var transient bool bHasCompleteMissions;

event bool Start(optional bool StartPaused = false)
{
    local IMissionDirector MissionDirector;

    MissionDirector
    GetInstanceContextObject().QueryInterface(class'IMissionDirector');
    // End:0x72
    if(NotEqual_InterfaceInterface(MissionDirector, IMissionDirector(none)))
    {
        UnknownLocal_1 = super.Start(StartPaused);
    }
    // End:0x84
    if(UnknownLocal_1)
    {
        CheckMissionState();
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

function OnTick()
{
    super(GearboxGFxMovie).OnTick();
    CheckMissionState();
    //return;    
}

function CheckMissionState()
{
    local IMissionDirector MissionDirector;
    local array<MissionDefinition> EligibleMissions, CompletedMissions;

    MissionDirector = GetInstanceContextObject().QueryInterface(class'IMissionDirector');
    MissionDirector.GetEligibleMissions(EligibleMissions);
    MissionDirector.GetRedeemableMissions(CompletedMissions);
    bHasEligibleMissions = EligibleMissions.Length > 0;
    bHasCompleteMissions = CompletedMissions.Length > 0;
    // End:0xEC
    if(bHasCompleteMissions)
    {
        MovieState_Enable('Green');
        TickRateSeconds = default.TickRateSeconds;        
    }
    else
    {
        // End:0x123
        if(bHasEligibleMissions)
        {
            MovieState_Enable('Blue');
            TickRateSeconds = default.TickRateSeconds;            
        }
        else
        {
            MovieState_Enable('Red');
            TickRateSeconds = 5 * default.TickRateSeconds;
        }
    }
    //return;    
}

event OnClose()
{
    super.OnClose();
    //return;    
}

defaultproperties
{
    TickRateSeconds=1
    bTickScript=true
    bSupportsStatePooling=true
    bAllowInput=false
    bAllowFocus=false
}