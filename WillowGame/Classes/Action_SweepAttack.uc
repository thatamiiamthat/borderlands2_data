class Action_SweepAttack extends WillowActionSequencePawn
    editinlinenew
    hidecategories(Mobile,Object,HideMe,ActionSequence,LoadBalance,Movement);

enum ESweepDirection
{
    Sweep_Left,
    Sweep_Right,
    Sweep_Random,
    Sweep_MAX
};

var(Sweep) const bool bShootTarget;
var(Sweep) const float Angle;
var(Sweep) const float Height;
var(Sweep) const float Radius;
var(Sweep) const Action_SweepAttack.ESweepDirection Direction;
var transient Action_SweepAttack.ESweepDirection SweepDirection;
var(Sweep) const float MaxIntervalAngle;
var transient Vector NextLoc;
var transient float AngleTraveled;

event name CanRun()
{
    local name SuperVal;

    SuperVal = super(ActionSequence).CanRun();
    // End:0x35
    if(SuperVal != 'None')
    {
        return SuperVal;
    }
    // End:0x4E
    if(Target == none)
    {
        return 'NoTarget';
    }
    // End:0x67
    if(!IsFlying())
    {
        return 'NotFlying';
    }
    return 'None';
    //return ReturnValue;    
}

event Start()
{
    super.Start();
    InvalidatePath();
    AngleTraveled = 0;
    GotoState('Sweep');
    SetPawnMovementSpeed(1);
    MyWillowMind.bWantsToFireWeapon = bShootTarget;
    // End:0x9A
    if(int(Direction) == int(2))
    {
        SweepDirection = ((FRand() > 0.5) ? 0 : 1);        
    }
    else
    {
        SweepDirection = Direction;
    }
    //return;    
}

event Stop()
{
    super.Stop();
    MyWillowMind.bWantsToFireWeapon = false;
    //return;    
}

function CalcNextLoc()
{
    local Vector ToMyPawn;
    local Rotator CurrentRot;

    ToMyPawn = MyWillowPawn.Location - Target.Location;
    ToMyPawn.Z = 0;
    CurrentRot = Rotator(ToMyPawn);
    UnknownLocal_1 = float(Min(int(MaxIntervalAngle), int(Angle - AngleTraveled)));
    UnknownLocal_3 = int(182.0444 * UnknownLocal_1);
    UnknownLocal_3 *= float(((int(SweepDirection) == int(0)) ? 1 : -1));
    CurrentRot.Yaw += UnknownLocal_3;
    NextLoc = Target.Location + (Radius * Vector(CurrentRot));
    NextLoc.Z = Target.Location.Z + Height;
    //return;    
}

state Sweep
{
    event bool PathFind()
    {
        // End:0x12
        if(PathIsValid())
        {
            return false;            
        }
        else
        {
            CreateVectorPath(NextLoc);
            return true;
        }
        //return ReturnValue;        
    }
Begin:

    CalcNextLoc();
    WaitForPath();
    FollowPath();
    InvalidatePath();
    AngleTraveled += MaxIntervalAngle;
    // End:0x60
    if(AngleTraveled < Angle)
    {
        goto 'Begin';        
    }
    else
    {
        Finish();
    }
    stop;                    
}

defaultproperties
{
    bShootTarget=true
    Angle=90
    Height=1024
    Radius=1024
    MaxIntervalAngle=30
}