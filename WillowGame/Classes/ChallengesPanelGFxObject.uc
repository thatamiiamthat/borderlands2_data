function bool PanelOnInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    switch(ukey)
    {
        // End:0x1F
        case 'XboxTypes_X':
        // End:0x60
        case 'E':
            // End:0x5E
