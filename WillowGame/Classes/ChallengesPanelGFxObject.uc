        // End:0x6C
        case 'Gamepad_LeftStick_Up':
        // End:0x78
        case 'XboxTypeS_DPad_Up':
        // End:0xBC
        case 'Up':
            // End:0xBA
            if((int(uevent) == int(0)) || int(uevent) == int(2))
            {
                ScrollLog(0);
            }
            return true;
        // End:0xC8
        case 'Gamepad_LeftStick_Down':
        // End:0xD4
        case 'XboxTypeS_DPad_Down':
        // End:0x118
        case 'Down':
            // End:0x116
            if((int(uevent) == int(0)) || int(uevent) == int(2))
            {
                ScrollLog(1);
            }
            return true;
        // End:0x146
        case 'MouseScrollUp':
            // End:0x144
            if(int(uevent) == int(1))
            {
                ScrollLog(0);
            }
            return true;
        // End:0x174
        case 'MouseScrollDown':
            // End:0x172
            if(int(uevent) == int(1))
            {
                ScrollLog(1);
            }
            return true;
        // End:0x180
        case 'PageUp':
        // End:0x1C4
        case 'XboxTypeS_LeftTrigger':
            // End:0x1C2
            if((int(uevent) == int(1)) || int(uevent) == int(2))
            {
                ScrollLog(6);
            }
            return true;
        // End:0x1D0
        case 'PageDown':
        // End:0x214
        case 'XboxTypeS_RightTrigger':
            // End:0x212
            if((int(uevent) == int(1)) || int(uevent) == int(2))
            {
                ScrollLog(7);
            }
            return true;
        // End:0x242
        case 'Home':
            // End:0x240
            if(int(uevent) == int(1))
            {
                ScrollLog(4);
            }
            return true;
        // End:0x270
        case 'End':
            // End:0x26E
            if(int(uevent) == int(1))
            {
                ScrollLog(5);
            }
            return true;
        // End:0x27C
        case 'XboxTypeS_Y':
        // End:0x2A9
        case 'Q':
            // End:0x2A6
            if(int(uevent) == int(1))
            {
                ChangeSort();
            }
            // End:0x321
            break;
        // End:0x2B5
        case 'XboxTypeS_A':
        // End:0x31E
        case 'Enter':
            // End:0x31C
            if(int(uevent) == int(1))
            {
                ParentPanel.ParentMovie.PlayUISound('Confirm');
                TrackHighlightedObject();
            }
            return true;
        // End:0xFFFF
        default:
            break;
    }
    return false;
    //return ReturnValue;    
}

