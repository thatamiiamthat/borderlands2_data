function OnClikEvent(EventData Data)
{
    local IWillowScrollingListDataProvider DataProvider, Submenu;

    super.OnClikEvent(Data);
    DataProvider = GetCurrentDataProvider();
    // End:0x2AA
    if(NotEqual_InterfaceInterface(DataProvider, IWillowScrollingListDataProvider(none)))
    {
        UnknownLocal_1 = IndexToEventId[Data.Index];
        // End:0x174
        if(Data.Type == "itemClick")
        {
            // End:0xBB
            if(UnknownLocal_1 == -1)
            {
                HandlePopList();                
            }
            else
            {
                // End:0x171
                if(!DataProvider.HandleClick(UnknownLocal_1, self))
                {
                    Submenu = DataProvider.GetSubmenuForEvent(UnknownLocal_1, self);
                    // End:0x171
                    if(NotEqual_InterfaceInterface(Submenu, IWillowScrollingListDataProvider(none)))
                    {
                        MyOwnerMovie.PlayUISound('MenuOpen');
                        PushDataProvider(Submenu);
                    }
                }
            }            
        }
        else
        {
            // End:0x255
            if(Data.Type == "change")
            {
                PlaySound_VerticalMovement();
                DataProviderStack[DataProviderStack.Length - 1].SelectedIndex = Data.Index;
                DataProvider.HandleSelectionChange(UnknownLocal_1, self);
                // End:0x252
                if(__OnSelectedIndexChanged__Delegate != none)
                {
                    OnSelectedIndexChanged(Data.Index);
                }                
            }
            else
            {
                // End:0x2AA
                if(Data.Type == "itemRollOver")
                {
                    DataProvider.HandleSelectionRollover(UnknownLocal_1, self);
                }
            }
        }
    }
    //return;    
}

function OnSliderValueChange(int EntryIndex, int NewValue)
{
    local IWillowScrollingListDataProvider DataProvider;

    DataProvider = GetCurrentDataProvider();
    // End:0x99
    if(NotEqual_InterfaceInterface(DataProvider, IWillowScrollingListDataProvider(none)))
    {
        MyOwnerMovie.PlayUISound('HorizontalMovement');
        DataProvider.HandleSliderChange(IndexToEventId[EntryIndex], NewValue, self);
    }
    //return;    
}

function OnSpinnerValueChange(int EntryIndex, int NewChoiceIndex, string NewChoiceValue)
{
    local IWillowScrollingListDataProvider DataProvider;

    DataProvider = GetCurrentDataProvider();
    // End:0xA2
    if(NotEqual_InterfaceInterface(DataProvider, IWillowScrollingListDataProvider(none)))
    {
        MyOwnerMovie.PlayUISound('HorizontalMovement');
        DataProvider.HandleSpinnerChange(IndexToEventId[EntryIndex], NewChoiceIndex, NewChoiceValue, self);
    }
    //return;    
}

function PlaySound_VerticalMovement()
{
    // End:0x37
    if(!bSuppressMovementSound)
    {
        MyOwnerMovie.PlayUISound('VerticalMovement');
    }
    //return;    
}

