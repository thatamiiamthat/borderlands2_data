function Init(WillowGFxMovie OwnerMovie, IWillowScrollingListDataProvider DefaultDataProvider)
{
    MyOwnerMovie = OwnerMovie;
    bSuppressMovementSound = false;
    AddClikEvent("itemClick");
    AddClikEvent("change");
    AddClikEvent("itemRollOver");
    SetFunction("onSliderValueChange", self, 'OnSliderValueChange');
    SetFunction("onSpinnerValueChange", self, 'OnSpinnerValueChange');
    SetString("wrapping", "stick");
    PushDataProvider(DefaultDataProvider);
    //return;    
}

function Cleanup()
{
    local DataProviderInfo StackEntry;

    // End:0x4C
    foreach DataProviderStack(StackEntry,)
    {
        StackEntry.DataProvider.Cleanup(self);        
    }    
    //return;    
}

function IWillowScrollingListDataProvider GetCurrentDataProvider()
{
    local IWillowScrollingListDataProvider DataProvider;

    DataProvider = none;
    // End:0x4F
    if(DataProviderStack.Length > 0)
    {
        DataProvider = DataProviderStack[DataProviderStack.Length - 1].DataProvider;
    }
    // End:0x73
    if(!NotEqual_InterfaceInterface(DataProvider, IWillowScrollingListDataProvider(none)))
    {
        return none;
    }
    return DataProvider;
    //return ReturnValue;    
}

function PushDataProvider(IWillowScrollingListDataProvider DataProvider)
{
    local DataProviderInfo NewDataProviderInfo;

    // End:0xD6
    if(NotEqual_InterfaceInterface(DataProvider, IWillowScrollingListDataProvider(none)))
    {
        bSuppressMovementSound = true;
        NewDataProviderInfo.DataProvider = DataProvider;
        NewDataProviderInfo.SelectedIndex = 0;
        DataProvider.OnPush(self);
        DataProviderStack.AddItem(NewDataProviderInfo;
        Refresh();
        // End:0xCA
        if(!bDontFocusFirstAvailableListItem)
        {
            FocusFirstAvailableListItem();
        }
        bSuppressMovementSound = false;
    }
    //return;    
}

function Refresh()
{
    local IWillowScrollingListDataProvider DataProvider;

    ClearListItems();
    DataProvider = GetCurrentDataProvider();
    // End:0x5F
    if(NotEqual_InterfaceInterface(DataProvider, IWillowScrollingListDataProvider(none)))
    {
        DataProvider.Populate(self);
    }
    // End:0xB3
    if(int(class'GearboxGlobals'.static.GetPlatform()) == int(0))
    {
        // End:0xB3
        if(DataProviderStack.Length > 1)
        {
            AddListItem(-1, BackCaption, false, false);
        }
    }
    CommitListItems();
    // End:0xDF
    if(__OnListChanged__Delegate != none)
    {
        OnListChanged();
    }
    //return;    
}

function bool HandlePopList()
{
    // End:0xCB
    if(DataProviderStack.Length > 1)
    {
        MyOwnerMovie.PlayUISound('MenuBack');
        bSuppressMovementSound = true;
        GetCurrentDataProvider().OnPop(self);
        DataProviderStack.Remove(DataProviderStack.Length - 1, 1;
        Refresh();
        SetSelectedIndex(DataProviderStack[DataProviderStack.Length - 1].SelectedIndex);
        bSuppressMovementSound = false;
        return true;
    }
    return false;
    //return ReturnValue;    
}

