event UpdateFrameForAspectRatio(bool bWidescreen)
{
    CachedWidescreen = bWidescreen;
    // End:0x4E
    if(CachedWidescreen)
    {
        SingleArgInvokeS("itemInspect.gotoAndStop", "16x9");        
    }
    else
    {
        SingleArgInvokeS("itemInspect.gotoAndStop", "4x3");
    }
    Advance(0);
    ItemCard = ItemCardGFxObject(GetVariableObject("itemInspect.itemCard", class'ItemCardGFxObject'));
    ItemCard.Init();
    SingleArgInvokeF("itemInspect.itemCard.ConfigureForPlayer", float(((WPCOwner.IsPrimaryPlayer()) ? 0 : 1)));
    SingleArgInvokeB("itemInspect.itemCard.SetBottomGlowVisible", false);
    //return;    
}

