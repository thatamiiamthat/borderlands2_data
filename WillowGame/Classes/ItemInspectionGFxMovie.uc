function InspectItem(WillowInventory Thing, optional int OverrideValue = -1, optional Engine.WillowInventoryDefinition.ECurrencyType CurrencyType = 0)
{
    local string ControllerPrefix;

    WPCOwner.bViewingThirdPersonMenu && !WillowPlayerPawn(WPCOwner.Pawn).bLastMenuMeshHidden;
    WillowPlayerPawn(WPCOwner.Pawn).SetMenuMeshVisibility(true, true);
    StartFOV = WPCOwner.GetFOVAngle();
    MyInspectionMesh = Thing.ClonePrimaryMeshForUI();
    MyInspectionMesh.SetLightEnvironment(WPCOwner.Pawn.Mesh.LightEnvironment);
    MyInspectionMesh.SetOnlyOwnerSee(true);
    MyInspectionMesh.SetDepthPriorityGroup(2);
    MyInspectionMesh.SetAbsolute(true, true, true);
    MyInspectionMesh.SetRotation(rot(0, 0, 0));
    MyInspectionMesh.SetScale3D(vect(1, 1, 1));
    // End:0x26A
    if(SkeletalMeshComponent(MyInspectionMesh) != none)
    {
        SkeletalMeshComponent(MyInspectionMesh).bIgnoredByFXCoordinator = true;
    }
    // End:0x2AC
    if(StaticMeshComponent(MyInspectionMesh) != none)
    {
        StaticMeshComponent(MyInspectionMesh).bIgnoredByFXCoordinator = true;
    }
    WPCOwner.Pawn.AttachComponent(MyInspectionMesh);
    InvDef = Thing.GetInventoryDefinition();
    MeshRotation = InvDef.UIMeshRotation;
    MeshRotationQuat = QuatFromRotator(MeshRotation);
    MeshRotationPitchQuat = QuatFromRotator(rot(0, 0, 0));
    MeshRotationYawQuat = QuatFromRotator(rot(0, 0, 0));
    // End:0x3CA
    if(WPCOwner.IsPrimaryPlayer())
    {
        ControllerPrefix = "";        
    }
    else
    {
        ControllerPrefix = "p2_";
    }
    CardContents.Tex = GetRecommendedThumbnail(3, 2, Class.Name);
    SetExternalTexture(ControllerPrefix $ "weaptex23", CardContents.Tex);
    CardContents.Inv = Thing;
    CardContents.Mesh = Thing.ClonePrimaryMeshForUI();
    UnknownLocal_1 = class'GearboxGlobals'.static.GetGearboxGlobals().GetRenderTextureManager();
    UnknownLocal_1.SetThumbnailMesh(CardContents.Tex, CardContents.Mesh);
    ItemCard.SetItemCardEx(WPCOwner, IItemCardable(Thing), none, CurrencyType, OverrideValue);
    SingleArgInvokeF("itemInspect.itemCard.ConfigureForPlayer", float(((WPCOwner.IsPrimaryPlayer()) ? 0 : 1)));
    SingleArgInvokeB("itemInspect.itemCard.SetBottomGlowVisible", false);
    OnTick();
    SerialNumberString = Thing.GetSerialNumberString();
    DemoPerkCode = "";
    //return;    
}

event OnClose()
{
    PlayUISound('ItemInspect_End');
    WPCOwner.Pawn.DetachComponent(MyInspectionMesh);
    MyInspectionMesh = none;
    // End:0x100
    if(WPCOwner.bViewingThirdPersonMenu && !WillowPlayerPawn(WPCOwner.Pawn).bLastMenuMeshHidden)
    {
        WillowPlayerPawn(WPCOwner.Pawn).SetMenuMeshVisibility(true, false);
    }
    // End:0x1A2
    if(CardContents.Tex != none)
    {
        FreeGFxThumbnail(CardContents.Tex);
        CardContents.Tex = none;
        CardContents.Mesh = none;
        CardContents.Inv = none;
    }
    super(WillowGFxMovie).OnClose();
    MyInspDef = none;
    bCtrl = false;
    bLBDown = false;
    bRBDown = false;
    bXDown = false;
    bRequestInFlight = false;
    SerialNumberString = "";
    DemoPerkCode = "";
    //return;    
}

