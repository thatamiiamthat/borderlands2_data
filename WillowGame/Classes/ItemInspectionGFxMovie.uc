event UpdateTooltips()
{
    local string Tips, PanString, RotateString, ZoomString, ScreenshotString;

    // End:0x11
    if(ScreenShotCounter > 0)
    {
        return;
    }
    UnknownLocal_1 = OffsetBounds > 0.0001;
    // End:0xD9
    if((int(class'GearboxGlobals'.static.GetPlatform()) != int(0)) || WPCOwner.PlayerInput.bUsingGamepad)
    {
        PanString = TooltipsText_Pan_Controller;
        RotateString = TooltipsText_Rotate_Controller;
        ZoomString = TooltipsText_Zoom_Controller;
        ScreenshotString = TooltipsText_Screenshot_Controller;        
    }
    else
    {
        PanString = TooltipsText_Pan_Mouse;
        RotateString = TooltipsText_Rotate_Mouse;
        ZoomString = TooltipsText_Zoom_Mouse;
        ScreenshotString = TooltipsText_Screenshot_Keyboard;
    }
    // End:0x167
    if(!UnknownLocal_1)
    {
        PanString = ("<font color='#666666'>" $ PanString) $ "</font>";
    }
    // End:0x1F3
    if(int(class'GearboxGlobals'.static.GetPlatform()) == int(0))
    {
        Tips = (((((((RotateString $ "    ") $ PanString) $ "    ") $ ZoomString) $ "    ") $ ScreenshotString) $ "    ") $ TooltipsText_Close;        
    }
    else
    {
        Tips = (((((RotateString $ "    ") $ PanString) $ "    ") $ ZoomString) $ "    ") $ TooltipsText_Close;
    }
    SetVariableBool("itemInspect.tooltips._visible", true);
    SetVariableString("itemInspect.tooltips.tooltips.htmlText", ResolveDataStoreMarkup(Tips));
    SetVariableNumber("itemInspect.tooltips.bkgd._width", GetVariableNumber("itemInspect.tooltips.tooltips.textWidth") * 1.15);
    //return;    
}

function TrySaveDemoPerk()
{
    // End:0x35
    if((bLBDown && bRBDown) && bXDown)
    {
        SaveDemoPerk();
    }
    //return;    
}

function SaveDemoPerk()
{
    local SparkInterface Spark;
    local string JsonString, URL;
    local HttpParameters HttpParameters;

    // End:0x0F
    if(bRequestInFlight)
    {
        return;
    }
    UnknownLocal_1 = false;
    // End:0x3E
    if(Len(DemoPerkCode) > 0)
    {
        ShowDemoPerkCreatedDialog(true, DemoPerkCode);        
    }
    else
    {
        Spark = class'GearboxEngine'.static.GetSparkInterface();
        UnknownLocal_3 = Spark.GetGearboxAccountData(WPCOwner.GetMyControllerId());
        // End:0x328
        if((UnknownLocal_3 != none) && UnknownLocal_3.RequestId != "")
        {
            UnknownLocal_5 = UnknownLocal_3.GetService('DemoPerk');
            // End:0x31E
            if(UnknownLocal_5 != none)
            {
                UnknownLocal_7 = new class'JsonObject';
                UnknownLocal_7.SetStringValue("serialnumber", SerialNumberString);
                UnknownLocal_7.SetStringValue("request_id", UnknownLocal_3.RequestId);
                UnknownLocal_7.SetStringValue("language", Locs(GetLanguage()));
                JsonString = UnknownLocal_7.EncodeJson(UnknownLocal_7);
                URL = UnknownLocal_5.GetParameter("EndpointUrl") $ "/v1/demoperk";
                HttpParameters.ServiceConfiguration = UnknownLocal_5;
                HttpParameters.Method = 0;
                HttpParameters.ContentType = 2;
                HttpParameters.AcceptsType = 2;
                UnknownLocal_9 = Spark.IssueSparkStringRequest(HttpParameters, URL, JsonString, HandleCreateDemoPerkResponse);
                // End:0x31B
                if(UnknownLocal_9 != 0)
                {
                    bRequestInFlight = true;
                }                
            }
            else
            {
                UnknownLocal_1 = true;
            }            
        }
        else
        {
            UnknownLocal_1 = true;
        }
        // End:0x357
        if(!bRequestInFlight && !UnknownLocal_1)
        {
            ShowDemoPerkCreatedDialog(false, "");
        }
    }
    bCtrl = false;
    bLBDown = false;
    bRBDown = false;
    bXDown = false;
    //return;    
}

function HandleCreateDemoPerkResponse(const out SparkResult Result)
{
    local ArchwayResult Archway;

    bRequestInFlight = false;
    // End:0xC6
    if((class'GearboxAccountData'.static.ExtractArchwayResultJson(Result.ResponseBody, Archway) && Archway.Success) && Archway.Messages.Length > 0)
    {
        ShowDemoPerkCreatedDialog(true, Archway.Messages[0]);        
    }
    else
    {
        ShowDemoPerkCreatedDialog(false, "");
    }
    //return;    
}

function ShowDemoPerkCreatedDialog(bool Success, string Code)
{
    local string DemoPerkCodeMarkup;

    DemoPerkCode = Code;
    UnknownLocal_1 = WPCOwner.GFxUIManager.ShowDialog();
    UnknownLocal_1.AutoLocEnable("WillowMenu", "dlg");
    UnknownLocal_1.AutoAppendButton('OK');
    UnknownLocal_1.DlgCaptionMarkup = "Thank You For Playing Borderlands 2!";
    DemoPerkCodeMarkup = "<font size='30' color='#00BDF3' letterspacing='6'>CODE</font>";
    // End:0x21C
    if(Success)
    {
        UnknownLocal_1.DlgTextMarkup = "Write this Loot Code on your card. Remember to give it to your Demo Supervisor before you leave.

Collect your loot when Borderlands 2 is released!

Your Loot Code:     " $ Repl(DemoPerkCodeMarkup, "CODE", DemoPerkCode);        
    }
    else
    {
        UnknownLocal_1.DlgTextMarkup = "Your Loot Code could not be created.
Please try again or contact your Demo Supervisor.";
    }
    UnknownLocal_1.ApplyLayout();
    //return;    
}

