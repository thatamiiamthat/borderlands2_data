function extOnSpawnVehicleButtonClick(int ModuleIndex)
{
    UnknownLocal_1 = GetVehicleChoiceModule(ModuleIndex);
    // End:0x229
    if(UnknownLocal_1 != none)
    {
        // End:0x48
        if(!UnknownLocal_1.SelectedVehicleUIDefinition != none)
        {
            return;
        }
        // End:0x229
        if(WPCOwner.ConnectedVSSTerminal != none)
        {
            // End:0xA7
            if(int(UnknownLocal_1.CachedVehicleState) == int(0))
            {
                PlayUISound('VSS_SpawnNew');                
            }
            else
            {
                // End:0xE2
                if(int(UnknownLocal_1.CachedVehicleState) == int(1))
                {
                    PlayUISound('VSS_RespawnDeployed');                    
                }
                else
                {
                    // End:0x11A
                    if(int(UnknownLocal_1.CachedVehicleState) == int(2))
                    {
                        PlayUISound('VSS_SpawnFailed');
                    }
                }
            }
            // End:0x181
            if(int(UnknownLocal_1.CachedVehicleState) == int(1))
            {
                WPCOwner.DespawnVehicleFromConnectedVehicleSpawnStationTerminal(ModuleIndex, UnknownLocal_1.SelectedVehicleUIDefinition);
            }
            // End:0x229
            if((int(UnknownLocal_1.CachedVehicleState) == int(0)) || int(UnknownLocal_1.CachedVehicleState) == int(1))
            {
                WPCOwner.SpawnVehicleFromConnectedVehicleSpawnStationTerminal(ModuleIndex, UnknownLocal_1.SelectedVehicleUIDefinition, UnknownLocal_1.EquippedVehicleCustomizationDefinition);
            }
        }
    }
    //return;    
}

