function extOnSkinCellClick(string EventName, int CellIndex)
{
    UnknownLocal_1 = EventName == "change";
    UnknownLocal_3 = EventName == "rollover";
    UnknownLocal_5 = EventName == "click";
    // End:0x90
    if(UnknownLocal_3 || UnknownLocal_5)
    {
        UpdatePreview(AvailableVehicleSkinDefinitions[CellIndex]);
        // End:0x8D
        if(UnknownLocal_5)
        {
            CommitCustomization();
        }        
    }
    else
    {
        // End:0xAB
        if(UnknownLocal_1)
        {
            PreviewIndex = CellIndex;
        }
    }
    //return;    
}

function CommitCustomization()
{
    UnknownLocal_1 = GetVehicleChoiceModule(SelectedModuleIndex);
    UnknownLocal_1.EquippedVehicleCustomizationDefinition = UnknownLocal_1.PreviewVehicleCustomizationDefinition;
    // End:0xA8
    if(WPCOwner != none)
    {
        WPCOwner.SetVehicleCustomizationForModule(DesiredFamilyDefinition, SelectedModuleIndex, UnknownLocal_1.EquippedVehicleCustomizationDefinition);
    }
    HideSkinInfoCard(SelectedModuleIndex);
    //return;    
}

function CancelCustomization()
{
    UnknownLocal_1 = GetVehicleChoiceModule(SelectedModuleIndex);
    UpdatePreview(UnknownLocal_1.EquippedVehicleCustomizationDefinition);
    //return;    
}

function UpdatePreview(CustomizationDefinition CustomDef)
{
    PlayUISound('SelectVehicle');
    UnknownLocal_1 = GetVehicleChoiceModule(SelectedModuleIndex);
    // End:0x16A
    if(UnknownLocal_1.PreviewVehicleCustomizationDefinition != CustomDef)
    {
        UnknownLocal_1.PreviewVehicleCustomizationDefinition = CustomDef;
        // End:0x8B
        if(!CustomDef != none)
        {
            return;
        }
        // End:0xD6
        if(PreviewActor[SelectedModuleIndex] != none)
        {
            PreviewActor[SelectedModuleIndex].InitiateCustomizationRequest(CustomDef);
        }
        class'WillowGlobals'.static.GetWillowGlobals().GetCustomizationManager().SetCustomizationSeen(CustomDef, WPCOwner, true);
        // End:0x16A
        if(SeenVehicleSkinDefinitions.Find(CustomDef == -1)
        {
            SeenVehicleSkinDefinitions.AddItem(CustomDef;
        }
    }
    //return;    
}

function bool HandleInputAxis(int ControllerId, name ukey, float Delta, float DeltaTime)
{
    // End:0x6B
    if((ukey == 'XboxTypeS_RightY') && DoHorizontalSplitscreenPanning())
    {
        FocusOffset.Y += ((500 * Delta) * DeltaTime);
        ClampFocusOffset();
        return true;
    }
    return false;
    //return ReturnValue;    
}

