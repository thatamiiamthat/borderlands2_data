function bool HandleKeyDefaults(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    switch(ukey)
    {
        // End:0x1F
        case 'XboxTypeS_B':
        // End:0x4B
        case 'Escape':
            // End:0x4B
            if(int(uevent) == int(1))
            {
                CloseOrReturnToFamilySelection();
                return true;
            }
        // End:0xFFFF
        default:
            return false;
            break;
    }
    //return ReturnValue;    
}

function bool VehicleChoiceInfoCardInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0x59
    if((ukey == 'XboxTypeS_B') || ukey == 'Escape')
    {
        // End:0x57
        if(int(uevent) == int(1))
        {
            HideVehicleInfoCard(SelectedModuleIndex);
        }
        return true;
    }
    return SharedInfoCardInputKey(ControllerId, ukey, uevent);
    //return ReturnValue;    
}

function bool SkinChoiceInfoCardInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    switch(ukey)
    {
        // End:0x1F
        case 'XboxTypeS_B':
        // End:0x5E
        case 'Escape':
            // End:0x5C
            if(int(uevent) == int(1))
            {
                CancelCustomization();
                HideSkinInfoCard(SelectedModuleIndex);
            }
            return true;
        // End:0x6A
        case 'Gamepad_LeftStick_Up':
        // End:0x76
        case 'XboxTypeS_DPad_Up':
        // End:0x82
        case 'Up':
        // End:0x8E
        case 'Gamepad_LeftStick_Down':
        // End:0x9A
        case 'XboxTypeS_DPad_Down':
        // End:0xA6
        case 'Down':
        // End:0xB2
        case 'XboxTypeS_LeftTrigger':
        // End:0xBE
        case 'PageUp':
        // End:0xCA
        case 'XboxTypeS_RightTrigger':
        // End:0x10A
        case 'PageDown':
            // End:0x107
            if(int(uevent) == int(1))
            {
                UpdatePreview(AvailableVehicleSkinDefinitions[PreviewIndex]);
            }
            // End:0x10D
            break;
        // End:0xFFFF
        default:
            break;
    }
    return SharedInfoCardInputKey(ControllerId, ukey, uevent);
    //return ReturnValue;    
}

function bool SharedInfoCardInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0x16C
    if((int(uevent) == int(0)) || int(uevent) == int(2))
    {
        switch(ukey)
        {
            // End:0x49
            case 'Gamepad_LeftStick_Right':
            // End:0x55
            case 'XboxTypeS_DPad_Right':
            // End:0x82
            case 'Right':
                VehicleChoiceInfoCard.TryScrollRight();
                return true;
            // End:0x8E
            case 'Gamepad_LeftStick_Left':
            // End:0x9A
            case 'XboxTypeS_DPad_Left':
            // End:0xC7
            case 'Left':
                VehicleChoiceInfoCard.TryScrollLeft();
                return true;
            // End:0xD3
            case 'Gamepad_LeftStick_Up':
            // End:0xDF
            case 'XboxTypeS_DPad_Up':
            // End:0xEB
            case 'Up':
            // End:0x118
            case 'MouseScrollUp':
                VehicleChoiceInfoCard.TryScrollUp();
                return true;
            // End:0x124
            case 'Gamepad_LeftStick_Down':
            // End:0x130
            case 'XboxTypeS_DPad_Down':
            // End:0x13C
            case 'Down':
            // End:0x169
            case 'MouseScrollDown':
                VehicleChoiceInfoCard.TryScrollDown();
                return true;
            // End:0xFFFF
            default:
                break;
            }
    }
    else
    {
        return false;
        //return ReturnValue;        
    }
}

