function extGenericButtonClicked(string ActionName)
{
    local name Action;

    Action = name(ActionName);
    switch(Action)
    {
        // End:0x41
        case 'Close':
            CloseOrReturnToFamilySelection();
            // End:0x44
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

function CloseOrReturnToFamilySelection()
{
    // End:0x22
    if(int(CurrentStage) == int(2))
    {
        Close();        
    }
    else
    {
        // End:0x103
        if(int(CurrentStage) == int(3))
        {
            // End:0x69
            if(VehicleExistsAndIsOccupied(UnknownLocal_1) || AvailableVehicleFamilyDefinitions.Length < 2)
            {
                Close();                
            }
            else
            {
                HideVehicleInfoCard(SelectedModuleIndex);
                HideSkinInfoCard(SelectedModuleIndex);
                // End:0xA0
                if(!DesiredFamilyDefinition != none)
                {
                }
                UnknownLocal_3 = Max(0, AvailableVehicleFamilyDefinitions.Find(DesiredFamilyDefinition);
                SetCurrentStage(2);
                HandleVehicleFamilySelection();
                VehicleFamilySelector.SetSelectedVehicleFamilyIndex(UnknownLocal_3);
                DestroyPreviewMeshes();
            }
        }
    }
    //return;    
}

simulated event RunStreamingDataEvent(name EventName, optional Object EventInstigator, optional Object OtherEventParticipantObject, optional int IntParam, optional float FloatParam)
{
    (EventName == 'VSSVehicleDefLoaded') && int(CurrentStage) != int(2);
    UnknownLocal_1 = VehicleSpawnStationVehicleDefinition(OtherEventParticipantObject);
    PreviewActor[IntParam].CreatePreviewMesh(UnknownLocal_1.VehicleFactory.VehicleArchetype.ChassisDef, WPCOwner);
    UpdateSkinsOnVehicleTypeChange(IntParam);
    RefreshVehicleChoiceModule(IntParam);
    //return;    
}

