event ConfigureTooltips()
{
    local string Tooltips;

    switch(CurrentStage)
    {
        // End:0x3B
        case 2:
            Tooltips = "TooltipsSelectFamily";
            // End:0x10E
            break;
        // End:0xFC
        case 3:
            // End:0x92
            if(VehicleExistsAndIsOccupied(UnknownLocal_1) || AvailableVehicleFamilyDefinitions.Length < 2)
            {
                Tooltips = "TooltipsMainFamilyNotAvailable";                
            }
            else
            {
                // End:0xE1
                if(VehicleChoiceInfoCard.GetBool("_visible"))
                {
                    Tooltips = "TooltipsSelectFamily";                    
                }
                else
                {
                    Tooltips = "TooltipsMain";
                }
            }
            // End:0x10E
            break;
        // End:0xFFFF
        default:
            Tooltips = "";
            // End:0x10E
            break;
            break;
    }
    // End:0x16F
    if(Len(Tooltips) > 0)
    {
        Tooltips = ResolveDataStoreMarkup(Localize("VehicleSpawnStationGFxMovie", Tooltips, "WillowGame"));
    }
    ConfigureTooltipsInternal(Tooltips);
    //return;    
}

