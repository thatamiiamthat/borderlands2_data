        VehicleFamilySelector.BeginAddCells();
        // End:0xC6
        foreach AvailableVehicleFamilyDefinitions(UnknownLocal_1,)
        {
            VehicleFamilySelector.AddCell(UnknownLocal_1.FamilyName, UnknownLocal_1.GetVehiclePreviewMoviePath());            
        }        
        VehicleFamilySelector.EndAddCells();
    }
    UnknownLocal_3 = 0;
    UnknownLocal_5 = class'WillowGlobals'.static.GetWillowGlobals();
    UnknownLocal_7 = UnknownLocal_5.GetVehicleLifetimeManager();
    // End:0x192
    if((UnknownLocal_7 != none) && UnknownLocal_7.GetCurrentVehicleFamily() != none)
    {
        UnknownLocal_3 = Max(AvailableVehicleFamilyDefinitions.Find(UnknownLocal_7.GetCurrentVehicleFamily(), 0);
    }
    VehicleFamilySelector.SetSelectedVehicleFamilyIndex(UnknownLocal_3);
    //return;    
}

function extOnVehicleChoiceModuleLoad(string TargetPath, int ModuleIndex)
