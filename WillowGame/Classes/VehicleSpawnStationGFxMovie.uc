        {
            // End:0x49
            case 'Gamepad_LeftStick_Left':
            // End:0x55
            case 'XboxTypeS_DPad_Left':
            // End:0x61
            case 'Left':
            // End:0x6D
            case 'Gamepad_LeftStick_Up':
            // End:0x79
            case 'XboxTypeS_DPad_Up':
            // End:0x85
            case 'Up':
            // End:0xB2
            case 'MouseScrollUp':
                VehicleFamilySelector.TryScrollUp();
                return true;
            // End:0xBE
            case 'Gamepad_LeftStick_Right':
            // End:0xCA
            case 'XboxTypeS_DPad_Right':
            // End:0xD6
            case 'Right':
            // End:0xE2
            case 'Gamepad_LeftStick_Down':
            // End:0xEE
            case 'XboxTypeS_DPad_Down':
            // End:0xFA
            case 'Down':
            // End:0x127
            case 'MouseScrollDown':
                VehicleFamilySelector.TryScrollDown();
                return true;
            // End:0xFFFF
            default:
                break;
            }
    }
    else
    {
        return HandleKeyDefaults(ControllerId, ukey, uevent);
        //return ReturnValue;        
    }
}

