function CreateEffect()
{
    local Vector SpawnLoc;

    // End:0x64
    if(bMoveSeeker)
    {
        SpawnLoc = MyWillowPawn.Location + (SeekStartOffset >> MyWillowPawn.Rotation);        
    }
    else
    {
        SpawnLoc = Target.Location;
    }
    Effect = MyWillowMind.Spawn(class'WillowReplicatedEmitter',,, SpawnLoc);
    Effect.SetTemplate(TargetParticle, true);
    //return;    
}

function FireMortar()
{
    local Vector Velocity, StartLoc;
    local Rotator StartRot;
    local AttributeBaseValueData BaseValueData;

    // End:0x5E
    if(!MyWillowPawn.GetWorldBodyAttachmentLocation(MortarSocket, StartLoc))
    {
        StartLoc = MyWillowPawn.Location;
    }
    // End:0xBC
    if(!MyWillowPawn.GetWorldBodyAttachmentRotation(MortarSocket, StartRot))
    {
        StartRot = MyWillowPawn.Rotation;
    }
    UnknownLocal_1 = MyWillowMind.Spawn(MortarProjectile.ProjectileClass, MyWillowMind,, StartLoc, StartRot,, MortarProjectile.bSpawnNoCollisionFail);
    class'WillowProjectile'.static.CalcTrajectoryAtActor(UnknownLocal_1, Effect, Options, UnknownLocal_3, UnknownLocal_5, Velocity);
    UnknownLocal_1.InitializeFromDefinition(MortarProjectile, MyWillowPawn.GetExpLevel());
    UnknownLocal_1.InitWithVelocity(Velocity);
    UnknownLocal_1.CustomGravityScaling = -UnknownLocal_5 / float(1000);
    // End:0x298
    foreach MortarValues(BaseValueData,)
    {
        class'AttributeInitializationDefinition'.static.SetBaseValue(BaseValueData.Attribute, BaseValueData.BaseValue, MyWillowMind, UnknownLocal_1);        
    }    
    //return;    
}

state Attack
{
    event Update()
    {
        global.Update();
        // End:0xD3
        if((bSeeking && Effect != none) && Target != none)
        {
            Effect.SetLocation(VInterpTo(Effect.Location, Target.Location, MyWillowMind.WorldInfo.DeltaSeconds, SeekSpeed));
        }
        //return;        
    }
Begin:

    CreateEffect();
    AttachBeam();
    bSeeking = bMoveSeeker;
    // End:0x85
    if(bStartAnimDefinesSeekTime)
    {
        Sleep(MyWillowPawn.SMComponent.Play(StartAnim));        
    }
    else
    {
        MyWillowPawn.SMComponent.Play(StartAnim);
        Sleep(SeekTime);
    }
    bSeeking = false;
    DetachBeam();
    ShotsTaken = 0;
    J0xFB:

    // End:0x192 [Loop If]
    if(ShotsTaken < NumShots)
    {
        ++ ShotsTaken;
        FireMortar();
        TriggerBehavior('Shoot');
        MyWillowPawn.SMComponent.Play(ShootAnim);
        Sleep(ShotDelay);
        // [Loop Continue]
        goto J0xFB;
    }
    Sleep(MyWillowPawn.SMComponent.Play(StopAnim));
    Finish();
    stop;            
}

