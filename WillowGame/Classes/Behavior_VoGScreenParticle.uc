{
    local IScreenParticle ContextInterface;

    super.ApplyBehaviorToContext(ContextObject, KernelInfo, SelfObject, MyInstigatorObject, OtherEventParticipantObject, EventData);
    ContextInterface = ContextObject.QueryInterface(class'IScreenParticle');
