class Behavior_SimpleAnimStop extends BehaviorBase
    editinlinenew
    collapsecategories
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(SimpleAnim) WillowAnimTree Tree;
var(SimpleAnim) name AnimName;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local ISimpleAnimPlayer AnimPlayer;

    AnimPlayer = ContextObject.QueryInterface(class'ISimpleAnimPlayer');
    // End:0xB6
    if((NotEqual_InterfaceInterface(AnimPlayer, ISimpleAnimPlayer(none)) && Tree != none) && AnimName != 'None')
