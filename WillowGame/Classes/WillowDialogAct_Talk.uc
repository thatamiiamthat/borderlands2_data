event TalkStarted(Actor InTalker)
{
    local GearboxDialogInterface GDI;

    super.TalkStarted(InTalker);
    // End:0xDC
    if(Emote != none)
    {
        GDI = GearboxDialogInterface(InTalker);
        // End:0xDC
        if(NotEqual_InterfaceInterface(GDI, GearboxDialogInterface(none)))
