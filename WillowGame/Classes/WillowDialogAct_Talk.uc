            UnknownLocal_1 = WillowDialogNameTag(GDI.GetDialogNameTag());
            // End:0xDC
            if(UnknownLocal_1 != none)
            {
                UnknownLocal_1.BeginStance(GDI.GetActor(), Emote);
            }
        }
    }
    //return;    
}

