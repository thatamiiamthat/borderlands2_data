        {
            ApplyDamage *= UnknownLocal_1.GetMaxHealth();            
        }
        else
        {
            // End:0xB5
            if(UnknownLocal_3 != none)
            {
                ApplyDamage *= UnknownLocal_3.GetMaxHealth();
            }
        }
    }
    UnknownLocal_5 = GetSpeedDamageModifier(VSize(ApplyForce));
    // End:0x100
    if(Formula.bApplySpeedDamage)
    {
        ApplyDamage *= UnknownLocal_5;
    }
    // End:0x142
    if(Formula.bApplyReverseMomentum)
    {
        ApplyForce = vect(0, 0, 0) - ApplyForce;
    }
    ApplyForce = Normal(ApplyForce);
    ApplyForce *= Formula.MomentumFactor;
    // End:0x1AE
    if(Formula.bApplySpeedMomentum)
    {
        ApplyForce *= UnknownLocal_5;
    }
    ApplyForce.Z += Formula.AddZMomentum;
    //return;    
}

function WillowAnimDefinition GetEnterAnim(int SeatIndex, ChassisDefinition.EVehicleSide Side, int IncomingSeatIndex)
{
    // End:0x210
    if(IncomingSeatIndex == SeatIndex)
    {
        switch(Side)
        {
            // End:0xA2
            case 0:
                UnknownLocal_1 = ((Seats[SeatIndex].SeatDefinition != none) ? Seats[SeatIndex].SeatDefinition.Anim_EnterLeft : none);
                // End:0x20D
                break;
            // End:0x11A
            case 1:
                UnknownLocal_1 = ((Seats[SeatIndex].SeatDefinition != none) ? Seats[SeatIndex].SeatDefinition.Anim_EnterRight : none);
                // End:0x20D
                break;
            // End:0x192
            case 2:
                UnknownLocal_1 = ((Seats[SeatIndex].SeatDefinition != none) ? Seats[SeatIndex].SeatDefinition.Anim_EnterFront : none);
                // End:0x20D
                break;
            // End:0x20A
            case 3:
                UnknownLocal_1 = ((Seats[SeatIndex].SeatDefinition != none) ? Seats[SeatIndex].SeatDefinition.Anim_EnterBack : none);
                // End:0x20D
                break;
            // End:0xFFFF
            default:
                break;
        }        
    }
    else
    {
        UnknownLocal_1 = ((Seats[SeatIndex].SeatDefinition != none) ? Seats[SeatIndex].SeatDefinition.Anim_SeatSwap[IncomingSeatIndex] : none);
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

