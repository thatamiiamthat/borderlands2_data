simulated function Vector GetEjectionVelocity(int Seat)
{
    local Vector FinalRand, EjectRandMax, EjectRandMin;

    // End:0xB6
    if(Seats[Seat].SeatDefinition != none)
    {
        EjectRandMax = Seats[Seat].SeatDefinition.EjectRandMax;
        EjectRandMin = Seats[Seat].SeatDefinition.EjectRandMin;
    }
    FinalRand.X = (FRand() * (EjectRandMax.X - EjectRandMin.X)) + EjectRandMin.X;
    FinalRand.Y = (FRand() * (EjectRandMax.Y - EjectRandMin.Y)) + EjectRandMin.Y;
    FinalRand.Z = (FRand() * (EjectRandMax.Z - EjectRandMin.Z)) + EjectRandMin.Z;
    return FinalRand;
    //return ReturnValue;    
}

