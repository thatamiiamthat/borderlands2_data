class Behavior_DropItems extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) const Vector ItemDropOffset;
var(Action) const Vector ItemDropVelocity;
var(Action) const Vector ItemScatterOffset;
var(Action) bool bDisablePickups;
var(Action) bool bCircularScatter;
var const bool bTorque;
var(Action) RelativeDirectionData CustomDirection;
var(Action) float CustomVelocity;
var(Action) const Vector Torque;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local ILootable ContextInterface;
    local IWorldBody AttachmentBase;
    local array<SpawnedDroppedLootData> SpawnedLoot;

    ContextInterface = ContextObject.QueryInterface(class'ILootable');
    AttachmentBase = ContextObject.QueryInterface(class'IWorldBody');
    // End:0xF0
    if((NotEqual_InterfaceInterface(ContextInterface, ILootable(none)) && NotEqual_InterfaceInterface(AttachmentBase, IWorldBody(none))) && ContextInterface.GetDroppedLoot(SpawnedLoot))
    {
        DropItems(AttachmentBase, SpawnedLoot);
    }
    //return;    
}

function DropItems(IWorldBody AttachmentBase, const out array<SpawnedDroppedLootData> SpawnedLoot)
{
    local Vector X, Y, Z, DropOffset, AdjustedVelocity, CustomDirVector,
	    PickupLocation;

    local Rotator ScatterRotation;
    local SpawnedDroppedLootData CurrentLoot;

    DropOffset = ItemDropOffset;
    AdjustedVelocity = ItemDropVelocity;
    UnknownLocal_1 = 1;
    UnknownLocal_3 = 1;
    class'Actor'.static.GetAxes(AttachmentBase.GetWorldBodyRotation(), X, Y, Z);
    // End:0x490
    foreach SpawnedLoot(CurrentLoot,)
    {
        // End:0x15A
        if(bCircularScatter)
        {
            ScatterRotation.Roll = 0;
            ScatterRotation.Pitch = 0;
            ScatterRotation.Yaw = Rand(32768) * 2;
            DropOffset = ItemDropOffset + (ItemScatterOffset >> ScatterRotation);
            AdjustedVelocity = ItemDropVelocity >> ScatterRotation;            
        }
        else
        {
            UnknownLocal_1 *= float(-1);
            DropOffset += (float(UnknownLocal_3 * UnknownLocal_1) * ItemScatterOffset);
            DropOffset.Z = Abs(DropOffset.Z);
        }
        PickupLocation = ((DropOffset.X * X) + (DropOffset.Y * Y)) + (DropOffset.Z * Z);
        PickupLocation = AttachmentBase.GetWorldBodyLocation() + PickupLocation;
        // End:0x30B
        if(int(CustomDirection.Direction) != int(0))
        {
            CustomDirVector = class'BehaviorHelpers'.static.GetRelativeDirection(CustomDirection, AttachmentBase, Normal(AdjustedVelocity));
            AdjustedVelocity = CustomDirVector * CustomVelocity;
        }
        class'WillowLeviathanService'.static.RecordItemSpawnedEventForAllPlayers(2, CurrentLoot.Inv, CurrentLoot.Inv.SourceResponsibleName, CurrentLoot.Inv.SourceDefinitionName);
        CurrentLoot.Inv.ItemLocation = 2;
        UnknownLocal_5 = WillowPickup(CurrentLoot.Inv.DropFrom(PickupLocation, AdjustedVelocity, CurrentLoot.bDisableRigidBodyPhysics, bTorque, Torque));
        UnknownLocal_5.SetPickupability(!bDisablePickups);
        ++ UnknownLocal_3;        
    }    
    //return;    
}

defaultproperties
{
    ItemScatterOffset=(X=40,Y=0,Z=0)
    CustomDirection=(Direction=EDirectionRelativeToParent.DIRECTION_Default,ConeAroundDirection=(BaseValueConstant=0,BaseValueAttribute=none,InitializationDefinition=none,BaseValueScaleConstant=1),AdditionalRotation=(Pitch=0,Yaw=0,Roll=0))
}