event InitFogOfWarBlobs()
{
    local WorldDiscoveryData WDA;

    // End:0xBD
    if((MyHUDMovie != none) && MyHUDMovie.WPCOwner != none)
    {
        // End:0xBC
        foreach MyHUDMovie.WPCOwner.DiscoveredWorldAreas(WDA,)
        {
            ToggleFogOfWarBlob(string(WDA.DiscoveryName), WDA.HasBeenUncovered);            
        }        
    }
    //return;    
}

event ToggleFogOfWarBlob(coerce string BlobName, bool bEnabled)
{
    ActionScriptVoid("toggleFogOfWarBlob");
    //return;    
}

