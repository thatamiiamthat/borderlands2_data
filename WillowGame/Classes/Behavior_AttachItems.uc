class Behavior_AttachItems extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action,Behavior_AttachItems);

var(Action) bool bDisablePickups;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local ILootable ContextInterface;
    local IWorldBody AttachmentBase;
    local array<SpawnedAttachedLootData> SpawnedLoot;
    local SpawnedAttachedLootData CurrentLoot;

    ContextInterface = ContextObject.QueryInterface(class'ILootable');
    AttachmentBase = ContextObject.QueryInterface(class'IWorldBody');
    // End:0x29B
    if((NotEqual_InterfaceInterface(ContextInterface, ILootable(none)) && NotEqual_InterfaceInterface(AttachmentBase, IWorldBody(none))) && ContextInterface.GetAttachedLoot(SpawnedLoot))
    {
        // End:0x100
        if(!ContextInterface.WillLootableBeResetOnLevelLoad())
        {
            UnknownLocal_1 = true;
        }
        // End:0x29A
        foreach SpawnedLoot(CurrentLoot,)
        {
            class'WillowLeviathanService'.static.RecordItemSpawnedEventForAllPlayers(6, CurrentLoot.Inv, CurrentLoot.Inv.SourceResponsibleName, CurrentLoot.Inv.SourceDefinitionName);
            CurrentLoot.Inv.ItemLocation = 6;
            UnknownLocal_3 = WillowPickup(CurrentLoot.Inv.GetPickup(true, !bDisablePickups));
            UnknownLocal_3.bCanBeSavedAcrossLevelTransition = UnknownLocal_1;
            UnknownLocal_3.AttachPickupToWorldBody(AttachmentBase, CurrentLoot.AttachmentPointName);            
        }        
    }
    //return;    
}
