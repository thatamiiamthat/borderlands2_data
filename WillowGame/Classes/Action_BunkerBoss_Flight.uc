            OffsetDir = FaceVector;
        }
        OffsetPoint = MyWillowPawn.Location + (OffsetDir * float(5000));
        DirFromTargetToOffset = Normal(OffsetPoint - TargetLocation);
        MovePoint = TargetLocation + (DirFromTargetToOffset * CircleFlightDistance);
        MovePoint.Z = TargetLocation.Z + CircleFlightHeight;
        CreateVectorPath(MovePoint);
        return true;
        //return ReturnValue;        
