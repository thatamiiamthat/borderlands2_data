state MoveToDistance
{
    function BeginState(name PreviousStateName)
    {
        local Vector FaceDir, FlightPoint;

        TriggerBehavior('MoveToDistanceStart');
        FaceDir = Vector(MyWillowPawn.Rotation);
        // End:0xE6
        if(Target != none)
        {
            FlightPoint = Target.Location + (FaceDir * CircleFlightDistance);
            FlightPoint.Z = Target.Location.Z + CircleFlightHeight;            
        }
        else
        {
            FlightPoint = NonTargetOrigin + (FaceDir * CircleFlightDistance);
            FlightPoint.Z = NonTargetOrigin.Z + CircleFlightHeight;
        }
        // End:0x1C5
        if((NearDeathExpression != none) && NearDeathExpression.Evaluate(AI.GetAIActor()))
        {
            bNearDeath = true;
            FlightPoint = MoveToPointNearDeath;
        }
        CreateVectorPath(FlightPoint);
        //return;        
    }

    function EndState(name NextStateName)
    {
        TriggerBehavior('MoveToDistanceStop');
        //return;        
    }
Begin:

    WaitForPath();
    FollowPath();
    GotoState('CircleAtDistance');
    stop;        
}

