simulated function bool AttemptReflection(Actor Other, PrimitiveComponent OtherComp, Vector HitLocation, Vector HitNormal)
{
    local IHitRegionConsumer HitRegionConsumerInterface;
    local ReflectionInfo ReflectionInfo;
    local TraceHitInfo HitInfo;
    local Vector ReflectionDestination;
    local Rotator ReflectionAngle;
    local Vector ReflectedDirection;

    HitRegionConsumerInterface = Other.QueryInterface(class'IHitRegionConsumer');
    // End:0x3DE
    if(NotEqual_InterfaceInterface(HitRegionConsumerInterface, IHitRegionConsumer(none)))
    {
        UnknownLocal_1 = GetInstigatingController();
        HitInfo.HitComponent = OtherComp;
        UnknownLocal_3 = HitRegionConsumerInterface.GetHitRegionForTakenDamage(UnknownLocal_1, HitInfo);
        UnknownLocal_5 = FRand() <= class'AttributeInitializationDefinition'.static.EvaluateInitializationData(UnknownLocal_3.BulletReflectionOffSelfChance, Other);
        // End:0x3DE
        if(((UnknownLocal_3 != none) && UnknownLocal_3.bReflectProjectiles) && UnknownLocal_5 || UnknownLocal_3.bRicochetIfReflectionChanceFails)
        {
            // End:0x3DE
            if(int(Physics) == int(6))
            {
                UnknownLocal_7 = true;
                ReflectionInfo.bReflectTowardAttacker = UnknownLocal_3.bOnlyReflectToAttacker;
                // End:0x21D
                if(UnknownLocal_5)
                {
                    ReflectionInfo.ReflectedInaccuracyModifier = class'AttributeInitializationDefinition'.static.EvaluateInitializationData(UnknownLocal_3.ReflectionAccuracyModifier, Other);                    
                }
                else
                {
                    ReflectionInfo.ReflectedInaccuracyModifier = class'AttributeInitializationDefinition'.static.EvaluateInitializationData(UnknownLocal_3.RicochetAccuracyModifier, Other);
                }
                ReflectionDestination = class'WillowLightProjectileManager'.static.GetReflectionDestination(ReflectionInfo, HitLocation, Other, Instigator);
                ReflectionAngle = Rotator(ReflectionDestination - Location) + class'WillowLightProjectileManager'.static.GetReflectionInaccuracyAngle(Instigator, ReflectionInfo.ReflectedInaccuracyModifier);
                SetRotation(ReflectionAngle);
                ReflectedDirection = Vector(ReflectionAngle);
                SetVelocityAndAcceleration(ReflectedDirection);
                Definition.OnReflected(ConsumerHandle, Other, ReflectedDirection, HitLocation);
                UnknownLocal_3.OnReflectedProjectile(ConsumerHandle, ReflectedDirection, HitLocation);
            }
        }
    }
    return UnknownLocal_7;
    //return ReturnValue;    
}

singular simulated function HitWall(Vector HitNormal, Actor Other, PrimitiveComponent OtherComp)
{
    // End:0x3A
    if((int(Role) != int(ROLE_Authority)) && Definition.bClientIgnoreHitAndTouch)
    {
        return;
    }
    // End:0x64
    if((ExtraNonBlockingActor != none) && Other == ExtraNonBlockingActor)
    {
        return;
    }
    // End:0xD1
    if(Definition.bTreatVehicleHitsAsTouch && Vehicle(Other) != none)
    {
        ProcessTouch(Other, OtherComp, Location, HitNormal);        
    }
    else
    {
        DoHitWall(HitNormal, Other, OtherComp, Location);
    }
    //return;    
}

simulated function DoHitWall(Vector HitNormal, Actor Other, PrimitiveComponent OtherComp, Vector HitLocation)
{
    local WillowPhysicalMaterialProperty.EDamageSurfaceType DamageSurfaceType;
    local ImpactInfo ImpactData;
    local BehaviorParameters EventData;
    local ImpactResponseParameters ImpactResponseParams;
    local editinline BlockingMeshComponent BlockingMeshComp;

    // End:0x3A
    if((int(Role) != int(ROLE_Authority)) && Definition.bClientIgnoreHitAndTouch)
    {
        return;
    }
    // End:0xE4
    if((Other != none) && Other.bIsBlockingMesh)
    {
        BlockingMeshComp = BlockingMeshComponent(OtherComp);
        // End:0xE4
        if((BlockingMeshComp != none) && BlockingMeshComp.bIsDisabled || !BlockingMeshComp.bBlockRocketsAndGrenades)
        {
            return;
        }
    }
    // End:0x41B
    if(!bIsProjectileAttached)
    {
        SetDamageSurfaceTypeImpactDataAndBoneIndex(Other, HitLocation, HitNormal, EventData, DamageSurfaceType, ImpactData, UnknownLocal_1);
        class'BehaviorBase'.static.SetVectorParameter(EventData, 'HitNormal', HitNormal);
        class'BehaviorBase'.static.SetActorParameter(EventData, 'HitActor', Other);
        Definition.OnHitWall(ConsumerHandle, Other, HitNormal, HitLocation);
        HandleOnHitEvents(Other, OtherComp, HitNormal, HitLocation, DamageSurfaceType, UnknownLocal_1, false);
        // End:0x2A5
        if(VSize(Velocity) < Definition.AtRestSpeedThreshold)
        {
            bBounce = false;
            SetPhysics(0);
            Definition.OnComeToRest(ConsumerHandle, HitNormal, HitLocation);
        }
        ImpactResponseParams = class'WillowPhysicalMaterialProperty'.default.DefaultResponseParameters;
        // End:0x39D
        if(Definition.BounceImpactAkRtpc != none)
        {
            ImpactResponseParams.RtpcParameterValues.Add(1;
            ImpactResponseParams.RtpcParameterValues[0].AkRtpc = Definition.BounceImpactAkRtpc;
            ImpactResponseParams.RtpcParameterValues[0].Value = VSize(Velocity);
        }
        class'WillowPhysicalMaterialProperty'.static.StaticTraceImpact(Definition.BounceImpact, self, Location - (HitNormal * float(64)), Location + (HitNormal * float(16)), ImpactResponseParams, true);
    }
    // End:0x438
    if(int(Role) == int(ROLE_Authority))
    {
        MakeNoise(1);
    }
    AttachmentNormal = HitNormal;
    //return;    
}

