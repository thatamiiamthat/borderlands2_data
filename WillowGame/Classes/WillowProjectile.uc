simulated function PostBeginPlay()
{
    local ITargetable SelfTargetable;

    super.PostBeginPlay();
    LastHomingPollLocation = Location;
    // End:0x2C
    if(bDeleteMe)
    {
        return;
    }
    bWideCheck = ((((int(Role) == int(ROLE_Authority)) && Instigator != none) && WillowPlayerController(GetInstigatingController()) != none) && WillowPlayerController(Instigator.Controller).bConsoleController) && CheckRadius > float(0);
    SelfTargetable = QueryInterface(class'ITargetable');
    // End:0x15A
    if(NotEqual_InterfaceInterface(SelfTargetable, ITargetable(none)))
    {
        class'GearboxEngineGlobals'.static.GetGearboxEngineGlobals().GetTargetableList().RegisterTargetable(SelfTargetable);
    }
    CreatedTime = WorldInfo.TimeSeconds;
    //return;    
}

