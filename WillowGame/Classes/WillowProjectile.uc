simulated event RigidBodyCollision(PrimitiveComponent HitComponent, PrimitiveComponent OtherComponent, const out CollisionImpactData RigidCollisionData, int ContactIndex)
{
    local Vector HitLocation, HitNormal;
    local ImpactResponseParameters ImpactResponseParams;

    super(Actor).RigidBodyCollision(HitComponent, OtherComponent, RigidCollisionData, ContactIndex);
    // End:0x2B1
    if((WorldInfo.TimeSeconds - LastRBImpactEffectTime) > Definition.RigidBodyImpactEffectDelay)
    {
        HitLocation = RigidCollisionData.ContactInfos[ContactIndex].ContactPosition;
        HitNormal = RigidCollisionData.ContactInfos[ContactIndex].ContactNormal;
        ImpactResponseParams = class'WillowPhysicalMaterialProperty'.default.DefaultResponseParameters;
        // End:0x20B
        if(Definition.BounceImpactAkRtpc != none)
        {
            ImpactResponseParams.RtpcParameterValues.Add(1;
            ImpactResponseParams.RtpcParameterValues[0].AkRtpc = Definition.BounceImpactAkRtpc;
            ImpactResponseParams.RtpcParameterValues[0].Value = VSize(RigidCollisionData.TotalNormalForceVector);
        }
        class'WillowPhysicalMaterialProperty'.static.StaticTraceImpact(Definition.BounceImpact, self, HitLocation - (HitNormal * float(64)), HitLocation + (HitNormal * float(16)), ImpactResponseParams, true);
        LastRBImpactEffectTime = WorldInfo.TimeSeconds;
    }
    //return;    
}

simulated event ReplicatedEvent(name VarName)
{
    // End:0x74
    if(VarName == 'Definition')
    {
        InitializeFromDefinition(Definition, ExpLevel);
        // End:0x71
        if((int(Physics) == int(10)) && !IsZero(InitialRBImpulse))
        {
            InitWithVelocity(InitialRBImpulse);
        }        
    }
    else
    {
        // End:0xA1
        if(VarName == 'MyDamageTypeDefinition')
        {
            InitializeDamageType(MyDamageTypeDefinition);            
        }
        else
        {
            // End:0xCE
            if(VarName == 'MyExplosionDefinition')
            {
                InitializeExplosion(MyExplosionDefinition);                
            }
            else
            {
                // End:0x184
                if(VarName == 'ReplicatedInstanceDataState')
                {
                    ReplicatedInstanceDataState.bNeedToApplyThisState = true;
                    // End:0x181
                    if(Definition != none)
                    {
                        ReplicatedInstanceDataState.bNeedToApplyThisState = class'InstanceDataHelper'.static.ApplyReplicatedInstanceDataState(ReplicatedInstanceDataState, self, Definition.BodyComposition, InstanceDataState);
                    }                    
                }
                else
                {
                    // End:0x1B3
                    if(VarName == 'bIsHoming')
                    {
                        bRotationFollowsVelocity = bIsHoming;                        
                    }
                    else
                    {
                        // End:0x1D4
                        if(VarName == 'bExploded')
                        {
                            SpawnClientExplosion();
                        }
                    }
                }
            }
        }
    }
    // End:0x226
    if(VarName == 'InitialRBImpulse')
    {
        // End:0x223
        if((int(Physics) == int(10)) && Definition != none)
        {
            InitWithVelocity(InitialRBImpulse);
        }        
    }
    else
    {
        // End:0x272
        if(VarName == 'Allegiance')
        {
            class'TargetableList'.static.ResetAllegiance(QueryInterface(class'ITargetable'));            
        }
        else
        {
            // End:0x320
            if(VarName == 'ReplicatedBehaviorConsumerState')
            {
                ReplicatedBehaviorConsumerState.bNeedToApplyThisState = true;
                // End:0x31D
                if(ConsumerHandle.PID != -1)
                {
                    ReplicatedBehaviorConsumerState.bNeedToApplyThisState = class'BehaviorKernel'.static.ProcessReplicatedBehaviorConsumerState(ConsumerHandle, ReplicatedBehaviorConsumerState);
                }                
            }
            else
            {
                // End:0x36B
                if(VarName == 'ReplicatedBehaviorEvent')
                {
                    class'BehaviorKernel'.static.ProcessReplicatedBehaviorEvent(ConsumerHandle, ReplicatedBehaviorEvent);                    
                }
                else
                {
                    // End:0x398
                    if(VarName == 'DrunkenRandomNumberSeed')
                    {
                        SetDrunkenRandomNumberSeed(DrunkenRandomNumberSeed);                        
                    }
                    else
                    {
                        // End:0x3C9
                        if(VarName == 'bOvercharged')
                        {
                            // End:0x3C6
                            if(bOvercharged)
                            {
                                ApplyOverchargedEffect();
                            }                            
                        }
                        else
                        {
                            // End:0x3ED
                            if(VarName == 'GearLikenessActor')
                            {
                                RefreshGearLikenessComponents();                                
                            }
                            else
                            {
                                super(Actor).ReplicatedEvent(VarName);
                            }
                        }
                    }
                }
            }
        }
    }
    //return;    
}

