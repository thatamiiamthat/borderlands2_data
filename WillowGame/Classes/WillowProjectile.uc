simulated function Init(Vector Direction)
{
    // End:0x5A
    if(Definition.bUseCustomAimDirection)
    {
        Direction = Normal(Definition.CustomAimDirection) >> Rotator(Direction);
    }
    SetRotation(Rotator(Direction));
    SetVelocityAndAcceleration(Direction);
    //return;    
}

simulated function SetVelocityAndAcceleration(Vector Direction)
{
    Velocity = MaxSpeed * Direction;
    Velocity.Z += Definition.UpwardVelocityBonus;
    Acceleration = AccelRate * Normal(Velocity);
    //return;    
}

