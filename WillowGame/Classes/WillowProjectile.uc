}

simulated function SetDamageSurfaceTypeImpactDataAndBoneIndex(Actor Other, Vector HitLocation, Vector HitNormal, out BehaviorParameters EventData, out WillowPhysicalMaterialProperty.EDamageSurfaceType DamageSurfaceType, out ImpactInfo ImpactData, out int BoneIndex)
{
    local IDamageSurface DamageSurfaceInterface;

    DamageSurfaceType = 0;
    // End:0x150
    if(GetImpactInfoForTouch(Other, HitLocation, HitNormal, ImpactData))
    {
        AddHitActor(Other, ImpactData.HitInfo, HitLocation, HitNormal);
        DamageSurfaceInterface = Other.QueryInterface(class'IDamageSurface');
        // End:0x116
        if(NotEqual_InterfaceInterface(DamageSurfaceInterface, IDamageSurface(none)))
        {
            DamageSurfaceType = DamageSurfaceInterface.GetDamageSurfaceTypeFromHit(ImpactData.HitInfo);
        }
        class'BehaviorBase'.static.SetImpactInfoParameter(EventData, 'ImpactData', ImpactData);
    }
    BoneIndex = -1;
    // End:0x22C
    if((Pawn(Other) != none) && ImpactData.HitInfo.BoneName != 'None')
    {
        BoneIndex = Pawn(Other).Mesh.MatchRefBone(ImpactData.HitInfo.BoneName);
    }
    //return;    
}

simulated function HandleOnHitEvents(Actor Other, PrimitiveComponent OtherComp, Vector HitNormal, Vector HitLocation, WillowPhysicalMaterialProperty.EDamageSurfaceType DamageSurfaceType, int BoneIndex, bool bIsProximityTouch)
{
    local editinline BlockingMeshComponent BlockingMeshComp;

    // End:0x3A
    if((int(Role) != int(ROLE_Authority)) && Definition.bClientIgnoreHitAndTouch)
    {
        return;
    }
    // End:0xE4
    if((Other != none) && Other.bIsBlockingMesh)
    {
        BlockingMeshComp = BlockingMeshComponent(OtherComp);
        // End:0xE4
        if((BlockingMeshComp != none) && BlockingMeshComp.bIsDisabled || !BlockingMeshComp.bBlockRocketsAndGrenades)
        {
            return;
        }
    }
    // End:0x534
    if(Other.bCanBeDamaged)
    {
        UnknownLocal_1 = Pawn(Other);
        // End:0x1B4
        if(bIsProximityTouch)
        {
            // End:0x1B1
            if((UnknownLocal_1 == none) || !UnknownLocal_1.IsDead())
            {
                Definition.OnTouchProximity(ConsumerHandle, 0, Other, HitNormal, HitLocation, int(DamageSurfaceType), BoneIndex);
            }            
        }
        else
        {
            Definition.OnHitDamagableObject(ConsumerHandle, 0, Other, HitNormal, HitLocation, int(DamageSurfaceType), BoneIndex);
        }
        // End:0x21C
        if(bIsProjectileDisabled)
        {
            return;
        }
        // End:0x324
        if(IsEnemy(Other))
        {
            // End:0x2C8
            if(bIsProximityTouch)
            {
                // End:0x2C5
                if((UnknownLocal_1 == none) || !UnknownLocal_1.IsDead())
                {
                    Definition.OnTouchProximity(ConsumerHandle, 1, Other, HitNormal, HitLocation, int(DamageSurfaceType), BoneIndex);
                }                
            }
            else
            {
                Definition.OnHitDamagableObject(ConsumerHandle, 1, Other, HitNormal, HitLocation, int(DamageSurfaceType), BoneIndex);
            }            
        }
        else
        {
            // End:0x42C
            if(IsFriendly(Other))
            {
                // End:0x3D0
                if(bIsProximityTouch)
                {
                    // End:0x3CD
                    if((UnknownLocal_1 == none) || !UnknownLocal_1.IsDead())
                    {
                        Definition.OnTouchProximity(ConsumerHandle, 2, Other, HitNormal, HitLocation, int(DamageSurfaceType), BoneIndex);
                    }                    
                }
                else
                {
                    Definition.OnHitDamagableObject(ConsumerHandle, 2, Other, HitNormal, HitLocation, int(DamageSurfaceType), BoneIndex);
                }                
            }
            else
            {
                // End:0x531
                if(IsNeutral(Other))
                {
                    // End:0x4D8
                    if(bIsProximityTouch)
                    {
                        // End:0x4D5
                        if((UnknownLocal_1 == none) || !UnknownLocal_1.IsDead())
                        {
                            Definition.OnTouchProximity(ConsumerHandle, 3, Other, HitNormal, HitLocation, int(DamageSurfaceType), BoneIndex);
                        }                        
                    }
                    else
                    {
                        Definition.OnHitDamagableObject(ConsumerHandle, 3, Other, HitNormal, HitLocation, int(DamageSurfaceType), BoneIndex);
                    }
                }
            }
        }        
    }
    else
    {
        // End:0x586
        if(!bIsProximityTouch)
        {
            Definition.OnHitTheWorld(ConsumerHandle, Other, HitNormal, HitLocation);
        }
    }
    CheckAIAvoidance();
    //return;    
}

