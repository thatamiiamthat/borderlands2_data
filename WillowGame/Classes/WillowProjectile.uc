simulated event Touch(Actor Other, PrimitiveComponent OtherComp, Vector HitLocation, Vector HitNormal)
{
    local BehaviorParameters EventData;

    // End:0x3A
    if((int(Role) != int(ROLE_Authority)) && Definition.bClientIgnoreHitAndTouch)
    {
        return;
    }
    // End:0x76
    if(Other.bIsWillowInteractiveObject)
    {
        // End:0x76
        if(!IsBlockedByWillowInteractiveObject(Other))
        {
            return;
        }
    }
    super.Touch(Other, OtherComp, HitLocation, HitNormal);
    // End:0xBE
    if(ProximityActor(Other) != none)
    {
        return;
    }
    // End:0x1BA
    if((int(Role) == int(ROLE_Authority)) || bBegunPlay)
    {
        // End:0x1BA
        if(Other.IsWaterVolume())
        {
            class'BehaviorBase'.static.SetVectorParameter(EventData, 'HitNormal', HitNormal);
            class'BehaviorBase'.static.SetActorParameter(EventData, 'HitActor', Other);
            Definition.OnHitWater(ConsumerHandle, Other, HitNormal, HitLocation);
        }
    }
    //return;    
}

// Export UWillowProjectile::execShouldIgnoreTouchFrom(FFrame&, void* const)
native final function bool ShouldIgnoreTouchFrom(Actor TouchedActor, PrimitiveComponent TouchedComponent, bool bIsProximityTouch, out byte bTurnTouchIntoHitWall);

simulated function HandleTouch(Actor Other, PrimitiveComponent OtherComp, Vector HitLocation, Vector HitNormal, bool bIsProximityTouch)
{
    local BehaviorParameters EventData;
    local WillowPhysicalMaterialProperty.EDamageSurfaceType DamageSurfaceType;
    local ImpactResponseParameters ImpactResponseParams;
    local ImpactInfo ImpactData;

    // End:0x0F
    if(bIsProjectileDisabled)
    {
        return;
    }
    // End:0x29
    if(Volume(Other) != none)
    {
        return;
    }
    // End:0x63
    if((int(Role) != int(ROLE_Authority)) && Definition.bClientIgnoreHitAndTouch)
    {
        return;
    }
    // End:0x9F
    if(Other.bIsWillowInteractiveObject)
    {
        // End:0x9F
        if(!IsBlockedByWillowInteractiveObject(Other))
        {
            return;
        }
    }
    // End:0x68F
    if(((Definition.bCanTouchInstigator || Other != Instigator) && Other != ExtraNonBlockingActor) && (int(Role) == int(ROLE_Authority)) || bBegunPlay)
    {
        // End:0x186
        if(ShouldIgnoreTouchFrom(Other, OtherComp, bIsProximityTouch, UnknownLocal_1))
        {
            // End:0x184
            if(int(UnknownLocal_1) == int(1))
            {
                DoHitWall(HitNormal, Other, OtherComp, HitLocation);
            }
            return;
        }
        SetDamageSurfaceTypeImpactDataAndBoneIndex(Other, HitLocation, HitNormal, EventData, DamageSurfaceType, ImpactData, UnknownLocal_3);
        class'BehaviorBase'.static.SetVectorParameter(EventData, 'HitNormal', HitNormal);
        class'BehaviorBase'.static.SetActorParameter(EventData, 'HitActor', Other);
        class'BehaviorBase'.static.SetVectorParameter(EventData, 'HitLocation', HitLocation);
        class'BehaviorBase'.static.SetImpactInfoParameter(EventData, 'ImpactInfo', ImpactData);
        // End:0x519
        if(!AttemptReflection(Other, OtherComp, HitLocation, HitNormal))
        {
            Definition.OnTouched(ConsumerHandle, Other, HitNormal, HitLocation, UnknownLocal_3);
            HandleOnHitEvents(Other, OtherComp, HitNormal, HitLocation, DamageSurfaceType, UnknownLocal_3, bIsProximityTouch);
            // End:0x519
            if(!bIsProjectileDisabled)
            {
                switch(DamageSurfaceType)
                {
                    // End:0x42E
                    case 1:
                        Definition.OnHitFlesh(ConsumerHandle, Other, HitNormal, HitLocation, UnknownLocal_3);
                        Definition.OnHitFleshOrArmor(ConsumerHandle, Other, HitNormal, HitLocation, UnknownLocal_3);
                        // End:0x519
                        break;
                    // End:0x4C6
                    case 2:
                        Definition.OnHitArmor(ConsumerHandle, Other, HitNormal, HitLocation, UnknownLocal_3);
                        Definition.OnHitFleshOrArmor(ConsumerHandle, Other, HitNormal, HitLocation, UnknownLocal_3);
                        // End:0x519
                        break;
                    // End:0x516
                    case 3:
                        Definition.OnHitShields(ConsumerHandle, Other, HitNormal, HitLocation, UnknownLocal_3);
                        // End:0x519
                        break;
                    // End:0xFFFF
                    default:
                        break;
                }
            }
            else
            {
            }/* !MISMATCHING REMOVE, tried If got Type:Else Position:0x519! */
            ImpactResponseParams = class'WillowPhysicalMaterialProperty'.default.DefaultResponseParameters;
            // End:0x611
            if(Definition.BounceImpactAkRtpc != none)
            {
                ImpactResponseParams.RtpcParameterValues.Add(1;
                ImpactResponseParams.RtpcParameterValues[0].AkRtpc = Definition.BounceImpactAkRtpc;
                ImpactResponseParams.RtpcParameterValues[0].Value = VSize(Velocity);
            }
            class'WillowPhysicalMaterialProperty'.static.StaticTraceImpact(Definition.BounceImpact, self, HitLocation - (HitNormal * float(64)), HitLocation + (HitNormal * float(16)), ImpactResponseParams, true);
        }
        AttachmentNormal = HitNormal;
        //return;        
