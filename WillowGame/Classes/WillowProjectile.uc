function WillowLightProjectileManager GetLightProjMgrFor(WillowWeapon aWeapon)
{
    // End:0x48
    if((LightProjMgr == none) && int(Role) == int(ROLE_Authority))
    {
        LightProjMgr = Spawn(class'WillowLightProjectileManager', self);
    }
    return LightProjMgr;
    //return ReturnValue;    
}

state WaitingForVelocity
{
    simulated function Tick(float DeltaTime)
    {
        // End:0x3F
        if(!IsZero(Velocity))
        {
            Acceleration = AccelRate * Normal(Velocity);
            GotoState('Auto');
        }
        //return;        
    }
    stop;    
}

defaultproperties
{
    bCauseRadiusDamageToInstigator=true
    AutoAimProfile=EAutoAimProfile.AAP_Medium
    begin object name=MyLightEnvironment class=DynamicLightEnvironmentComponent
        bCastShadows=false
        bEnabled=false
    object end
    // Reference: DynamicLightEnvironmentComponent'Default__WillowProjectile.MyLightEnvironment'
    LightEnvironment=MyLightEnvironment
    HomingTargetComponentIndex=-1
    RetryFindTargetDelay=0.5
}