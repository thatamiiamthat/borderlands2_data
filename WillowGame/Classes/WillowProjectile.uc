simulated function ProcessTouch(Actor Other, PrimitiveComponent OtherComp, Vector HitLocation, Vector HitNormal)
{
    // End:0x3A
    if((int(Role) != int(ROLE_Authority)) && Definition.bClientIgnoreHitAndTouch)
    {
