}

simulated function Behavior_SetStickyGrenade()
{
    CollisionComponent = CylinderComponent;
    CollisionRadiusBeforeSticky = CylinderComponent.CollisionRadius;
    // End:0x7D
    if((Definition != none) && !Definition.bStickyProjectilesDontChangeCollisionSize)
    {
        SetCollisionSize(1, 1);
    }
    bCollideComplex = true;
    bTraceIgnoreRigidBodyForPawns = false;
    bIsStickyGrenade = true;
    //return;    
}

function Behavior_SetDamageTypeDefinition(WillowDamageTypeDefinition DamageTypeDef)
{
    InitializeDamageType(DamageTypeDef);
    //return;    
}

function Behavior_SetExplosionDefinition(ExplosionDefinition MyExplosionDef)
{
    InitializeExplosion(MyExplosionDef);
    //return;    
}

simulated function Behavior_LevelOffTrajectory(float ZHeight, float TurnSpeed)
{
    WantsToLevelOffTrajectory = true;
    DesiredWorldZForLeveling = ZHeight;
    LevelingTurnSpeed = TurnSpeed;
    //return;    
}

function Behavior_TagPayloadType(IProjectileBehavior.EProjectilePayloadType InPayloadType)
{
    PayloadType = InPayloadType;
    //return;    
}

