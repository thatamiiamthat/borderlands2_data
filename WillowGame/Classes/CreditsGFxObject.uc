class CreditsGFxObject extends GFxObject within GFxMoviePlayer
    hidecategories(Mobile);

var CreditsGFxDefinition CreditsDef;
var float CachedDelta;

function Init(CreditsGFxDefinition CreditsDefinition)
{
    CreditsDef = CreditsDefinition;
    CachedDelta = CreditsDef.DefaultSpeed + 1;
    UpdateDelta(CreditsDef.DefaultSpeed);
    //return;    
}

function StartCreditScroll()
{
    ActionScriptVoid("StartCreditScroll");
    //return;    
}

function UpdateDelta(float NewDelta)
{
    // End:0x44
    if(NewDelta != CachedDelta)
    {
        CachedDelta = NewDelta;
        SetFloat("delta", NewDelta);
    }
    //return;    
}
