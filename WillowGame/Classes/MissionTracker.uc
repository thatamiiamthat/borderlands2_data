simulated event ReplicatedEvent(name VarName)
{
    // End:0x24
    if(VarName == 'ActiveMission')
    {
        NotifyLocalPlayerOfActiveMission();        
    }
    else
    {
        // End:0x48
        if(VarName == 'DynamicMissionDirectives')
        {
            ProcessDynamicMissionDirectives();            
        }
        else
        {
            super.ReplicatedEvent(VarName);
        }
    }
    //return;    
}

simulated function NotifyLocalPlayerOfActiveMission()
{
    // End:0xB6
    if(((WorldInfo.GRI != none) && WillowGameReplicationInfo(WorldInfo.GRI).MissionTracker != none) && IsDataValid())
    {
        WillowPlayerController(GetALocalPlayerController()).UpdateActiveMission(ActiveMission);
        TriggerActiveMissionChangedDelegates();        
    }
    else
    {
        SetTimer(0.1, false, 'NotifyLocalPlayerOfActiveMission');
    }
    //return;    
}

