function AcceptReward(int RewardChoice)
{
    PlayUISound('claim_reward');
    // End:0x84
    if(RewardObject != none)
    {
        RewardObject.AcceptReward(RewardChoice);
        RewardObject.FreeCellData();
        __OnInputKey__Delegate = HandleInputKey;
    }
    // End:0x104
    if(bTurnedInPlotMission)
    {
        UnknownLocal_1 = WillowPlayerController(GetPC());
        PlayUISound('MenuClose');
        Close();
        UnknownLocal_1.ServerShowChapterHeader(MissionDefForRewardPage.NextMissionInChain);        
    }
    else
    {
        MissionDefForRewardPage = none;
        DetermineQuestEntries();
        // End:0x141
        if(MissionList.Length > 0)
        {
            GotoCorrectPartOfMovie(true);
            extPopulateQuestEntries();            
        }
        else
        {
            PlayUISound('MenuClose');
            Close();
        }
    }
