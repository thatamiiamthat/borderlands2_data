function DisplayRewardsPage(PendingMissionRewardData MissionReward)
{
    SingleArgInvokeS("gotoAndPlay", "reward");
    Advance(1);
    PlayUISound('OpenMissionComplete');
    // End:0x6F
    if(RewardObject != none)
    {
        RewardObject.FreeCellData();
    }
    RewardObject = MissionRewardGFxObject(GetVariableObject("reward", class'MissionRewardGFxObject'));
    // End:0xB0
    if(!RewardObject != none)
    {
        return;
    }
    RewardObject.Init(self);
    RewardObject.SetPendingMissionRewardData(MissionReward);
    __OnInputKey__Delegate = HandleRewardInputKey;
    //return;    
}

function ShowNoRewardScreen(MissionDefinition Mission, IMission.EMissionStatus OldStatus)
