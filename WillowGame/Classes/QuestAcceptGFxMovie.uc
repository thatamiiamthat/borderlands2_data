    UnknownLocal_1
    OnlyIfThisMissionIsAlreadyInTheList == none;
    UnknownLocal_3 = 0;
    J0x1A:

    // End:0x77 [Loop If]
    if((UnknownLocal_3 < MissionList.Length) && !UnknownLocal_1)
    {
        UnknownLocal_1 = MissionList[UnknownLocal_3].MissionDef == OnlyIfThisMissionIsAlreadyInTheList;
        ++ UnknownLocal_3;
