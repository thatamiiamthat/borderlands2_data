    MissionDef.GetMissionRewardPresentation(RewardPresentations, true);
    // End:0x65
    if(!RewardPresentations.Length <= 2)
    {
    }
    return RewardPresentations;
    //return ReturnValue;    
}

private final function SetInnerReward(GFxObject InnerRewardClip, MissionRewardPresentationData Presentation)
{
    local ASColorTransform cxform;

    UnknownLocal_1 = class'WillowGlobals'.static.GetWillowGlobals().GetGlobalsDefinition();
    cxform.Multiply = ColorToLinearColor(UnknownLocal_1.GetRarityColorForLevel(int(Presentation.Rarity)));
    cxform.Add = ColorToLinearColor(MakeColor(0, 0, 0, 0));
    InnerRewardClip.GotoAndStop(Presentation.PresentationDefinition.ZippyFrame);
    InnerRewardClip.SetColorTransform(cxform);
    //return;    
}

private final function SetRewardCard(MissionDefinition MissionDef, WillowPlayerController WPC)
{
    local array<MissionRewardPresentationData> RewardPresentations;

    RewardPresentations = GetRewardPresentations(MissionDef, WPC);
    // End:0xE7
    if(RewardPresentations.Length == 1)
    {
        SetVariableBool("missions.reward_weap._visible", true);
        SingleArgInvokeS("missions.reward_weap.gotoAndStop", "oneReward");
        UnknownLocal_1 = GetVariableObject("missions.reward_weap.innerReward");
        SetInnerReward(UnknownLocal_1, RewardPresentations[0]);        
    }
    else
    {
        // End:0x1F9
        if(RewardPresentations.Length == 2)
        {
            SetVariableBool("missions.reward_weap._visible", true);
            SingleArgInvokeS("missions.reward_weap.gotoAndStop", "twoRewards");
            UnknownLocal_1 = GetVariableObject("missions.reward_weap.innerReward1");
            UnknownLocal_3 = GetVariableObject("missions.reward_weap.innerReward2");
            SetInnerReward(UnknownLocal_1, RewardPresentations[0]);
            SetInnerReward(UnknownLocal_3, RewardPresentations[1]);            
        }
        else
        {
            SetVariableBool("missions.reward_weap._visible", false);
        }
    }
    //return;    
}

