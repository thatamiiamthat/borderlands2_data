function extChoiceConfirmed()
{
    local IMission.EMissionStatus MissionStatus;

    MissionStatus = MissionList[GetSelectedIndex()].MissionStatus;
    // End:0x68
    if((int(MissionStatus) == int(3)) || int(MissionStatus) == int(2))
    {
        extCompleteConfirmed();        
    }
    else
    {
        // End:0x9C
        if((int(MissionStatus) == int(0)) || int(MissionStatus) == int(5))
        {
            extAcceptConfirmed();
        }
    }
    UpdateMissionDetails();
    SetFocus();
    //return;    
}

event OnClose()
{
    // End:0x39
    if(RewardObject != none)
    {
        RewardObject.DestroyPreviewInventory();
        RewardObject = none;
    }
    // End:0xB6
    if(MissionUIDef.bUsePPOverride)
    {
        LocalPlayer(WPCOwner.Player).ClearPostProcessSettingsOverride(MissionUIDef.PostProcessInterpolationTime);
    }
    UnknownLocal_1 = WillowPlayerController(GetPC());
    UnknownLocal_3 = WillowPlayerPawn(GetPC().Pawn);
    // End:0x14D
    if(NotEqual_InterfaceInterface(FocusSubject, IFocusable(none)))
    {
        FocusSubject.EndFocus(UnknownLocal_3);
        FocusSubject = none;
    }
    // End:0x18B
    if(ContextNPC != none)
    {
        UnknownLocal_3.ServerPlayerEndUseNPC(ContextNPC);
        ContextNPC = none;
    }
    MissionDirector.OnPlayerClosedMissionUI(UnknownLocal_1);
    MissionDirector = none;
    // End:0x1E9
    if(RewardObject != none)
    {
        RewardObject.FreeCellData();
    }
    super(WillowGFxMovie).OnClose();
    //return;    
}

