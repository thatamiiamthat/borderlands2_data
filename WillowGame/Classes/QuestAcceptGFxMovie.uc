function ConditionallyScroll(string Direction)
{
    UnknownLocal_1 = GetVariableBool("missions.selections.bHovering");
    // End:0x63
    if(UnknownLocal_1)
    {
        // End:0x56
        if(Direction == "Up")
        {
            LogUp();            
        }
        else
        {
            LogDown();
        }        
    }
    else
    {
        // End:0xCB
        if(Direction == "Up")
        {
            SetVariableNumber("missions.description.scroll", GetVariableNumber("missions.description.scroll") - float(1));            
        }
        else
        {
            SetVariableNumber("missions.description.scroll", GetVariableNumber("missions.description.scroll") + float(1));
        }
        SetScrollArrows();
    }
    //return;    
}

