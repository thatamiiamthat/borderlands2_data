}

function MoveHighlight()
{
    local string currentButton;

    currentButton = GetVariableString("currentButton");
    // End:0x46
    if(currentButton == "moreup")
    {
        LogUp();        
    }
    else
    {
        // End:0x69
        if(currentButton == "moredn")
        {
            LogDown();            
        }
        else
        {
            StopMovingHighlight();
        }
    }
    //return;    
}

function bool HandleInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    UnknownLocal_1 = false;
    // End:0x3DD
    if(LocalPlayer(WPCOwner.Player).ControllerId == ControllerId)
    {
        // End:0x9A
        if(ukey == 'LeftMouseButton')
        {
            // End:0x97
            if((int(uevent) == int(1)) && bSingleMissionDisplay)
            {
                WantsAcceptCounter = 2;
            }            
        }
        else
        {
            // End:0x130
            if(int(uevent) == int(1))
            {
                switch(ukey)
                {
                    // End:0xCD
                    case 'XboxTypeS_A':
                    // End:0xED
                    case 'Enter':
                        extChoiceConfirmed();
                        UnknownLocal_1 = true;
                        // End:0x130
                        break;
                    // End:0xF9
                    case 'XboxTypeS_B':
                    // End:0x12D
                    case 'Escape':
                        PlayUISound('MenuClose');
                        Close();
                        UnknownLocal_1 = true;
                        // End:0x130
                        break;
                    // End:0xFFFF
                    default:
                        break;
                }
            }
            else
            {
            }
            switch(ukey)
            {
                // End:0x14F
                case 'Gamepad_LeftStick_Up':
                // End:0x15B
                case 'XboxTypeS_DPad_Up':
                // End:0x1B4
                case 'Up':
                    // End:0x1AA
                    if((int(uevent) == int(0)) || int(uevent) == int(2))
                    {
                        LogUp();
                        SetDescriptionScrollValue(1);
                    }
                    UnknownLocal_1 = true;
                    // End:0x228
                    break;
                // End:0x1C0
                case 'Gamepad_LeftStick_Down':
                // End:0x1CC
                case 'XboxTypeS_DPad_Down':
                // End:0x225
                case 'Down':
                    // End:0x21B
                    if((int(uevent) == int(0)) || int(uevent) == int(2))
                    {
                        LogDown();
                        SetDescriptionScrollValue(1);
                    }
                    UnknownLocal_1 = true;
                    // End:0x228
                    break;
                // End:0xFFFF
                default:
                    break;
            }
            // End:0x31C
            if((int(uevent) == int(0)) || int(uevent) == int(2))
            {
                switch(ukey)
                {
                    // End:0x271
                    case 'PageUp':
                    // End:0x2BF
                    case 'XboxTypeS_LeftTrigger':
                        SetDescriptionScrollValue(GetVariableNumber("missions.description.scroll") - 1);
                        UnknownLocal_1 = true;
                        // End:0x31C
                        break;
                    // End:0x2CB
                    case 'PageDown':
                    // End:0x319
                    case 'XboxTypeS_RightTrigger':
                        SetDescriptionScrollValue(GetVariableNumber("missions.description.scroll") + 1);
                        UnknownLocal_1 = true;
                        // End:0x31C
                        break;
                    // End:0xFFFF
                    default:
                        break;
                }
            }
            else
            {
                // End:0x3DA
                if(!UnknownLocal_1)
                {
                    // End:0x35B
                    if(int(uevent) == int(0))
                    {
                        // End:0x35B
                        if(ukey == 'LeftMouseButton')
                        {
                            StartMovingHighlight();
                        }
                    }
                    // End:0x3DA
                    if(int(uevent) == int(1))
                    {
                        switch(ukey)
                        {
                            // End:0x39B
                            case 'LeftMouseButton':
                                StopMovingHighlight();
                                // End:0x3DA
                                break;
                            // End:0x3B8
                            case 'MouseScrollUp':
                                ConditionallyScroll("Up");
                                // End:0x3DA
                                break;
                            // End:0x3D7
                            case 'MouseScrollDown':
                                ConditionallyScroll("Down");
                                // End:0x3DA
                                break;
                            // End:0xFFFF
                            default:
                                break;
                        }
                    }
                    else
                    {
                    }/* !MISMATCHING REMOVE, tried If got Type:Else Position:0x3DA! */                    
                }
                else
                {
                    UnknownLocal_1 = true;
                }
                return UnknownLocal_1;
                //return ReturnValue;                
            }
        }
    }/* !MISMATCHING REMOVE, tried Else got Type:If Position:0x007! */
}

