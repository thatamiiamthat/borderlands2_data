private final function PlayStatusMovie()
{
    ClearTimer('PlayStatusMovie', self);
    WPlayerOwner.bStopgapBlockForDeferredMovies = false;
    // End:0xF2
    if(bShowHUD)
    {
        StatusMenuExMovie = StatusMenuExGFxMovie(WPlayerOwner.GFxUIManager.PlayMovie(HUDDef.StatusMenuDefinition, none));
        // End:0xC4
        if(StatusMenuExMovie != none)
        {
            TryFakePauseInSinglePlayer();            
        }
        else
        {
            WPlayerOwner.SetStatusMenuOpen(false);
            OpenHUDMovie();
        }        
    }
    else
    {
        WPlayerOwner.SetStatusMenuOpen(false);
    }
    //return;    
}

