    MeshComp.Animations
    FindAllAnimNodes(AnimNodes, 'DualWieldSwitch');
    // End:0x104
    foreach AnimNodes(UnknownLocal_1,)
    {
        // End:0xB1
        if(AnimNodeBlend(UnknownLocal_1) != none)
        {
            AnimNodeBlend(UnknownLocal_1).SetBlendTarget(float(((bEnabled) ? 1 : 0)), BlendTime);            
        }
        else
        {
            // End:0x103
            if(AnimNodeBlendList(UnknownLocal_1) != none)
            {
                AnimNodeBlendList(UnknownLocal_1).SetActiveChild(((bEnabled) ? 1 : 0), BlendTime);
            }
        }        
    }    
    //return;    
}

simulated event EnableActionSkillHUD(WillowHUDGFxMovie HUDMovie)
{
    HUDMovie.SetVariableBool("p1.bullets._visible", false);
    HUDMovie.SetVariableBool("p1.bullet_c._visible", false);
    HUDMovie.SetVariableBool("p1.bullet_icon._visible", false);
    HUDMovie.SetVariableBool("p1.crosshairsDualWield._visible", true);
    WeaponCache.CachedClipSize = -1;
    WeaponCache.CachedAmmoInClip = -1;
    WeaponCache.CachedAmmoNotInClip = -1;
    WeaponCache.CachedWeaponIsReloading = 255;
    WeaponCache.CachedWeaponType = "Invalid Weapon Type";
    WeaponCache.CachedWeaponTypeDLCClip = none;
    WeaponCache.IsReloadIconDisplayed = -1;
    WeaponCache.IsInteractionIconDisplayed = -1;
    OffhandWeaponCache.CachedClipSize = -1;
    OffhandWeaponCache.CachedAmmoInClip = -1;
    OffhandWeaponCache.CachedAmmoNotInClip = -1;
    OffhandWeaponCache.CachedWeaponIsReloading = 255;
    OffhandWeaponCache.CachedWeaponType = "Invalid Weapon Type";
    OffhandWeaponCache.CachedWeaponTypeDLCClip = none;
    OffhandWeaponCache.IsReloadIconDisplayed = -1;
    OffhandWeaponCache.IsInteractionIconDisplayed = -1;
    TickActionSkillHUD(HUDMovie, 0, 0);
    CrosshairWidget = HUDWidget_Crosshairs(HUDMovie.GetVariableObject("p1.crosshairsDualWield", class'HUDWidget_Crosshairs'));
    // End:0x410
    if(CrosshairWidget != none)
    {
        CrosshairWidget.bDualWieldCrosshair = true;
        CrosshairWidget.Init(HUDMovie);
        SetOffHandCrosshair(WillowWeapon(MyWillowPawn.OffHandWeapon));
    }
    //return;    
}

simulated function SetOffHandCrosshair(WillowWeapon OffHandWeapon)
{
    // End:0x13
