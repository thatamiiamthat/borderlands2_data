        return;
    }
    CrosshairWidget.AssociateWeapon(OffHandWeapon);
    //return;    
}

simulated event DisableActionSkillHUD(WillowHUDGFxMovie HUDMovie)
{
    HUDMovie.SetVariableBool("p1.bullets._visible", true);
    HUDMovie.SetVariableBool("p1.bullet_c._visible", true);
    HUDMovie.SetVariableBool("p1.bullet_icon._visible", true);
    HUDMovie.SetVariableBool("p1.crosshairsDualWield._visible", false);
    // End:0x11E
    if(CrosshairWidget != none)
    {
        CrosshairWidget.Deinit();
        CrosshairWidget = none;
    }
    HUDMovie.CachedWeaponInfo.CachedClipSize = -1;
    HUDMovie.CachedWeaponInfo.CachedAmmoInClip = -1;
    HUDMovie.CachedWeaponInfo.CachedAmmoNotInClip = -1;
    HUDMovie.CachedWeaponInfo.CachedWeaponIsReloading = 255;
    HUDMovie.CachedWeaponInfo.CachedWeaponType = "Invalid Weapon Type";
    HUDMovie.CachedWeaponInfo.CachedWeaponTypeDLCClip = none;
    //return;    
}

simulated event TickActionSkillHUD(WillowHUDGFxMovie HUDMovie, float ActionSkillTime, float DeltaTime)
{
    UnknownLocal_1 = WillowWeapon(MyWillowPawn.Weapon);
    // End:0x70
