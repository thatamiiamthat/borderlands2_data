    }
    // End:0xF6
    if(bApplyToThirdPerson && MyWillowPlayerPawn.Mesh != none)
    {
        SetDualWieldSwitchEx(bEnabled, MyWillowPlayerPawn.Mesh, BlendTime);
    }
    //return;    
}

protected simulated function SetDualWieldSwitchEx(bool bEnabled, SkeletalMeshComponent MeshComp, optional float BlendTime)
{
