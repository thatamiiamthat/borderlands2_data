class Behavior_StopMeleeAttack extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IMeleeAttacker MeleeInterface;

    MeleeInterface = ContextObject.QueryInterface(class'IMeleeAttacker');
    // End:0x72
    if(NotEqual_InterfaceInterface(MeleeInterface, IMeleeAttacker(none)))
    {
        MeleeInterface.EndMeleeOverTime();
    }
    //return;    
}
