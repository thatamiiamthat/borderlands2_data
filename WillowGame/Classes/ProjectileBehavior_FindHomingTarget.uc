class ProjectileBehavior_FindHomingTarget extends ProjectileBehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Action) const IProjectileBehavior.EHomingTargetType TargetType;
var(Action) const float TargetSearchFOVAngle;
var(Action) const float TargetSearchRange;
var(Action) const bool bNotInstigator;
var(Action) const bool bIgnoreFOVZTest;
var(Action) const bool bBestForwardTarget;
var(Action) const bool bRetryIfTargetNotFound;
var(Action) const bool bUniqueTarget;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IProjectileBehavior ContextInterface;

    ContextInterface = ContextObject.QueryInterface(class'IProjectileBehavior');
    // End:0xBF
    if(NotEqual_InterfaceInterface(ContextInterface, IProjectileBehavior(none)))
    {
        ContextInterface.FindHomingTarget(TargetType, TargetSearchRange, TargetSearchFOVAngle, bNotInstigator, bIgnoreFOVZTest, bBestForwardTarget, bRetryIfTargetNotFound, bUniqueTarget);
    }
    //return;    
}

defaultproperties
{
    bNotInstigator=true
}