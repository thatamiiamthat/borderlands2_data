function SetTooltips()
{
    local string S, Spacing;

    Spacing = "    ";
    // End:0x100
    if(TwoPanelInterface.TransferringThing != none)
    {
        // End:0x8E
        if(TwoPanelInterface.GetSelectedThing() != none)
        {
            S = Localize("storage", "SwapBar", "WillowMenu");            
        }
        else
        {
            S = ColorizeTooltipText(((Localize("storage", "PlaceBar", "WillowMenu")) $ " ") $ (_GetAddTip()), !TwoPanelInterface.OnValidCell());
        }        
    }
    else
    {
        S = ColorizeTooltipText(Localize("storage", "TakeBar", "WillowMenu"), TwoPanelInterface.GetSelectedThing() == none);
    }
    // End:0x1DE
    if(TwoPanelInterface.GetCurrentPanel().bCanChangeSort)
    {        
        S $= (Spacing $ (Localize("vending", "SortBar", "WillowMenu")));
    }    
    S $= (Spacing $ (Localize("vending", "CancelBar", "WillowMenu")));
    TwoPanelInterface.SetTooltipText(ResolveDataStoreMarkup(S));
    //return;    
}

