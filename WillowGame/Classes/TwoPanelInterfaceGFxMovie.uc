function extGenericButtonClicked(string ActionName)
{
    local name Action;

    Action = name(ActionName);
    switch(Action)
    {
        // End:0x41
        case 'Close':
            BeginClosing();
            // End:0x1D2
            break;
        // End:0x173
        case 'Sort':
            // End:0xF1
            if(TwoPanelInterface.bOnLeftPanel)
            {
                // End:0xEE
                if(TwoPanelInterface.StoragePanel.bCanChangeSort)
                {
                    PlayUISound('HorizontalMovement');
                    TwoPanelInterface.StoragePanel.extOnChangeSort(1);
                }                
            }
            else
            {
                // End:0x170
                if(TwoPanelInterface.PlayerPanel.bCanChangeSort)
                {
                    PlayUISound('HorizontalMovement');
                    TwoPanelInterface.PlayerPanel.extOnChangeSort(1);
                }
            }
            // End:0x1D2
            break;
        // End:0x1A1
        case 'nav1':
            TwoPanelInterface.TrySwitchToRightPanel();
            // End:0x1D2
            break;
        // End:0x1CF
        case 'nav2':
            TwoPanelInterface.TrySwitchToLeftPanel();
            // End:0x1D2
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

function PressedHotkeyNumber(int HotkeyNum)
{
    switch(HotkeyNum)
    {
        // End:0x2A
        case 1:
            extGenericButtonClicked("nav2");
            // End:0x45
            break;
        // End:0x42
        case 2:
            extGenericButtonClicked("nav1");
            // End:0x45
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

