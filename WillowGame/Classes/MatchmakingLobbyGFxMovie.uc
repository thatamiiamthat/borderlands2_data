function bool HandleInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0x31
    if(ControllerId != int(WPCOwner.GetMyControllerId()))
    {
        return true;
    }
    // End:0x71
    if(int(WPCOwner.WorldInfo.NetMode) == int(NM_Client))
    {
        return true;
    }
    switch(ukey)
    {
        // End:0x90
        case 'XboxTypeS_B':
        // End:0xE1
        case 'Escape':
            // End:0xDF
            if(int(uevent) == int(1))
            {
                // End:0xD5
                if(__OnCancel__Delegate != none)
                {
                    OnCancel();                    
                }
                else
                {
                    BeginClose();
                }
            }
            return true;
        // End:0xED
        case 'XboxTypeS_A':
        // End:0x147
        case 'Enter':
            // End:0x145
            if(int(uevent) == int(1))
            {
                // End:0x145
                if((int(CurrentMatchmakingState) == int(5)) && __OnHostGameAccept__Delegate != none)
                {
                    OnHostGameAccept();
                }
            }
            return true;
        // End:0xFFFF
        default:
            return false;
            break;
    }
    //return ReturnValue;    
}

