            // End:0x20F
            if(int(Role) == int(ROLE_Authority))
            {
                AttachedToData.AttachmentBase = ActorToAttachTo;
                AttachedToData.AttachmentRelativeOffset = AttachRelativeOffset;
                AttachedToData.AttachmentRelativeRotation = AttachRelativeRotation;
                AttachedToData.AttachmentBaseBoneName = NewBaseBoneName;
                AttachedToData.AttachmentPhysicsMode = NewPhysicsMode;
            }
        }
    }
