        bPlayerFellIntoPlayerKillVolume = false;
        //return;        
    }

    simulated event BeginState(name PreviousStateName)
    {
        super.BeginState(PreviousStateName);
        bInjuredDeadHasRagdolled = false;
        bInjuredDeadCameraActive = false;
        // End:0x1E0
        if((Controller != none) && Controller.IsLocalPlayerController())
        {
            SetupPlayerInjuredState();
            InjuredStartTime = WorldInfo.TimeSeconds;
            UnknownLocal_1 = WillowPlayerController(Controller);
            // End:0x1E0
            if(UnknownLocal_1 != none)
            {
                // End:0x1C0
                if(UnknownLocal_1.IsLocalPlayerController())
                {
                    UnknownLocal_1.SetBehindView(true);
                    // End:0x12E
