                    UnknownLocal_3 = WillowWeapon(Weapon);
                    // End:0x1C0
                    if(UnknownLocal_3 != none)
                    {
                        UnknownLocal_3.ForceUnzoom(true);
                        UnknownLocal_3.ClearPendingFire(0);
                        UnknownLocal_3.ClearPendingFire(1);
                    }
                }
                UnknownLocal_1.PostProcessDurationMultiplier = 1;
            }
        }
        //return;        
    }

    simulated event EndState(name NextStateName)
    {
        super.EndState(NextStateName);
        // End:0x2A
        if(bInjuredDeadHasRagdolled)
        {
            InjuredDeadTermRagdoll();
        }
        EndInjuredCamera();
        //return;        
    }
    stop;    
}

