simulated function DoAttachPlayerToBase(Actor ActorToAttachTo, optional Vector AttachRelativeOffset, optional Rotator AttachRelativeRotation, optional name NewBaseBoneName, optional Engine.Actor.EPhysics NewPhysicsMode = 13)
{
