state AwaitingRespawn
{
    event BeginState(name PreviousStateName)
    {
        bIsAwaitingRespawn = true;
        SetCanTarget(false);
        AwaitingRespawnBeginState(PreviousStateName);
        super(Object).BeginState(PreviousStateName);
        //return;        
    }

    event EndState(name NextStateName)
    {
        bIsAwaitingRespawn = false;
        SetCanTarget(true);
        SetShadowCasting(true);
        super(Object).EndState(NextStateName);
        //return;        
    }
    stop;    
}

simulated state ClientAwaitingRespawn
{
    simulated event BeginState(name PreviousStateName)
    {
        AwaitingRespawnBeginState(PreviousStateName);
        super(Object).BeginState(PreviousStateName);
        //return;        
    }

    simulated event EndState(name NextStateName)
    {
        super(Object).EndState(NextStateName);
        //return;        
    }
    stop;    
}

