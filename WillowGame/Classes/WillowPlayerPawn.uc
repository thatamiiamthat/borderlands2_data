    SetHardAttach(false);
    SetBase(none);
    SetPhysics(2);
    // End:0x25B
    if(int(Role) == int(ROLE_Authority))
    {
        AttachedToData.AttachmentBase = none;
    }
    J0x25B:

    //return;    
}

