function bool CanChallengeToDuel(WillowPlayerPawn Competitor)
{
    // End:0x22
    if((Competitor == none) || Competitor == self)
    {
        return false;
    }
    // End:0x59
    if(!IsAliveAndWell() || !Competitor.IsAliveAndWell())
    {
        return false;
    }
    // End:0x6A
    if(!IsDuelingEnabled())
    {
        return false;
    }
    // End:0x115
    if(!Competitor.IsDuelingEnabled())
    {
        ReceiveLocalizedMessage(class'WillowVersusDuelMessage', 0, PlayerReplicationInfo, Competitor.PlayerReplicationInfo);
        class'WillowLeviathanService'.static.RecordDeclinedDuelEventForPlayer(WillowPlayerController(Competitor.GetController()), 0);
        return false;
    }
    // End:0x125
    if(HasActiveDuel())
