                }
                else
                {
                    // End:0x380
                    if(Action.BoneName == 'None')
                    {
                        AttachedToData.AttachmentRelativeRotation = Rotation - UnknownLocal_3.Rotation;
                    }
                }
                // [Explicit Continue]
