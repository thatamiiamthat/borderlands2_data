        }
    }
    // End:0x150
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_3 = class'WillowPickup'.static.CreatePickupFromMemento(Memento.PickupMemento, UnknownLocal_1);
    }
    return UnknownLocal_3;
    //return ReturnValue;    
}

