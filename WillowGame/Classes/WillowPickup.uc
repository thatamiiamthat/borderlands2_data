function InitializeDropLifespan()
{
    // End:0x1C
    if(bIsMissionItem)
    {
        LifeSpanType = 3;        
    }
    else
    {
        LifeSpanType = class'WillowGlobals'.static.GetWillowGlobals().GetGlobalsDefinition().GetDropLifeSpanType(InventoryRarityLevel);
    }
    // End:0x104
    if(!bIsMissionItem && Inventory.GetInventoryDefinition().PickupLifeSpan > float(0))
    {
        UnknownLocal_1 = Inventory.GetInventoryDefinition().PickupLifeSpan;        
    }
    else
    {
        switch(LifeSpanType)
        {
            // End:0x12E
            case 0:
                UnknownLocal_1 = VeryShortLivedDropLifeSpan;
                // End:0x177
                break;
            // End:0x145
            case 1:
                UnknownLocal_1 = ShortLivedDropLifeSpan;
                // End:0x177
                break;
            // End:0x15C
            case 2:
                UnknownLocal_1 = LongLivedDropLifeSpan;
                // End:0x177
                break;
            // End:0x161
            case 4:
            // End:0x174
            case 3:
                UnknownLocal_1 = 0;
                // End:0x177
                break;
            // End:0xFFFF
            default:
                break;
        }
    }
    LifeSpan = UnknownLocal_1;
    // End:0x1BB
    if(LifeSpan > 0)
    {
        SetTimer(LifeSpan - PickupShrinkDuration, false, 'ShrinkPickupBeforeDestruction');
    }
    //return;    
}

function ShrinkPickupBeforeDestruction()
{
    UnknownLocal_1 = 0.1 * (1 / PickupShrinkDuration);
    UnknownLocal_3 = DrawScale - UnknownLocal_1;
    UnknownLocal_3 = FMax(UnknownLocal_3, 0);
    SetDrawScale(UnknownLocal_3);
    SetTimer(0.1, false, 'ShrinkPickupBeforeDestruction');
    //return;    
}

