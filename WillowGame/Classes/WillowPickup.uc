simulated function PickupableMeshActor GetPickupableMeshActor()
{
    UnknownLocal_1 = Spawn(class'PickupableMeshActor', self,, Location, GetSaveRotation());
    Inventory.AttachMeshToPickup(UnknownLocal_1);
    return UnknownLocal_1;
    //return ReturnValue;    
}

function AttachPickupToWorldBody(IWorldBody AttachmentBase, name AttachmentPointName)
{
    // End:0x56
    if(NotEqual_InterfaceInterface(AttachmentBase, IWorldBody(none)))
    {
        AttachmentBase.WorldBodyAttachActor(self,,, AttachmentPointName);
        AdjustPickupPhysicsAndCollisionForBeingAttached();
    }
    //return;    
}

function AdjustPickupPhysicsAndCollisionForBeingAttached()
{
    bIsPickupAttachedToSomething = true;
    SetPhysics(0);
    SetCollision(false, false);
    bCollideWorld = false;
    PickupAtRest();
    //return;    
}

function AdjustPickupPhysicsAndCollisionForBeingDropped()
{
    SetPhysics(2);
    SetCollision(true, false);
    bCollideWorld = true;
    bUseRBPhysics = true;
    //return;    
}

function PickupMemento GetMemento()
{
    local PickupMemento Memento;

    Memento.Rotation = GetSaveRotation();
    Memento.bIsAttachedToSomething = bIsPickupAttachedToSomething;
    return Memento;
    //return ReturnValue;    
}

simulated function FailedPickup()
{
    local Vector RandomImpulse, RandomTorque;
    local editinline MeshComponent Mesh;

    // End:0x1A9
    if(!bIsPickupAttachedToSomething)
    {
        ConvertFixedToRigidBody();
        Mesh = MeshComponent(CollisionComponent);
        // End:0x1A9
        if(Mesh != none)
        {
            RandomImpulse.X = -5 + (FRand() * float(10));
            RandomImpulse.Y = -5 + (FRand() * float(10));
            RandomImpulse.Z = 20;
            RandomTorque.X = -2 + (FRand() * float(4));
            RandomTorque.Y = -2 + (FRand() * float(4));
            RandomTorque.Z = -2 + (FRand() * float(4));
            // End:0x1A9
            if(__NFUN_228__(Velocity) < float(1))
            {
                Mesh.AddImpulse(RandomImpulse);
                Mesh.AddTorque(RandomTorque);
            }
        }
    }
    //return;    
}

simulated event ConvertRigidBodyToFixed()
{
    local editinline MeshComponent Mesh;
    local editinline SkeletalMeshComponent SKMesh;

    Mesh = MeshComponent(CollisionComponent);
    // End:0x16D
    if(Mesh != none)
    {
        Mesh.SetNotifyRigidBodyCollision(false);
        Mesh.SetBlockRigidBody(false);
        Mesh.SetActorCollision(false, false);
        SKMesh = SkeletalMeshComponent(Mesh);
        // End:0x137
        if((SKMesh != none) && SKMesh.PhysicsAssetInstance != none)
        {
            SKMesh.PhysicsAssetInstance.SetAllBodiesFixed(true);
            SKMesh.bUpdateKinematicBonesFromAnimation = false;            
        }
        else
        {
            Mesh.GetRootBodyInstance().SetFixed(true);
        }
    }
    //return;    
}

simulated event ConvertFixedToRigidBody()
{
    local editinline MeshComponent Mesh;
    local editinline SkeletalMeshComponent SKMesh;

    NetUpdateFrequency = 8;
    Mesh = MeshComponent(CollisionComponent);
    // End:0x17B
    if(Mesh != none)
    {
        Mesh.SetNotifyRigidBodyCollision(true);
        Mesh.SetBlockRigidBody(true);
        Mesh.SetActorCollision(true, false);
        SKMesh = SkeletalMeshComponent(Mesh);
        // End:0x125
        if((SKMesh != none) && SKMesh.PhysicsAssetInstance != none)
        {
            SKMesh.PhysicsAssetInstance.SetAllBodiesFixed(false);            
        }
        else
        {
            Mesh.GetRootBodyInstance().SetFixed(false);
        }
        Mesh.WakeRigidBody();
    }
    StartRigidBodyTimers();
    //return;    
}

static function WillowPickup CreatePickupFromMemento(PickupMemento Memento, WillowInventory InventoryThisPickupIsFor)
{
    // End:0x112
    if(InventoryThisPickupIsFor != none)
    {
        UnknownLocal_1 = WillowPickup(InventoryThisPickupIsFor.GetPickup(Memento.bIsAttachedToSomething, true));
        // End:0x112
        if(UnknownLocal_1 != none)
        {
            UnknownLocal_1.bIsPopulationSystemAwareOfPickup = true;
            UnknownLocal_1.bKillDuringLevelTransition = false;
            // End:0xDB
            if(Memento.bIsAttachedToSomething)
            {
                UnknownLocal_1.AdjustPickupPhysicsAndCollisionForBeingAttached();
            }
            UnknownLocal_1.SetSaveRotation(Memento.Rotation);
        }
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

function GiveTo(Pawn P, bool bReady)
{
    local editinline WaypointComponent Waypoint;

    UnknownLocal_1 = WillowVendingMachineBase(Base);
    // End:0x3F
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_1.NotifyBasedPickupRemoved(self);
    }
    UnknownLocal_3 = WillowItem(Inventory);
    // End:0x7E
    if(UnknownLocal_3 != none)
    {
        UnknownLocal_3.PickupDisassociated(self);
    }
    // End:0xC0
    foreach ComponentList(class'WaypointComponent', Waypoint)
    {
        Waypoint.RemoveWaypoint();
        // End:0xC0
        break;        
    }    
    super.GiveTo(P, bReady);
    //return;    
}

