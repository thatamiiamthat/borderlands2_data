simulated event RigidBodyCollision(PrimitiveComponent HitComponent, PrimitiveComponent OtherComponent, const out CollisionImpactData RigidCollisionData, int ContactIndex)
{
    local ImpactResponseParameters ImpactResponseParams;

    UnknownLocal_1 = WillowImpactDefinition(Inventory.GetDroppedImpactDefinition());
    // End:0x21D
    if((UnknownLocal_1 != none) && (WorldInfo.TimeSeconds - LastImpactEffectTime) >= ImpactEffectDelay)
    {
        // End:0x1DD
        if(ImpactEffectPlayCount < MaxImpactEffectPlayCount)
        {
            ImpactResponseParams = class'WillowPhysicalMaterialProperty'.default.DefaultResponseParameters;
            // End:0x157
            if(ImpactVelocityAkRtpc != none)
            {
                ImpactResponseParams.RtpcParameterValues.Add(1;
                ImpactResponseParams.RtpcParameterValues[0].AkRtpc = ImpactVelocityAkRtpc;
                ImpactResponseParams.RtpcParameterValues[0].Value = VSize(Velocity);
            }
            LastImpactEffectTime = WorldInfo.TimeSeconds;
            ++ ImpactEffectPlayCount;
            class'WillowPhysicalMaterialProperty'.static.StaticRigidBodyImpact(UnknownLocal_1, self, HitComponent, OtherComponent, RigidCollisionData, ContactIndex, ImpactResponseParams);
        }
        // End:0x21D
        if(ImpactEffectPlayCount >= MaxImpactEffectPlayCount)
        {
            MeshComponent(CollisionComponent).SetNotifyRigidBodyCollision(false);
        }
    }
    //return;    
}

