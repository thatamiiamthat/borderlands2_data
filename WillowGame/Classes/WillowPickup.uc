function Behavior_ChangeUsability(Engine.ITargetable.EChangeStatus ChangeType, ActorComponent UsedComponent, IUsable.EUsabilityType UsedType)
{
    // End:0x18
    if(!int(UsedType) == int(0))
    {
        return;
    }
    switch(ChangeType)
    {
        // End:0x49
        case 0:
            SetPickupability(!bPickupable);
            // End:0x72
            break;
        // End:0x5C
        case 1:
            SetPickupability(true);
            // End:0x72
            break;
        // End:0x6F
        case 2:
            SetPickupability(false);
            // End:0x72
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

function Behavior_ChangeUsabilityCost(Engine.ITargetable.EChangeStatus ChangeType, Engine.WillowInventoryDefinition.ECurrencyType CostType, int CostAmount, IUsable.EUsabilityType UsedType)
{
    // End:0x18
    if(!int(UsedType) == int(0))
    {
        return;
    }
    switch(ChangeType)
    {
        // End:0x45
        case 0:
            UnknownLocal_1 = !bCostsToPickUp;
            // End:0x66
            break;
        // End:0x54
        case 1:
            UnknownLocal_1 = true;
            // End:0x66
            break;
        // End:0x63
        case 2:
            UnknownLocal_1 = false;
            // End:0x66
            break;
        // End:0xFFFF
        default:
            break;
    }
    // End:0x8A
    if(UnknownLocal_1 != bCostsToPickUp)
    {
        bCostsToPickUp = UnknownLocal_1;
    }
    // End:0xB8
    if(int(CostType) != int(CostsToPickUpType))
    {
        CostsToPickUpType = CostType;
    }
    // End:0xE2
    if(CostAmount != CostsToPickUpAmount)
    {
        CostsToPickUpAmount = CostAmount;
    }
    //return;    
}

function SetPickupability(bool bNewPickupability)
{
    bPickupable = bNewPickupability;
    RegisterMissionDirector();
    SetMissionMaterialParameter();
    TryToSetInteractParticles(bPickupable);
    //return;    
}

simulated function SetMissionMaterialParameter()
{
    local LinearColor GlowColor;
    local editinline MeshComponent Mesh;
    local name GlowColorName;

    // End:0x189
    if(bIsMissionItem)
    {
        Mesh = MeshComponent(CollisionComponent);
        // End:0x189
        if(Mesh != none)
        {
            UnknownLocal_1 = 0;
            GlowColorName = class'WillowGlobals'.static.GetWillowGlobals().GetGlobalsDefinition().MissionGlowColorParameter;
            Mesh.Behavior_GetColorParameterValue(UnknownLocal_1, GlowColorName, GlowColor);
            // End:0x131
            if(bPickupable)
            {
                GlowColor.A = 1;
                Mesh.Behavior_SetColorParameterValue(UnknownLocal_1, GlowColorName, GlowColor);                
            }
            else
            {
                GlowColor.A = 0;
                Mesh.Behavior_SetColorParameterValue(UnknownLocal_1, GlowColorName, GlowColor);
            }
        }
    }
    //return;    
}

