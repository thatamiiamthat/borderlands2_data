simulated function BeginFocus(Pawn User)
{
    local Vector POVLocation;
    local Rotator POVRotation;

    UnknownLocal_1 = WillowPlayerController(User.Controller);
    // End:0x3C
    if(!UnknownLocal_1 != none)
    {
        return;
    }
    // End:0x71
    if(!EqualEqual_InterfaceInterface(UnknownLocal_1.FocusObject, IFocusable(none)))
    {
        return;
    }
    UnknownLocal_1.GetPlayerViewPoint(POVLocation, POVRotation);
    UnknownLocal_1.FocusObject = IFocusable(self);
    UnknownLocal_1.FocusCamRot = POVRotation;
    UnknownLocal_1.FocusCamLoc = POVLocation;
    UnknownLocal_1.FocusFOVAngle = -1;
    //return;    
}

simulated function EndFocus(Pawn User)
{
    UnknownLocal_1 = WillowPlayerController(User.Controller);
    // End:0x3C
    if(!UnknownLocal_1 != none)
    {
        return;
    }
    // End:0x71
    if(!EqualEqual_InterfaceInterface(UnknownLocal_1.FocusObject, IFocusable(self)))
    {
        return;
    }
    UnknownLocal_1.FocusObject = none;
    UnknownLocal_1.FocusCamReturnTime = WorldInfo.TimeSeconds;
    //return;    
}

