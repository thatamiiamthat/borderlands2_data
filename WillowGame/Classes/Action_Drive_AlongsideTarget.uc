class Action_Drive_AlongsideTarget extends Action_Drive_Pursuit
    editinlinenew
    hidecategories(Mobile,Object,HideMe,ActionSequence,LoadBalance,Movement,Pursuit);

var() float IdealDistanceFromTarget;
var() float IdealDistanceAheadOfTarget;
var() float MinSpeedMultiplierWhenAheadOfTarget;
var() float MaxSpeedMultiplierWhenAheadOfTarget;
var() float SpeedDamperWhenRightAlongsideTarget;
var() float DistanceAheadOfTargetToAimFor;
var() float NudgeDistance;

function Vector DetermineClosestFlankPoint()
{
    local Vector tx, ty, TZ, TargetLeftFlank, TargetRightFlank;

    Target.GetAxes(Target.Rotation, tx, ty, TZ);
    TargetLeftFlank = (Target.Location - (IdealDistanceFromTarget * ty)) + (IdealDistanceAheadOfTarget * tx);
    TargetRightFlank = (Target.Location + (IdealDistanceFromTarget * ty)) + (IdealDistanceAheadOfTarget * tx);
    // End:0x176
    if(VSize(TargetLeftFlank - MyVehicle.Location) < VSize(TargetRightFlank - MyVehicle.Location))
    {
        return TargetLeftFlank + (DistanceAheadOfTargetToAimFor * tx);        
    }
    else
    {
        return TargetRightFlank + (DistanceAheadOfTargetToAimFor * tx);
    }
    //return ReturnValue;    
}

function Vector GetPursuitPointAndSpeedMultiplier(out float OutSpeedMultiplier)
{
    local Vector ClosestFlankPoint, TargetReferencePoint, tx, ty, TZ;

    OutSpeedMultiplier = 1;
    // End:0xA4
    if(((EnemyPosBreadCrumbs.Length > 0) && int(CurrentState) != int(1)) && VSize(MyVehicle.Location - Target.Location) >= DistanceStopUsingBreadcrumbs)
    {
        return EnemyPosBreadCrumbs[0].pos;
    }
    EnemyPosBreadCrumbs.Length = 0;
    ClosestFlankPoint = DetermineClosestFlankPoint();
    TargetReferencePoint = Target.Location + (IdealDistanceAheadOfTarget * Vector(Target.Rotation));
    // End:0x200
    if(((MyVehicle.Location - TargetReferencePoint) Dot Vector(Target.Rotation)) > float(0))
    {
        WantsToStopBoosting = true;
        OutSpeedMultiplier = SpeedDamperWhenRightAlongsideTarget * FClamp(VSize(Target.Velocity) / MyVehicle.MaxSpeed, 0, 1);
        OutSpeedMultiplier = FClamp(OutSpeedMultiplier, MinSpeedMultiplierWhenAheadOfTarget, MaxSpeedMultiplierWhenAheadOfTarget);
    }
    Target.GetAxes(Target.Rotation, tx, ty, TZ);
    UnknownLocal_1 = (MyVehicle.Location - Target.Location) Dot ty;
    UnknownLocal_3 = Vector(MyVehicle.Rotation) Dot Vector(Target.Rotation);
    // End:0x3CD
    if(UnknownLocal_3 > 0.7071)
    {
        // End:0x363
        if(Abs(UnknownLocal_1) <= (0.7 * IdealDistanceFromTarget))
        {
            // End:0x341
            if(UnknownLocal_1 > float(0))
            {
                ClosestFlankPoint += (NudgeDistance * ty);                
            }
            else
            {
                ClosestFlankPoint -= (NudgeDistance * ty);
            }            
        }
        else
        {
            // End:0x3CD
            if(Abs(UnknownLocal_1) >= (1.3 * IdealDistanceFromTarget))
            {
                // End:0x3AE
                if(UnknownLocal_1 > float(0))
                {
                    ClosestFlankPoint -= (NudgeDistance * ty);                    
                }
                else
                {
                    ClosestFlankPoint += (NudgeDistance * ty);
                }
            }
        }
    }
    // End:0x440
    if(((ClosestFlankPoint - MyVehicle.Location) Dot Vector(MyVehicle.Rotation)) < 0.1)
    {
        OutSpeedMultiplier = FMin(OutSpeedMultiplier, SpeedMultiplierDuringSharpTurns);
    }
    // End:0x4C9
    if((UnknownLocal_3 > 0.7071) && (Normal(Target.Location - MyVehicle.Location) Dot Vector(MyVehicle.Rotation)) > 0.7071)
    {
        WantsToBoost = true;
    }
    return ClosestFlankPoint;
    //return ReturnValue;    
}

defaultproperties
{
    IdealDistanceFromTarget=1100
    IdealDistanceAheadOfTarget=1000
    MaxSpeedMultiplierWhenAheadOfTarget=1
    SpeedDamperWhenRightAlongsideTarget=0.9
    DistanceAheadOfTargetToAimFor=10000
    NudgeDistance=1000
    DistanceToTargetStartAction=5000
    DistanceToTargetStopAction=10000
}