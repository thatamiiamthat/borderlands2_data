function QuitToMenu(bool bSaveProfile)
{
    local GearboxFramework.GearboxGlobals.EGBXPlatform Platform;

    Platform = class'GearboxGlobals'.static.GetPlatform();
    // End:0x8B
    if(SaveOwner.IsPrimaryPlayer())
    {
        SaveOwner.bIgnoreNetworkMessages = true;
        SaveOwner.ClearGameInviteDelegates();
    }
    // End:0x297
    if(bSaveProfile)
    {
        SavingDlg = SaveOwner.GFxUIManager.ShowDialog();
        SavingDlg.ShowTooltips(false);
        // End:0x14D
        if(int(Platform) == int(2))
        {
            SavingDlg.AutoLocEnable("WillowMenu", "dlgSavingOnQuitPS3");            
        }
        else
        {
            SavingDlg.AutoLocEnable("WillowMenu", "dlgSavingOnQuit");
        }
        SavingDlg.ApplyLayout();
        // End:0x1CE
        if(int(Platform) == int(1))
        {
            MinSaveDuration = 3;            
        }
        else
        {
            MinSaveDuration = 0;
        }
        PlayersToSave.Length = 0;
        // End:0x270
        if(SaveOwner.IsPrimaryPlayer())
        {
            // End:0x26C
            foreach SaveOwner.LocalPlayerControllers(class'WillowPlayerController', UnknownLocal_1)
            {
                // End:0x26B
