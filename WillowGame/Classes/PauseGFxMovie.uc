private final function ApplySaveText(WillowGFxDialogBox Dlg, int PlayerIndex, WillowPlayerController WPC, bool bCanSave)
{
    local string PlayerName, SaveString;

    PlayerName = WPC.PlayerReplicationInfo.GetHumanReadableHTMLName();
    SaveString = Localize("dlgExit", ((bCanSave) ? "SaveState_Yes" : "SaveState_No"), "WillowMenu");
    Dlg.ReplaceDialogText("%PLAYER" $ string(PlayerIndex), PlayerName);
    Dlg.ReplaceDialogText("%SAVESTATE" $ string(PlayerIndex), SaveString);
    //return;    
}

