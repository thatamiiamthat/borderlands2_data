                {
                    PlayersToSave.AddItem(UnknownLocal_1;
                }                
            }                        
        }
        else
        {
            PlayersToSave.AddItem(SaveOwner;
        }
        SaveNextPlayer(0);
        return;
    }
    // End:0x2C2
    if(!SaveOwner.IsPrimaryPlayer())
    {
        UnknownLocal_3 = true;
    }
    CompleteQuitToMenu(UnknownLocal_3);
    //return;    
}

