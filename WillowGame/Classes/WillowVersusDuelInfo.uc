function EndDuel(optional WillowPlayerPawn NewWinner, optional WillowPlayerPawn NewLoser, optional bool bCausedByGoingOutOfBounds)
{
    !bDuelEnded;
    bDuelEnded = true;
    ClearDuelTimers();
    SetWinnerAndLoser(NewWinner, NewLoser);
    NotifyDuelResult();
    RestoreTemporaryProfilesForCombatants();
    OnDuelEnd();
    //return;    
}

function SetWinnerAndLoser(WillowPlayerPawn NewWinner, WillowPlayerPawn NewLoser)
{
    // End:0xAD
    if(NewLoser != none)
    {
        // End:0x47
        if(NewWinner != none)
        {
            Winner = NewWinner;
            Loser = NewLoser;            
        }
        else
        {
            // End:0x87
            if(NewLoser == Challenger)
            {
                Winner = Competitor;
                Loser = Challenger;                
            }
            else
            {
                Winner = Challenger;
                Loser = Competitor;
            }
        }
    }
    //return;    
}

function NotifyDuelResult()
{
    // End:0x1CC
    if((Winner == none) && Loser == none)
    {
        UpdatePlayerStat(Challenger, 'STAT_PLAYER_DUELS_DRAWS');
        UpdatePlayerStat(Competitor, 'STAT_PLAYER_DUELS_DRAWS');
        BroadcastLocalizedMessage(class'WillowVersusDuelMessage', 9, Challenger.PlayerReplicationInfo, Competitor.PlayerReplicationInfo);
        class'BehaviorBase'.static.RunBehaviors(DuelGlobals.OnDuelDraw, self, Challenger, Competitor);
        class'WillowLeviathanService'.static.RecordDuelEndedEventForPlayer(WillowPlayerController(Challenger.GetController()), CompetitorPRI.PlayerID, 2);
        class'WillowLeviathanService'.static.RecordDuelEndedEventForPlayer(WillowPlayerController(Competitor.GetController()), ChallengerPRI.PlayerID, 2);        
    }
    else
    {
        UpdatePlayerStat(Winner, 'STAT_PLAYER_DUELS_WINS');
        UpdatePlayerStat(Loser, 'STAT_PLAYER_DUELS_LOSSES');
        // End:0x23C
        if(Winner == Challenger)
        {
            UnknownLocal_1 = ChallengerPRI;
            UnknownLocal_3 = CompetitorPRI;            
        }
        else
        {
            // End:0x271
            if(Winner == Competitor)
            {
                UnknownLocal_1 = CompetitorPRI;
                UnknownLocal_3 = ChallengerPRI;
            }
        }
        BroadcastLocalizedMessage(class'WillowVersusDuelMessage', 10, UnknownLocal_1, UnknownLocal_3);
        class'BehaviorBase'.static.RunBehaviors(DuelGlobals.OnDuelWinLoss, self, Winner, Loser);
        class'WillowLeviathanService'.static.RecordDuelEndedEventForPlayer(WillowPlayerController(Winner.GetController()), UnknownLocal_3.PlayerID, 0);
        class'WillowLeviathanService'.static.RecordDuelEndedEventForPlayer(WillowPlayerController(Loser.GetController()), UnknownLocal_1.PlayerID, 1);
    }
    //return;    
}

