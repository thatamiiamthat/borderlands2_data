function CreateDuelArena()
{
    local Vector SpawnLoc;
    local Rotator SpawnRot;

    SpawnLoc = Competitor.Location;
    SpawnLoc.Z -= Competitor.CylinderComponent.CollisionHeight;
    SpawnRot.Yaw = Competitor.Rotation.Yaw;
