function float GetTimeSinceHurt()
{
    // End:0x19
    if(LastHurtTime == 0)
    {
        return 9999;
    }
    return Owner.WorldInfo.TimeSeconds - LastHurtTime;
    //return ReturnValue;    
}

function float GetTimeSinceAttacked()
{
    // End:0x19
    if(LastAttackedTime == 0)
    {
        return 9999;
    }
    return Owner.WorldInfo.TimeSeconds - LastAttackedTime;
    //return ReturnValue;    
}

