function float DistToFormationLeader()
{
    local Vector MyLoc, LeaderLoc;
    local IAIInterface MyAI, LeaderAI;

    MyAI = IAIInterface(Owner);
    LeaderAI = GetFormationLeader();
    // End:0x78
    if(EqualEqual_InterfaceInterface(MyAI, IAIInterface(none)) || EqualEqual_InterfaceInterface(LeaderAI, IAIInterface(none)))
    {
        return -1;
    }
    MyLoc = MyAI.GetAILocation();
    LeaderLoc = LeaderAI.GetAILocation();
    return VSize(MyLoc - LeaderLoc);
    //return ReturnValue;    
}

