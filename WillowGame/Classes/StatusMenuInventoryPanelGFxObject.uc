function extCompleteDrag_Equipped(int CellSuffix)
{
    // End:0x86
    if((StartEquipPanel == EquippedPanel) && EquippingThing == EquippedPanel.GetSelectedThing())
    {
        EquippedPanel.CleanUpAfterCancelledDrag();
        CancelEquip();
        FinishEquip('None', false);        
    }
    else
    {
        // End:0x106
        if(EquippedPanel.CanFinishDragOnCell(CellSuffix))
        {
            bInEquippedView = true;
            EquippedPanel.PrepareForFinishDrag(CellSuffix);
            CompleteEquip();
            FinishEquip('None', true);            
        }
        else
        {
            EquippedPanel.CleanUpAfterCancelledDrag();
            CancelEquip();
            FinishEquip('None', false);
        }
    }
    UpdateTooltipsText();
    //return;    
}

function extCompleteDrag_Backpack(int DropTargetIndex)
{
    local WillowDeclarations.EQuickWeaponSlot QuickWeaponSlot;

    UnknownLocal_1 = ParentMovie.WPCOwner.GetPawnInventoryManager();
    // End:0xF0
    if(DropTargetIndex == -1)
    {
        // End:0xCF
        if((StartEquipPanel == EquippedPanel) && SlotsUsed < MaxCapacity)
        {
            UnreadyThing(EquippingThing);
            ParentMovie.PlayUISound('DropItem');
            FinishEquip('None', true);            
        }
        else
        {
            CancelEquip();
            FinishEquip('None', false);
        }        
    }
    else
    {
        // End:0x128
        if(StartEquipPanel == BackpackPanel)
        {
            CancelEquip();
            FinishEquip('None', false);            
        }
        else
        {
            UnknownLocal_3 = BackpackPanel.GetThingByIndex(DropTargetIndex);
            // End:0x1B3
            if(UnknownLocal_3 == none)
            {
                UnreadyThing(EquippingThing);
                ParentMovie.PlayUISound('UnEquip');
                FinishEquip('None', true);                
            }
            else
            {
                // End:0x2CD
                if(CanReady(UnknownLocal_3))
                {
                    QuickWeaponSlot = EquippedPanel.GetWeaponSlotFromThing(EquippingThing);
                    // End:0x237
                    if(int(QuickWeaponSlot) != int(0))
                    {
                        UnknownLocal_1.ReadyBackpackInventory(UnknownLocal_3, QuickWeaponSlot);                        
                    }
                    else
                    {
                        UnknownLocal_1.ReadyBackpackInventory(UnknownLocal_3);
                    }
                    FlourishEquip(Localize("StatusMenu", "Equipped", "WillowGame"));
                    ParentMovie.PlayUISound('FinishEquip');
                    FinishEquip('None', true);                    
                }
                else
                {
                    ParentMovie.PlayUISound('ResultFailure');
                    FinishEquip('None', true);
                }
            }
        }
    }
    //return;    
}

