function FinishEquip(name TriggerKey, bool bCompleted)
{
    local name FocusPanelName, UnFocusPanelName;

    QueueNewInputHandler(NormalInputKey, TriggerKey);
    StatusMenuExGFxMovie(ParentMovie).FrozenThingType = 5;
    UnknownLocal_1 = EquippingThing != none;
    UnknownLocal_3 = SecondEquippingThing != none;
    EquippedPanel.StopEquip();
    EquippingThing = none;
    SecondEquippingThing = none;
    UnknownLocal_5 = BackpackPanel.GetThingByIndex(BackpackPanel.CurrentSelectedIndex);
    TweenCards(false, false);
    ItemCards[0].ItemCard.SetBackgroundStyle("highlight");
    // End:0x20D
    if(bCompleted)
    {
        // End:0x1BA
        if((UnknownLocal_1 && !UnknownLocal_3) && !bInEquippedView)
        {
            UnknownLocal_7 = BackpackPanel;
            UnknownLocal_9 = EquippedPanel;
            FocusPanelName = 'Backpack';
            UnFocusPanelName = 'Equipped';
            bInEquippedView = false;            
        }
        else
        {
            UnknownLocal_7 = EquippedPanel;
            FocusPanelName = 'Equipped';
            UnknownLocal_9 = BackpackPanel;
            UnFocusPanelName = 'Backpack';
            bInEquippedView = true;
        }        
    }
    else
    {
        UnknownLocal_7 = StartEquipPanel;
        // End:0x277
        if(StartEquipPanel == EquippedPanel)
        {
            FocusPanelName = 'Equipped';
            UnknownLocal_9 = BackpackPanel;
            UnFocusPanelName = 'Backpack';
            bInEquippedView = true;            
        }
        else
        {
            FocusPanelName = 'Backpack';
            UnknownLocal_9 = EquippedPanel;
            UnFocusPanelName = 'Equipped';
            bInEquippedView = false;
        }
    }
    UnknownLocal_7.SetActive(true);
    UnknownLocal_9.SetActive(false);
    TweenPanelToPosition(FocusPanelName, 0);
    TweenPanelToPosition(UnFocusPanelName, 1);
    UnknownLocal_7.OnSettingPanelForTransferring(true, false);
    UnknownLocal_9.OnSettingPanelForTransferring(false, false);
    SetLeftRightArrowVisibility(!bInEquippedView, bInEquippedView);
    StatusMenuExGFxMovie(ParentMovie).CurrentScreenTime = 0;
    bIsDoingEquip = false;
    BackpackPanel.bCanRolloverEmptyCells = false;
    BackpackPanel.ApplySortConfiguration(CachedSortFilterConfig);
    StatusMenuExGFxMovie(ParentMovie).RefreshInventoryScreen(true);
    // End:0x44E
    if(UnknownLocal_5 != none)
    {
        BackpackPanel.SetSelectedIndexByThing(UnknownLocal_5);
    }
    UpdateTooltipsText();
    Refresh();
    //return;    
}

