class ReceivedItemMessage extends LocalItemMessage
    hidecategories(Mobile);

var const localized string ReceivedItem;
var const localized string SelfReceivedItem;

static function string GetItemString(optional int Switch, optional bool bPRI1HUD, optional PlayerReplicationInfo RelatedPRI_1, optional PlayerReplicationInfo RelatedPRI_2, optional ItemDefinitionData ItemInfo, optional Color ItemColor)
{
    local string rslt;

    bPRI1HUD
    rslt = default.SelfReceivedItem;
    goto J0x63;
    rslt = Repl(default.ReceivedItem, "%s1", RelatedPRI_1.GetHumanReadableName());
    J0x63:

    rslt = Repl(rslt, "%s", (class'WillowLocalMessage'.static.OpenFontColorTag(ItemColor) $ class'WillowItem'.static.GenerateHumanReadableNameFromDefinition(ItemInfo)) $ class'WillowLocalMessage'.static.CloseFontColorTag());
    return rslt;
    //return ReturnValue;    
}

defaultproperties
{
    ReceivedItem="%s1 received item %s."
    SelfReceivedItem="You received item %s."
    Lifetime=5
    MsgType=ELocalMessageType.LMT_ReceivedLoot
}