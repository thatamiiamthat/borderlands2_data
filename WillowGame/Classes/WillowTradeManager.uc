simulated function bool InventoryMatch(WillowInventory Inv, TradeSlot Slot)
{
    // End:0xE1
    if((int(Slot.Status) == int(2)) && WillowWeapon(Inv) != none)
    {
        return WillowWeapon(Inv).DefinitionData == Slot.WeaponData && (Slot.WInv == none) || Slot.WInv == Inv;        
    }
    else
    {
        // End:0x1BF
        if((int(Slot.Status) == int(1)) && WillowItem(Inv) != none)
        {
            return WillowItem(Inv).DefinitionData == Slot.ItemData && (Slot.WInv == none) || Slot.WInv == Inv;
        }
    }
    return false;
    //return ReturnValue;    
}

