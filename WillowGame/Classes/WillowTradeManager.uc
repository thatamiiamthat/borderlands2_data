simulated function UpdateStance(WillowTradeManager.PlayerTradingStance NewStance)
{
    // End:0x27
    if(!GetWPC().IsLocalPlayerController())
    {
        return;
    }
    TransactionHash = CalcTransactionHash();
    // End:0x6D
    if(!int(Role) == int(ROLE_Authority))
    {
        DoUpdateStance(NewStance, TransactionHash);
    }
    ServerUpdateStance(NewStance, TransactionHash);
    //return;    
}

simulated function UpdateCashOffered(int NewCashValue)
{
    // End:0x27
    if(!GetWPC().IsLocalPlayerController())
    {
        return;
    }
    UnknownLocal_1 = WillowPlayerReplicationInfo(GetWPC().PlayerReplicationInfo);
    // End:0x84
    if(!UnknownLocal_1.GetCurrencyOnHand(0) >= NewCashValue)
    {
        return;
    }
    // End:0x9C
    if(!int(Status) == int(3))
    {
        return;
    }
    // End:0xC5
    if(!int(Role) == int(ROLE_Authority))
    {
        DoUpdateCashOffered(NewCashValue);
    }
    ServerUpdateCashOffered(NewCashValue);
    //return;    
}

