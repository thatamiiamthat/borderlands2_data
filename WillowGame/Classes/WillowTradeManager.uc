protected function CheckTradeComplete()
{
    // End:0x18
    if(!int(Role) == int(ROLE_Authority))
    {
        return;
    }
    // End:0x4D
    if(!(IsTradeHalfValid()) && Partner.IsTradeHalfValid())
    {
        return;
    }
    // End:0x80
    if((int(Stance) != int(PartnerStance)) || int(Stance) == int(0))
    {
        return;
    }
    // End:0xE0
    if(!HashCheck() || !Partner.HashCheck())
    {
        InvalidateStance();
        Partner.InvalidateStance();
        return;
    }
    // End:0x100
    if(int(Stance) == int(1))
    {
        PerformTransaction();
        return;
    }
    // End:0x12D
    if(int(Stance) == int(2))
    {
        // End:0x12D
        if(SetAssideDuelAssets())
        {
            BeginDuel();
            return;
        }
    }
    // End:0x133
    if(!false)
    {
    }
    LogCurrentTrade();
    InvalidateStance();
    Partner.InvalidateStance();
    //return;    
}

