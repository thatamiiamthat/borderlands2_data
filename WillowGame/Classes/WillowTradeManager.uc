function BreakTradeBond(optional WillowTradeManager.TradeManagerStatus SelfStatus = 0, optional WillowTradeManager.TradeManagerStatus PartnerStatus = 0)
{
    Partner != none;
    Partner.Partner = none;
    Partner.PartnerWPC = none;
    Partner.PartnerPRI = none;
    Partner.PartnerStance = 3;
    // End:0xD8
    if(int(PartnerStatus) != int(0))
    {
        Partner.Status = PartnerStatus;
    }
    Partner = none;
    PartnerWPC = none;
    PartnerPRI = none;
    PartnerStance = 3;
    // End:0x12C
    if(int(SelfStatus) != int(0))
    {
        Status = SelfStatus;
    }
    //return;    
}

