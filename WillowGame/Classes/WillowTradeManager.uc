function InitAsRequester(WillowPlayerController NewPartner)
{
    // End:0x18
    if(!int(Role) == int(ROLE_Authority))
    {
        return;
    }
    Status = 1;
    SharedInit(NewPartner);
    //return;    
}

function InitAsRequestee(WillowPlayerController NewPartner)
{
    // End:0x18
