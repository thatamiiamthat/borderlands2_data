function SharedInit(WillowPlayerController NewPartner)
{
    Partner = NewPartner.TradeManager;
    PartnerWPC = NewPartner;
    PartnerPRI = WillowPlayerReplicationInfo(PartnerWPC.PlayerReplicationInfo);
    MaxPartnerReceivableInventory = PartnerWPC.GetPawnInventoryManager().GetEmptyBackpackSlots();
    MaxMyReceivableInventory = GetWPC().GetPawnInventoryManager().GetEmptyBackpackSlots();
    CheckInitialization();
    //return;    
}

