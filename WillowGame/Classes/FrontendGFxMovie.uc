function ResetMOTD()
{
    ClearTimer('ShowMOTD');
    ClearTimer('HideMOTD');
    ClearTimer('DelayedHideMOTD');
    MessageOfTheDayIdx = -1;
    MessagesOfTheDay = GetMessagesOfTheDay();
    HideMOTD();
    //return;    
}

function DelayedResetMOTD()
{
    // End:0x1BC
    if((MessagesOfTheDay.Length > 0) && (IsTimerActive('HideMOTD')) || IsTimerActive('DelayedHideMOTD'))
    {
        UnknownLocal_1 = TimerPauseTicker.Timers.Find('FuncName', 'HideMOTD';
        // End:0x104
        if((UnknownLocal_1 == -1) || TimerPauseTicker.Timers[UnknownLocal_1].Rate == float(0))
        {
            UnknownLocal_1 = TimerPauseTicker.Timers.Find('FuncName', 'DelayedHideMOTD';
        }
        UnknownLocal_3 = TimerPauseTicker.Timers[UnknownLocal_1].Rate - TimerPauseTicker.Timers[UnknownLocal_1].Count;
        ClearTimer('HideMOTD');
        ClearTimer('ShowMOTD');
        SetTimer(UnknownLocal_3, false, 'DelayedHideMOTD');        
    }
    else
    {
        ResetMOTD();
    }
    //return;    
}

protected function DelayedHideMOTD()
{
    local MessageOfTheDay CurrentMessage;

    // End:0x24
    if(MessageOfTheDayIdx == 0)
    {
        CurrentMessage = MessagesOfTheDay[0];
    }
    MessageOfTheDayIdx = -1;
    MessagesOfTheDay = GetMessagesOfTheDay();
    // End:0x123
    if(MessagesOfTheDay.Length > 1)
    {
        // End:0x123
        if(((CurrentMessage.Header == MessagesOfTheDay[0].Header) && CurrentMessage.Body == MessagesOfTheDay[0].Body) && CurrentMessage.DisplayTime == MessagesOfTheDay[0].DisplayTime)
        {
            MessageOfTheDayIdx = 0;
        }
    }
    HideMOTD();
    //return;    
}

