function MessageOfTheDay GetMessageOfTheDay(string SectionName, string KeyName, string PackageName)
{
    local MessageOfTheDay MOTD;
    local string StructValue;

    StructValue = ResolveDataStoreMarkup(Localize(SectionName, KeyName, PackageName));
    // End:0x1E1
    if(StructValue != "")
    {
        UnknownLocal_1 = InStr(StructValue, "Header=\"");
        UnknownLocal_3 = InStr(StructValue, "\",Body=\"");
        UnknownLocal_5 = InStr(StructValue, "\",DisplayTime=");
        // End:0x1E1
        if(((UnknownLocal_1 > -1) && UnknownLocal_3 > -1) && UnknownLocal_5 > -1)
        {
            UnknownLocal_7 = UnknownLocal_1 + Len("Header=\"");
            MOTD.Header = Mid(StructValue, UnknownLocal_7, UnknownLocal_3 - UnknownLocal_7);
            UnknownLocal_7 = UnknownLocal_3 + Len("\",Body=\"");
            MOTD.Body = Mid(StructValue, UnknownLocal_7, UnknownLocal_5 - UnknownLocal_7);
            UnknownLocal_7 = UnknownLocal_5 + Len("\",DisplayTime=");
            MOTD.DisplayTime = int(Mid(StructValue, UnknownLocal_7, (Len(StructValue) - 1) - UnknownLocal_7));
        }
    }
    return MOTD;
    //return ReturnValue;    
}

function bool IsValidMessageOfTheDay(MessageOfTheDay MOTD)
{
    return ((MOTD.Header != "") && MOTD.Body != "") && MOTD.DisplayTime > 0;
    //return ReturnValue;    
}

function ShowMOTD()
{
    // End:0x151
    if((MyFrontendDefinition != none) && MessagesOfTheDay.Length > 0)
    {
        MessageOfTheDayIdx = __NFUN_253__(MessageOfTheDayIdx + 1, MessagesOfTheDay.Length);
        SetVariableString(MyFrontendDefinition.MOTD_HeaderPath, MessagesOfTheDay[MessageOfTheDayIdx].Header);
        SetVariableString(MyFrontendDefinition.MOTD_BodyPath, MessagesOfTheDay[MessageOfTheDayIdx].Body);
        SingleArgInvokeS("menu.inner.messageOfTheDay.gotoAndPlay", "go");
        SetTimer(float(MessagesOfTheDay[MessageOfTheDayIdx].DisplayTime), false, 'HideMOTD');
    }
    //return;    
}

function HideMOTD()
{
    // End:0xD6
    if((MyFrontendDefinition != none) && MessagesOfTheDay.Length > 0)
    {
        SingleArgInvokeS("menu.inner.messageOfTheDay.gotoAndPlay", "reverse");
