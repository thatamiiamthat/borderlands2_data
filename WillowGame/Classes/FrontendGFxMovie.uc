        else
        {
            // End:0x281
            if(WPCOwner.WorldInfo.IsConsoleBuild(2) && int(LoginStatus) < int(2))
            {
                return false;
            }
        }
    }
    UnknownLocal_3 = PlayerList.GetPRI(UniqueId);
    // End:0x2DC
    if((UnknownLocal_3 != none) && UnknownLocal_3.bIsGuest)
