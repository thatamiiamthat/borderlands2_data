function HandleSplitscreenJoinAttempt(int ControllerId)
{
    local WillowPlayerController.EWillowNetworkType NetworkType;
    local Engine.OnlineSubsystem.ELoginStatus LoginStatus;

    // End:0x20A
    if((!bSplitJoinInProgress && !WPCOwner.IsCurrentGameFull()) && class'UIInteraction'.static.GetPlayerCount() < 2)
    {
        bSplitJoinInProgress = true;
        UnknownLocal_1 = WPCOwner.OnlineSub.GameInterface.GetGameSettings('Game');
        NetworkType = GetNetworkType(UnknownLocal_1);
        LoginStatus = WPCOwner.OnlineSub.PlayerInterface.GetLoginStatus(byte(ControllerId));
        // End:0x1F7
        if(!IsProfileValidForCurrentGame(NetworkType, LoginStatus, ControllerId))
        {
            SavedSplitJoinControllerId = ControllerId;
            // End:0x1D8
            if((int(LoginStatus) == int(0)) || int(WPCOwner.WorldInfo.NetMode) == int(NM_Client))
            {
                ShowSplitLoginUI();                
            }
            else
            {
                ShowSplitJoinSessionChangeConfirmation(NetworkType, LoginStatus);
            }            
        }
        else
        {
            AddSplitscreenPlayer(ControllerId);
        }
    }
    //return;    
}

private final function bool IsProfileValidForCurrentGame(WillowPlayerController.EWillowNetworkType CurrentNetworkType, Engine.OnlineSubsystem.ELoginStatus LoginStatus, int ControllerId)
{
    // End:0x5C
    if(((int(CurrentNetworkType) == int(0)) && !CanPlayOnline(ControllerId)) || (int(CurrentNetworkType) == int(1)) && int(LoginStatus) == int(0))
    {
        return false;
    }
    return true;
    //return ReturnValue;    
}

