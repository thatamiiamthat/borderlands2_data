event OnClose()
{
    PlayerList.ShutDown();
    PlayerList = none;
    TheList.Cleanup();
    MessagesOfTheDay.Remove(0, MessagesOfTheDay.Length;
    ClearTimer('ShowMOTD');
    ClearTimer('HideMOTD');
    ClearTimer('RefreshFriends');
    ClearTimer('RegisterGRIDelegates');
    ClearSplitscreenLoginDelegates();
    ClearOSSDelegates();
    ClearGRIDelegates();
    ClearTimer('StartMenuMusic');
    WPCOwner.UnregisterSaveGameLoadedDelegate(OnSaveGameLoaded);
    WPCOwner.__OnLoadLastSaveGameComplete__Delegate = None;
    // End:0x176
    if(ConfirmDisconnectDlg != none)
    {
        ConfirmDisconnectDlg.Close();
        ConfirmDisconnectDlg = none;
    }
    // End:0x1B0
    if(ConfirmReturnToTitleDlg != none)
    {
        ConfirmReturnToTitleDlg.Close();
        ConfirmReturnToTitleDlg = none;
    }
    HideOptionsMovie();
    // End:0x1F4
    if(MatchmakingMovie != none)
    {
        MatchmakingMovie.Close();
        MatchmakingMovie = none;
    }
    HideNetworkOptions();
    // End:0x238
    if(SaveGameDlg != none)
    {
        SaveGameDlg.Close();
        SaveGameDlg = none;
    }
    HideServerBrowser();
    HideAccountMovie();
    HideMarketplaceMovie();
    HideMatchmakingDialog();
    HideUpsell();
    HideUpsellNotification();
    // End:0x2AE
    if(UpsellMovie != none)
    {
        UpsellMovie.Close();
        UpsellMovie = none;
    }
    UnknownLocal_1 = InteractionOverrideSounds.Find('Interaction', 'MusicStop';
    // End:0x33B
    if(UnknownLocal_1 != -1)
    {
        GetPC().WorldInfo.PostAkEvent(InteractionOverrideSounds[UnknownLocal_1].AkEvent);
    }
    super(WillowGFxMovie).OnClose();
    //return;    
}

