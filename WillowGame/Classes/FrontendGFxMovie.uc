            UnknownLocal_1.AppendButton('Dif1', Repl(ButtonText, "%PLAYTHROUGH_NAME%", Localize("Playthrough", "PLAYTHROUGH_NAME_1", "WillowMenu")),, OnChooseDifficulty_Click);
            UnknownLocal_1.AutoAppendButton('Cancel');
            UnknownLocal_1.ApplyLayout();
            // End:0x440
            if(SaveGame.PlaythroughsCompleted > 2)
            {
                UnknownLocal_1.SetDefaultButton('Dif4', false);                
            }
            else
            {
                // End:0x48C
