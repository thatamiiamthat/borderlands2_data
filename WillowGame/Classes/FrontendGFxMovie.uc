    if((WPCOwner.OnlineSub != none) && NotEqual_InterfaceInterface(WPCOwner.OnlineSub.PlayerInterfaceEx, OnlinePlayerInterfaceEx(none)))
    {
        return true;
    }
    return false;
    //return ReturnValue;    
}

function bool CanMute(UniqueNetId UniqueId)
{
    // End:0x59
    if(class'GameEngine'.static.GetOnlineSubsystem().Class.Name == 'OnlineSubsystemEpicStore')
    {
        return false;
    }
    // End:0xF1
    if(class'GameEngine'.static.GetOnlineSubsystem().Class.Name == 'OnlineSubsystemSteamworks')
    {
        return !class'GameEngine'.static.GetOnlineSubsystem().UniqueNetIdIsBifrostUser(UniqueId);
    }
    // End:0x210
    if(WPCOwner.WorldInfo.IsConsoleBuild(1))
    {
        // End:0x210
        if((WPCOwner.OnlineSub != none) && NotEqual_InterfaceInterface(WPCOwner.OnlineSub.PlayerInterface, OnlinePlayerInterface(none)))
        {
            // End:0x210
            if(int(WPCOwner.OnlineSub.PlayerInterface.GetLoginStatus(WPCOwner.GetMyControllerId())) != int(2))
            {
                return false;
            }
        }
    }
    UnknownLocal_1 = PlayerList.GetPRI(UniqueId);
    // End:0x26B
    if((UnknownLocal_1 != none) && UnknownLocal_1.bIsGuest)
    {
        return false;
    }
    // End:0x2E1
    if((!IsLocalPlayerId(UniqueId) && PlayerList.IsInCurrentGame(UniqueId)) && !PlayerList.IsPlayerMuted(UniqueId))
    {
        return true;
    }
    return false;
    //return ReturnValue;    
}

