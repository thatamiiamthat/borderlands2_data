function bool OverpowerLevelInputKey(WillowGFxDialogBox Dlg, int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    UnknownLocal_1 = WPCOwner.GetCachedSaveGame();
    // End:0x32
