private final function ShowSplitJoinSessionChangeConfirmation(WillowPlayerController.EWillowNetworkType CurrentNetworkType, Engine.OnlineSubsystem.ELoginStatus SplitPlayerLoginStatus)
{
    local string DialogSection;

    // End:0x8E
    if(int(CurrentNetworkType) == int(0))
    {
        // End:0x59
        if(int(SplitPlayerLoginStatus) > int(0))
        {
            DialogSection = "dlgConfirmSwitchSessionOnlineToLan";            
        }
        else
        {
            DialogSection = "dlgConfirmSwitchSessionOnlineToOffline";
        }        
    }
    else
    {
        DialogSection = "dlgConfirmSwitchSessionLanToOffline";
    }
    UnknownLocal_1 = WPCOwner.GFxUIManager.ShowDialog();
    UnknownLocal_1.DisplayYesNoBox("WillowMenu", DialogSection, OnConfirmSwitchSession);
    UnknownLocal_1.SetAllowNonOwnerInput(true);
    //return;    
}

function bool OnConfirmSwitchSession(WillowGFxDialogBox Dlg, int ControllerId)
{
    // End:0x19
    if(ControllerId != SavedSplitJoinControllerId)
    {
        return true;
    }
    // End:0x188
    if(Dlg.DialogResult == 'Yes')
    {
        bSplitJoinAwaitingNetworkTransition = true;
        // End:0x165
        if((!class'WorldInfo'.static.IsConsoleBuild() || WPCOwner.AreAllPlayersLoggedIn() && int(WPCOwner.OnlineSub.PlayerInterface.GetLoginStatus(byte(SavedSplitJoinControllerId))) > int(0)) && class'UIInteraction'.static.HasLinkConnection())
        {
            WPCOwner.bHostLanGame = true;
            WPCOwner.AttemptSystemLinkTransition(true);            
        }
        else
        {
            WPCOwner.AttemptOfflineTransition(true);
        }        
    }
    else
    {
        bSplitJoinInProgress = false;
