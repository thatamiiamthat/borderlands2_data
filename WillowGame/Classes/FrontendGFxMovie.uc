function bool SharedHandleInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    local WillowPlayerController.EWillowNetworkType NetworkType;

    UnknownLocal_1 = class'UIInteraction'.static.GetPlayerIndex(ControllerId);
    switch(ukey)
    {
        // End:0x4D
        case 'XboxTypeS_Y':
        // End:0x94
        case 'C':
            // End:0x92
            if(CanShowCharacterSelect(ControllerId))
            {
                // End:0x92
                if(int(uevent) == int(1))
                {
                    OpenCharacterSelect(UnknownLocal_1);
                }
            }
            return true;
        // End:0xA0
        case 'XboxTypeS_Back':
        // End:0x1CF
        case 'N':
            // End:0x1CD
            if(int(uevent) == int(1))
            {
                // End:0x1CD
                if((IsPlayerOwner(ControllerId)) && int(WPCOwner.WorldInfo.NetMode) != int(NM_Client))
                {
                    // End:0x1B0
                    if(WPCOwner.bRestoringNetwork)
                    {
                        WPCOwner.GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgNetworkRestoreInProgress");                        
                    }
                    else
                    {
                        PlayUISound('MenuOpen');
                        ShowNetworkOptions();
                    }
                }
            }
            return true;
        // End:0x1DB
        case 'Escape':
        // End:0x279
        case 'XboxTypeS_B':
            // End:0x277
            if(int(uevent) == int(1))
            {
                // End:0x242
                if(IsPlayerOwner(ControllerId))
                {
                    // End:0x23F
                    if(!TheList.HandlePopList())
                    {
                        HandlePopListFail();
                    }                    
                }
                else
                {
                    // End:0x277
                    if(class'WillowGameViewportClient'.static.PlatformSupportsSplitscreen())
                    {
                        HandleSplitscreenLeaveAttempt(ControllerId);
                    }
                }
            }
            return true;
        // End:0x2B5
        case 'XboxTypes_X':
            // End:0x2B3
            if(int(uevent) == int(1))
            {
                // End:0x2B3
                if(UnknownLocal_1 == 1)
                {
                    ShowOptions(UnknownLocal_1);
                }
            }
            return true;
        // End:0x2C1
        case 'XboxTypeS_RightShoulder':
        // End:0x455
        case 'P':
            // End:0x453
            if(int(uevent) == int(1))
            {
                NetworkType = GetNetworkType(WPCOwner.OnlineSub.GameInterface.GetGameSettings('Game'));
                // End:0x453
                if(int(NetworkType) == int(0))
                {
                    // End:0x453
                    if(NotEqual_InterfaceInterface(WPCOwner.OnlineSub.PartyChatInterface, OnlinePartyChatInterface(none)))
                    {
                        // End:0x453
                        if(WPCOwner.OnlineSub.PartyChatInterface.IsInPartyChat(byte(ControllerId)))
                        {
                            WPCOwner.OnlineSub.PartyChatInterface.SendPartyGameInvites(byte(ControllerId));
                        }
                    }
                }
            }
            return true;
        // End:0x461
        case 'XboxTypeS_LeftShoulder':
        // End:0x6D8
        case 'O':
            // End:0x6D6
            if(int(uevent) == int(1))
            {
                // End:0x65F
                if(int(WPCOwner.OnlineSub.PlayerInterface.GetLoginStatus(byte(ControllerId))) == int(2))
                {
                    // End:0x563
                    if(int(class'GearboxGlobals'.static.GetPlatform()) == int(2))
                    {
                        WPCOwner.OnlineSub.PlayerInterfaceEx.ShowMessagesUI(byte(ControllerId));                        
                    }
                    else
                    {
                        // End:0x65C
                        if(NotEqual_InterfaceInterface(WPCOwner.OnlineSub.PartyChatInterface, OnlinePartyChatInterface(none)))
                        {
                            // End:0x65C
                            if(!WPCOwner.OnlineSub.PlayerInterface.IsGuestLogin(byte(ControllerId)))
                            {
                                WPCOwner.OnlineSub.PartyChatInterface.ShowPartyUI(byte(ControllerId));
                            }
                        }
                    }                    
                }
                else
                {
                    // End:0x6D6
                    if(int(class'GearboxGlobals'.static.GetPlatform()) == int(2))
                    {
                        WPCOwner.OnlineSub.PlayerInterface.ShowLoginUI();
                    }
                }
            }
            return true;
        // End:0x6E4
        case 'XboxTypeS_RightTrigger':
        // End:0x748
        case 'PageDown':
            // End:0x746
            if(CanShowSpectatorControls())
            {
                // End:0x746
                if(int(uevent) == int(1))
                {
                    // End:0x746
                    if(IsPlayerOwner(ControllerId))
                    {
                        WPCOwner.ViewNextSpectatorPoint();
                    }
                }
            }
            return true;
        // End:0x754
        case 'XboxTypeS_LeftTrigger':
        // End:0x7B8
        case 'PageUp':
            // End:0x7B6
            if(CanShowSpectatorControls())
            {
                // End:0x7B6
                if(int(uevent) == int(1))
                {
                    // End:0x7B6
                    if(IsPlayerOwner(ControllerId))
                    {
                        WPCOwner.ViewPrevSpectatorPoint();
                    }
                }
            }
            return true;
        // End:0xFFFF
        default:
            UnknownLocal_3 = WillowPlayerInput(WPCOwner.PlayerInput);
            // End:0x85C
            if(UnknownLocal_3 != none)
            {
                // End:0x85C
                if(ukey == UnknownLocal_3.GetKeyForAction('Say'))
                {
                    // End:0x85A
                    if(int(uevent) == int(1))
                    {
                        WPCOwner.StartTextChat();
                    }
                    return true;
                }
            }
            return false;
            break;
    }
    //return ReturnValue;    
}

