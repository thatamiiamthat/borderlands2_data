function bool DefaultHandleInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    UnknownLocal_1 = class'UIInteraction'.static.GetPlayerIndex(ControllerId);
    // End:0xBD
    if(UnknownLocal_1 == -1)
    {
        // End:0xB8
        if(class'WillowGameViewportClient'.static.PlatformSupportsSplitscreen())
        {
            // End:0xB8
            if((int(uevent) == int(1)) && (ukey == 'XboxTypeS_A') || ukey == 'XboxTypeS_Start')
            {
                HandleSplitscreenJoinAttempt(ControllerId);
            }
        }
        return true;        
    }
    else
    {
        PreviewInputKey(ControllerId, ukey, uevent);
        switch(ukey)
        {
            // End:0x101
            case 'Gamepad_LeftStick_Right':
            // End:0x10D
            case 'XboxTypeS_DPad_Right':
            // End:0x193
            case 'Right':
                // End:0x191
                if(int(uevent) == int(0))
                {
                    // End:0x191
                    if(IsPlayerOwner(ControllerId))
                    {
                        PlayerList.ResetFocus(false);
                        __OnInputKey__Delegate = PlayerListInputKey;
                        PlayUISound('VerticalMovement');
                    }
                }
                return true;
            // End:0xFFFF
            default:
                // End:0x1C0
                if(SharedHandleInputKey(ControllerId, ukey, uevent))
                {
                    return true;
                }
                // End:0x1DA
                if(!IsPlayerOwner(ControllerId))
                {
                    return true;
                }
                break;
            }
    }
    return false;
    //return ReturnValue;    
}

function bool PlayerListInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    UnknownLocal_1 = class'UIInteraction'.static.GetPlayerIndex(ControllerId);
    // End:0xBD
    if(UnknownLocal_1 == -1)
    {
        // End:0xB8
        if(class'WillowGameViewportClient'.static.PlatformSupportsSplitscreen())
        {
            // End:0xB8
            if((int(uevent) == int(1)) && (ukey == 'XboxTypeS_A') || ukey == 'XboxTypeS_Start')
            {
                HandleSplitscreenJoinAttempt(ControllerId);
            }
        }
        return true;        
    }
    else
    {
        PreviewInputKey(ControllerId, ukey, uevent);
        switch(ukey)
        {
            // End:0x101
            case 'Gamepad_LeftStick_Left':
            // End:0x10D
            case 'XboxTypeS_DPad_Left':
            // End:0x1C1
            case 'Left':
                // End:0x1BF
                if(int(uevent) == int(0))
                {
                    // End:0x1BF
                    if(IsPlayerOwner(ControllerId))
                    {
                        PlayerList.SelectedPlayerIndex = -1;
                        UpdateTooltips();
                        __OnInputKey__Delegate = DefaultHandleInputKey;
                        PlayUISound('VerticalMovement');
                        TheList.SetFocused(1);
                    }
                }
                return true;
            // End:0x1CD
            case 'Gamepad_LeftStick_Up':
            // End:0x1D9
            case 'XboxTypeS_DPad_Up':
            // End:0x1E5
            case 'Up':
            // End:0x265
            case 'MouseScrollUp':
                // End:0x263
                if((int(uevent) == int(0)) || int(uevent) == int(2))
                {
                    // End:0x263
                    if(IsPlayerOwner(ControllerId))
                    {
                        PlayerList.ScrollUp();
                        PlayUISound('VerticalMovement');
                    }
                }
                return true;
            // End:0x271
            case 'Gamepad_LeftStick_Down':
            // End:0x27D
            case 'XboxTypeS_DPad_Down':
            // End:0x289
            case 'Down':
            // End:0x309
            case 'MouseScrollDown':
                // End:0x307
                if((int(uevent) == int(0)) || int(uevent) == int(2))
                {
                    // End:0x307
                    if(IsPlayerOwner(ControllerId))
                    {
                        PlayerList.ScrollDown();
                        PlayUISound('VerticalMovement');
                    }
                }
                return true;
            // End:0xFFFF
            default:
                // End:0x336
                if(SharedHandleInputKey(ControllerId, ukey, uevent))
                {
                    return true;
                }
                break;
            }
    }
    return false;
    //return ReturnValue;    
}

