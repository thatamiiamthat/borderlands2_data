}

function ConfirmSplitLoginSucceeded()
{
    local WillowPlayerController.EWillowNetworkType NetworkType;
    local Engine.OnlineSubsystem.ELoginStatus LoginStatus;

    ClearSplitscreenLoginDelegates();
    UnknownLocal_1 = WPCOwner.OnlineSub.GameInterface.GetGameSettings('Game');
    NetworkType = GetNetworkType(UnknownLocal_1);
    LoginStatus = WPCOwner.OnlineSub.PlayerInterface.GetLoginStatus(byte(SavedSplitJoinControllerId));
    // End:0x187
    if(!IsProfileValidForCurrentGame(NetworkType, LoginStatus, SavedSplitJoinControllerId))
    {
        // End:0x168
        if(int(WPCOwner.WorldInfo.NetMode) == int(NM_Client))
        {
            ShowSplitJoinFailureMessage(NetworkType);
            SavedSplitJoinControllerId = -1;            
        }
        else
        {
            ShowSplitJoinSessionChangeConfirmation(NetworkType, LoginStatus);
        }        
    }
    else
    {
        AddSplitscreenPlayer(SavedSplitJoinControllerId);
        SavedSplitJoinControllerId = -1;
    }
    //return;    
}

function OnSplitLoginCancelled()
{
    local WillowPlayerController.EWillowNetworkType NetworkType;
    local Engine.OnlineSubsystem.ELoginStatus LoginStatus;

    ClearSplitscreenLoginDelegates();
    UnknownLocal_1 = WPCOwner.OnlineSub.GameInterface.GetGameSettings('Game');
    NetworkType = GetNetworkType(UnknownLocal_1);
    // End:0xDF
    if(int(WPCOwner.WorldInfo.NetMode) == int(NM_Client))
    {
        ShowSplitJoinFailureMessage(NetworkType);
        SavedSplitJoinControllerId = -1;        
    }
    else
    {
        LoginStatus = WPCOwner.OnlineSub.PlayerInterface.GetLoginStatus(byte(SavedSplitJoinControllerId));
        // End:0x177
        if(int(NetworkType) == int(2))
        {
            AddSplitscreenPlayer(SavedSplitJoinControllerId);
            SavedSplitJoinControllerId = -1;            
        }
        else
        {
            ShowSplitJoinSessionChangeConfirmation(NetworkType, LoginStatus);
        }
    }
    //return;    
}

function ClearSplitscreenLoginDelegates()
{
    ClearTimer('SplitJoinFailed');
    WPCOwner.OnlineSub.PlayerInterface.ClearLoginChangeDelegate(OnSplitLoginChanged);
    WPCOwner.OnlineSub.PlayerInterface.ClearLoginCancelledDelegate(OnSplitLoginCancelled);
    WPCOwner.OnlineSub.SystemInterface.ClearExternalUIChangeDelegate(OnExternalUIChanged);
    //return;    
}

