                        UnknownLocal_1.AddRefreshCompleteDelegate(DlcNetworkOptionsRefreshComplete);
                        WPCOwner.GetOnlineMessageMovie().DisplayBlockingMessage(Localize("OnlineMessages", "EnumeratingMarketplaceOffers", "WillowMenu"));
