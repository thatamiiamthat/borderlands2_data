                if(UnknownLocal_5.IsA('WillowGFxLobbyLoadCharacter'))
                {
                    UnknownLocal_1 = true;                    
                }
                else
                {                    
                }
            }                        
        }        
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

function ShowLanBrowser()
{
    local WillowPlayerController.EWillowNetworkType NetworkType;
    local WillowPlayerController.EWillowInviteType InviteType;

    // End:0x218
    if(int(WPCOwner.GetLoginStatus()) != int(0))
    {
        NetworkType = GetNetworkType(WPCOwner.OnlineSub.GameInterface.GetGameSettings('Game'));
        // End:0x218
        if(int(NetworkType) == int(2))
        {
            NetworkType = 1;
            InviteType = 2;
            // End:0x179
            if(WPCOwner.CheckCanCreateLanGame(false))
            {
                class'UIRoot'.static.SetDataStoreStringValue("<Registry:LastNetworkType>", string(int(NetworkType)) $ "");
                class'UIRoot'.static.SetDataStoreStringValue("<Registry:LastInviteType>", string(int(InviteType)) $ "");
            }
            class'UIRoot'.static.SetDataStoreStringValue("<Registry:RestoreNetworkType>", string(int(NetworkType)) $ "");
            class'UIRoot'.static.SetDataStoreStringValue("<Registry:RestoreInviteType>", string(int(InviteType)) $ "");
        }
    }
    WPCOwner.AttemptSystemLinkTransition(true);
    //return;    
}

function StartMenuMusic()
{
    // End:0x3A
    if(!WPCOwner.IsLoadingMoviePlaying())
    {
        PlayUISound('MusicStart');        
    }
    else
    {
        SetTimer(0.5, false, 'StartMenuMusic');
    }
    //return;    
}

