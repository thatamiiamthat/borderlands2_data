function bool CanViewGamercard(int ControllerId, UniqueNetId UniqueId)
{
    local Engine.OnlineSubsystem.ELoginStatus LoginStatus;
    local WillowPlayerController.EWillowNetworkType NetworkType;

    // End:0x10D
    if((WPCOwner.OnlineSub != none) && NotEqual_InterfaceInterface(WPCOwner.OnlineSub.GameInterface, OnlineGameInterface(none)))
    {
