function LaunchSaveGame(int PlayThrough)
{
    local array<WillowPlayerController> PlayersWithoutDlc;

    UnknownLocal_1 = WPCOwner.GetCachedSaveGame();
    // End:0x418
    if((UnknownLocal_1 != none) && UnknownLocal_1.SaveGameId != -1)
    {
        // End:0x12A
        if(WPCOwner.IsStationToUninstalledDlc(UnknownLocal_1.LastVisitedTeleporter))
        {
            DlcWarningPlaythroughLevel = PlayThrough;
            WPCOwner.GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgDlcOutpostNotInstalled", DisplayLastStationUninstalledDlc_Clicked);
            return;
        }
        UnknownLocal_3 = GetSaveGameTravelStationDefinition();
        // End:0x28B
        if((UnknownLocal_3 != none) && UnknownLocal_3.DlcExpansion != none)
        {
            PlayersWithoutDlc = WillowGameInfo(WPCOwner.WorldInfo.Game).GetDlcCannotTravelPlayerList(UnknownLocal_3.DlcExpansion);
            // End:0x28B
            if(PlayersWithoutDlc.Length > 0)
            {
                DlcWarningPlaythroughLevel = PlayThrough;
                WPCOwner.GFxUIManager.ShowDialog().DisplayYesNoBox("WillowMenu", "dlgDlcUnavailableToPartyMember", NotAllClientsCanAccessDlc_Clicked);
                return;
            }
        }
        // End:0x418
        if(UnknownLocal_1.ExpPoints > WPCOwner.GetExpPointsRequiredForLevel(WPCOwner.GetMaxExpLevel()))
        {
            DlcWarningPlaythroughLevel = PlayThrough;
            UnknownLocal_5 = WPCOwner.GFxUIManager.ShowDialog().DisplayOkBox("WillowMenu", "dlgDlcLevelCapNotInstalled", DisplayDlcLevelCapInUninstalledDlc_Clicked);
            UnknownLocal_5.ReplaceDialogText("%CHARACTERLEVEL%", string(UnknownLocal_1.ExpLevel));
            UnknownLocal_5.ReplaceDialogText("%LEVELCAP%", string(WPCOwner.GetMaxExpLevel()));
            return;
        }
    }
    LaunchSaveGameEx(PlayThrough);
    //return;    
}

function LaunchSaveGameEx(int PlayThrough)
{
    local name pMap;

    UnknownLocal_1 = WPCOwner.GetCachedSaveGame();
    // End:0x40A
    if((UnknownLocal_1 != none) && UnknownLocal_1.SaveGameId != -1)
    {
        WPCOwner.SetLobbyShown(true);
        WillowGameReplicationInfo(WPCOwner.WorldInfo.GRI).SetCurrentPlaythrough(WPCOwner, PlayThrough);
        WPCOwner.ApplyMissionSaveGameData(UnknownLocal_1, false);
        WPCOwner.ApplyVisitedTeleporterData(UnknownLocal_1);
        // End:0x167
        if(WPCOwner.LastVisitedTeleporter != none)
        {
            class'WillowGameInfo'.static.SetStartupTeleporterAttributeInitialization(true);
        }
        // End:0x1C9
        if(WPCOwner.LastVisitedTeleporter != none)
        {
            pMap = WPCOwner.LastVisitedTeleporter.GetStationLevelName();
        }
        // End:0x1E3
        if(pMap != 'None')
        {            
        }
        else
        {
            pMap = name(class'WillowPlayerController'.default.DefaultMapName);
        }
        WillowGameReplicationInfo(WPCOwner.WorldInfo.GRI).OverpowerLevelModifier = CurrentSelectedOverpowerLevel;
        // End:0x2C1
        if(PlayThrough == 2)
        {
            WPCOwner.OverpowerChoiceValue = CurrentSelectedOverpowerLevel;
            WPCOwner.OverpowerChoiceValuePendingSave = true;
        }
        WPCOwner.WorldInfo.Game.StartOnlineGame();
        // End:0x374
        foreach WPCOwner.WorldInfo.AllControllers(class'WillowPlayerController', UnknownLocal_3)
        {
            UnknownLocal_3.ClientFindPlayMovie(pMap);            
        }        
        WillowGameInfo(WPCOwner.WorldInfo.Game).HandlePublicGame();
        WPCOwner.openl(string(pMap) $ "?listen");
        Close();        
    }
    else
    {
        ScriptTrace();
    }
    //return;    
}

