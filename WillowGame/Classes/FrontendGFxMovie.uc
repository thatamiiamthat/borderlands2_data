                UnknownLocal_3 = true;
            }
        }
        // End:0x189
        if(UnknownLocal_3)
        {
            UnknownLocal_5 = Min(UnknownLocal_1.NumOverpowerLevelsUnlocked, class'WillowPlayerController'.static.GetMaximumPossibleOverpowerModifier());
            CurrentSelectedOverpowerLevel = Clamp(CurrentSelectedOverpowerLevel, 0, UnknownLocal_5);
