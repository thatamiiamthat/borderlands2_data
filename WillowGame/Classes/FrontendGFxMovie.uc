    //return ReturnValue;    
}

function string BuildOverpowerPromptString(int CurrentOverpowerLevel, int MaxOverpowerLevel)
{
    local Color OverpowerLevelHighlightColor;
    local string OverpowerString, ReturnString;

    OverpowerLevelHighlightColor = MakeColor(255, 255, 255);
    OverpowerString = Repl(Localize("dlgOverpowerSelect", "CurrentOPLevel", "WillowMenu"), "%OP_LEVEL%", string(CurrentOverpowerLevel));
    OverpowerString = Repl(OverpowerString, "%MAXOP_LEVEL%", string(MaxOverpowerLevel));
    OverpowerString = class'GearboxGFxMovie'.static.GFxColoredText(OverpowerLevelHighlightColor, OverpowerString);
    ReturnString = Repl(Localize("dlgOverpowerSelect", "Prompt", "WillowMenu"), "%CURROP_LEVEL%", OverpowerString);
    return ReturnString;
    //return ReturnValue;    
}

