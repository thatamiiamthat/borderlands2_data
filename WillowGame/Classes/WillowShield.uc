class WillowShield extends WillowEquipAbleItem
    native
    hidecategories(Mobile,Navigation,MovementReplication);

simulated event ReplicatedEvent(name VarName)
{
    // End:0x24
    if(VarName == 'bPrimed')
    {
        ShieldPrimedStateChanged();        
    }
    else
    {
        super(WillowItem).ReplicatedEvent(VarName);
    }
    //return;    
}

simulated function bool ClientInitializeFromItemDefinition()
{
    UnknownLocal_1 = super.ClientInitializeFromItemDefinition();
    ShieldDef = ShieldDefinition(DefinitionData.ItemDefinition);
    return UnknownLocal_1;
    //return ReturnValue;    
}

function ItemEquipped()
{
    super.ItemEquipped();
    UnknownLocal_1 = WillowPlayerPawn(Owner);
    // End:0x49
    if(UnknownLocal_1 != none)
