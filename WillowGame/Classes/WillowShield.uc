simulated event ShieldPrimedStateChanged()
{
    UnknownLocal_1 = WillowPlayerPawn(Owner);
    // End:0x3F
    if(UnknownLocal_1 != none)
    {
        UnknownLocal_1.ResetShieldPrimeCachedValues(self);
    }
    // End:0x8C
    if(bPrimed)
    {
        // End:0x8C
        if(ShieldDef != none)
        {
            ShieldDef.OnShieldPrimed(ConsumerHandle, Owner);
        }
    }
    bNetDirty = true;
    //return;    
}

function ShieldTriggered()
{
    ShieldDef.OnEffectTriggered(ConsumerHandle, Owner);
    //return;    
}

event SetDamageResistanceType(WillowDamageTypeDefinition NewType)
{
    // End:0x51
    if(DamageResistanceType != NewType)
    {
        ShieldDef.OnDamageResistanceTypeChanged(ConsumerHandle, Owner, NewType);
    }
    DamageResistanceType = NewType;
    //return;    
}

