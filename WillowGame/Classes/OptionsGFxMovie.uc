    // End:0x420
    if(UnknownLocal_9 != none)
    {
        UnknownLocal_9.OptionsMovie = none;
    }
    super(WillowGFxMovie).OnClose();
    //return;    
}

function SaveOptions()
{
    WPCOwner.SetSettingsFromProfile();
    // End:0x65
    if(class'WorldInfo'.static.IsMenuLevel())
    {
        WPCOwner.WriteProfile(true);        
    }
    else
    {
        WPCOwner.SetNeedsProfileWrite();
    }
    // End:0xE4
    if(bTrainingWasEnabled)
    {
        // End:0xE4
        if(WPCOwner.GetProfileSettingInt(118, false) == 1)
        {
            class'WillowLeviathanService'.static.RecordMinorActionEventForPlayer(WPCOwner, 0);
        }
    }
    //return;    
}

event OnTick()
{
    UnknownLocal_1 = WPCOwner.GetPlayerViewportClient().IsWidescreen();
    // End:0x5E
    if(UnknownLocal_1 != CachedWidescreen)
    {
        UpdateFrameForAspectRatio(UnknownLocal_1);
    }
    //return;    
}

function UpdateFrameForAspectRatio(bool bWidescreen)
{
    // End:0x91
    if(OptionsObj != none)
    {
        CachedWidescreen = bWidescreen;
        // End:0x59
        if(CachedWidescreen)
        {
            OptionsObj.SetAspectRatio("16x9");            
        }
        else
        {
            OptionsObj.SetAspectRatio("4x3");
        }
        UpdateHeader();
        UpdateTooltips();
    }
    //return;    
}

function OnScrollingListChanged()
{
    UpdateHeader();
    UpdateTooltips();
    //return;    
}

function OnScollingListSelectedIndexChanged(int NewSelectedIndex)
{
    UpdateTooltips();
    //return;    
}

function RefreshListHandler()
{
    TheList.Refresh();
    UpdateHeader();
    UpdateTooltips();
    //return;    
}

function bool HandleInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0x31
    if(ControllerId != int(WPCOwner.GetMyControllerId()))
    {
        return true;
    }
    // End:0x76
    if(HandleInputKeyHook != none)
    {
        // End:0x76
        if(HandleInputKeyHook.HandleInputKey(ukey, uevent))
        {
            return true;
        }
    }
    switch(ukey)
    {
        // End:0x95
        case 'Escape':
        // End:0xC1
        case 'XboxTypeS_B':
            // End:0xBF
            if(int(uevent) == int(1))
            {
                CloseMovie();
            }
            return true;
        // End:0xFFFF
        default:
            return false;
            break;
    }
    //return ReturnValue;    
}

function CloseMovie()
{
    // End:0x6F
    if(!TheList.HandlePopList())
    {
        WPCOwner.GetPrimaryPlayer().GetFrontendMovie().HideOptionsMovie();
    }
    //return;    
}

function UpdateHeader()
{
    local string HeaderString;

    // End:0x1A9
    if(OptionsObj != none)
    {
        OptionsObj.SetPlayerName(WPCOwner.PlayerReplicationInfo.PlayerName);
        HeaderString = PreviousMenuHeader;
        // End:0x9E
        if(HeaderString != "")
        {            
            HeaderString $= " / ";
        }
        UnknownLocal_1 = 0;
        J0xA5:

        // End:0x181 [Loop If]
        if(UnknownLocal_1 < TheList.DataProviderStack.Length)
        {            
            HeaderString $= TheList.DataProviderStack[UnknownLocal_1].DataProvider.GetMenuDisplayName();
            // End:0x177
            if(UnknownLocal_1 < (TheList.DataProviderStack.Length - 1))
            {                
                HeaderString $= " / ";
            }
            ++ UnknownLocal_1;
            // [Loop Continue]
            goto J0xA5;
        }
        OptionsObj.SetHeader(HeaderString);
    }
    //return;    
}

function AppendTooltipString(out string TooltipString, string StringToAppend, optional bool bDisabled)
{
    bDisabled
    StringToAppend = ("<font color='#808080'>" $ StringToAppend) $ "</font>";
    TooltipString = (TooltipString $ TooltipSpacing) $ StringToAppend;
    //return;    
}

function UpdateTooltips()
{
    local string TooltipString;

    // End:0xF7
    if(OptionsObj != none)
    {
        TooltipString = "";
        AppendTooltipString(TooltipString, Localize("FrontendGFxMovie", "SelectTooltip", "WillowGame"), TheList.IsSliderListItem() || TheList.IsSpinnerListItem());
        AppendTooltipString(TooltipString, BackTooltip);
        OptionsObj.SetTooltips(ResolveDataStoreMarkup(TooltipString));
    }
    //return;    
}

function OnScrollingListItemFocus(EventData Data)
{
    UpdateTooltips();
    //return;    
}

function WillowSystemSettings GetSystemSettings()
{
    // End:0x27
    if(SystemSettings == none)
    {
        SystemSettings = new (self) class'WillowSystemSettings';
    }
    return SystemSettings;
    //return ReturnValue;    
}

function extOptionsMenuOnLoad(string TargetPath, string ListTargetPath)
{
    OptionsObj = OptionsGFxObject(GetVariableObject(TargetPath, class'OptionsGFxObject'));
    TheList = WillowScrollingList(GetVariableObject(ListTargetPath, class'WillowScrollingList'));
    // End:0x124
    if(TheList != none)
    {
        TheList.__OnListChanged__Delegate = OnScrollingListChanged;
        TheList.__OnSelectedIndexChanged__Delegate = OnScollingListSelectedIndexChanged;
        TheList.Init(self, IWillowScrollingListDataProvider(new class'WillowScrollingListDataProviderTopLevelOptions'));
        TheList.SetFocused(1);
    }
    UpdateHeader();
    //return;    
}

defaultproperties
{
    TooltipSpacing="    "
    BackTooltip="<StringAliasMap:GFx_Cancel> Back"
    bFullscreenMovie=true
    TickRateSeconds=0.1
    bTickScript=true
    bHideLesserMovies=true
    Priority=3
}