event bool Start(optional bool StartPaused = false)
{
    UnknownLocal_1
    super.Start(StartPaused);
    // End:0xDD
    if(UnknownLocal_1)
    {
        PlayUISound('MenuOpen');
        Advance(0);
        UpdateFrameForAspectRatio(WPCOwner.GetPlayerViewportClient().IsWidescreen());
        __OnInputKey__Delegate = HandleInputKey;
        UpdateTooltips();
        bTrainingWasEnabled = WPCOwner.GetProfileSettingInt(118, false) == 0;
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

event OnClose()
{
    PlayUISound('MenuBack');
    SaveOptions();
    UnknownLocal_1 = GetSystemSettings().SystemOptions.Find('Name', 'NumberOfDecals';
    // End:0x354
    if(UnknownLocal_1 != -1)
