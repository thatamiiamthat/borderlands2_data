            {
                WPCOwner.WorldInfo.MyDecalManager.MaxActiveDecals = WPCOwner.WorldInfo.MyDecalManager.MaxActiveDecalsHigh;
            }            
        }
        else
        {
            // End:0x30B
            if(UnknownLocal_3 == 1)
            {
                // End:0x30B
                if(WPCOwner.WorldInfo.MyDecalManager.MaxActiveDecals != WPCOwner.WorldInfo.MyDecalManager.MaxActiveDecalsLow)
                {
                    WPCOwner.WorldInfo.MyDecalManager.MaxActiveDecals = WPCOwner.WorldInfo.MyDecalManager.MaxActiveDecalsLow;
                }
            }
            WPCOwner.WorldInfo.MyDecalManager.ClearAllPoolComponents();
        }
    }
    OptionsObj = none;
    TheList.Cleanup();
    TheList = none;
    UnknownLocal_5 = class'UIInteraction'.static.GetLocalPlayer(0);
