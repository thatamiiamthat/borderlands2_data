class PlayerDetailsGFxMovie extends WillowGFxMovie
    config(Game)
    hidecategories(Mobile);

var transient PlayerDetailsGFxObject PlayerDetailsObject;
var transient IPlayerListOwner OwningMovie;
var delegate<OnLoad> __OnLoad__Delegate;

delegate OnLoad(PlayerDetailsGFxObject PlayerDetailsObj)
{
    //return;    
}

event bool Start(optional bool StartPaused = false)
{
    super.Start();
    Advance(0);
    PlayUISound('MenuOpen');
    return true;
    return false;
    //return ReturnValue;    
}

event OnClose()
{
    OwningMovie.PlayUISound('MenuClose');
    super.OnClose();
    //return;    
}

function extOnLoad(string Path)
{
    PlayerDetailsObject = PlayerDetailsGFxObject(GetVariableObject(Path, class'PlayerDetailsGFxObject'));
    __OnInputKey__Delegate = HandleInputKey;
    // End:0x75
    if(__OnLoad__Delegate != none)
    {
        OnLoad(PlayerDetailsObject);
    }
    //return;    
}

function extClosed()
{
    Close();
    //return;    
}

function bool HandleInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0x31
    if(ControllerId != int(WPCOwner.GetMyControllerId()))
    {
        return true;
    }
    switch(ukey)
    {
        // End:0x50
        case 'Gamepad_LeftStick_Up':
        // End:0x5C
        case 'XboxTypeS_DPad_Up':
        // End:0x68
        case 'Up':
        // End:0xE8
        case 'MouseScrollUp':
            // End:0xE6
            if((int(uevent) == int(0)) || int(uevent) == int(2))
            {
                PlayerDetailsObject.NavigateUp();
                OwningMovie.PlayUISound('VerticalMovement');
            }
            return true;
        // End:0xF4
        case 'Gamepad_LeftStick_Down':
        // End:0x100
        case 'XboxTypeS_DPad_Down':
        // End:0x10C
        case 'Down':
        // End:0x18C
        case 'MouseScrollDown':
            // End:0x18A
            if((int(uevent) == int(0)) || int(uevent) == int(2))
            {
                PlayerDetailsObject.NavigateDown();
                OwningMovie.PlayUISound('VerticalMovement');
            }
            return true;
        // End:0x198
        case 'XboxTypeS_B':
        // End:0x204
        case 'Escape':
            // End:0x202
            if(int(uevent) == int(1))
            {
                WPCOwner.GetFrontendMovie().PlayerList.HidePlayerDetailsMovie();
            }
            return true;
        // End:0x210
        case 'XboxTypeS_A':
        // End:0x21C
        case 'Enter':
        // End:0x22A
        case 'LeftMouseButton':
            return false;
        // End:0xFFFF
        default:
            return true;
            break;
    }
    //return ReturnValue;    
}

defaultproperties
{
    bBlurLesserMovies=true
    Priority=2
}