function HandleOpen()
{
    PlayUISound('MenuOpen');
    __OnInputKey__Delegate = HandleInputKey;
    BuildLocationData();
    FastTravelClip.SendLocationData(LocationDisplayNames, LocationStationStrings, InitialSelectionIndex, LocationStationDefinitions.Find(CurrentWaypointStationDef);
    PreviousSelectionIndex = InitialSelectionIndex;
    UpdateLocationDisplayNamesAlphabetical(LocationStationDefinitions.Find(CurrentWaypointStationDef);
    ProcessDLCMovies();
    FastTravelClip.SetSortMode(SortMode, GetFastTravelHeader());
    WPCOwner.bUsingFastTravelStation = true;
    SetVariableString("teleport.locationMissions.headerText.text", LocationMissionTeaserHeader);
    OverrideNavigation();
    //return;    
}

event OnClose()
{
    super.OnClose();
    FastTravelClip = none;
    LocationDisplayNames.Length = 0;
    LocationStationDefinitions.Length = 0;
    FastTravelLocationListPanelClip = none;
    LocationDisplayNamesAlphabetical.Length = 0;
    LocationIsHeader.Length = 0;
    CurrentWaypointStationDef = none;
    //return;    
}

