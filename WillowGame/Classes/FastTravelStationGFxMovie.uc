function bool HandleInputKey(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    // End:0x1D
    if(int(GetControllerId()) != ControllerId)
    {
        return false;
    }
    switch(ukey)
    {
        // End:0x3C
        case 'XboxTypeS_B':
        // End:0x8E
        case 'Escape':
            // End:0x8B
            if(int(uevent) == int(1))
            {
                SingleArgInvokeS("gotoAndPlay", "outro");
                BeginClosing();
                UnknownLocal_1 = true;
            }
            // End:0x1A8
            break;
        // End:0x9A
        case 'XboxTypeS_Y':
        // End:0x113
        case 'Q':
            // End:0x109
            if(int(uevent) == int(1))
            {
                SortMode = ((SortMode == 0) ? 1 : 0);
                FastTravelClip.SetSortMode(SortMode, GetFastTravelHeader());
            }
            UnknownLocal_1 = true;
            // End:0x1A8
            break;
        // End:0x15C
        case 'MouseScrollUp':
            // End:0x159
            if(int(uevent) == int(0))
            {
                FastTravelClip.ScrollLocationListUp();
                UnknownLocal_1 = true;
            }
            // End:0x1A8
            break;
        // End:0x1A5
        case 'MouseScrollDown':
            // End:0x1A2
            if(int(uevent) == int(0))
            {
                FastTravelClip.ScrollLocationListDown();
                UnknownLocal_1 = true;
            }
            // End:0x1A8
            break;
        // End:0xFFFF
        default:
            break;
    }
    // End:0x1DD
    if(!UnknownLocal_1)
    {
        UnknownLocal_1 = HandleKeyDefaults(ControllerId, ukey, uevent);
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

