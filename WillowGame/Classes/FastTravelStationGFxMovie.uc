function extGenericButtonClicked(string ActionName)
{
    local name Action;

    Action = name(ActionName);
    switch(Action)
    {
        // End:0x41
        case 'Close':
            BeginClosing();
            // End:0xA2
            break;
        // End:0x9F
        case 'Sort':
            SortMode = ((SortMode == 0) ? 1 : 0);
            FastTravelClip.SetSortMode(SortMode, GetFastTravelHeader());
            // End:0xA2
            break;
        // End:0xFFFF
        default:
            break;
    }
    //return;    
}

