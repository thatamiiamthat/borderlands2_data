function extActivate(int LocationIndex)
{
    // End:0x33
    if(LocationIndex == InitialSelectionIndex)
    {
        PlaySpecialUISound("ResultFailure");        
    }
    else
    {
        // End:0x262
        if((LocationIndex >= 0) && LocationIndex < LocationStationDefinitions.Length)
        {
            UnknownLocal_1 = LocationStationDefinitions[LocationIndex];
            PlaySpecialUISound("ResultSuccess");
            BeginClosing();
            WillowPlayerController(GetPC()).ServerTeleportPlayerToStation(UnknownLocal_1);
            // End:0x25F
            if((UnknownLocal_1.DlcExpansion != none) && !UnknownLocal_1.DlcExpansion.IsLicensed())
            {
                WPCOwner.LastUpsellOfferId = 0;
                // End:0x25F
                if(class'CharacterSelectionReduxGFxMovie'.static.GetOfferIdForDlc(LocationStationDefinitions[LocationIndex].DlcExpansion, WPCOwner.LastUpsellOfferId))
                {
                    // End:0x25F
                    if(class'CustomizationGFxMovie'.static.ShowPurchaseDialog(WPCOwner, WPCOwner.OnPurchaseRequest, WPCOwner.OnPurchaseCanceled))
                    {
                        WPCOwner.OnPurchaseRequest(none, int(WPCOwner.GetMyControllerId()));
                    }
                }
            }            
        }
        else
        {
            PlaySpecialUISound("ResultFailure");
        }
    }
    //return;    
}

