function SetBackpackList(out array<WillowInventory> BackpackThings)
{
    local SortFilterConfiguration OutConfig;

    // End:0x98
    if(int(BackpackPanel.CurrentSortFilterConfig.FilterType) != int(1))
    {
        OutConfig = TradingGFxMovie(ParentMovie).GenericSortConfigurations[TradingGFxMovie(ParentMovie).GenericSortConfigIndex];        
    }
    else
    {
        OutConfig = BackpackPanel.CurrentSortFilterConfig;
    }
    BackpackPanel.SaveState();
    BackpackPanel.SetList(BackpackThings, OutConfig);
    BackpackPanel.RestoreState();
    //return;    
}

