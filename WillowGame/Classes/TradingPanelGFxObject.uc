function StartOffer()
{
    local SortFilterConfiguration NewSort;

    OfferingThing = GetSelectedThing();
    __OnInputKey__Delegate = OfferInputKey;
    CachedSortFilterConfig = BackpackPanel.CurrentSortFilterConfig;
    // End:0x15E
    if(int(CurrentPanel) == int(1))
    {
        ReturnPanel = 1;
        SwitchFocus(0);
        ParentMovie.FrozenThing = OfferingThing;
        // End:0x15B
        if(OfferingThing != none)
        {
            NewSort = CachedSortFilterConfig;
            NewSort.FilterType = 1;
            ParentMovie.FrozenThingType = class'InventoryListPanelGFxObject'.static.GetInventoryType(OfferingThing);
            BackpackPanel.ApplySortConfiguration(NewSort);
        }        
    }
    else
    {
        ReturnPanel = 0;
        SwitchFocus(1);
        OffersPanel.StartOffer(OfferingThing);
    }
    BackpackPanel.OnSettingPanelForTransferring(int(CurrentPanel) == int(0), int(CurrentPanel) != int(0));
    OffersPanel.OnSettingPanelForTransferring(int(CurrentPanel) == int(1), int(CurrentPanel) != int(1));
    SetLeftRightArrowVisibility(false, false);
    //return;    
}

