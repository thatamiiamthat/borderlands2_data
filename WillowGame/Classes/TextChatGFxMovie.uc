class TextChatGFxMovie extends WillowGFxMovie
    native(GFx)
    config(Game)
    hidecategories(Mobile);

var transient GFxObject ChatObj;

event bool Start(optional bool StartPaused = false)
{
    UnknownLocal_1
    super.Start(StartPaused);
    // End:0x36
    if(UnknownLocal_1)
    {
        Advance(0);
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

event OnClose()
{
    ChatObj = none;
    super.OnClose();
    //return;    
}

function StartTextChat()
{
    StartTextChatInternal();
    //return;    
}

function AddChatMessage(PlayerReplicationInfo PRI, string msg)
{
    local string TimeStamp;
    local OnlinePlayerInterfaceEx PlayerInt;

    PlayerInt = class'GameEngine'.static.GetOnlineSubsystem().PlayerInterfaceEx;
    // End:0x81
    if(PlayerInt.NetIdIsBlockedForLocalUser(PRI.UniqueId))
    {
        return;
    }
    TimeStamp = GetTimestampString(class'WillowSaveGameManager'.default.TimeFormat);
    AddChatMessageInternal(PRI.PlayerName @ TimeStamp, msg);
    //return;    
}

// Export UTextChatGFxMovie::execGetTimestampString(FFrame&, void* const)
native function string GetTimestampString(string TimeFormat);

private final function StartTextChatInternal()
{
    // End:0x85
    if(ChatObj != none)
    {
        ChatObj.ActionScriptVoid("StartTextChat");
        SetMovieCanReceiveFocus(true);
        SetMovieCanReceiveInput(true);
        bCaptureInput = true;
        FlushPlayerInput(false);
        __OnInputKey__Delegate = HandleTextChatInput;
    }
    //return;    
}

private final function StopTextChatInternal()
{
    // End:0x79
    if(ChatObj != none)
    {
        ChatObj.ActionScriptVoid("StopTextChat");
        SetMovieCanReceiveFocus(false);
        SetMovieCanReceiveInput(false);
        bCaptureInput = false;
        __OnInputKey__Delegate = None;
    }
    //return;    
}

function string GetChatObjText()
{
    // End:0x3C
    if(ChatObj != none)
    {
        return ChatObj.ActionScriptString("GetTextChat");
    }
    return "";
    //return ReturnValue;    
}

function bool HandleTextChatInput(int ControllerId, name ukey, Core.Object.EInputEvent uevent)
{
    local string ChatText;

    switch(ukey)
    {
        // End:0x1F
        case 'LeftMouseButton':
        // End:0x2D
        case 'RightMouseButton':
            return true;
        // End:0xA5
        case 'Enter':
            // End:0xA3
            if(int(uevent) == int(1))
            {
                StopTextChatInternal();
                ChatText = GetChatObjText();
                // End:0xA3
                if(ChatText != "")
                {
                    WPCOwner.Say(ChatText);
                }
            }
            return true;
        // End:0xD1
        case 'Escape':
            // End:0xCF
            if(int(uevent) == int(1))
            {
                StopTextChatInternal();
            }
            return true;
        // End:0xFFFF
        default:
            return false;
            break;
    }
    //return ReturnValue;    
}

function AddChatMessageInternal(string PlayerName, string msg)
{
    // End:0x3E
    if(ChatObj != none)
    {
        ChatObj.ActionScriptVoid("AddChatMessage");
    }
    //return;    
}

function extTextChatOnLoad(string TargetPath)
{
    ChatObj = GetVariableObject(TargetPath);
    //return;    
}

defaultproperties
{
    Priority=250
}