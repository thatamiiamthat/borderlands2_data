class Behavior_PhaseLockHold extends BehaviorBase
    editinlinenew
    hidecategories(Mobile,Object)
    autoexpandcategories(Action);

var(Hold) name Reason;
var(Hold) GearboxFramework.Behavior_AIHold.AIHoldAction Action;

protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IAIInterface AIInterface;
    local editinline WillowAIComponent WillowAI;

    AIInterface = ContextObject.QueryInterface(class'IAIInterface');
    WillowAI = ((NotEqual_InterfaceInterface(AIInterface, IAIInterface(none))) ? WillowAIComponent(AIInterface.GetAIComponent()) : none);
    // End:0x129
    if((WillowAI != none) && Reason != 'None')
    {
        // End:0xF8
        if(int(Action) == int(0))
        {
            WillowAI.HoldPhaseLock(Reason, ContextObject);            
        }
        else
        {
            WillowAI.ReleasePhaseLock(Reason, ContextObject);
        }
    }
    //return;    
}
