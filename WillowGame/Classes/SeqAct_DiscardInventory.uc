class SeqAct_DiscardInventory extends SequenceAction
    native(Sequence)
    forcescriptorder(true)
    hidecategories(Mobile,Object);

var(Action) const bool bSpawnPickupsForOldInventory;
var(Action) const bool bRepopulateInventory;

event OnActivated(WillowPawn WPawn)
{
    // End:0x66
    if(WPawn != none)
    {
        WPawn.DiscardInventory(!bSpawnPickupsForOldInventory);
        // End:0x66
        if(bRepopulateInventory)
        {
            WPawn.AddDefaultInventory();
        }
    }
    //return;    
}

defaultproperties
{
    ObjName="Discard Inventory"
    ObjCategory="Pawn"
}