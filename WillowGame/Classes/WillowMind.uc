        }
    }
    // End:0xE2
    if(!bVehicleTransition && MyWillowPawn != none)
    {
        AIClass = MyWillowPawn.AIClass;
        MyWillowPawn.UpdatePlayerMaster();
    }
    super.Possess(inPawn, bVehicleTransition);
    MyWillowPawn.MyWillowMind = self;
    // End:0x1D7
    if(!bVehicleTransition && MyWillowPawn != none)
    {
        CharacterClass = MyWillowPawn.AIClass;
        HomeLocation = MyWillowPawn.Location;
        InitializeCharacterClass();
        MyWillowPawn.InitializeBehaviorProviders();
        MyWillowPawn.PostSpawn();
    }
    //return;    
}

function InitializeCharacterClass()
{
    // End:0x4A
    if(!bCharacterClassInitialized)
    {
        bCharacterClassInitialized = true;
        ApplyCharacterClassStartingValues(AIClass);
        ApplyCharacterClassDefaults(MyWillowPawn, AIClass);
    }
    //return;    
}

event UnPossess()
{
    // End:0x2F
