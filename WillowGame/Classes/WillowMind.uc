    MyWillowPawn.Behavior_Killed(Action.Killer, Action.DamageType, Action.DeathType);
    //return;    
}

function OnAIScriptedFollow(WillowSeqAct_AIScriptedFollow Action)
{
    // End:0x25F
    if(int(Action.Action) == int(0))
    {
        WillowNav.ClearPath();
        FollowActor = Action.ToFollow;
        FollowMinDist = Action.HoldStillDistance;
        FollowMaxDist = Action.CatchupDistance;
        bScriptedCanAttack = Action.bCanShoot;
        ScriptedStance = Action.Stance;
        // End:0x179
        if((FollowActor != none) && FollowActor.IsA('Controller'))
        {
            FollowActor = Controller(FollowActor).Pawn;
        }
        FollowComponent = none;
        // End:0x1FC
        if(Action.bUseFormation)
        {
            FollowComponent = WillowAIComponent(AIComponent).GetFormation(FollowComponent, 'None', WillowPawn(FollowActor));
        }
        // End:0x234
        if(FollowComponent != none)
        {
            FollowComponent.AIOwner = IAIInterface(self);
        }
        AIComponent.ActivateEvent('Scripted');        
    }
    else
    {
        FollowActor = none;
        // End:0x2A4
        if(FollowComponent != none)
        {
            FollowComponent.AIOwner = none;
            FollowComponent = none;
        }
    }
    //return;    
}

