    {
        return MyWillowPawn.GetAimRotation();
    }
    TargetLoc = WillowMindTargetInfo(AIComponent.GetTargetRecord()).GetTargetLocation() + GetTargetLeadOffset();
    return Rotator(TargetLoc - StartFireLoc);
    //return ReturnValue;    
}

