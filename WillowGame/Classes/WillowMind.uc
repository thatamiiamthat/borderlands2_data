        ScriptedFocus = UnknownLocal_1.Pawn;
    }
    ScriptedStance = Action.Stance;
    ScriptedFocusStyle = Action.FocusStyle;
    bScriptedCanAttack = int(ScriptedFocusStyle) == int(1);
    AIComponent.ActivateEvent('Scripted');
    //return;    
}

function OnAIScriptedHold(WillowSeqAct_AIScriptedHold Action)
