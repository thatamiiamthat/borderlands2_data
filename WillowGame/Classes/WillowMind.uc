event NotifyFallingHitWall(Vector HitNormal, Actor Wall)
{
    UnknownLocal_1 = WillowAIPawn(Pawn);
    // End:0x1E6
    if((((((((UnknownLocal_1 != none) && UnknownLocal_1.BodyClass != none) && UnknownLocal_1.BodyClass.bStaggerWhenLandingOnUnwalkableTerrain) && !UnknownLocal_1.IsInState('Staggered')) && HitNormal.Z < UnknownLocal_1.WalkableFloorZ) && VSize(UnknownLocal_1.Velocity) >= UnknownLocal_1.BodyClass.LandedMinVel) && Normal(UnknownLocal_1.Velocity).Z <= UnknownLocal_1.BodyClass.UnwalkableTerrainStaggerVelocityZ) && UnknownLocal_1.BodyClass.StaggerSettings != none)
    {
        UnknownLocal_1.Stagger();
    }
    //return;    
}

