function float ParentDistToTarget()
{
    // End:0x3B
    if((SpawnParent == none) || !AIComponent.HasTarget())
    {
        return 0;
    }
    return VSize(AIComponent.GetTarget().Location - SpawnParent.Pawn.Location);
    //return ReturnValue;    
}

function float GetNumSpawnChildren()
{
    return float(SpawnChildren.Length);
    //return ReturnValue;    
}

function float ParentIsScripted()
{
    // End:0x3C
    if((SpawnParent != none) && SpawnParent.IsInScriptedMovement())
    {
        return 1;        
    }
    else
    {
        return 0;
    }
    //return ReturnValue;    
}

