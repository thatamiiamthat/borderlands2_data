event bool GetInstanceData(name DataName, out array<InstanceDataUnion> InstanceData)
{
    local InstanceDataUnion Datum;
    local array<WillowPawn> Members;

    switch(DataName)
    {
        // End:0xA2
        case 'HelperActor':
            Datum.Name = DataName;
            Datum.Type = 6;
            Datum.Object = SpawnedHelperActor;
            InstanceData.AddItem(Datum;
            return true;
        // End:0x132
        case 'Den':
            Datum.Name = DataName;
            Datum.Type = 6;
            Datum.Object = GetPopOpDen();
            InstanceData.AddItem(Datum;
            return true;
        // End:0x1F7
        case 'FormationLeader':
            Datum.Name = DataName;
            Datum.Type = 6;
            Datum.Object = WillowAIComponent(AIComponent).GetFormationLeader().GetAIActor();
            InstanceData.AddItem(Datum;
            return true;
        // End:0x2C0
        case 'DenMembers':
            GetPopOpDen().GetDenMembers(Members);
            // End:0x2BD
            foreach Members(UnknownLocal_1,)
            {
                Datum.Name = DataName;
                Datum.Type = 6;
                Datum.Object = UnknownLocal_1;
                InstanceData.AddItem(Datum;                
            }            
            return true;
        // End:0x35E
        case 'SpawnParent':
            // End:0x35C
            if(SpawnParent != none)
            {
                Datum.Name = DataName;
                Datum.Type = 6;
                Datum.Object = SpawnParent;
                InstanceData.AddItem(Datum;
            }
            return true;
        // End:0x3FE
        case 'SpawnChildren':
            // End:0x3FB
            foreach SpawnChildren(UnknownLocal_3,)
            {
                Datum.Name = DataName;
                Datum.Type = 6;
                Datum.Object = UnknownLocal_3;
                InstanceData.AddItem(Datum;                
            }            
            return true;
        // End:0x4A3
        case 'Target':
            Datum.Name = DataName;
            Datum.Type = 6;
            Datum.Object = AIComponent.GetTarget();
            InstanceData.AddItem(Datum;
            return true;
        // End:0xFFFF
        default:
            return false;
            break;
    }
    //return ReturnValue;    
}

event bool RemoveInstanceData(name DataName)
{
    switch(DataName)
    {
        // End:0x2B
        case 'HelperActor':
            KillHelperActor();
            return true;
        // End:0xFFFF
        default:
            return false;
            break;
    }
    //return ReturnValue;    
}

event bool RemoveInstanceDataObject(Object InstanceDataObject)
{
    // End:0x28
    if(InstanceDataObject == SpawnedHelperActor)
    {
        KillHelperActor();
        UnknownLocal_1 = true;
    }
    return UnknownLocal_1;
    //return ReturnValue;    
}

function KillHelperActor()
{
    // End:0xAF
    if(SpawnedHelperActor != none)
    {
        UnknownLocal_1 = Pawn(SpawnedHelperActor);
        // End:0x52
        if(UnknownLocal_1 != none)
        {
            UnknownLocal_1.KilledBy(UnknownLocal_1);
        }
        WillowAIPawn(SpawnedHelperActor).PlayerMaster = none;
        WillowAIPawn(SpawnedHelperActor).PlayerMasterPRI = none;
        SpawnedHelperActor = none;
    }
    //return;    
}

function DestroyOwnedInstanceData()
{
    // End:0x32
    if(SpawnedHelperActor != none)
    {
        SpawnedHelperActor.Destroy();
        SpawnedHelperActor = none;
    }
    //return;    
}

