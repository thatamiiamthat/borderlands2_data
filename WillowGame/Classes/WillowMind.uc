    {
        bPawnAddedToRadar = false;
        WillowGameReplicationInfo(WorldInfo.GRI).RadarMgr.RemoveDynamicIcon(Pawn);
    }
    AIComponent.SetTarget(none);
    super(Controller).UnPossess();
    //return;    
}

