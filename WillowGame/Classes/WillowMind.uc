function Rotator GetAdjustedAimFor(Weapon InWeapon, Vector StartFireLoc)
{
    local Vector TargetLoc;

    // End:0x5B
    if(bWeaponFireUseRotation)
    {
        UnknownLocal_1 = WillowWeapon(InWeapon);
        return UnknownLocal_1.GetWeaponMuzzleRotation(UnknownLocal_1.ThirdPersonMesh);
    }
    // End:0x9F
