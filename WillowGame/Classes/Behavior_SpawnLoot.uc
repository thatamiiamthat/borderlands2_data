protected function ApplyBehaviorToContext(Object ContextObject, out BehaviorKernelInfo KernelInfo, Object SelfObject, Object MyInstigatorObject, Object OtherEventParticipantObject, BehaviorParameters EventData)
{
    local IBalancedActor GameStageContext;
    local ILootable LootableContext;
    local array<WillowInventory> SpawnedItems;
    local array<SpawnedDroppedLootData> SpawnedLoot;

    // End:0x290
    if(int(class'WorldInfo'.static.GetWorldInfo().NetMode) != int(NM_Client))
    {
        GameStageContext = ContextObject.QueryInterface(class'IBalancedActor');
        // End:0x95
        if(!NotEqual_InterfaceInterface(GameStageContext, IBalancedActor(none)))
        {
            return;
        }
        // End:0x1DF
        foreach ItemPools(UnknownLocal_1,)
        {
            SpawnedItems.Length = 0;
            class'ItemPool'.static.SpawnBalancedInventoryFromPool(UnknownLocal_1, GameStageContext.GetGameStage(), GameStageContext.GetAwesomeLevel(), ContextObject, SpawnedItems);
            SpawnedLoot.Length = SpawnedItems.Length;
            // End:0x1C1
            foreach SpawnedItems(UnknownLocal_3, UnknownLocal_5)
            {
                SpawnedLoot[UnknownLocal_5].bDisableRigidBodyPhysics = UnknownLocal_1.bDisablePhysicsDrop;
                SpawnedLoot[UnknownLocal_5].Inv = UnknownLocal_3;                
            }            
            PlaceSpawnedItems(SpawnedLoot, ContextObject);            
        }        
        // End:0x290
        if(bIncludeLootFromLootableContext)
        {
            LootableContext = ContextObject.QueryInterface(class'ILootable');
            // End:0x290
            if(NotEqual_InterfaceInterface(LootableContext, ILootable(none)))
            {
                SpawnedLoot.Length = 0;
                LootableContext.GetDroppedLoot(SpawnedLoot);
                PlaceSpawnedItems(SpawnedLoot, ContextObject);
            }
        }
    }
    //return;    
}

